   Sharfi and Zhu, Yifei and Siam, Md Kamrul and Ivanitskiy, Michael and
   Ahmed, M. Ahmed and Hallinan, Michael and Grisak, Alexander and Fierro,
   Gabe},
Book-Group-Author = {ACM},
Title = {Early Adoption of Generative Artificial Intelligence in Computing
   Education: Emergent Student Use Cases and Perspectives in 2023},
Booktitle = {PROCEEDINGS OF THE 2024 CONFERENCE INNOVATION AND TECHNOLOGY IN COMPUTER
   SCIENCE EDUCATION, VOL 1, ITICSE 2024},
