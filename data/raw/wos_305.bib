@inproceedings{ WOS:001669704400064,
Author = {Luna-Villarreal, Kevin and Bonila-Bustillo, Eduardo and Swain Oropeza,
   Ricardo and Hernandez-Aguirre, Angel},
Book-Group-Author = {IEEE},
Title = {AI-Driven Assessment: Redefining Student Preparation for Standardised
   Graduation},
Booktitle = {2025 WORLD ENGINEERING EDUCATION FORUM-GLOBAL ENGINEERING DEANS COUNCIL,
   WEEF-GEDC},
Series = {World Engineering Education Forum - Global Engineering Deans Council},
Year = {2025},
Note = {2025 World Engineering Education Forum - Global Engineering Deans
   Council-WEEF-GEDC, Daegu, SOUTH KOREA, SEP 21-25, 2025},
Organization = {Daegu Gyeongbuk Institute of Science \& Technology (DGIST); Dassault
   Systemes; MathWorks; Hyosung Corporation; ABET; Celltrion Inc; CAS;
   George Mason University},
Abstract = {Standardised examinations are essential tools in higher education,
   providing a reliable assessment of graduation competencies and
   institutional accountability. However, traditional preparation methods
   for standard examinations can often lack in student engagement and
   opportunities for personalised learning. This study explores the
   potential of artificial intelligence (AI) in addressing these gaps,
   particularly through AI-generated standardised assessments. A virtual
   assistant was created using the ChatGPT platform to help Civil
   Engineering students at Tecnologico de Monterrey prepare for their
   Mexican national standardised exams. Surveys were used to gather
   information about student engagement, self-directed learning,
   educational outcomes, and acceptance of technology. Initial expectations
   suggest that by integrating AI assessment, practitioners can
   significantly enhance student engagement and foster self-directed
   learning behaviour, improving overall preparation and outcomes in formal
   graduation exams. These findings offer new insights into the educational
   benefits of AI, suggesting a significant shift toward more interactive
