   Ananya and Paul, Anwesha and Poornachandra, M. and Simha, Tejas R.},
Editor = {Karkare, A and Prasad, P and Raman, A},
Title = {Scaling Evaluation of Non-objective Assessments Using AI-Based Solutions},
Booktitle = {COMPUTING EDUCATION RESEARCH, COMPUTE 2024},
