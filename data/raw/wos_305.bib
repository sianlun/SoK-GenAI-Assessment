Title = {Integration of Artificial Intelligence in Higher Education Programming
   Courses: Insights from Student Perspectives and Practices},
Booktitle = {FUTUREPROOFING ENGINEERING EDUCATION FOR GLOBAL RESPONSIBILITY, ICL2024,
   VOL 1},
Series = {Lecture Notes in Networks and Systems},
