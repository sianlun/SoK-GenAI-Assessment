@inproceedings{ WOS:001569143300039,
Author = {Xu, Ruoyu and Li, Gaoxiang and Sheng, Victor S.},
Editor = {Huang, DS and Zhang, C and Zhang, Q and Pan, Y},
Title = {Enhancing ChatGPT-4o's Automated Programming Assignment Grading and
   Feedback with Human-in-the-Loop Refinement},
Booktitle = {ADVANCED INTELLIGENT COMPUTING TECHNOLOGY AND APPLICATIONS, ICIC 2025,
   PT IX},
Series = {Lecture Notes in Computer Science},
Year = {2025},
