@inproceedings{ WOS:001687512700042,
Author = {Zlotnikova, Irina and Mokgetse, Tshepiso Larona and Hlomani, Hlomani},
Book-Group-Author = {ACM},
Title = {Generative AI in Postgraduate Computing Research in Sub-Saharan Africa:
   A Threat to Academic Integrity or a Catalyst for Innovation?},
Booktitle = {PROCEEDINGS OF THE ACM GLOBAL COMPUTING EDUCATION CONFERENCE 2025 VOL 1,
   COMPED 2025},
Year = {2025},
Pages = {289-293},
Note = {2025 Conference on Global Computing Education-COMPED, Gaborone,
   BOTSWANA, OCT 21-25, 2025},
Organization = {Association for Computing Machinery; University of Botswana; Ireland ACM
   SIGCSE Chapter},
Abstract = {The integration of Generative AI (GenAI) into postgraduate computing
   research presents both transformative opportunities and pressing ethical
   challenges. While GenAI tools enhance research productivity through
   support for academic writing, data analysis, and coding tasks, they also
   raise complex issues around academic integrity, authorship,
   overreliance, and digital inequality. These concerns are especially
   salient in Sub-Saharan Africa, where postgraduate students often face
   infrastructural constraints, limited mentorship, and systemic inequities
   in access to advanced technologies. This position paper critically
   examines the dual role of GenAI as a catalyst for innovation and a
   source of epistemic and institutional risk drawing on literature and
   observations from the context of Botswana. We explore ethical gray areas
   in GenAI use, review institutional policy responses, and highlight the
   underrepresentation of Indigenous data in large language models, which
   perpetuates Western epistemic dominance. Particular attention is given
   to the implications for postgraduate computing education, where
   contextually relevant and socially responsive GenAI applications are
   urgently needed. We argue for ethical, inclusive, and locally grounded
   frameworks that support responsible GenAI integration in postgraduate
   research. The paper concludes by outlining key areas for future
   empirical investigation, including disciplinespecific adoption,
   supervisor engagement, and equity in GenAI access across higher
   education systems in the Global South.},
