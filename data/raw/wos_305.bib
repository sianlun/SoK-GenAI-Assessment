Title = {Does Industry 5.0 Need an Engineering Education 5.0? Exploring
   Potentials and Challenges in the Age of Generative AI},
Booktitle = {2024 IEEE GLOBAL ENGINEERING EDUCATION CONFERENCE, EDUCON 2024},
