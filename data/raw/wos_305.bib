@inproceedings{ WOS:001265872600071,
Author = {Apiola, Mikko and Vartiainen, Henriikka and Tedre, Matti},
Book-Group-Author = {ACM},
Title = {First Year CS Students Exploring And Identifying Biases and Social
   Injustices in Text-to-Image Generative AI},
Booktitle = {PROCEEDINGS OF THE 2024 CONFERENCE INNOVATION AND TECHNOLOGY IN COMPUTER
   SCIENCE EDUCATION, VOL 1, ITICSE 2024},
Year = {2024},
Pages = {485-491},
Note = {29th Annual Conference on Innovation and Technology in Computer Science
