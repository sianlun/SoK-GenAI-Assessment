@inproceedings{ WOS:001533112700157,
Author = {Ferreira, Jose Manuel Martins},
Book-Group-Author = {IEEE},
Title = {AI-Assisted Assessment: a Dual Perspective on Effective Usage Plans for
   Students and Teachers},
Booktitle = {2025 IEEE GLOBAL ENGINEERING EDUCATION CONFERENCE, EDUCON},
