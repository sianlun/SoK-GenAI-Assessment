@inproceedings{ WOS:001583180500006,
Author = {Marazzini, Stefano and Pozzi, Rossella and Rossi, Tommaso and Saporiti,
   Nicolo and Pirola, Fabiana and Rossi, Monica and Terzi, Sergio},
Editor = {Mizuyama, H and Morinaga, E and Nonaka, T and Kaihara, T and VonCieminski, G and Romero, D},
Title = {Use of Generative AI for Assessing Experiential Learning in Engineering
   Education},
Booktitle = {ADVANCES IN PRODUCTION MANAGEMENT SYSTEMS. CYBER-PHYSICAL-HUMAN
   PRODUCTION SYSTEMS: HUMAN-AI COLLABORATION AND BEYOND, APMS 2025, PT VI},
Series = {IFIP Advances in Information and Communication Technology},
Year = {2026},
