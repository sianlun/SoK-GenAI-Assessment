@inproceedings{ WOS:001669704400008,
Author = {Punnoose, Naveen John and Mathew, M. D. and Baxi, Viplav},
Book-Group-Author = {IEEE},
Title = {Enhancing Student Engagement through a Curated Digital Learning Library
   Platform},
Booktitle = {2025 WORLD ENGINEERING EDUCATION FORUM-GLOBAL ENGINEERING DEANS COUNCIL,
   WEEF-GEDC},
Series = {World Engineering Education Forum - Global Engineering Deans Council},
Year = {2025},
Note = {2025 World Engineering Education Forum - Global Engineering Deans
   Council-WEEF-GEDC, Daegu, SOUTH KOREA, SEP 21-25, 2025},
Organization = {Daegu Gyeongbuk Institute of Science \& Technology (DGIST); Dassault
   Systemes; MathWorks; Hyosung Corporation; ABET; Celltrion Inc; CAS;
   George Mason University},
Abstract = {Traditional approaches to resource sharing, primarily via email or
   static repositories, pose challenges in accessibility and continuity of
   learning. The integration of a curated course webpage with the
   institutional digital library was explored to form a Digital Learning
   Library Platform (DLLP), to centralize delivery of learning material and
   provide easy access to relevant scholarly resources. This centralized
   digital learning environment was introduced as a single access point for
   course notes, reference papers, assignments, and multimedia resources,
   aiming to streamline the learning experience. The project aimed to
   assess whether such a platform enhances student engagement, improves
   resource access, and supports learning outcomes better than traditional
   delivery methods.
   The approach was evaluated using platform usage reports, course
   assignments, and examination results. Analysis of student outcomes shows
   that students who actively used DLLP generally performed better on
   assignments and exams. There was also a clear improvement in student
   outcomes before and after the implementation of DLLP. Indirect
   assessment was carried out through a structured survey with Likert scale
   and open-ended questions, evaluating students' experiences with the
   platform and the use of other AI tools, as well as direct student
   interactions. Survey results indicated that most of the students found
   DLLP helpful for accessing materials, with a majority favouring it over
   email-based delivery. Although many students used generative AI tools,
   their responses revealed that AI-generated content often lacked the
   depth and academic alignment provided by a curated academic source.
   Students expressed a strong preference for mobile accessibility and
   requested features such as instant feedback on assignments. The
   centralized digital platform was found to enhance engagement, resource
   access, and learning quality in a technical educational context.},
Publisher = {IEEE},
Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Punnoose, NJ (Corresponding Author), Saintgits Coll Engn Autonomous, Dept Mech Engn, Kottayam, Kerala, India.
   Punnoose, Naveen John; Mathew, M. D., Saintgits Coll Engn Autonomous, Dept Mech Engn, Kottayam, Kerala, India.
   Baxi, Viplav, Knimbus Online Pvt Ltd, New Delhi, India.},
DOI = {10.1109/WEEF-GEDC66748.2025.11256211},
ISSN = {2837-5017},
ISBN = {979-8-3315-8880-9; 979-8-3315-8879-3},
