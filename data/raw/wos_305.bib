@inproceedings{ WOS:001289091100123,
Author = {Zoennchen, Benedikt and Thurner, Veronika and Boettcher, Axel},
Book-Group-Author = {IEEE},
Title = {On the Impact of ChatGPT on Teaching and Studying Software Engineering},
Booktitle = {2024 IEEE GLOBAL ENGINEERING EDUCATION CONFERENCE, EDUCON 2024},
