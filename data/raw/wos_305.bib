Article-Number = {3960},
EISSN = {2076-3417},
Keywords = {artificial intelligence; generative AI; ChatGPT; computer science
   education; programming education; database instruction; AI in education;
   systematic review},
Research-Areas = {Chemistry; Engineering; Materials Science; Physics},
