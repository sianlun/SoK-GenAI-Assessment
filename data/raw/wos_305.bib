@article{ WOS:001504548400004,
Author = {Kiryakova, Gabriela},
Title = {ChatGPT as a Supportive Tool for Creating Assessment Resources},
Journal = {TEM JOURNAL-TECHNOLOGY EDUCATION MANAGEMENT INFORMATICS},
