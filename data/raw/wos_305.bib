@inproceedings{ WOS:001265872600004,
Author = {Menezes, Tyler and Egherman, Lola and Garg, Nikhil},
Book-Group-Author = {ACM},
Title = {AI-Grading Standup Updates to Improve Project-Based Learning Outcomes},
Booktitle = {PROCEEDINGS OF THE 2024 CONFERENCE INNOVATION AND TECHNOLOGY IN COMPUTER
   SCIENCE EDUCATION, VOL 1, ITICSE 2024},
Year = {2024},
Pages = {17-23},
Note = {29th Annual Conference on Innovation and Technology in Computer Science
   Education (ITiCSE), Univ Milano, Milan, ITALY, JUL 08-10, 2024},
Organization = {Assoc Comp Machinery; Assoc Comp Machinery Special Interest Grp Comp Sci
   Educ; ACM Europe Council; Informat Europe; Github Educ; Univ Milano,
   Dipartimento Informatica},
Abstract = {Integrating project-based learning (such as class projects, capstones,
   or internships) into a Computer Science degree helps students apply what
   they have learned in lectures and homework. Often, these projects
   involve group work, but ensuring all students are contributing and
   learning equally is a large challenge.
   This experience report describes how we built and used a chatbot to
   collect and publish brief answers to the ``standup{''} questions used
   daily in the technology industry: ``What did you do yesterday? What are
   you doing today? Is anything blocking you?{''}. We share the rubric we
   used to grade these updates, as well as how we trained an AI tool to
   perform this work for us.
   This tool was used by several hundred students from US-based Career and
   Technical Colleges (CTCs) and non-R1 universities, who were largely
   underrepresented in Computer Science. We found that collecting and
   publishing standups reduced the number of students who did not
   significantly contribute. We also found that scoring the standups
   according to a rubric helped identify and reach out to any students who
   were still not contributing, which helped some students but not others.
   Finally, we found that an AI tool can be used to evaluate student
   updates at scale helping under-resourced schools and over-worked faculty
   to implement this program in their classrooms.},
Publisher = {ASSOC COMPUTING MACHINERY},
