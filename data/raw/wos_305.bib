@article{ WOS:001577102900001,
Author = {Salifu Umar, Salimatu and Bih, Francis Kofi and Antwi, Kwaku and
   Chakurah, Issah and Minta, Michael Darko},
Title = {Comparative assessment of outdoor coating systems on hardwood species in
   Ghana's Wet Semi-Equatorial and Savannah climate conditions},
Journal = {WOOD MATERIAL SCIENCE \& ENGINEERING},
Year = {2025},
Month = {2025 SEP 16},
Abstract = {Tropical hardwoods in Ghana's tropical climate are facing rapid
   degradation due to weathering, yet comparative data on coating
   performance for local species in regional climates are lacking, which
   hinders the development of durable protection strategies. This first
   Ghanaian study compares coating durability across two climate zones by
   evaluating three coating systems: clear acrylic urethane (CAU), wood
   stain with urethane sealer (WSU), and pigmented polyurethane (PP),
   applied in 2, 3, or 4 layers to akasa (Chrysophyllum albidum), danta
   (Nesogordonia papaverifera), and teak (Tectona grandis). It investigated
   the effects of climate, application frequency, and hardwood species on
   coating durability, and to identify the optimal coating system by
   measuring colour change, peeling, cracking, and mass loss. In total, 162
   panels were exposed to natural weathering over six months in Ghana's Wet
   Semi-Equatorial and Savannah regions. Data were analysed using
   non-parametric tests. Results showed greater colour change in the
   Savannah, with no differences in peeling, cracking, or mass loss. Two
   layers sufficed for durability. Teak enhanced coating performance,
   resisting colour change, peeling, and mass loss better than akasa and
   danta. PP outperformed WSU and CAU. PP on teak was identified as
   optimal, providing region-specific guidance for sustainable hardwood
   protection.},
