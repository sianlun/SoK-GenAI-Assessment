@inproceedings{ WOS:001593084100009,
Author = {Haque, Summit and Hundhausen, Christopher},
Book-Group-Author = {ACM},
Title = {Generative AI Access, Usage, and Perceptions: An Empirical Comparison of
   Computing Students In The United States and Bangladesh},
Booktitle = {PROCEEDINGS OF THE ACM CONFERENCE ON INTERNATIONAL COMPUTING EDUCATION
   RESEARCH V. 1, ICER 2025},
