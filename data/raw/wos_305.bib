Title = {A Review of Generative AI in Computer Science Education: Challenges and
   Opportunities in Accuracy, Authenticity, and Assessment},
Booktitle = {COMPUTATIONAL SCIENCE AND COMPUTATIONAL INTELLIGENCE, CSCI 2024, PT IV},
