@inproceedings{ WOS:001485246400033,
Author = {Velicea, Fabian Pavel and Ghimbasan, Alexandra Elena and Filip, Razvan
   Costin and Danciu, Gabriel Mihail and Kertesz, Csaba Zoltan},
Editor = {Auer, ME and Ruutmann, T},
Title = {Programming Examination Platform: Generative AI-Driven Evaluation Tool
   for Computer Programming Classes},
Booktitle = {FUTUREPROOFING ENGINEERING EDUCATION FOR GLOBAL RESPONSIBILITY, ICL2024,
   VOL 4},
Series = {Lecture Notes in Networks and Systems},
Year = {2025},
Volume = {1281},
Pages = {345-356},
Note = {27th International Conference on Interactive Collaborative Learning-ICL,
   Tallinn, ESTONIA, SEP 24-27, 2024},
Abstract = {The Programming Examination Platform (PeP) is an innovative system that
   leverages GPT-4o technology to revolutionize programming exams. This
   advanced platform generates personalized exam questions on demand,
   ensuring high security and relevance to each student's study material.
   Using AI, PeP creates unique, customized questions for each exam
   session, enhancing both the security and fairness of the examination
   process.
   Accessibility is a key focus of PeP. The platform includes dedicated
   support for visually impaired students, featuring text-to-speech and
   speech-to-text functionality. In PeP, traditional exams are task-based
   and challenge students to demonstrate their coding skills through
   practical assignments. In contrast, exams for visually impaired students
   are formatted as multiple-choice questions to accommodate their needs.
   This distinction ensures that all students, regardless of their
   abilities, can effectively showcase their knowledge.
   PeP also implements robust anti-cheat measures, preventing students from
   exiting the exam or copying content, thus maintaining the integrity of
   the examination. The platform is designed with redundancy and
   reliability in mind, saving completed exams to a secure database to
   ensure continuity even if AI services are interrupted. Students benefit
   from comprehensive feedback, receiving immediate grades and feedback
   directly from the AI, which facilitates faster learning and improvement.
   Flexibility is another key feature of PeP, allowing students to resume
   exams after interruptions and enables supervisors to schedule and manage
   exams effortlessly. The platform includes a web management interface
   that allows teachers and proctors to efficiently manage exams and
   monitor student progress. Through this interface, students can view
   their results, check their rankings, and book their exams online.},
