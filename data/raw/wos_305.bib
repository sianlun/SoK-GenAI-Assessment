Title = {Lessons Learned from Embedding Generative AI in Cybersecurity-Oriented
   Computer Science Curricula},
Booktitle = {PROCEEDINGS OF THE 26TH ACM ANNUAL CONFERENCE ON CYBERSECURITY \&
   INFORMATION TECHNOLOGY EDUCATION, ACM SIGCITE 2025},
Year = {2025},
Pages = {284-285},
Note = {26th Annual Conference on Information Technology Education-SIGITE,
   Consumnes River College, Sacramento, CA, NOV 06-08, 2025},
Organization = {Jones \& Bartlett Learning LLC},
Abstract = {Generative AI tools like ChatGPT, Gemini, and GitHub Copilot are
   transforming computer science education, offering both challenges and
   opportunities. This panel features faculty from three diverse
   institutions-a large urban community college, a small rural community
   college, and a baccalaureate-granting university-all designated as
   National Centers of Academic Excellence in Cyber Defense (CAE-CD).
   Panelists will share practical approaches to integrating GenAI tools
   across courses such as CS0, CS1, CS2, and capstone experiences. Topics
   will include the impact of GenAI on student engagement, learning
   outcomes, and problem-solving skills, along with strategies to address
   concerns around academic integrity and prompt engineering. Through real
   classroom examples, student feedback, and assessment data, the panel
   will highlight effective practices and lessons learned across different
   institutional contexts. The session includes structured presentations
   and an interactive discussion, equipping attendees with actionable ideas
   to incorporate GenAI responsibly while supporting core computing
   competencies.},
