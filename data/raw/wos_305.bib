@inproceedings{ WOS:001722569700013,
Author = {Mahon, Joyce and Mac Namee, Brian and Becker, Brett A.},
Book-Group-Author = {ACM},
Title = {Teacher Perspectives on Strengthening AI and Machine Learning in
   Ireland's Leaving Certificate Computer Science Curriculum},
Booktitle = {PROCEEDINGS OF THE 2026 CONFERENCE ON HUMAN CENTERED ARTIFICIAL
   INTELLIGENCE - EDUCATION AND PRACTICE, HCAI-EP 2026},
