@inproceedings{ WOS:001597072200025,
Author = {Hussein, Aya},
Book-Group-Author = {IEEE},
Title = {Maintaining Assessment Validity in the GenAI Era: Insights from
   Human-Machine Interaction},
Booktitle = {2025 10TH INTERNATIONAL STEM EDUCATION CONFERENCE, ISTEM-ED},
