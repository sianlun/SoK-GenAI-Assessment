   Berrezueta-Guzman, Santiago; Wagner, Stefan, Tech Univ Munich, Heilbronn, Germany.
   Krusche, Stephan, Tech Univ Munich, Munich, Germany.},
DOI = {10.1109/ISET65607.2025.00022},
