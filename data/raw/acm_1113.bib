doi = {10.1145/3711670.3764642},
abstract = {This experience report explores the layout and outcome of an upper level rhetoric and professional writing course, “Writing with AI,” through the lens of centering student voice and story. Through narrativizing the author's experience developing the course and positioning student hesitation and fear alongside the professional focus on the course, this report reveals the importance of centering student voice in order to prepare and empower students for writing within the possibilities of AI.},
booktitle = {Proceedings of the 43rd ACM International Conference on Design of Communication},
