@inproceedings{10.1145/3775073.3775119,
author = {Du, Lingjun},
title = {Personalized Pathways for Digital Literacy Enhancement: A Data-Driven Approach Integrating Diagnostic Assessment and Decision Tree Modeling in Foreign Language Teacher Development},
year = {2025},
isbn = {9798400715792},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3775073.3775119},
doi = {10.1145/3775073.3775119},
abstract = {This study proposes a three-phase intervention mechanism of ‘Assessment - Diagnosis - Pathway Generation’ to address the problems of significant differences in teachers' digital literacy and the neglect of individual heterogeneity in standardised training in the transformation of global digital education. Based on the empirical assessment data of 2,187 teachers, a C5.0 decision tree model was constructed, and combined with case study analysis, four sensitive groups of teachers were identified, such as ‘high skills - low awareness’, ‘strong application - weak ethics’, etc. The study validated the diagnostic assessment and the dynamic assessment. The study verifies the effectiveness of the diagnostic assessment and dynamic path generation system, and the optimised model has a path prediction accuracy of 89.2%, providing a data-driven intelligent decision-making solution for the implementation of the industry standard of ‘Digital Literacy for Teachers’, helping to solve the structural contradiction between digital awareness and technical skills, and enhancing the efficiency of training resource allocation.},
booktitle = {Proceedings of the 2025 2nd International Symposium on Artificial Intelligence for Education},
pages = {275–287},
numpages = {13},
keywords = {decision tree models, diagnostic assessment, personalised development pathways, sensitive teacher groups, teachers' digital literacy},
location = {
},
series = {ISAIE '25}
}

