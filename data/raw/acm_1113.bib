@article{10.1145/3803805,
author = {Xiao, Xingyao and Cheng, Yihong},
title = {What Do I Know about AI beyond Everyday Knowledge? Unveiling Misconceptions Using Item Response Theory Analyses and Cognitive Interviews},
year = {2026},
issue_date = {December 2026},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {26},
number = {4},
url = {https://doi.org/10.1145/3803805},
doi = {10.1145/3803805},
abstract = {Advancements in AI make AI literacy essential. However, non-specialist university students often hold misunderstandings of basic AI concepts. This study used a mixed-methods approach to identify which AI concepts are most challenging for novice learners in a college population. Using the AI Concept Inventory (AI-CI) and a confirmatory multidimensional Item Response Theory (MIRT) analysis, we found that items in the AI-CI “Machine Learning (ML)” dimension (i.e., a dimension focused on general ML ideas such as learning from data and distinguishing supervised vs. unsupervised learning) were more difficult for participants than items in the other AI-CI dimensions (i.e., What is AI, Decision Trees, Supervised Learning, Generative Adversarial Networks, and Neural Networks). Cognitive interviews further suggested that everyday knowledge supported the interpretation of several AI concepts, but many ML items required more technical mental models (e.g., how training data relates to prediction and generalization). These findings highlight prevalent ML-related misconceptions among the students in our study and suggest the need for targeted instruction that explicitly addresses learning-from-data, labeling, and generalization in higher education AI literacy contexts.},
journal = {ACM Trans. Comput. Educ.},
month = may,
articleno = {62},
numpages = {28},
keywords = {AI literacy, Multidimensional Item Response Theory, Cognitive interview}
}

@inproceedings{10.1145/3625704.3625748,
author = {Lim, Jiyoung and Park, Soo Kyung and Ahn, Hong Hwan and Lee, Bong Gyou},
title = {Analyzing Diverse Issues on AI Education in South Korea: Focusing on news editorials text mining},
year = {2023},
isbn = {9798400709142},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3625704.3625748},
doi = {10.1145/3625704.3625748},
abstract = {The emergence of ChatGPT, an AI model capable of generating text, has ignited a profound discussion regarding AI education. In order to formulate well-suited policies that effectively encompass the advancements brought about by these novel technologies, it is imperative to thoroughly examine the comprehensive societal discourse that surrounds them. However, there is a dearth of comprehensive research conducted on this subject. The primary objective of this study is to assess the current issues in AI education within the context of South Korea, scrutinize the transformative impact that has occurred following the integration of ChatGPT, and identify future tasks necessary to effectively address these advancements. To achieve this objective, LDA topic modeling was employed to analyze editorials focused on AI education subsequent to the introduction of ChatGPT, consequently leading to the identification of seven topics. Given that the education industry is presently in the process of formulating specific strategies to effectively respond to the presence of ChatGPT, the findings obtained from this study are anticipated to provide substantial insights and recommendations to inform policy-making endeavors.},
booktitle = {Proceedings of the 7th International Conference on Education and Multimedia Technology},
pages = {82–87},
numpages = {6},
keywords = {AI Education, ChatGPT, Text Mining, Topic Modeling},
location = {Tokyo, Japan},
series = {ICEMT '23}
}

@article{10.1145/3785359,
author = {Janakiraman, Shamila and Sabin, Mihaela and Exter, Marisa and Duan, Suzhen},
title = {Preliminary Results from a Systematic Literature Review on Computing Competencies Valued in the Workplace},
year = {2026},
issue_date = {June 2026},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {26},
number = {2},
url = {https://doi.org/10.1145/3785359},
doi = {10.1145/3785359},
abstract = {The computing field is constantly evolving, causing researchers to question the degree to which the competencies required to perform computing-related roles may be changing. This research question has led to a number of studies that explore the gaps between what the computing industry currently demands and the level of competence displayed by graduates of higher education programs. In this article, we present a systematic search and review of research studies that have been published in prominent databases and have focused on competencies required by computing professionals in the workplace. From the formulation of the literature search strategy to the dissemination of the results, we applied a three-stage process consisting of planning the review, conducting the review, and reporting the review findings. The process was informed by the Preferred Reporting Items for Systematic Reviews and Meta-Analyses (PRISMA) 2020 methodology and guidelines. In this article, we report on characteristics of the reviewed studies, such as the location of the studies, computing disciplines of interest, and research methodologies. Further analysis of the reviewed studies allowed us to examine gaps in competencies that the studies identified between industry needs and academic preparation. Other equally important findings of the systematic literature review are the recommendations that computing professionals and managers offer to computing programs to address these gaps.},
journal = {ACM Trans. Comput. Educ.},
month = feb,
articleno = {22},
numpages = {50},
keywords = {Systematic literature review, professional computing competencies}
}

@inproceedings{10.1145/3797552.3797632,
author = {Luo, Xiaoxue and Ling, Shuzhen and Han, Fangting},
title = {Digital Empowerment of Foreign Language Education: A Dao–Fa–Shu–Qi Framework for Human–AI Collaborative Learning},
year = {2026},
isbn = {9798400720925},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3797552.3797632},
doi = {10.1145/3797552.3797632},
abstract = {In this study, “AI-enhanced” refers to Artificial Intelligence–enhanced digital learning systems, in which computational techniques augment instructional processes. This paper develops an AI-enhanced digital learning system for foreign language education based on the Dao–Fa–Shu–Qi framework. To bridge the gap between educational philosophy and computational implementation, we design a human–AI collaborative learning architecture that integrates large language models, automated speech evaluation, learning analytics dashboards, and prompt-engineering–based interaction workflows. A 16-week quasi-experimental study was conducted using an AI-supported English Public Speaking platform that automatically analyzes pronunciation, fluency, prosody, and discourse coherence using a multi-metric scoring algorithm. System logs, behavioral data, and speech performance metrics were collected and processed through Python-based data pipelines and NVivo qualitative coding. Experimental results show that students using the AI-driven system achieved significantly higher gains in pronunciation accuracy (+37.2%), speech fluency (+29.8%), and value-oriented cultural expression, compared with the control group. The study demonstrates how computational technologies can operationalize the Dao–Fa–Shu–Qi model and provides a reproducible technical pathway for integrating large language models into foreign language instruction.},
booktitle = {Proceedings of the 2025 4th International Conference on Artificial Intelligence and Education},
pages = {494–498},
numpages = {5},
keywords = {Dao-Fa-Shu-Qi, Digital Empowerment, Foreign Language Education, Large Language Models, English Public Speaking, Human-AI Collaboration},
location = {
},
series = {ICAIE '25}
}

@inbook{10.1145/3797552.3797617,
author = {Wang, Wei and Sun, Tengchao and Sun, Nairui and Xiao, Yao and Li, Shu and Yang, Liping},
title = {Research on AI-Enabled Curriculum System for Computer-Related Majors},
year = {2026},
isbn = {9798400720925},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3797552.3797617},
abstract = {Addressing the structural contradictions in talent cultivation for applied undergraduate computer-related majors in the AI era, this study innovatively proposes a “Five-Dimensional Reconstruction + Bidirectional Empowerment” dynamic adaptation model, constructing a “general education layer—foundation layer—advanced layer—integration layer” four-level progressive curriculum system. Empirical research was conducted through methods such as industry-university collaborative development of practical cases, knowledge graph-driven intelligent evaluation systems, and dynamic feedback mechanisms. The results indicate that this system significantly enhances students' AI application capabilities, interdisciplinary innovation abilities, and employment competitiveness. Over 10 industry scenario courses were jointly developed with enterprises, forming a closed-loop cultivation model of “enterprise demand—curriculum update—talent output”. This research provides a verifiable practical path for the AI-oriented curriculum system reform of applied undergraduate computer-related majors, and offers important talent cultivation support for educational digital transformation and national artificial intelligence development strategies.},
booktitle = {Proceedings of the 2025 4th International Conference on Artificial Intelligence and Education},
pages = {401–407},
numpages = {7}
}

@inproceedings{10.1145/3687311.3687336,
author = {Li, Xi and Sun, Dandan and Qiu, Jin},
title = {AI-supported Teaching in China (2014–2024)},
year = {2024},
isbn = {9798400709920},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3687311.3687336},
doi = {10.1145/3687311.3687336},
abstract = {This article provides a comprehensive overview of AI-supported teaching in China, encompassing a decade (2014–2024)'s worth of the selected research findings from the influential local journals. The researchers performed a bibliometric analysis to uncover the most commonly explored theme (AI-supported teaching) in the field. Next, a thorough examination was conducted on 43 studies with these specific categories and sub-categories. The review concluded by addressing the shortcomings and offering suggestions for the further research. A comprehensive examination of Chinese practitioners and researchers’ endeavors to enhance AI-assisted teaching is expected to lend valuable insights to the global advancement of AI-supported teaching.},
booktitle = {Proceedings of the 2024 International Conference on Intelligent Education and Computer Technology},
pages = {134–139},
numpages = {6},
location = {Guilin, China},
series = {IECT '24}
}

@inproceedings{10.1145/3797552.3797773,
author = {Li, Zhiping and Bao, Yuan and Luo, Xueyi and Yang, Boya},
title = {Research on Personalized Question-Answering Framework Based on Cognitive Diagnosis},
year = {2026},
isbn = {9798400720925},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3797552.3797773},
doi = {10.1145/3797552.3797773},
abstract = {In the current era of rapid development of information technology, education is facing a transformation from large-scale learning to personalized learning, and personalized learning has gradually become a focus topic in the field of education. This study constructed a personalized question-answering learning support framework based on cognitive diagnosis. This framework integrates main modules such as cognitive diagnosis technology, knowledge graphs, and personalized question-answering content design, aiming to enhance learners' learning outcomes. This study selects the “Numbers and Algebra” section of the fourth grade lower semester of the People's Education Edition of Primary School Mathematics as the teaching content for case analysis. In terms of cognitive diagnosis, the DRCDM model is adopted to utilize residual networks for feature extraction, accurately assessing the cognitive status of learners and providing personalized learner information for the subsequent question-answering system. Subsequently, the personalized answer content design module ensures the accurate identification of the knowledge points involved in the question, as well as the generation of personalized question answers.},
booktitle = {Proceedings of the 2025 4th International Conference on Artificial Intelligence and Education},
pages = {1391–1396},
numpages = {6},
location = {
},
series = {ICAIE '25}
}

@inproceedings{10.1145/3802607.3802689,
author = {Zhang, Junxiang and Zhou, Ningxin},
title = {Intervention-Response: A Grounded Theory Study on DeepSeek Empowering the Reform of Theoretical Courses in Higher Vocational Colleges in Wenzhou, China, from a Digital Intelligence Perspective},
year = {2026},
isbn = {9798400721700},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3802607.3802689},
doi = {10.1145/3802607.3802689},
abstract = {Amid the global digital intelligence (DI) transformation of vocational education, theoretical courses in higher vocational colleges face operability and visualization bottlenecks, demanding systemic reform. This study adopts a mixed-methods design integrating grounded theory and longitudinal tracking to investigate 240 stakeholders from 7 vocational colleges across 4 Chinese regions. Data were collected via 180 individual, 60 focus group interviews, and a 6-month pre-post survey. A refined “Stimulus-Intervention-Organism-Response (S-I-O-R)” framework was constructed, delineating how DeepSeek's intrinsic attributes (generative professionalism, interactive responsiveness) influence stakeholders’ internal states (excitement, value perception, trust) and usage intentions, with contextual factors (policy, infrastructure, institutional culture) as moderators. Heterogeneous stakeholder challenges (teachers’ trust deficit, students’ over-reliance, administrators’ efficiency-pedagogy trade-off) were identified, and targeted reform strategies embedded in a change management framework were proposed, validated by 3 pilot college cases. This research enriches AI-education integration theory and provides empirically grounded guidelines for vocational education reform in the DI era.},
booktitle = {Proceedings of the 2026 2nd International Conference on Digital Education and Information Technology},
pages = {522–527},
numpages = {6},
keywords = {Case Study, Cross-Regional Study, DeepSeek, Digital Intelligence, Grounded Theory, Higher Vocational Education, Longitudinal Research, Theoretical Course Reform},
location = {
},
series = {DEIT '26}
}

@inproceedings{10.1145/3641237.3691645,
author = {Liddle, Daniel and Grant, Carrie},
title = {AI Literacy as a Potential Mechanism of Stratification},
year = {2024},
isbn = {9798400705199},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3641237.3691645},
doi = {10.1145/3641237.3691645},
abstract = {Drawing on data from two parallel IRB-approved studies, this paper examines how students incorporate AI-generated text in their TPC writing assignments. In both studies, students were coached through the process of using AI tools for specific writing tasks, including an emphasis that AI-generated text should be scrutinized for rhetorical, stylistic, and factual errors. By looking at examples of students’ work and reflections of students’ experience, the authors identify differences in AI use between successful and unsuccessful writing samples. The authors consider how these differences could challenge the notion that AI might “level the playing field” of writing skill levels. The authors conclude with four AI literacies that will be necessary to prevent further stratification of student-writers’ skills.},
booktitle = {Proceedings of the 42nd ACM International Conference on Design of Communication},
pages = {3–10},
numpages = {8},
keywords = {AI literacy, Artificial Intelligence, instructional design, style},
location = {Fairfax, VA, USA},
series = {SIGDOC '24}
}

@inproceedings{10.1145/3802133.3802149,
author = {Xu, Xianying},
title = {Exploring Artificial Intelligence Literacy Among International Chinese Language Teachers},
year = {2026},
isbn = {9798400721564},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3802133.3802149},
doi = {10.1145/3802133.3802149},
abstract = {With the arrival of AI era, teachers' AI literacy has become an important topic. This study focuses on the international Chinese language teachers, to explore the general level of AI literacy of the teachers, and also the possible influencing factors of their AI literacy. Drawing on the AIL Scale for Teachers by Bilal Younis, the research investigates 75 international Chinese language teachers from different regions. From the findings, we can see that these international Chinese language teachers hold pretty favorable views on applications of AI to education, however their understanding of basic concepts of AI and computational thinking is rather poor. Teachers are stronger in motivating students to use AI tools and understanding the social and cultural impacts of AI but are worst in using AI for learning assessment. Gender, education level, teaching experience, institution type, and teaching region did not significantly predict teachers' AI literacy. Schools providing AI tools shows a big positive impact on teachers AI literacy. Even if the effect of the related training in AI does not achieve statistical significance, there is a practically significant upward trend towards the improvement of teachers' concept formation.},
booktitle = {Proceedings of the 2026 3rd International Conference on Informatics Education and Computer Technology Applications},
pages = {87–93},
numpages = {7},
keywords = {Artificial Intelligence Literacy, Educational Technology, International Chinese Language Education, Teacher Professional Development},
location = {
},
series = {IECA 2026}
}

@inproceedings{10.1145/3698205.3729542,
author = {Ahmad, Mak and Ravi, Prerna and Karger, David and Facciotti, Marc},
title = {How Adding Metacognitive Requirements in Support of AI Feedback in Practice Exams Transforms Student Learning Behaviors},
year = {2025},
isbn = {9798400712913},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3698205.3729542},
doi = {10.1145/3698205.3729542},
abstract = {Providing personalized, detailed feedback at scale in large undergraduate STEM courses remains a persistent challenge. We present an empirically evaluated practice exam system that integrates AI generated feedback with targeted textbook references, deployed in a large introductory biology course. Our system specifically aims to encourage metacognitive behavior by asking students to explain their answers and declare their confidence. It uses OpenAI's GPT-4o to generate personalized feedback based on this information, while directing them to relevant textbook sections. Through detailed interaction logs from consenting participants across three midterms (541, 342, and 413 students respectively), totaling 28,313 question-student interactions across 146 learning objectives, along with 279 post-exam surveys and 23 semi-structured interviews, we examined the system's impact on learning outcomes and student engagement. Analysis showed that across all midterms, the different feedback types showed no statistically significant differences in performance, though there were some trends suggesting potential benefits worth further investigation. The system's most substantial impact emerged through its required confidence ratings and explanations, which students reported transferring to their actual exam strategies. Approximately 40% of students engaged with textbook references when prompted by feedback---significantly higher than traditional reading compliance rates. Survey data revealed high student satisfaction (M=4.1/5), with 82.1% reporting increased confidence on midterm topics they had practiced, and 73.4% indicating they could recall and apply specific concepts from practice sessions. Our findings demonstrate how thoughtfully designed AI-enhanced systems can scale formative assessment while promoting sustainable study practices and self-regulated learning behaviors, suggesting that embedding structured reflection requirements may be more impactful than sophisticated feedback mechanisms.},
booktitle = {Proceedings of the Twelfth ACM Conference on Learning @ Scale},
pages = {164–175},
numpages = {12},
keywords = {ai-enhanced feedback, biology education, confidence ratings, higher education, learning at scale, metacognition, practice exams, self-regulated learning, student explanations, textbook engagement},
location = {Palermo, Italy},
series = {L@S '25}
}

@inproceedings{10.1145/3605390.3605393,
author = {Gennari, Rosella and Melonio, Alessandra and Pellegrino, Maria Angela and D'Angelo, Mauro},
title = {How to Playfully Teach AI to Young Learners: a Systematic Literature Review},
year = {2023},
isbn = {9798400708060},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3605390.3605393},
doi = {10.1145/3605390.3605393},
abstract = {Children are experiencing Artificial Intelligence (AI) devices in their daily lives. It is crucial to provide them with knowledge concerning how AI works, for enabling them to use AI responsibly and participate actively in their AI-driven future. To support motivation and engagement, playful tools are often used in technology education for K-12 children. This paper offers a systematic literature review of tools for teaching AI to K-12 learners in a playful manner. The most relevant articles are classified and analysed in terms of the nature of the tools they use, that is, whether tools are digital, partly physical and partly digital, or unplugged. Their analysis also considers the target age, the educational focus, and whether their impact is evaluated. According to the results of the review, there are tools for learners of all school grades, and digital tools are the most investigated. Moreover, several studies with tools tend to evaluate engagement and learning but in different manners. The paper concludes by discussing the evaluation aspect, general future work directions and limitations in relation to HCI and education for children.},
booktitle = {Proceedings of the 15th Biannual Conference of the Italian SIGCHI Chapter},
articleno = {1},
numpages = {9},
keywords = {Artificial Intelligence, K-12 education, game, gamification, learning, play},
location = {Torino, Italy},
series = {CHItaly '23}
}

@inproceedings{10.1145/3806980.3807355,
author = {Liu, Zhiming},
title = {Exploration of an AI-Deeply Empowered Model for Cultivating International Compound Talents in Universities Based on the Random Forest Algorithm from a Cross-Cultural Perspective},
year = {2026},
isbn = {9798400722073},
