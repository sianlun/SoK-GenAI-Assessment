@inbook{10.1145/3802133.3802292,
author = {Liu, Xu'an},
title = {Smart Teaching Assistant Empowers Engineering Foundational Courses: The Application of Generative Artificial Intelligence in Signals and Systems Education},
year = {2026},
isbn = {9798400721564},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3802133.3802292},
abstract = {The rapid development of generative artificial intelligence presents new opportunities for innovation in higher education. This paper focuses on the core course Signals and Systems in electronic information-related majors, which is known for its strong theoretical nature and high learning difficulty, and explores how to effectively integrate the Chinese generative AI model DeepSeek into teaching practices. Addressing issues such as conceptual abstraction, lack of visual aids, and monotonous training in course instruction, the paper systematically designs application scenarios for DeepSeek. These include its role as an intelligent teaching assistant for conceptual explanation and guided Q&amp;A, the use of code generation to achieve dynamic visualization of topics such as signal modulation and Fourier series, and the construction of an adaptive exercise generation and variation training system. Practice has shown that these designs can transform abstract theories into intuitive experiences and provide personalized learning support, thereby helping to stimulate student interest and promote knowledge internalization. This offers an intelligent solution with reference value for addressing the teaching challenges of traditional foundational courses.},
booktitle = {Proceedings of the 2026 3rd International Conference on Informatics Education and Computer Technology Applications},
pages = {987–993},
numpages = {7}
}

@inproceedings{10.1145/3625704.3625732,
author = {Yang, Jie},
title = {The impacts and responses of ChatGPT on education},
year = {2023},
isbn = {9798400709142},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3625704.3625732},
doi = {10.1145/3625704.3625732},
abstract = {Abstract: The emergence of intelligent chatbots represented by ChatGPT has aroused great attention and heated discussions in the education circles, and the public has also expressed their views on the impacts of ChatGPT on education on social platforms. Using the technology of web crawler collection, the re-searcher collected relevant public opinion on social platforms such as Weibo, and analyzed the data based on the content analysis method. The results show that the discussion of ChatGPT and education includes three aspects: the three elements of education, the purpose of education, and the human-machine relationship arising from artificial intelligence. Education in the era of artificial intelligence should return to the original intention of education, adhere to digital ethics, and move towards human-machine cooperation and symbiosis.},
booktitle = {Proceedings of the 7th International Conference on Education and Multimedia Technology},
pages = {69–73},
numpages = {5},
keywords = {ChatGPT, Education, Public opinion, web crawler technology},
location = {Tokyo, Japan},
series = {ICEMT '23}
}

@inproceedings{10.1145/3806980.3807016,
author = {Zhang, Caiyi and Sun, Lin},
title = {Fine-grained Rubric-Aware Automated Scoring of Programming Short Answer Questions via Large Language Models in Vocational Education},
year = {2026},
isbn = {9798400722073},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3806980.3807016},
doi = {10.1145/3806980.3807016},
abstract = {To address the challenges of automated scoring for subjective programming questions in vocational education—such as semantic ambiguity and colloquial student expressions—this paper proposes the Fine-grained Adaptive Scoring Framework (GASF). Built on Large Language Models and Prompt Engineering, GASF decomposes standard answers into Atomic Scoring Units (ASUs) and utilizes a reasoning alignment module to map student responses to these units. Experimental results across five knowledge dimensions (Q1-Q5) demonstrate that GASF significantly outperforms the zero-shot baseline. The framework achieved a peak Quadratic Weighted Kappa (QWK) of 0.7518, indicating high consistency with human graders. Notably, in complex logical tasks, the Mean Absolute Error (MAE) was reduced by up to 78.9% (from 1.4200 to 0.3000). These findings suggest that GASF provides a robust, interpretable, and scalable solution for the automated assessment of subjective tasks in large-scale educational settings, effectively bridging the gap between general AI capabilities and professional pedagogical requirements.},
booktitle = {Proceedings of the 2026 International Conference on Big Data and Informatization Education},
pages = {222–226},
numpages = {5},
keywords = {Automated Scoring, Fine-grained Evaluation, Large Language Models, Programming Education, Prompt Engineering},
location = {
},
series = {ICBDIE '26}
}

@inproceedings{10.1145/3636243.3636264,
author = {Brieven, Géraldine and Baum, Valentin and Donnet, Benoit},
title = {Tartare: Automatic Generation of C Pointer Statements and Feedback},
year = {2024},
isbn = {9798400716195},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3636243.3636264},
doi = {10.1145/3636243.3636264},
abstract = {This paper addresses the difficulties students face when learning and practicing pointers (i.e., variables storing the memory address of another variable as its value) in a computer programming class. To improve their understanding and practice, we have developed Tartare, an automatic C pointer statement and feedback generator. By creating statements with automatic feedback, students are given the opportunity to practice at will, each time on a different instance. In addition, if the statement must be done remotely and accounts in the final grade, Tartare discourages academic dishonesty since each student faces their own statement to solve. This paper describes the techniques implemented in Tartare, relying on a pattern template-based approach. The statement variety of Tartare is evaluated. Finally, current limitations and further improvements are discussed. We believe our approach for Tartare can be transposed for automatic exercises generation in various other fields.},
booktitle = {Proceedings of the 26th Australasian Computing Education Conference},
pages = {192–201},
numpages = {10},
keywords = {C programming language, Tartare, pointers, statement generation},
location = {Sydney, NSW, Australia},
series = {ACE '24}
}

@inproceedings{10.1145/3638067.3638100,
author = {Freire, André Pimenta and Cardoso, Paula Christina Figueira and Salgado, André de Lima},
title = {May We Consult ChatGPT in Our Human-Computer Interaction Written Exam? An Experience Report After a Professor Answered Yes},
year = {2024},
isbn = {9798400717154},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3638067.3638100},
doi = {10.1145/3638067.3638100},
abstract = {Using ChatGPT in education presents challenges for evaluating students. It requires distinguishing between original ideas and those generated by the model, assessing critical thinking skills, and gauging subject mastery accurately, which can impact fair assessment practices. The Human-Computer Interaction course described in this experience report has enabled consultation with textbooks, slides and other materials for over five years. This experience report describes reflections regarding using ChatGPT as a source of consultation in a written HCI exam in 2023. The paper describes experiences with analysis of the types of questions ChatGPT was able to solve immediately without mediation and the types of questions that could benefit from ChatGPT’s assistance without compromising the assessment of higher-level learning outcomes that professors want to analyse in teaching HCI. The paper uses Bloom’s taxonomy to analyse different questions and abilities to be evaluated and how they can be solved solely by using ChatGPT. The paper discusses questions that need mediation, previous lived experience in class and understanding of the knowledge acquired in class that cannot be answered directly by copying and pasting questions into ChatGPT. The discussions can raise reflections on the learning outcomes that can be assessed in HCI written exams and how professors should reflect upon their experiences and expectations for exams in the age of growing generative artificial intelligence resources.},
booktitle = {Proceedings of the XXII Brazilian Symposium on Human Factors in Computing Systems},
articleno = {6},
numpages = {11},
keywords = {ChatGPT, HCI education, evaluation, open-book exams},
location = {Maceió, Brazil},
series = {IHC '23}
}

@inproceedings{10.1145/3803869.3803878,
author = {Fan, Jixiang and Wang, WeiLu and Xia, Lei and Chen, Yuhao and Liu, Shuai and McCrickard, D. Scott},
title = {Between Evaluation and Facilitation: Teaching Assistants’ Challenges in HCI Education},
year = {2026},
isbn = {9798400724305},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3803869.3803878},
doi = {10.1145/3803869.3803878},
abstract = {In Human–Computer Interaction (HCI) education, Teaching Assistants (TAs) play a central role in project-based and collaborative learning environments, while operating under persistent structural tensions. Drawing on interviews with graduate TAs who supported HCI-related courses, this paper examines how TAs navigate responsibilities that extend beyond conventional instructional support. TAs are expected not only to evaluate students’ assignments and project outcomes, but also to facilitate learning by encouraging innovation, supporting collaboration, and maintaining the day-to-day functioning of the classroom. The coexistence of evaluative and facilitative responsibilities places TAs in a position where competing expectations are difficult to reconcile in practice. This paper outlines four unresolved challenges faced by TAs in HCI education. First, assessment in HCI courses often relies on open-ended and descriptive grading standards, concentrating a substantial amount of interpretive judgment in the hands of TAs. Second, within grade-oriented project environments, TAs are frequently positioned between encouraging innovative and high-risk design attempts and maintaining fairness and predictability in grading outcomes. Third, the widespread use of group-based projects requires TAs to take on responsibilities for coordinating collaboration and mediating group conflicts alongside evaluating learning outcomes. Finally, as generative AI tools become increasingly embedded in learning activities, judging the appropriateness and educational value of students’ AI use has emerged as an additional responsibility for TAs, yet shared criteria and guidance remain limited. This paper aims to foreground the perspectives of TAs and to encourage broader discussion within the HCI education community about the expanding responsibilities of TAs and the structural challenges these roles involve.},
booktitle = {Proceedings of the 8th Annual Symposium on HCI Education},
articleno = {10},
numpages = {6},
keywords = {Teaching Assistants, Instructional Challenges, Project-Based Learning, AI in Education},
location = {
},
series = {EduCHI '26}
}

@inproceedings{10.1145/3660043.3660191,
author = {Lian, Weichen and Xu, Juan},
title = {Exploration of Multi-round Dialogue Function of International Chinese Education Robot Based on LLM},
year = {2024},
isbn = {9798400716157},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3660043.3660191},
doi = {10.1145/3660043.3660191},
abstract = {In the process of international Chinese language education, issues such as the shortage of Chinese language teachers and insufficient input and output for Chinese learners are common. To enable learners to effectively engage in input and output activities based on their learning levels, this article attempts to integrate educational robot technology into the field of international Chinese education. Firstly, the article explains the form and function of robots; Then, based on the characteristics of robot technology, large language models, and multi-turn dialogue systems, it proposes the use of educational robots equipped with large language models specific to international Chinese education to assist learners. This research uses LangChain to connect a local Chinese resource library with a large language model, exploring the practical effects of educational robots equipped with this multi-turn dialogue function in international Chinese education, and compares it with the dialogue effects of general large language models. Finally, the article concludes with a summary and future outlook.},
booktitle = {Proceedings of the 2023 International Conference on Information Education and Artificial Intelligence},
pages = {833–838},
numpages = {6},
location = {Xiamen, China},
series = {ICIEAI '23}
}

@inproceedings{10.1145/3797552.3797623,
author = {Wang, Dang and Du, Yingqi and Sha, Zhengyu},
title = {University Information Resource Management and Sharing Services Empowered by AI},
year = {2026},
isbn = {9798400720925},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3797552.3797623},
doi = {10.1145/3797552.3797623},
abstract = {In the new phase of the intersection between the digital transformation of higher education and the strategy of building a strong education nation, the information resources of university teachers and students are shifting from “physical custody” to “data governance”. Taking the 18-month AI-empowered information resource management project at University W as a sample and using a four-step method of “need—model—case—strategy”, this study systematically explores the feasible paths for the transformation and upgrading of university archives and libraries driven by generative AI. The findings indicate that students expect “seamless services, continuous recording, and cross-border mutual recognition”, while universities urgently need “structured governance, proactive early warning, and value-added development”. Meanwhile, society calls for “trustworthy sharing chains, privacy computing, and international mutual recognition”. Based on these findings, a tripartite framework of “data hub + knowledge service platform + trustworthy exchange platform” is constructed. The study proposes a paradigm shift from “AI in System” to “System in AI”. University archives and libraries should be repositioned as “trustworthy data hubs + talent cultivation service hubs + cultural memory hubs”. By leveraging consortium chains, privacy computing, and a continuous learning loop, a demonstration model for the education data element market can be created.},
booktitle = {Proceedings of the 2025 4th International Conference on Artificial Intelligence and Education},
pages = {442–447},
numpages = {6},
keywords = {AI Large Models, Data Governance, Information Resources, Sharing Services, University archives, University libraries},
location = {
},
series = {ICAIE '25}
}

@inproceedings{10.1145/3799457.3799663,
author = {Gao, Yiyang and Yang, Tingting and Cao, Lihui and Fang, Xianyun and Ma, Li},
title = {From Tools to Partners: A Bibliometric Analysis of the Paradigm Shift in AI-Supported Creativity Cultivation in Higher Education},
year = {2026},
isbn = {9798400720710},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3799457.3799663},
doi = {10.1145/3799457.3799663},
abstract = {Artificial intelligence (AI) in higher education is undergoing a fundamental paradigm shift, moving from a focus on “technology application” toward a new era of “human-AI collaboration” in cultivating student creativity. To map the intellectual structure and evolution of this field, we conducted a comprehensive bibliometric analysis of literature published between 2005 and 2025. Our analysis, which included thematic evolution and burst detection, provides robust evidence of this transition: early research was dominated by intelligent tutoring systems and adaptive learning, whereas the current frontier is defined by generative AI, critical thinking, and AI literacy. This evolution signals that AI's role is being redefined from a functional tool to a cognitive partner in the creative process. In response to these findings, we propose the Human-AI Collaborative Creativity Model (HAI-CCM), an integrative theoretical framework that conceptualizes this new paradigm. The study equips educators and policymakers with a critical lens and practical guidance to navigate the challenges and opportunities of generative AI, thereby supporting the co-construction of future-oriented, creative learning ecosystems.},
booktitle = {Proceedings of the 2025 3rd International Conference on Information Education and Artificial Intelligence},
pages = {1257–1270},
numpages = {14},
keywords = {Bibliometrics, Artificial Intelligence in Education, Paradigm Shift, Generative Artificial Intelligence, Higher Education, Human-AI Collaboration, Creativity},
location = {
},
series = {ICIEAI '25}
}

@inproceedings{10.1145/3698205.3729551,
author = {Wang, Hanling and Chi, Banghao and Wu, Yufei and Chen, Kexin and Wu, Di and Liu, Songning and Li, Yiwei and Niu, Hanyan and Zhu, Xiaohui},
title = {LLMarking: Adaptive Automatic Short-Answer Grading Using Large Language Models},
year = {2025},
isbn = {9798400712913},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3698205.3729551},
doi = {10.1145/3698205.3729551},
abstract = {With the advancement of educational technology, automatic assessment systems are becoming increasingly essential, particularly for grading short-answer questions. However, due to the inherent ambiguity and complexity of language, automatic grading of short-answer questions remains a challenge. Traditional grading methods are often time-consuming and subjective, highlighting the need for efficient, objective, and feedback-driven solutions. This paper proposes an innovative approach to automatic short answer grading (ASAG) utilizing large language models (LLMs). We introduce a specialized design for crafting questions and corresponding answers named Key Point Scoring Framework (KPSF) which significantly enhances the model's performance in ASAG tasks and improves the flexibility and objectivity of assessments. Moreover, we incorporate Prompt Dynamic Adjustment (PDA) that continuously refines the grading process, effectively handling ambiguous student responses while ensuring reliable results. To evaluate our approach, we develop a multidisciplinary dataset and incorporate real-world dataset from actual exams. The experimental results demonstrate that our ASAG approach provides educators with a highly efficient, flexible and accurate tool for short-answer assessments, indicating a significant advancement in automatic grading technology.},
booktitle = {Proceedings of the Twelfth ACM Conference on Learning @ Scale},
pages = {105–115},
numpages = {11},
keywords = {automatic grading, key point scoring, large language models, natural language processing, prompt engineering},
location = {Palermo, Italy},
series = {L@S '25}
}

@inproceedings{10.1145/3704289.3704301,
author = {Chang, Chi In and Choi, Wan Chong and Choi, Iek Chong},
title = {A Systematic Literature Review of the Opportunities and Advantages for AIGC (OpenAI ChatGPT, Copilot, Codex) in Programming Course},
year = {2025},
isbn = {9798400716980},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3704289.3704301},
doi = {10.1145/3704289.3704301},
abstract = {This systematic literature review explored the opportunities and advantages of integrating Artificial Intelligence Generated Content (AIGC) tools like OpenAI's ChatGPT, Copilot, and Codex in programming education. From an initial pool of 1,173 papers, 24 were rigorously selected for detailed analysis. The findings highlighted the dominant use of ChatGPT, particularly versions 3/3.5 and 4, underscoring its effectiveness and accessibility. Python emerged as the most frequently studied language, followed by Java, C, R, and Scala. A notable research gap was identified in block-based programming languages and online/blended learning environments. Key opportunities and advantages identified included enhanced code review, where AIGC tools offer efficient and comprehensive assessments; personalized learning, with ChatGPT providing individualized feedback and improving student comprehension; and increased student engagement and motivation through interactive features. Additionally, AIGC tools significantly improved problem-solving and debugging support, effectively identifying and correcting coding errors. They also supported diverse learning styles by offering varied examples and solutions, facilitated innovative teaching strategies that improved educational outcomes, and reduced teacher workload by automating routine tasks. These insights demonstrated the transformative potential of AIGC tools in revolutionizing programming education.},
booktitle = {Proceedings of the 2024 7th International Conference on Big Data and Education},
pages = {29–35},
numpages = {7},
keywords = {Advantages of AIGC, Artificial intelligence generated content, ChatGPT, Codex, Copilot, Opportunities of AIGC, Programming Course, Systematic literature review},
location = {
},
series = {ICBDE '24}
}

@inproceedings{10.1145/3789859.3789903,
author = {Anotaipaiboon, Weerachai},
title = {Guided Incremental Grading for Java Programming Assignments},
year = {2026},
isbn = {9798400722356},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3789859.3789903},
doi = {10.1145/3789859.3789903},
abstract = {Automated grading systems play an increasingly vital role in programming education, yet most existing platforms rely on batch-style submissions and delayed evaluation, limiting their effectiveness for formative learning. This paper presents Guided Incremental Grading, a novel system for Java programming assignments that continuously monitors student code and delivers immediate, adaptive feedback. The platform integrates three core components: (1) a live code monitor, built on a web-based editor and JavaParser, which parses source code into Abstract Syntax Trees (ASTs), detects fine-grained changes, and triggers incremental testing upon successful compilation; (2) an incremental test execution engine that leverages custom Javadoc annotations and Java Reflection to dynamically run targeted tests on methods, constructors, and fields, with flexible configuration; and (3) a guidance and feedback generator that combines structural analysis with pedagogical metadata, progressively offering hints, examples, resource links, and partial code revelations. Unlike traditional systems, the proposed framework tightly integrates assessment with instruction, enabling immediate detection of structural errors, missing class members, and faulty logic. Preliminary deployment in an introductory Java programming course demonstrates that the system improves debugging efficiency, increases student confidence, and supports deeper conceptual understanding. By aligning automated grading with the iterative nature of programming practice, Guided Incremental Grading advances the shift from summative evaluation toward continuous, formative learning support.},
booktitle = {Proceedings of the 2025 9th International Conference on Education and E-Learning},
pages = {135–140},
numpages = {6},
keywords = {Adaptive guidance, Automated grading, Incremental testing, Java programming language, Programming education, Real-time feedback},
location = {
},
series = {ICEEL '25}
}

@inproceedings{10.1145/3746469.3746523,
author = {Wang, Shuai},
title = {Algorithm Design and Analysis Instruction Using the BOPPPS-ACPS Model: Dynamic Programming Algorithm: A Case Study},
year = {2025},
isbn = {9798400713811},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3746469.3746523},
doi = {10.1145/3746469.3746523},
abstract = {The Algorithm Design and Analysis course, one of the most important courses in the field of computer science education, often presents difficulties in teaching due to too much abstraction of theory and the lack of students' operational engineering skills. In this paper, we propose a novel course design model by combining the BOPPPS model with ACPS elements (Algorithm Cases, Political Education, Coding Platform, and Chaoxing Learning System) to improve the education of an algorithm course. The framework takes dynamic programming algorithms as the case and introduces national strategies, such as public health management and intelligent logistics scheduling, to the teaching exercises. Experimental results show that this model has encouraged students' practices on algorithm modeling and enhanced students' awareness of ethical choice. Comparative analysis shows that the dynamic programming scores in the unit test are significantly better than those obtained through traditional teaching and that there is a consistent trend of high interaction frequency in the classroom. These results confirm the successful incorporation of knowledge construction and value development in the teaching program we developed.},
booktitle = {Proceedings of the 2nd Guangdong-Hong Kong-Macao Greater Bay Area Education Digitalization and Computer Science International Conference},
pages = {324–330},
numpages = {7},
keywords = {Algorithm Design, BOPPPS-ACPS Model, Curriculum Ideological and Political Education, Dynamic Programming},
location = {
},
series = {EDCS '25}
}

@inproceedings{10.1145/3696630.3727250,
author = {Kassab, Mohamad},
title = {Navigating Academic Careers in Software Engineering: An Empirical Study of Faculty and Postdoctoral Roles},
year = {2025},
isbn = {9798400712760},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3696630.3727250},
doi = {10.1145/3696630.3727250},
abstract = {Academic hiring in software engineering is shaped by rapidly evolving technologies, shifting research priorities, and a growing emphasis on diversity and industry collaboration. Despite these changing dynamics, the current landscape of academic career pathways remains insufficiently understood. To address this gap, this paper analyzes 701 job postings from the SEWORLD archive (June 2021–June 2024), primarily focusing on postdoctoral and faculty roles. A mixed-method approach combining descriptive statistics, text mining, and topic modeling highlights several key trends: (1) an increasing requirement for interdisciplinary expertise and practical skills in areas such as AI, security, and cloud computing; (2) notable disparities in geographic distribution and compensation structures; and (3) diversity initiatives that, while present, often emphasize gender over other underrepresented categories. The findings offer actionable curriculum and hiring insights for academic institutions, educators, and early-career researchers, pointing toward curriculum enhancements that integrate advanced technologies, industry-relevant practices, and inclusive recruitment strategies.},
booktitle = {Proceedings of the 33rd ACM International Conference on the Foundations of Software Engineering},
pages = {936–946},
numpages = {11},
keywords = {software engineering education, academic job market, tenure-track positions, postdoctoral positions, interdisciplinary collaboration, diversity initiatives},
location = {Clarion Hotel Trondheim, Trondheim, Norway},
series = {FSE Companion '25}
}

@inproceedings{10.1145/3696630.3727254,
author = {Lund, Camilla Kielland and Stabell, Idunn and Stray, Viktoria and Lindsjørn, Yngve},
title = {Teamwork Quality in Agile Capstone Courses: Insights from 790 Software Engineering Students},
year = {2025},
isbn = {9798400712760},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3696630.3727254},
doi = {10.1145/3696630.3727254},
abstract = {Teamwork quality (TWQ), team members' success, and team performance are critical components of effective collaboration in modern software development. As capstone courses in software engineering aim to prepare students for industry practices, understanding the factors that influence team dynamics is essential. This study investigates the relationship between team ambition levels and TWQ, team members' success, and team performance in an agile capstone course. Our study involves 133 student teams comprising 790 students across three consecutive years (2022–2024). Data collection included 1,122 responses from pre- and post-surveys. In all three years, students were grouped into teams based on ambition levels. In 2024, the course structure was changed to place less emphasis on written project reports due to the widespread adoption of AI tools like ChatGPT. The results show that ambition levels were positively correlated with TWQ, team members' success, and team performance in 2022 and 2023, with higher ambition levels generally associated with improved collaboration and outcomes. However, in 2024, there were reduced disparities between lower and higher-ambition teams, enabling more equitable success across all teams. This study highlights that while ambition levels play a role in influencing teamwork and success, structured interventions that prioritize collaboration and inclusivity have a more substantial impact. These findings suggest that moving away from ambition-based team formation and focusing on fostering high-quality teamwork processes can better prepare students for real-world agile environments.},
booktitle = {Proceedings of the 33rd ACM International Conference on the Foundations of Software Engineering},
pages = {976–986},
numpages = {11},
keywords = {capstone course, teamwork, agile software development, ambition, team dynamics, software engineering education, collaboration},
location = {Clarion Hotel Trondheim, Trondheim, Norway},
series = {FSE Companion '25}
}

@inproceedings{10.1145/3769694.3771146,
author = {Parakh, Abhishek and Subramaniam, Mahadevan},
title = {AI Agents Assisted Platform for Secure Quantum-Classical Networking Education},
year = {2025},
isbn = {9798400722400},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3769694.3771146},
doi = {10.1145/3769694.3771146},
abstract = {This paper presents Sonata, an AI-agent-assisted platform designed to address the challenges of educating students in secure quantum-classical hybrid networking. By integrating a multi-agent AI framework with a quantum-classical network simulator and a learning objects repository, Sonata offers a hands-on, interactive learning environment. The platform leverages large language models to provide conversational interfaces, personalized feedback, and scenario generation, enabling students to explore complex quantum networking concepts without requiring extensive prior expertise. The system includes a user-friendly GUI for designing network topologies, a Python API for programmatic control, and educational modules tailored to various knowledge levels. Sonata aims to bridge the gap in quantum education by making transdisciplinary concepts accessible, fostering experiential learning, and preparing a workforce proficient in quantum information sciences.},
booktitle = {Proceedings of the 26th ACM Annual Conference on Cybersecurity &amp; Information Technology Education},
pages = {127–133},
numpages = {7},
keywords = {Quantum networking education, AI-assisted learning, quantum workforce development},
location = {
},
series = {SIGCITE '25}
}

@inproceedings{10.1145/3796496.3811749,
author = {Williams, Rua M. and Park, Chorong and Waisome, Jeremy A. M. and Williams, Damien P. and Robinson, Desmine T.},
title = {ProMe: Supporting the new Merit-Based Professoriate through AI-powered, Robot-Assisted Professional Development (Satire)},
year = {2026},
isbn = {9798400725104},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3796496.3811749},
doi = {10.1145/3796496.3811749},
abstract = {To support all students in their professorial aspirations, we have developed ProMe, an AI-powered Socially Assistive Robot which performs multiple professional development functions to accelerate graduate student merit. In trials, ProMe - an AI-powered Socially Assistive Robot - outperformed traditional mentoring programs in supporting learning and internalization of important professional, academic, and social standards. This work leverages satire to illuminate the oppressive and normalizing conditions of both digital and analog professional development programs in the academic context. This satire is intended to generate much-needed discussion and values-realignment among marginalized academics in computing seeking to form more effective mentoring systems and networking coalitions.},
booktitle = {Proceedings of the 2026 Conference on Research on Equity and Sustained Participation in Engineering, Computing, and Technology},
pages = {199–205},
numpages = {7},
keywords = {Artificial Intelligence, Professional Development, Robotics, Satire},
location = {
},
series = {RESPECT 2026}
}

