@inproceedings{10.1145/3652620.3687774,
author = {Chen, Kua and Chen, Boqi and Yang, Yujing and Mussbacher, Gunter and Varró, Dániel},
title = {Embedding-based Automated Assessment of Domain Models},
year = {2024},
isbn = {9798400706226},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3652620.3687774},
doi = {10.1145/3652620.3687774},
abstract = {Domain modeling is an essential component in many software engineering courses since it serves as a way to represent and understand the concepts and relationships in a problem domain. Course instructors evaluate student-generated diagrams manually, comparing them against a reference solution and providing feedback. However, as enrollment in software engineering courses continues to rise, manual grading of a large number of student submissions becomes an overwhelming and time-intensive task for instructors. Hence, there is a need for automated assessment of domain models which assists course instructors during the grading process. In this paper, we propose a novel text embedding-based approach that automatizes the assessment of domain models expressed in a textual domain-specific language, against reference solutions created by modeling experts. Our algorithm showcases remarkable proficiency in matching model elements across domain models, achieving an F1-score of 0.82 for class matching, 0.75 for attribute matching, and 0.80 for relation matching. Our algorithm also yields grades highly correlated with human grader assessments, with correlations exceeding 0.8 and mean absolute errors below 0.05.},
booktitle = {Proceedings of the ACM/IEEE 27th International Conference on Model Driven Engineering Languages and Systems},
pages = {87–94},
numpages = {8},
keywords = {domain modeling, text embeddings, domain model assessment},
location = {Linz, Austria},
series = {MODELS Companion '24}
}

@inproceedings{10.1145/3772318.3791236,
author = {Barghorn, Jérémy Valentin and Sotnikova, Anna and Friedli, Sacha and Bosselut, Antoine},
title = {AI meets Mathematics Education: Supporting Instructors in Large Mathematics Classes with Context-Aware AI},
year = {2026},
isbn = {9798400722783},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3772318.3791236},
doi = {10.1145/3772318.3791236},
abstract = {Large-enrollment university courses face persistent challenges in providing timely and scalable instructional support. While generative AI holds promise, its effective use depends on reliability and pedagogical alignment. We present a human-centered case study of AI-assisted support in a Calculus I course, implemented in close collaboration with the course instructor. We developed a system to answer students’ questions on a discussion forum, fine-tuning a lightweight language model on 2,588 historical student–instructor interactions. The model achieved 75.3% accuracy on a benchmark of 150 representative questions annotated by five instructors, and in 36% of cases, its responses were rated equal to or better than instructor answers. Post-deployment student survey (N = 105) indicated that students valued the alignment of the responses with the course materials and their immediate availability, while still relying on the instructor verification for trust. We highlight the importance of hybrid human–AI workflows for safe and effective course support.},
booktitle = {Proceedings of the 2026 CHI Conference on Human Factors in Computing Systems},
articleno = {700},
numpages = {27},
keywords = {Mathematics Education, Large-Enrollment Courses, Pedagogical Alignment, Context-Aware Response Generation},
location = {
},
series = {CHI '26}
}

@inproceedings{10.1145/3775073.3775120,
author = {Zhang, Ling and Chen, Pingxing and Sun, Wenjing and Wang, Yongjiang},
title = {Research on the Design and Application of Learning Assistance Centered on Student Development Based on RAG LLM Agent},
year = {2025},
isbn = {9798400715792},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3775073.3775120},
doi = {10.1145/3775073.3775120},
abstract = {In alignment with national policies and the current demands and trends in the field of education, AI digital empowerment in teaching has emerged as a new highlight in educational reform. Addressing the challenge of leveraging AI to accentuate the student-centered learning approach and to resolve prevalent issues such as imprecision and weak relevance in AI-assisted learning, this paper focuses on student development to explore learning assistance strategies and constructs an AI learning assistant based on RAG technology knowledge base, aiming to provide precise, efficient, and personalized learning support. Firstly, a CPACCP multi-strategy four-stage learning assistance model centered on student development is proposed. This model divides the entire learning process into four assistance nodes: pre-learning, during-learning, learning-stage, and post-learning. It designs six learning assistance strategies including customized plan, personalized learning, active detection, crowdfunding proposal, Cooperative design, and participatory evaluation, forming a learning assistance matrix model in conjunction with learning objectives. Secondly, integrating the CPACCP strategies, this paper elaborates on how to configure roles and external knowledge bases based on RAG technology to construct an AI agent learning assistance tool. Finally, teaching activities are designed using this assistance model, and the constructed AI agent assistant is applied to teaching practice. Analysis shows that this research has promotional value in enhancing teaching and learning effectiveness, fostering students' personalized and autonomous learning interests, and innovation capabilities. It also provides ideas and a research foundation for optimizing educational resource allocation and promoting the innovative development of educational technology.},
booktitle = {Proceedings of the 2025 2nd International Symposium on Artificial Intelligence for Education},
pages = {288–298},
numpages = {11},
keywords = {AI teaching reform, Agent, Learning assistance strategy, RAG, Student development as the center},
location = {
},
series = {ISAIE '25}
}

