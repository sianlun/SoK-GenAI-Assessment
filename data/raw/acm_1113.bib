doi = {10.1145/3806262.3806363},
abstract = {Amid global digital transformation, artificial intelligence (AI) has deeply integrated into industrial design, reshaping digital prototype iteration—boosting enterprise efficiency and competitiveness while creating a prominent "AI design talent gap." Existing talent training systems also suffer from disconnected technology application and cultivation, as well as separated theory and practice.This study, targeting an AI-assisted digital prototype iteration-oriented industrial design talent training system, uses "bibliometric analysis-industry research-case study". It compares traditional and AI-assisted prototype iteration processes, identifies flaws in three domestic training models and talent-demand gaps, then innovatively builds a "trinity" framework and a closed-loop teaching model based on enterprise projects, optimizing via training objectives, curriculum, and methods.},
booktitle = {Proceedings of the 2nd International Conference on Artificial Intelligence, Digital Media Technology and Social Computing},
pages = {693–701},
