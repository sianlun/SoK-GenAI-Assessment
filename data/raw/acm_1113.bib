@inproceedings{10.1145/3772318.3790292,
author = {Liu, Yijun and Gallagher, John and Sterman, Sarah and August, Tal},
title = {From Crafting Text to Crafting Thought: Grounding AI Writing Support to Writing Center Pedagogy},
year = {2026},
isbn = {9798400722783},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3772318.3790292},
doi = {10.1145/3772318.3790292},
abstract = {As AI writing tools evolve from fixing surface errors to creating language with writers, new capabilities raise concerns about negative impacts on student writers, such as replacing their voices and undermining critical thinking skills. To address these challenges, we look at a parallel transition in university writing centers from focusing on fixing errors to preserving student voices. We develop design guidelines informed by writing center literature and interviews with 10 writing tutors. We illustrate these guidelines in a prototype AI tool, Writor. Writor helps writers revise text by setting goals, providing balanced feedback, and engaging in conversations without generating text verbatim. We conducted an expert review with 30 writing instructors, tutors, and AI researchers on Writor to assess the pedagogical soundness, alignment with writing center pedagogy, and integration contexts. We distill our findings into design implications for future AI writing feedback systems, including designing for trust among AI-skeptical educators.},
booktitle = {Proceedings of the 2026 CHI Conference on Human Factors in Computing Systems},
articleno = {81},
numpages = {36},
keywords = {AI Writing Support, Writing Assistants, Writing Support Tools, Writing Center, Large Language Models},
location = {
},
series = {CHI '26}
}

@inproceedings{10.1145/3775073.3775165,
author = {Xie, Wenyi and Shi, Haojie and Li, Yixuan and Liu, Junwei},
title = {STAP: A Socratic Tutor for Adaptive Programming with Pedagogical Scaffolding},
year = {2025},
isbn = {9798400715792},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3775073.3775165},
doi = {10.1145/3775073.3775165},
abstract = {The integration of Large Language Models (LLMs) into education presents a pedagogical paradox. This paper introduces the Socratic Tutor for Adaptive Programming (STAP), a system that facilitates guided discovery rather than direct answers. We reframe the LLM’s role from an "oracle" to a "Socratic tutor" via pedagogical scaffolding. STAP employs a four-stage pipeline—Checking, Correcting, Complementing, Segmenting—to analyze student code in real time. We detail design and implementation through an example, followed by a scope-limited formative evaluation providing feasibility signals. We also formalize key concepts (Socratic hints, MVH, and answer leakage). Findings indicate adherence to pedagogical principles and motivate classroom studies.},
booktitle = {Proceedings of the 2025 2nd International Symposium on Artificial Intelligence for Education},
pages = {584–587},
numpages = {4},
keywords = {Adaptive Learning, Large Language Models, Programming Education, Pedagogical Scaffolding, Human-Computer Interaction, Formative Evaluation},
location = {
},
series = {ISAIE '25}
}

@article{10.1145/3710966,
author = {Showkat, Dilruba and Wang, Lingqing and Chan, Laveda and To, Alexandra},
title = {Equality Engine: Fostering Critical Machine Learning Bias Literacy Through a Transformational Game},
year = {2025},
issue_date = {May 2025},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {9},
number = {2},
url = {https://doi.org/10.1145/3710966},
doi = {10.1145/3710966},
abstract = {Machine Learning (ML) is now integrated from everyday technologies to sophisticated infrastructures, providing fast, efficient, and scalable decision-making services, with increasing evidence of ML perpetuating invisible harms and biases. The hidden and socio-technical nature of ML biases can make them difficult to detect and prevent without proper literacy. To investigate this, we developed a novel online multiplayer board game Equality Engine, where players learn about various ML biases and debiasing techniques. We conducted a mixed-method formative playtest case study to solicit feedback from post-secondary students (N = 12) with a range of ML experience. We found that students' self-reported ML bias-debias knowledge improved significantly after playing the game. The game was perceived as easy to use because of the social interaction and immersion the game enabled. Students would also use the game in the future because of the self-reported knowledge gained from the game. Although these positive results may be influenced by measurement bias, our study contributes to the design of an approachable game, which not only facilitates exposure, collaboration, and opportunities for critical reflection on ML biases but also provides recommendations for future game designs that can facilitate ML ethics discourse and literacy among a broader audience.},
journal = {Proc. ACM Hum.-Comput. Interact.},
month = may,
articleno = {CSCW068},
numpages = {31},
keywords = {AI/ML literacy, ML biases, ML ethics, game design, machine learning, transformational games}
}

@inproceedings{10.1145/3766671.3766811,
author = {Xu, Xibin and Zhao, Xiaolei},
title = {Research on Practical Education and Innovative Application of Artificial Intelligence Large Model in Higher Vocational Education},
year = {2025},
isbn = {9798400714047},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3766671.3766811},
doi = {10.1145/3766671.3766811},
abstract = {Under the tide of global digitalization, vocational education is undergoing profound changes. This paper studies the practical education and innovative application of artificial intelligence large model in higher vocational education, and analyzes the development status, achievements and existing problems in this field at home and abroad. With its data processing and analysis capabilities, the large model is reshaping the ecology of vocational education, but the technology landing is facing challenges such as adaptation gap, inadequate capacity, ethical norms . These challenges can be solved and the sustainable development paradigm of the deep integration of artificial intelligence and vocational education can be established through the paths to industry-education collaboration, teacher literacy reconstruction and teaching scene integration. This paper puts forward some strategies, such as the reconstruction of demand-oriented teaching mode and the innovation of teaching technology with the integration of virtual and real, in order to improve the quality of teaching and cultivate high-quality skilled personnel to adapt to the era of intellectualization.},
booktitle = {Proceedings of the 9th International Conference on Electronic Information Technology and Computer Engineering},
pages = {804–808},
numpages = {5},
location = {
},
series = {EITCE '25}
}

@inproceedings{10.1145/3797552.3797633,
author = {Wang, Ziyang and Du, Jinyu},
title = {AI-Driven Natural Language Processing for Higher Legal Education: A Technical Framework to Enhance Practical Competencies via Self-Efficacy Mediation},
year = {2026},
isbn = {9798400720925},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3797552.3797633},
doi = {10.1145/3797552.3797633},
abstract = {The gap between legal education and advancements in digital technology presents significant challenges to cultivating competent legal professionals for the digital era. This study investigates the integration of Natural Language Processing (NLP) into legal education to address the theory-practice gap, which is exacerbated by outdated teaching methods and inadequate digital literacy. Using an empirical approach with multi-source data, including pass rates from China's Unified Legal Professional Qualification Examination (CLPQE), legal competition outcomes, bibliometric analysis of Web of Science (WOS) literature, and visualization techniques such as heatmaps and word clouds, this research systematically identifies deficiencies in practical legal skills training within traditional curricula. The core methodology combines empirical data analysis, bibliometric assessment, and visualization to map the current state of legal education and its alignment with digital advancements. The findings indicate that NLP technology enhances legal education by providing immersive learning opportunities through advanced language understanding, text analysis, knowledge graphs, and intelligent question-answering systems. These capabilities enable the effective simulation of legal scenarios, thereby fostering practical skills such as legal document drafting, case analysis, and moot court performance. A key finding is the mediating role of self-efficacy in the relationship between NLP application and the enhancement of practical competencies. By providing sustained successful learning experiences and positive feedback, NLP tools bolster students’ confidence in their legal abilities, thereby strengthening the internalization of professional knowledge, academic writing, and critical thinking. The study's practical value lies in providing a theoretical foundation and actionable strategies for integrating NLP into legal education.},
booktitle = {Proceedings of the 2025 4th International Conference on Artificial Intelligence and Education},
pages = {499–509},
numpages = {11},
keywords = {Higher Legal Education, Natural Language Processing, Practical Legal Skills, Practical Teaching, Self-efficacy},
location = {
},
series = {ICAIE '25}
}

