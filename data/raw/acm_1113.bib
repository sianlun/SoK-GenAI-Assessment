@inproceedings{10.1145/3799457.3799629,
author = {Jiang, Yuying and Luan, Shan and Nardo, Mario Di},
title = {Sustainable Approaches to Action Recognition and Evaluation of Practical Skills Training for Engineering Students Using Convolutional Neural Networks},
year = {2026},
isbn = {9798400720710},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3799457.3799629},
doi = {10.1145/3799457.3799629},
abstract = {With the increasing demand for practical skill development in engineering education, traditional assessment methods have become inadequate, as they are often subjective and time-consuming. This research proposes an advanced framework for action recognition and practical skill assessment based on Convolutional Neural Networks (CNN), BiLSTM with an Attention Mechanism, Spatio-Temporal Convolutional Networks (ST-CNN), and Particle Swarm Optimization (PSO). The framework aims to provide real-time, accurate, and automated skill assessments, addressing the growing need for efficient and scalable solutions in education. By leveraging deep learning, this approach aligns with the Sustainable Development Goals (SDGs), particularly Quality Education (SDG 4), by offering accessible, objective, and data-driven solutions that enhance learning outcomes and promote equitable, inclusive, and quality-driven education. Experimental results demonstrate significant improvements in training time, computational efficiency, and assessment accuracy, marking a step forward in modernizing skill evaluation in engineering education.},
booktitle = {Proceedings of the 2025 3rd International Conference on Information Education and Artificial Intelligence},
pages = {1050–1054},
numpages = {5},
keywords = {Action Recognition, Convolutional Neural Networks, Deep Learning, Practical Skill Assessment, Quality Education},
location = {
},
series = {ICIEAI '25}
}

@inproceedings{10.1145/3775073.3775233,
author = {Li, Zilong and Zhang, Xinyue},
title = {The Impact of AI on Student Productivity in Multitasking Environments: An IPO Framework Analysis},
year = {2025},
isbn = {9798400715792},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3775073.3775233},
doi = {10.1145/3775073.3775233},
abstract = {The rapid popularity of generative AI tools in higher education has prompted research topics to shift from “whether they can be used” to “how to use them efficiently”. This study constructs a comprehensive analysis model based on the “input-process-output framework” to identify students' AI usage patterns, measure students' learning productivity after AI use, and explore the productivity differences between different groups and their mechanisms. First, the AI Learning Productivity Index (AIPL) was constructed from AI interaction log data from interdisciplinary students. The index includes five dimensions: interaction duration, number of interactions, usage results, revolt intention and satisfaction. Secondly, twelve typical behavior patterns composed of six main uses and high and low frequency interactions are identified through cluster analysis. After testing, it was found that the AIPL of students in the high-frequency group was significantly higher than that in the low-frequency group in all use scenarios. Finally, regression analysis further shows that the productivity of undergraduate students mainly depends on the frequency of interaction, while the graduate students benefit more from the balanced combination of frequency and depth. Although it has not been able to significantly verify the diminishing marginal benefits that may result from overuse of AI, there is still a trend of saturation in some tasks. The research contribution is to propose new learning productivity measurement indicators, empirically reveal the differences in students' AI use behavior, and clarify the mechanism of action of different educational groups, which provides theoretical value for expanding the application of IPO models in digital learning scenarios, and provides practical enlightenment for universities to formulate differentiated AI use strategies.},
booktitle = {Proceedings of the 2025 2nd International Symposium on Artificial Intelligence for Education},
pages = {1017–1025},
numpages = {9},
keywords = {Generative Artificial Intelligence (GenAI), IPO Model, Learning Productivity, Student Behavior Patterns},
location = {
},
series = {ISAIE '25}
}

@inproceedings{10.1145/3660650.3660662,
author = {Goddard, Quinn and Moton, Nathan and Hudson, Jonathan and He, Helen Ai},
title = {A Chatbot Won't Judge Me: An Exploratory Study of Self-disclosing Chatbots in Introductory Computer Science Classes},
year = {2024},
isbn = {9798400709975},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3660650.3660662},
doi = {10.1145/3660650.3660662},
abstract = {Students in introductory Computer Science (CS) courses sometimes struggle with learning course content, but feel these struggles are uniquely theirs. To foster a more inclusive CS culture and normalize challenges in the learning process, we designed a conversational agent (“chatbot”) that self-discloses information about the chatbot’s own imaginary struggles with learning course material. Inspired by previous work in the mental health domain where humans reciprocated disclosure when a chatbot disclosed sensitive information, our goal was to promote student self-disclosure of learning challenges and to help students feel less alone. To inform design, we first conducted three focus groups with CS students on themes of identity and belonging. Based on these findings, we designed a self-disclosing chatbot (“Mibi”) and deployed it in a pilot summer course (40 students) and a larger course (460 students) in the fall semester of 2023. Our work is the first real-world deployment of a chatbot in higher education for promoting student wellbeing, rather than assisting with practical course content. We highlight findings from this exploratory study, sharing how students engaged with Mibi, where it succeeded, where it has room to grow, and how that can inform future iterations of this promising new classroom companion for student mental health.},
booktitle = {Proceedings of the 26th Western Canadian Conference on Computing Education},
articleno = {9},
numpages = {7},
keywords = {CS1/CS2, Chatbot, Computer Science, Mental well-being, Qualitative, Self-Disclosure},
location = {Kelowna, BC, Canada},
series = {WCCCE '24}
}

@article{10.1145/3748627,
author = {Chen, Max and Smith, Gillian},
title = {Bridging Cultural Representation and Game Making: Analyzing the Experiences, Outcomes, and Lessons of Early-Stage Game Developers in a Professional Development Program},
year = {2025},
issue_date = {October 2025},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
volume = {9},
number = {6},
url = {https://doi.org/10.1145/3748627},
doi = {10.1145/3748627},
abstract = {As the game industry expands, an increasing number of students and hobbyists are entering the game development field, eager to create their own titles. However, there is a lack of structured training programs that effectively prepare them for industry demands. Games convey meaningful messages through stories, assets, and mechanics, yet how early-stage developers make creative decisions while building production skills remains unclear. We explored skill development and cultural representation in game design during a 10-week professional development program at MassDigi with early-stage developers from the United Arab Emirates (UAE). Our findings reveal three observed strategies as themes through which developers incorporate their personal experiences and cultural backgrounds into game development to achieve cultural representation, as well as four themes that address developers' skill set improvement and personal growth during this process. We recommend structuring programs by considering these themes to enhance self-expressive game design and support skill development through a peer learning community.},
journal = {Proc. ACM Hum.-Comput. Interact.},
month = oct,
articleno = {GAMES032},
numpages = {31},
keywords = {cultural representation, game design, game development education, professional development program, situated learning}
}

@inproceedings{10.1145/3797552.3797655,
author = {Yang, Xiaonan},
title = {Towards a CDIO Teaching Model for Software Testing Courses under the Bidirectional Empowerment of Artificial Intelligence},
year = {2026},
isbn = {9798400720925},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3797552.3797655},
doi = {10.1145/3797552.3797655},
abstract = {This paper addresses the emerging challenges posed to the traditional “Software Testing” course by the advancement of new engineering education initiatives and artificial intelligence (AI) technologies. It proposes a novel teaching model that integrates the CDIO engineering education framework with a bidirectional AI empowerment strategy. The study begins by clarifying the dual roles of AI—both as a tool for software testing and as a target of testing—and systematically develops a four-stage teaching model aligned with the CDIO paradigm. Four integrated case studies are presented, encompassing functional testing of AI mini-programs, automated testing of AI applications, performance evaluation of AI calculators, and interface testing of AI chatbots, which collectively illustrate the seamless integration of theoretical instruction and hands-on engineering practice. Empirical results demonstrate that this approach not only significantly enhances student engagement and strengthens their practical competencies across diverse testing scenarios, but also equips them with the ability to leverage AI tools for improved testing efficiency and to conduct quality assurance for AI-based systems. As such, the model offers an innovative and scalable solution for reforming engineering education in the age of AI.},
booktitle = {Proceedings of the 2025 4th International Conference on Artificial Intelligence and Education},
pages = {635–640},
numpages = {6},
keywords = {Artificial Intelligence, Bidirectional Empowerment, CDIO, Software Testing Education},
location = {
},
series = {ICAIE '25}
}

@inproceedings{10.1145/3800645.3813071,
author = {Li, Leyi and Du, Chenyu and Sun, Jiafei and Purwanto, Erick and Zhang, Qing},
title = {RoboBlockly Studio: Conversational Block Programming with Embodied Robot Feedback for Computational Thinking},
year = {2026},
isbn = {9798400725630},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3800645.3813071},
doi = {10.1145/3800645.3813071},
abstract = {Computational thinking (CT) is increasingly promoted as a core literacy, yet learners and teachers face challenges in connecting abstract program logic to meaningful outcomes. We design and evaluate RoboBlockly Studio, an integrated interactive system that combines block-based programming, a conversational AI teaching agent, and embodied robot execution. RoboBlockly Studio creates a tight iterative loop of authoring, running, observing, and revising. Informed by interviews with five programming teachers, the system was designed to support four goals: (1) preserving learner agency in computational thinking, (2) making program behavior transparent and interpretable, (3) grounding programming in embodied, classroom-aligned tasks, and (4) scaffolding reflection through pedagogically grounded AI dialogue. We deployed RoboBlockly Studio with 32 high school students, observing how robot and AI feedback influenced students’ interactions with code, reflections on problem-solving strategies, and understanding of CT concepts. We discuss design insights and implications for creating interactive, embodied learning environments that integrate AI and robotics to support CT learning in computing education.},
booktitle = {Proceedings of the 2026 Designing Interactive Systems Conference},
pages = {1021–1040},
numpages = {20},
keywords = {Embodied interaction, computational thinking, educational robotics, block-based programming, conversational AI tutor, human-robot interaction},
