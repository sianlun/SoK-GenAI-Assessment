	title = {Towards a CDIO Teaching Model for Software Testing Courses under the Bidirectional Empowerment of Artificial Intelligence},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3797552.3797659,
	abstract = {Based on 597 English papers retrieved from the Web of Science Core Collection between 2018 and 2025, this study employs CiteSpace and VOSviewer to visualize the knowledge structure and identify research trends of Generative Artificial Intelligence (GenAI) in higher education. Quantitative results show an annual growth rate of 46.2% since 2023, reflecting the rapid diffusion of GenAI across disciplines such as educational technology, computer science, and psychology. China, the United States, and Australia constitute the main publication centers, while research themes have evolved from technology adoption to ethics and creativity cultivation. This study contributes to clarifying the global research landscape, highlighting the transition from tool-oriented innovation to human–AI collaborative learning, and providing data-driven insights for policymakers and educators to promote equitable and ethical AI integration.},
	affiliations = {},
	author = {Xu, Gang and Li, Gui and Lu, Yachao},
