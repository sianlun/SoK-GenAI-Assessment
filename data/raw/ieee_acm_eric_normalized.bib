@article{10.1145/3806980.3807014,
	abstract = {Motivated by technological revolution and industrial transformation, the integration of industry and education as well as interdisciplinary cooperation represent the core directions of China's new engineering education reform. There is an urgent requirement for cultivating emerging talents in intelligent manufacturing. Machine Vision Inspection, a core course in intelligent manufacturing, suffers from pain points such as abstract theories and impractical teaching content, which impede the cultivation of students' competencies. This research takes this course as a vehicle to establish a three-dimensional collaborative innovation system featuring “school-enterprise, interdisciplinary, and teacher-student” cooperation. By integrating Generative Artificial Intelligence (GenAI), a talent cultivation model characterized by “collaboration mechanism + GenAI technology + teaching practice” is developed. A grouped comparative experiment was conducted on 120 students. The experimental group adopted the new model, while the control group used the traditional one. An eight-week teaching practice was carried out on a real PCBA circuit board inspection project, and an evaluation framework was constructed from the aspects of technical competence, collaborative literacy, and industrial adaptability. The results indicate that the experimental group witnessed an improvement of 10.8%-12.6% in core technical indicators, and the scores of collaborative literacy and industrial adaptability increased by 34.6% and 36.6% respectively. This model addresses the issues of the disconnection between theory and practice and resource allocation in new engineering courses, offering replicable approaches and references for the cultivation of emerging engineering talents through collaborative innovation.},
	affiliations = {},
	author = {Zhang, Xiaojie and Chi, Shengyuan and Qu, Yifan and Chen, Xingwu},
	author_keywords = {Generative Artificial Intelligence (GenAI); Industry-Education Integration; Intelligent Manufacturing; Machine Vision Inspection; New Engineering Education},
