@article{11304353,
	abstract = {This article presents a pedagogical methodology designed for engineering education, particularly in electrical and electronic disciplines, that leverages the accessibility of information and simulation tools to foster meaningful, studentcentered learning. The proposal integrates constructivist principles, project-based learning, and circuit simulation to develop both theoretical understanding and practical skills. Organized into five structured learning moments-pre-reading, theoretical class, simulation analysis, laboratory experimentation, and portfolio development-the methodology emphasizes individual and collaborative engagement, reflection, and progressive knowledge construction. Additionally, it includes two summative assessments per unit to reinforce theoretical and practical integration. The approach promotes continuous evaluation and self-directed learning while recognizing generative AI as a supplementary tool. This methodology was successfully implemented over a semester in an Analog Electronic Design course on demonstrating its effectiveness in enhancing student learning outcomes.},
