@article{11256373,
	abstract = {At Tecnologico de Monterrey, engineering students are required to take a final examination, the CENEVAL EGEL, a widely accepted option for certifying essential disciplinary knowledge and skills in Mexico. At this institution of higher education, the completion of this examination is significant for our future graduates, as it is a mandatory component of the graduation requirements. The utilization of generative artificial intelligence (Gen AI) holds considerable potential in the development of customized and effective practice exams, thereby facilitating enhanced student preparation for the CENEVAL EGEL examination. These tools have been identified as instrumental in improving student success and confidence. The advantages of this approach include the ability to customize content, access to a range of practice questions, immediate feedback, and the enhancement of confidence derived from prior experience with a similar examination. This study explores the impact of a personalized Gen AI agent that has been specifically trained in the knowledge areas of the CENEVAL exam. The artificial intelligence (AI) agent provides customized, practice-based feedback, with an emphasis on questions, with the objective of minimizing unsatisfactory results and maximizing outstanding grades. The experimental design involves a comparison between a control group ($n=43$) that did not utilize the AI agent and a pilot group ($n=41$) that did employ the tool. Each student in the experimental group completed over 160 questions, which encompassed four primary subject areas delineated by CENEVAL. The analysis showed consistent improvements in the experimental group after using the AI agent, with increases in performance on practical assessments and a reduction in the gap compared to the control group. Although the latter had a higher GPA, both groups achieved similar rates of satisfactory results on the final exam. Furthermore, students who used the agent reported a positive experience, highlighting its usefulness, quality of feedback, and effect on confidence. These findings suggest that generative AI can be an effective tool to support students' preparation for standardized assessments, especially for those starting at lower academic levels.},
	affiliations = {},
	author = {Solís, Germán Domínguez and Robles, Laura Eugenia Romero and Oropeza, Ricardo Swain},
	author_keywords = {Knowledge engineering; Surveys; Technological innovation; Generative AI; Instruments; Digital transformation; Employment; Industrial engineering; Artificial intelligence; Engineering students; Generative AI; Higher Education; Assessment; Educational innovation},
	doi = {10.1109/WEEF-GEDC66748.2025.11256373},
	issn = {2837-5025},
	journal = {2025 World Engineering Education Forum - Global Engineering Deans Council (WEEF-GEDC)},
	keywords = {},
	number = {},
	pages = {1-8},
	source = {Scopus},
	title = {AI Agent to Prepare Students for Final Assessments: A Strategy to Strengthen and Maximize Student Performance in Engineering Programs},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11256378,
	abstract = {The rapid integration of Generative Artificial Intelligence (GenAI) into higher education presents both opportunities and challenges for assessment design, particularly within Project-Based Assessment (PBA) contexts. Traditional assessment methods often emphasise the final product in the PBA, which can now be significantly influenced or created by GenAI tools, raising concerns regarding product authenticity, academic integrity, and learning validation. This paper advocates for a reimagined assessment model for Project-Based Learning (PBL) or a capstone project that prioritises process-oriented evaluation, multi-modal and multifaceted assessment design, and ethical engagement with GenAI to enable higher-order thinking. The model also emphasises the use of (GenAI-assisted) personalised feedback by a supervisor as an observance of the learning process during the project lifecycle. A use case scenario is provided to illustrate the application of the model in a capstone project setting. The paper concludes with recommendations for educators and curriculum designers to ensure that assessment practices remain robust, learner-centric, and integrity-driven in the evolving landscape of GenAI.},
	affiliations = {},
	author = {Kadel, Rajan and Shailendra, Samar and Saxena, Urvashi Rahul},
	author_keywords = {Ethics; Generative AI; Navigation; Learning (artificial intelligence); Engineering education; Academic integrity; assessment design; authentic assessment; capstone project; Generative Artificial Intelligence (GenAI); higher education; Project-Based Assessment (PBA); Project-Based Learning (PBL); reflective practice},
	doi = {10.1109/WEEF-GEDC66748.2025.11256378},
