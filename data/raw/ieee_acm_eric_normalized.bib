@article{10.1145/3768801.3768813,
	abstract = {The digital economy is reshaping jobs faster than universities adapt. Focusing on Guangdong, China, we review global and domestic evidence and survey 528 undergraduates about their digital-skill readiness and career plans. Most students value digital skills and favor adding courses, industry mentors, and hands-on projects. A follow-up of Certified Data Analyst (CDA) graduates confirms that an industry-recognized credential boosts employment and mobility. We conclude with concrete steps—updating curricula, deepening university-industry ties, expanding practical training, and improving policy support—to close the talent gap and keep higher education aligned with the digital economy's demands.},
