	pages = {211–215},
	source = {Scopus},
	title = {Collaborative Innovation-Driven Generative Artificial Intelligence Empowering Emerging Talent Cultivation: A Practical Case Study of the Machine Vision Inspection Course},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3806980.3807015,
	abstract = {The integration of artificial intelligence in higher education has increased the demand for interdisciplinary AI literacy among non-AI graduate students, yet sustaining learning outcomes remains challenging. This study proposes a dual-instructor AI-enhanced teaching framework that combines subject instructors with an AI-based virtual instructor. An experimental-control study with short-term and three-month follow-up assessments was conducted. Paired t-tests with Bonferroni correction and ordinary least squares regression were applied for analysis. Results show that the dual-instructor group achieved significantly stronger long-term retention, and key short-term learning components significantly predicted long-term AI application ability. The findings provide data-driven evidence for effective AI-enhanced interdisciplinary education.},
	affiliations = {},
	author = {Zhang, Yuezhou and Zhang, Miaomiao and Sun, Shaohua and Qu, Lin},
