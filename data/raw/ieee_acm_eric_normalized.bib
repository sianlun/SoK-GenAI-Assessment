	title = {GAGA: Game Asset Generative AI Pipeline},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11346646,
	abstract = {The rapid development of artificial intelligence (AI) large models, represented by GPT-4 and Claude, has ushered in a new era of intelligent education and has significantly changed the educational ecosystem. This paper conducts an in-depth analysis for the transformative impact of AI large models on higher education by integrating empirical data from several referenced studies and proposes a comprehensive reform framework to accommodate the change. It is revealed that the AI large models can enhance the educational efficiency by 20-45% through a personalized learning pathways and interdisciplinary knowledge integration, while posing significant challenges in academic integrity and algorithmic bias. To respond to the challenges, this paper proposes a construction of three-dimensional reform model, i.e., the technical capability building, teaching ecosystem reconstruction, and ethical governance system optimization. The constructed model can efficiently overcome the negative influence of AI large models on the higher education and provide a practical strategy for universities to navigate the AI-driven educational transformation.},
	affiliations = {},
	author = {Tong, Mei Song and Yang, Chen Wei and Wan, Guo Chun},
	author_keywords = {Ethics; Adaptation models; Solid modeling; Navigation; Biological system modeling; Education; Ecosystems; Learning (artificial intelligence); Artificial intelligence; Optimization; Artificial Intelligence (AI) Large Models; Higher Education Reform; Human-AI Collaboration; Educational Ethics; Adaptive Assessment},
