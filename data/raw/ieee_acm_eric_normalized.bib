@article{11336596,
	abstract = {This paper proposes an Artificial Intelligence (AI)-Driven Heutagogy Framework custom-designed for engineering education with intentional alignment to Sustainable Development Goal 4 and sustainable software practices. The framework consists of: (1) an AI-Assessment Engine that automates multi-level evaluations according to Revised Bloom's Taxonomy with supervised learning algorithms and rubric-based scores; (2) an Automated E-Learning System providing AI-driven, gamified learning trajectories with adaptive neural architectures; and (3) a Metacognitive Layer utilizing NLP-based sentiment and creativity detection with reflective journals. In an empirical case study with 120 engineering students (AI-assisted vs. non-AI groups), they created real-time image classification CNN models. The AI-assisted cohort produced a 133% increment in model iterations $(28\pm 3\ \text{vs}.\ 12\pm 2)$, 53% decrease in debugging time (1.5 vs. 3.2 hours), and 42% increase in RBT-based rubric scores $(9.2\pm 1.1\ \text{vs}.\ 6.5\pm 1.5)$ • Moreover, their models exhibited a 42% higher inference speed (135 vs. 95 frames per second), 29% reduced memory usage (220 vs. 310 MB), and higher classification accuracy (F1-score: $0.92\pm 0.03$ vs. $0.85\pm 0.04)$. Nonetheless, their peer-reviewed creativity ratings were 15% lower (7.1 vs. 8.3/10), which is a signal to curb algorithmic dependency. Critical incident technique-based qualitative analysis found that the AI cohort attained 35% higher metacognitive depth and facilitated a 60% reduction in grading workloads for educators. To counter creativity risks, the framework incorporates randomized prompt modules and reflective checkpoints. These findings validate AI-based heutagogy's scalability to efficiently upgrade engineering curricula and assessment to meet SDG 4 with open-source tool deployment and policy initiatives toward balanced technical and creativity development.},
	affiliations = {},
	author = {Rathod, Ganesh and Mane, Suresh D. and Mane, Abhijit M.},
	author_keywords = {Ethics; Technological innovation; Electronic learning; Scalability; Taxonomy; Learning (artificial intelligence); Artificial intelligence; Sustainable development; Creativity; Engines; Artificial Intelligence (AI); Heutagogy; Sustainable Development Goal 4 (SDG 4); Self-Directed Learning; Engineering Education; Sustainable Technology; Generative AI; Educational Assessment; Automated E-Learning},
	doi = {10.1109/ICFT66708.2025.11336596},
	issn = {},
	journal = {2025 International Conference on Future Technologies (ICFT)},
	keywords = {},
	number = {},
	pages = {1-8},
	source = {Scopus},
	title = {Emerging Approaches in Computing Education: AI-Powered Heutagogy for Sustainable and Self-Directed Learning},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11346464,
	abstract = {Automata Theory is widely recognized as one of the more challenging subjects in computer science, largely due to its abstract nature and theoretical models like DFA, NFA, and epsilon-closures. In this study, we explored how combining reflective learning journals with AI tools like ChatGPT can help students better understand these complex topics. Sixty undergraduate students participated in a three-week intervention where they used AI to clarify doubts, seek analogies, and reflect more deeply on what they were learning. The reflective journals provided a space for students to express confusion and track their progress, while the AI offered immediate explanations that supported their thought process. Survey results showed that students found this combination helpful in reducing confusion, building confidence, and improving their overall grasp of difficult concepts. However, we also observed that the benefits were greatest when students were guided to engage critically with AI outputs, rather than accepting them at face value. This study contributes to growing evidence that, when thoughtfully integrated, AI tools like ChatGPT can support reflective learning and help make abstract subjects more approachable. Our findings offer practical insights for educators looking to blend AI tools with reflective practices in computer science education.},
	affiliations = {},
	author = {K S, Sampada and S, Deepa and B N, Yashasvi},
	author_keywords = {Surveys; Computer science; Learning automata; Large language models; Face recognition; Education; Fasteners; Chatbots; Computer science education; Artificial intelligence; Automata Theory; Reflective Learning; Large Language Models; ChatGPT; Cognitive Load; Computer Science Education},
