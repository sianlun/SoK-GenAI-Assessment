	issn = {},
	journal = {Companion Proceedings of the ACM Web Conference 2026},
	keywords = {},
	number = {},
	pages = {295–302},
	source = {Scopus},
	title = {Industrialized Deception: The Collateral Effects of LLM-Generated Misinformation on Digital Ecosystems},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3775073.3775080,
	abstract = {While the integration of real-world decision-making scenarios into engineering education has proven to enrich experiential learning, developing such authentic case studies remains a persistent challenge. In this exploratory study, we investigate the potential of ChatGPT-4 as a co-producer in the creation of authentic engineering case studies. Rooted in interdisciplinary educational theories, our investigation is set within the context of the graduate-level course “Managing Big Data Projects”. We introduce a structured framework that helps faculty engage with ChatGPT-4 through guided prompts and iterative conversations. We also conduct a quantitative linguistic assessment of the generated case study, using standard Natural Language Processing (NLP) metrics. The results revealed that while ChatGPT-4 succeeded to a certain extent in creating authentic case studies that stimulate problem solving and decision making, it showed several limitations such as lack of narrative depth, weak storytelling, occasional fake citations, limited memory capacity, readability constraints, and an inability to follow detailed instructions. Our findings underscore the importance of human oversight and "human-in-the-loop" approaches in leveraging generative AI for educational design.},
	affiliations = {},
	author = {Kamoun, Faouzi and Iqbal, Farkhund},
	author_keywords = {ChatGPT; Experiential learning; Generative AI; LLMs; case studies; decision-making; engineering education},
	doi = {10.1145/3775073.3775080},
	issn = {},
	journal = {Proceedings of the 2025 2nd International Symposium on Artificial Intelligence for Education},
	keywords = {},
	number = {},
	pages = {33–38},
	source = {Scopus},
	title = {Human-AI Co-Creation in Engineering Education: Leveraging ChatGPT-4 to Develop Authentic Case Studies},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{10.1145/3775073.3775095,
	abstract = {The rapid advancement of generative AI technology in higher engineering education has presented unparalleled prospects and challenges for developing exceptional future-oriented engineers. This paper introduces a delineation of a new generative AI-enabled engineering curriculum framework (GAE-ECF) that differentiates similar innovation based on existing CDIO (ideate-design-implement-operate) and OBE (outcomes-based education) frameworks. The GAE-ECF framework presents a multi-organizational level generative collaborative teaching mechanism, which merges different scaffolding for AI content generation, specific learning path modeling for students using a transformer, and a teaching swarm feedback system based on dual-agent reinforcement learning. GAE-ECF is supported with the KCA-am (knowledge-capacity-attitude-alignment) three-layer alignment module, prompt engineering task engine, and generative reflection analyzer - headed to genuinely enhance students' design thinking and metacognition capabilities in genuine engineering contexts, and achieve integrated collaborative optimization of teaching - learning - evaluation. GAE-ECF significantly surpassed traditional teaching frameworks in student engagement, project completeness, and personalized learning effectiveness.},
	affiliations = {},
	author = {Li, Yuansheng and Liang, Jingwen and Zhao, Yangguiyi},
	author_keywords = {Course Design; Engineering Education; Generative AI; Personalized Learning; Teaching Model Innovation},
	doi = {10.1145/3775073.3775095},
	issn = {},
	journal = {Proceedings of the 2025 2nd International Symposium on Artificial Intelligence for Education},
	keywords = {},
	number = {},
	pages = {127–131},
	source = {Scopus},
	title = {Course Design and Teaching Model Innovation for Excellent Engineers Driven by Generative AI},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{10.1145/3775073.3775099,
	abstract = {“Power Electronics Technology,” known for its abstract theories and strong practical orientation, has faced challenges in traditional teaching models, such as insufficient personalized guidance, limited practical training, and difficulties in fostering students' innovation capabilities. To address these issues, a study at NingboTech University designed and implemented an artificial intelligence-integrated “trinity” teaching reform framework in the “Power Electronics Technology” course. This framework includes: an intelligent tutoring system based on Retrieval-Augmented Generation (RAG) and domain knowledge graphs, providing students with round-the-clock personalized support; a virtual-real integration experimental platform combining MATLAB/Simulink and PSIM environments enhanced by AI algorithms, enabling safe and efficient practical training; and a project-based learning (PBL) module incorporating generative AI tools to enhance students’ ability to solve complex engineering problems. Through a quasi-experimental study spanning three semesters and involving 180 students, with a control group for comparative analysis, results indicated that the experimental group significantly outperformed the control group in theoretical knowledge mastery, practical skills, and project innovation. This study not only validates the potential of AI technology in power electronics education but also offers a reference model with both theoretical depth and practical value for the intelligent transformation of engineering education. It also reflects on and discusses potential issues such as over-reliance on AI applications.},
	affiliations = {},
	author = {Liu, Feng},
	author_keywords = {Artificial Intelligence; Educational Data Mining; Engineering Pedagogy; Intelligent Tutoring Systems; Power Electronics Education; Virtual Simulation},
	doi = {10.1145/3775073.3775099},
