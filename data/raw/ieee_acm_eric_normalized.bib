@article{10.1145/3797552.3797773,
	abstract = {In the current era of rapid development of information technology, education is facing a transformation from large-scale learning to personalized learning, and personalized learning has gradually become a focus topic in the field of education. This study constructed a personalized question-answering learning support framework based on cognitive diagnosis. This framework integrates main modules such as cognitive diagnosis technology, knowledge graphs, and personalized question-answering content design, aiming to enhance learners' learning outcomes. This study selects the “Numbers and Algebra” section of the fourth grade lower semester of the People's Education Edition of Primary School Mathematics as the teaching content for case analysis. In terms of cognitive diagnosis, the DRCDM model is adopted to utilize residual networks for feature extraction, accurately assessing the cognitive status of learners and providing personalized learner information for the subsequent question-answering system. Subsequently, the personalized answer content design module ensures the accurate identification of the knowledge points involved in the question, as well as the generation of personalized question answers.},
