	pages = {1256–1263},
	source = {Scopus},
	title = {An AI-Supported “333” Teaching Framework Based on Generative Models and Learning Analytics for Vocational Medical Technology Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3806980.3807177,
	abstract = {Teaching abstract concepts such as spatial stress remains a persistent bottleneck in engineering mechanics due to the computational cost of real-time visualization. Traditional VR methods rely on pre-rendered animations, lacking true interactivity and physical fidelity. This study proposes a novel digital twin-driven VR/AR framework integrated with a physics-informed neural network (PINN) surrogate model. By training a deep learning model on high-fidelity finite element method (FEM) datasets, we achieve real-time (&lt; 20ms latency) reconstruction of volumetric stress fields under arbitrary user-defined loads, bypassing the computational latency of traditional solvers. We deployed this system in a quasi-experimental study (n = 120). Furthermore, we employed unsupervised machine learning (K-Means Clustering) on user interaction logs to identify learning behavior patterns. Results show that the ML-driven high-fidelity visualization significantly reduced extraneous cognitive load (NASA-TLX) and improved concept mastery (Cohen's d = 1.78). This work demonstrates how combining AI-accelerated simulation with immersive technology can fundamentally transform engineering pedagogy.},
	affiliations = {},
	author = {Yuan, Xuelian},
	author_keywords = {Cognitive load; Engineering education; Engineering mechanics; Spatial visualization; Virtual and augmented reality},
	doi = {10.1145/3806980.3807177},
	issn = {},
	journal = {Proceedings of the 2026 International Conference on Big Data and Informatization Education},
	keywords = {},
	number = {},
	pages = {1269–1275},
	source = {Scopus},
	title = {High-Fidelity Real-Time Stress Field Reconstruction in VR/AR: A Physics-Informed Deep Learning Approach},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3806980.3807180,
	abstract = {To addressed key challenges in traditional practical training for New Engineering disciplines-including overemphasis on technical skills, inadequate support for self-directed learning, lack of timely feedback, and weakened educational effectiveness. Taking the Fundamentals of Automation Practical Training course as a platform, we proposed a teaching model characterized by “one project throughout, dual‑principle guidance, multi‑skill integration, and AI empowerment”. The model is project‑centered, integrating skills such as instrument operation, circuit‑board design, and debugging. Following the Outcomes‑Based Education (OBE) philosophy, it systematically incorporates the Five Pillars of Education throughout project implementation. Furthermore, GAI tools (such as Doubao, DeepSeek, and Kimi) have been introduced to provide students with real-time diagnostic feedback and operational guidance, fostering a closed‑loop learning progression of “learning–doing–diagnosing-refining”. Results showed that after adopting this model, the defective solder‑joint rate in student projects decreased by approximately 41%, the rate of functionally incomplete circuits dropped by 20%, proficiency in advanced instrument operation increased by 18%, operational endurance improved by about 20%, and tool-management capability rose by 30%. And confirm that the model effectively enhances students’ engineering practical competence and holistic literacy, demonstrating its pedagogical feasibility and practical value for New Engineering training.},
	affiliations = {},
	author = {Wang, Hu and Zhang, Geng'e and Li, Zehui and Yang, Xiaozhe},
