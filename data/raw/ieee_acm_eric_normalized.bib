	title = {Research on Evaluating China' s Educational Intelligent Transformation Policies Through a Four-Dimensional Analytical Framework: A Quantitative Text-Based Analysis},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{10.1145/3748825.3748859,
	abstract = {Under the background of the digital society and the rapid development of artificial intelligence (AI), the traditional teaching of medicinal chemistry is facing many challenges. This study explored the practice and outcomes of AI-empowered medicinal chemistry teaching reform guided by the Outcome-Based Education (OBE) concept. The research has constructed a teaching model of 'dual integration of OBE concept and AI technology'. Through measures such as clarifying the teaching objectives of the course, optimizing the teaching content, innovating the teaching methods, and improving the evaluation system, the learning enthusiasm, participation and comprehensive ability of students have been significantly enhanced. Practice shows that after the reform, both the process evaluation scores and the summative assessment scores of students have significantly improved, and the teaching effect has been widely recognized by students. This research provides new ideas for the teaching reform of medicinal chemistry and helps cultivate compound and innovative pharmaceutical talents who meet the needs of the industry and possess innovative ability and sense of responsibility.},
	affiliations = {},
	author = {Li, Linzhen and Li, Hong and Wei, Xi},
