	issn = {},
	journal = {Proceedings of the 2025 Working Group Reports on Innovation and Technology in Computer Science Education},
	keywords = {},
	number = {},
	pages = {313–359},
	source = {Scopus},
	title = {Navigating the Ethical and Societal Impacts of Generative AI in Higher Computing Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3760545.3783976,
	abstract = {Artificial intelligence (AI) is an integral part of daily life, yet public understanding of its core concepts remains limited and often influenced by misconceptions. While AI literacy is increasingly recognized as a key competence for all, efforts to support such knowledge and skills are still in their early stages. A notable gap exists in resources and tools for assessing non-expert understanding of core concepts and uncovering potential misconceptions. Without such insights it is difficult to determine what curricula and educational initiatives should address. Our working group responds to this gap by developing a research-based AI concept inventory for diverse non-expert audiences, which here refer to individuals engaging with AI technologies without formal training or professional expertise in computer science or AI. A concept inventory is a multiple-choice assessment designed to measure understanding of core concepts in a subject area and to identify common misconceptions, with one correct answer per item and remaining options serving as distractors. Following established concept inventory methodologies, we first identified key AI concepts and common misconceptions through literature reviews, expert consultations, and empirical data collection. These findings informed the creation of multiple-choice items with empirically-derived distractors, refined through iterative evaluation with both experts and non-experts to ensure clarity and applicability across contexts. The resulting instrument is a first draft to assess AI understanding, supporting benchmarking across populations, and enabling tracking of changes over time, thus providing an evidence base to inform education, guide policy and advance the broader goal of AI literacy in everyday contexts.},
	affiliations = {},
	author = {Mannila, Linda and Henry, Julie and Bahr, Tobias and Chytas, Christos and Connamacher, Harold and Müller, Barbara C. N. and Opel, Simone and Scholl, Andreas},
	author_keywords = {artificial intelligence; concept inventory; conceptions; preconceptions; misconceptions; ai literacy; non-experts; key concepts; distractors},
	doi = {10.1145/3760545.3783976},
	issn = {},
	journal = {Proceedings of the 2025 Working Group Reports on Innovation and Technology in Computer Science Education},
	keywords = {},
	number = {},
	pages = {360–406},
	source = {Scopus},
	title = {Towards Validating an Artificial Intelligence Concept Inventory for Non-Experts (AICI-NE): Common Misconceptions and Item Development},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3761843.3761874,
	abstract = {In recent years, digital learning has revolutionized educational environments, replacing traditional methods of resource acquisition and course delivery with advanced, technology-driven alternatives. Once reliant on extensive physical searches through libraries, students can now access vast educational resources with ease, thanks to rapid technological advancements. This transformation, accelerated by the COVID-19 pandemic, has brought forth new platforms for online learning, collaborative tools, and interactive multimedia networks, including mobile and instant communication tools. As technology continues to reshape education, critical questions arise regarding its impact on learning effectiveness and student cognition. With diverse learning styles and varying degrees of autonomy in digital settings, the role of adaptive learning tools and artificial intelligence (AI) in shaping knowledge acquisition, retention, and transfer becomes increasingly significant. This paper explores the cognitive shifts from traditional to digital learning, examines the evolution of learning materials and learner behavior, and critically assesses whether AI has a transformative influence on how students think and learn in modern educational contexts.},
	affiliations = {},
	author = {Villanueva, Myrrh Dorothy A and Nazareth, Jessica D and Pinugu, Jasmine Nadja J and Liwanag, Jyrh Alexia B and Lindzae, Lu Aleckxa E and Moral, Alanisse Klaudette M and Domael, Bless N. and Alvarez, Jamal Silas F},
	author_keywords = {AI; Cognitive Psychology; Cognitive Shifts; Educational Psychology; Gen Z; mediation analysis},
	doi = {10.1145/3761843.3761874},
	issn = {},
	journal = {Proceedings of the 2025 9th International Conference on Education and Multimedia Technology},
	keywords = {},
	number = {},
	pages = {293–298},
	source = {Scopus},
	title = {Artificial Intelligence and Gen Z: Cognitive Shifts in a Tech- Savvy Generation},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3761843.3761883,
	abstract = {In the rapidly evolving field of educational technology, the potential for integrating Artificial Intelligence (AI) tools like ChatGPT into teaching and learning processes remains untapped and ripe for exploration. This study aims to address the gaps in this field by proposing a framework of AI-assisted teaching and Learning, namely Decompose-Ask-Response (AI-DAR). We compare the learning outcomes of students exposed to AI-assisted teaching with those in a traditional setting. Our findings reveal that AI-assisted instruction significantly enhances student performance, particularly for those with weaker foundational knowledge. Moreover, we find that AI is notably effective in aiding conceptual understanding but shows limited impact on operational tasks. An analysis of student-AI interactions indicates that the ability to formulate effective questions to AI are critical factors for achieving higher scores. Gender-specific behaviors also emerged as differential factors. Overall, this study establishes the efficacy of AI-assisted teaching and offering actionable insights, setting a foundation for future research in this rapidly expanding field.},
	affiliations = {},
	author = {Wang, Jinpeng and Li, Yiying and Qian, Yihe},
	author_keywords = {Artificial Intelligence in Education; ChatGPT in Education; Course Design; Higher Education; Learning Assessment},
	doi = {10.1145/3761843.3761883},
	issn = {},
	journal = {Proceedings of the 2025 9th International Conference on Education and Multimedia Technology},
	keywords = {},
	number = {},
	pages = {249–255},
	source = {Scopus},
	title = {AI-Assisted Teaching and Learning: A Real Application Of Course Design, Assessment and Evaluation in Higher Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3761843.3761888,
	abstract = {This study extended a previous paper that focuses on the acceptability of selected Bachelor of Science in Computer Science (BSCS) and Information Technology (BSIT) students on the use of Intelligent Tutoring System (ITS) as an educational technology tool for C/C++ Programming. A one-shot case study research design was carried out in 5 programming classes taught by the author. A Slovin's formula computation from the population was 35.54. A stratified sampling method was employed with the 4 intervals between students to mitigate bias. The study involved 39 participants, out of which 74.36% were male and 25.64% were female computer science and IT students. Utilizing the Technology Acceptance Model (TAM) as an evaluation tool online enabled importing the dataset into IBM SPSS for finding the correlations and factor loading calculations. Cronbach alpha was conducted by the author with a value of 0.947, which signifies the measure of internal consistency. The seven (7) factors of TAM were analyzed to reveal coefficient values for comparisons and derive their relative implications. Research indicates that every factor significantly influences the acceptance of ITS among BSCS and BSIT students. Interestingly, PerUse→Att has the highest coefficient value (0.883) next in the rank was SocNor→Att by a factor of 0.822 signifying their impact on ITS (Att), leaving SocNor→PerEas ranking last amongst relations with a 0.630 coefficient value. Finally, the results implied CS and IT students are open to the notion of incorporating intelligent teaching tools into their laboratory sessions to supplement their programming activity and increase their efficiency when building console applications.},
	affiliations = {},
	author = {Arguson, Angelo Condol and Ambat, Shaneth Cueno and Malasaga, Elisa Villamor and Almeniana, Fanny Cabiso and Sanchez, Marilyn Mamansag},
	author_keywords = {Computer programming; Intelligent tutoring system; Structural equation modeling; Technology acceptance model; Tinkering},
	doi = {10.1145/3761843.3761888},
	issn = {},
	journal = {Proceedings of the 2025 9th International Conference on Education and Multimedia Technology},
	keywords = {},
	number = {},
	pages = {14–20},
	source = {Scopus},
	title = {Factors influencing C/C++ Intelligent Tutoring System adoption: An analysis of modified technology acceptance model using structural equation modeling},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3764206.3764233,
	abstract = {Data-oriented Thinking is a core disciplinary thinking skill in computer networking Laboratory courses, and its cultivation strategy emphasizes transfer and application. Industry and enterprises urgently require talents equipped with Data-oriented Thinking, which drives the progression of Laboratory instruction from basic verification to practical application. This study adopts a ``verification–transfer” strategy, structuring each Laboratory as a progression from basic verification tasks to transfer-oriented application tasks. Following the Data-oriented Thinking process—task execution, data collection, data analysis, intelligent data interpretation, and principle verification—ChatGPT is employed to design verification tasks as well as practical or contextual application tasks, while AI teaching assistants assist in data interpretation. Cognitive load is regulated at the preparation, implementation, and summary stages of each Laboratory. Practical results indicate that students report high levels of satisfaction with the Data-oriented Thinking methodology, cognitive load regulation, and the support functions provided by the AI teaching assistant. A K-means clustering analysis of 97 questionnaire responses identifies three student profiles: higher-order thinking-oriented, AI-supported, and passive task-completing types. Targeted instructional optimization strategies are proposed for each profile.},
	affiliations = {},
	author = {Yi, Huiyan},
	author_keywords = {},
	doi = {},
	issn = {},
	journal = {Proceedings of the 2nd International Conference on Intelligent Education and Computer Technology},
	keywords = {},
	number = {},
	pages = {178–188},
	source = {Scopus},
	title = {Progressive Laboratory Teaching Based on Data-oriented Thinking and Cognitive Load Regulation Empowered by AI},
	type = {Book chapter},
	volume = {},
	year = {2025}
}

@article{10.1145/3764206.3764261,
	abstract = {More than 2,000 years ago, classical Chinese educators put forward the concept of ``teaching students according to their aptitude", but this idea has gradually given way to a system of ``formalism" and ``bureaucracy" during historical development. With the development of Artificial Intelligence Generated Content (AIGC), this is finally changing. However, the dependence on the network environment has brought about many hidden dangers such as network information interference and privacy data protection. To practice the concept of ``teaching students according to their aptitude" put forward by educators in the classical Chinese era, we have designed a series of software CLAP (Chat Local and Persistent) based on AIGC technology and using large language models. On the other hand, the software can also help learners transfer their own conversational context, allowing them to ``personalize learning" according to their situation. Of course, this software is still in the early stages of development, and its current functions are limited to scenarios based on generalized language learning, including programming language learning and foreign language learning. Future research may consider further focusing on multimodal support and complex discipline support.},
	affiliations = {},
	author = {Li, Shu-Jun and Yu, Qiu-Ye and Yang, Hao-Zhi and Wang, Zhi-Yan and Zhang, Li-Ming},
	author_keywords = {AIGC; Differentiated Instruction; Large Language Model; Personalized Learning},
	doi = {10.1145/3764206.3764261},
	issn = {},
	journal = {Proceedings of the 2nd International Conference on Intelligent Education and Computer Technology},
	keywords = {},
	number = {},
	pages = {356–361},
	source = {Scopus},
	title = {AIGC-Assisted "Teaching According to Aptitude" and "Personalized Learning": A Design Approach Based on Large Language Models},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{10.1145/3764206.3764318,
	abstract = {In the face of the transformation of the information receiving mode of Generation Z students and the demand for the precision of ideological and political education, this study constructs a two-wheel drive model of ``knowledge graph + topic evolution analysis" to explore the innovation path of artificial intelligence technology empowering ideological and political education. The topic evolution monitoring model is constructed based on dynamic Bayesian network (prediction accuracy is 87.3%). Empirical research shows that in the pilot application of three universities, the intelligent ideological and political system improves the average score of students 'theoretical knowledge test by 15.2 points (p&lt;0.01), the score of values identity scale by 23.7%, and the efficiency of teachers 'lesson preparation by 40%. It is found that the knowledge graph can effectively solve the problem of knowledge fragmentation of ideological and political education, and the topic evolution analysis can accurately capture the life cycle law of hot topics such as ``20 Spirits" (timeliness is increased by 60%).The values identity scale adopted the validated 20-item questionnaire developed by Wang et al. (2021), consisting of four dimensions: socialist core values identification (5 items), political identity (6 items), cultural identity (4 items), and moral values (5 items). Scores were quantified on a 5-point Likert scale (1=strongly disagree, 5=strongly agree), with Cronbach's α=0.89 for internal consistency. Aiming at the problems of algorithm bias and data security in technical applications, the optimization strategies of constructing an ethical review committee, an interpretability model, and a blockchain certificate storage system were proposed. The research provided a theoretical framework and practical path for the digital transformation of ideological and political education, and promoted the transformation of educational decision-making from experience-driven to data-driven.},
	affiliations = {},
	author = {Jian, Xiaoyu},
	author_keywords = {Application path; Artificial intelligence; Ideological and political education; Knowledge graph; Topic evolution analysis},
	doi = {10.1145/3764206.3764318},
	issn = {},
	journal = {Proceedings of the 2nd International Conference on Intelligent Education and Computer Technology},
	keywords = {},
	number = {},
	pages = {717–723},
	source = {Scopus},
	title = {Research on the Application Path of Artificial Intelligence Technology in Ideological and Political Education -- Based on Knowledge Graph and Topic Evolution Analysis},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

