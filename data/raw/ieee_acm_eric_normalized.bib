@article{10.1145/3797552.3797579,
	abstract = {In order to meet the problem that course redundancy and competency deficiency in the integrated software technology education, an AIGC toolchain aided CDIO model is proposed in this paper. As such, when we build domain-specific knowledge base by means of Retrieval-Augmented Generation (RAG) and fine-tune a pre-trained language model, the framework is able to support end-to-end intelligent assistance during major development stages including code synthesis, intelligent architectural design, test case construction, and even automatic requirement generation. To enhance the effect of the proposed model in this study, critical adaptations are applied to the template for prompt engineering and mechanism used to verify the result of generated contents. It contributes to accelerating the progress in requirements analysis phase by 68%, and reaching 89% accuracy in generated codes. The experimented outcomes prove that the proposed model is an effective means to boost development speed and quality of teaching software engineering, and validate it as technology-enhanced approach.},
