@article{10.1145/3802607.3802689,
	abstract = {Amid the global digital intelligence (DI) transformation of vocational education, theoretical courses in higher vocational colleges face operability and visualization bottlenecks, demanding systemic reform. This study adopts a mixed-methods design integrating grounded theory and longitudinal tracking to investigate 240 stakeholders from 7 vocational colleges across 4 Chinese regions. Data were collected via 180 individual, 60 focus group interviews, and a 6-month pre-post survey. A refined “Stimulus-Intervention-Organism-Response (S-I-O-R)” framework was constructed, delineating how DeepSeek's intrinsic attributes (generative professionalism, interactive responsiveness) influence stakeholders’ internal states (excitement, value perception, trust) and usage intentions, with contextual factors (policy, infrastructure, institutional culture) as moderators. Heterogeneous stakeholder challenges (teachers’ trust deficit, students’ over-reliance, administrators’ efficiency-pedagogy trade-off) were identified, and targeted reform strategies embedded in a change management framework were proposed, validated by 3 pilot college cases. This research enriches AI-education integration theory and provides empirically grounded guidelines for vocational education reform in the DI era.},
	affiliations = {},
	author = {Zhang, Junxiang and Zhou, Ningxin},
	author_keywords = {Case Study; Cross-Regional Study; DeepSeek; Digital Intelligence; Grounded Theory; Higher Vocational Education; Longitudinal Research; Theoretical Course Reform},
	doi = {10.1145/3802607.3802689},
	issn = {},
