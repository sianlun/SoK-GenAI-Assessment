	keywords = {},
	number = {},
	pages = {1-7},
	source = {Scopus},
	title = {How Students Use Generative AI: Insights from Conversation Log Analysis},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11328653,
	abstract = {This innovative practice full paper describes the effectiveness of self-hosted large language models (LLMs) for automatic grading of introductory programming (CS1) assignments using various rubrics. As computer science education (CSE) expands, the need for scalable grading solutions increases. Traditional grading is timeconsuming, and automated tools often lack meaningful feedback. LLM-based grading offers efficient assessment of large numbers of student submissions with adaptive feedback. However, remotely hosted systems like ChatGPT raise privacy concerns due to sharing sensitive student data externally. Self-hosted LLMs address privacy concerns by keeping data local. Earlier studies reported inconsistent grading with selfhosted models, raising concerns about reliability. This study reevaluates the accuracy of self-hosted models for CS1 assignment grading and examines how rubric design influences scoring consistency. The study used grading data from a semester-long CS1 course with 124 students and nine programming assignments. Initially, ten self-hosted LLMs were evaluated on their ability to assign scores on a 100-point scale without rubric guidance, establishing a baseline. Subsequently, the five best-performing models were assessed using five distinct rubrics: holistic 4-point, holistic 8 point, analytic 15-point, analytic 20-point, and a hybrid 100-point rubric that was used in the course. These rubrics varied in assessment granularity, facilitating analysis of LLM performance across different scoring frameworks. The analysis examined grading consistency and assessed how rubric structure impacted performance. Findings from this research provide insights into self-hosted LLMs reliability for automated grading, effectiveness of different rubric styles, and implications for integrating LLM-assisted grading into broader CSE practices.},
	affiliations = {},
	author = {Mazzone, Samuel B and Forden, Jack and Brylow, Dennis},
	author_keywords = {Data privacy; Adaptation models; Analytical models; Accuracy; Large language models; Chatbots; Data models; Computer science education; Reliability; Programming profession; Large language model (LLMs); automated assessment tools (AATs); CS1; rubrics},
	doi = {10.1109/FIE63693.2025.11328653},
	issn = {2377-634X},
	journal = {2025 IEEE Frontiers in Education Conference (FIE)},
	keywords = {},
	number = {},
	pages = {1-9},
	source = {Scopus},
	title = {Can LLMs be Fair Graders? Only if You Bribe Them with the Right Rubric},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11328654,
	abstract = {This full paper in innovative practice provides an automated tool to summarize individual code contributions in project-based courses with external clients. Real industry projects offer valuable learning opportunities by immersing students in authentic problems defined by external clients. However, the open-ended and highly variable scope of these projects makes it challenging for instructors and teaching assistants to provide timely and detailed feedback. This paper addresses the need for an automated and objective approach to evaluate individual contributions within team projects. In this paper, we present a tool that leverages a large language model (LLM) to automatically summarize code contributions extracted from version control repositories. The tool preprocesses and structures repository data, and uses PyDriller to isolate individual contributions. Its uniqueness lies in the combination of LLM prompt engineering with automated repository analysis, thus reducing the manual grading burden while providing regular and informative updates. The tool was assessed over two semesters during a three-week, full-time software development sprint involving 65 students. Weekly summaries were provided to teams, and both student and faculty feedback indicated the tool's overall usefulness in informing grading and guidance. The tool reports, in large proportion, activities that were in fact performed by the student, with some failure to detect students contribution. The summaries were considered by the instructors as a useful potential tool to keep up with the projects.},
	affiliations = {},
	author = {Ferrão, Rafael Corsi and Miranda, Fabio de and Soler, Diego Pavan and Graglia, Marcelo Augusto Vieira},
	author_keywords = {Costs; Codes; Production; Manuals; Software; Regulation; Teamwork; Prompt engineering; Software engineering; Software development management; teamwork; project assessment; software engineering education; project-based learning; automated feedback; educational technology; software repository mining},
