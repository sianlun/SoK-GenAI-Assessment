@article{10.1145/3806980.3806985,
	abstract = {The integration of generative AI into computer science education has precipitated a paradigm shift, yet empirical evidence regarding its impact on student competency remains fragmented. This study presents a longitudinal analysis of 412 undergraduate students across three semesters, focusing on the critical “watershed” moment in early 2025 precipitated by the widespread adoption of high-performance domestic Chinese Large Language Models (LLMs) such as DeepSeek. Utilizing a mixed-method approach with questionnaires, code submissions, and examination data, we observed a structural transition in student behavior from sporadic tool assistance to infrastructure dependency. The quantitative results reveal a paradox: while LLM-assisted assignments demonstrated significantly higher accuracy (Mean Score Rate: 0.803) compared to self-written code (0.644), this performance advantage evaporated in closed-book examinations, where AI-reliant students showed no statistical improvement over their self-sufficient peers. Furthermore, error profile analysis indicates a migration of cognitive hurdles from basic syntax errors (Type S) to complex API misuse (Type A) and logical hallucinations (Type L). Notably, despite the automation of coding tasks, temporal efficiency did not significantly improve, suggesting that the cognitive load has merely shifted from code construction to verification and debugging. In light of these findings, particularly the evidence of “competency hollowing”, this paper proposes a pedagogical pivot towards process-oriented assessment, adversarial learning tasks, and a 3-layer curriculum structure to ensure that AI serves as a scaffold for, rather than a substitute of, fundamental computational thinking.},
	affiliations = {},
	author = {Zhu, Suyang and Liu, Zhengtao},
	author_keywords = {Generative AI; Programming Education; Empirical Analysis; LLM; Competency Hollowing},
	doi = {10.1145/3806980.3806985},
	issn = {},
	journal = {Proceedings of the 2026 International Conference on Big Data and Informatization Education},
	keywords = {},
	number = {},
	pages = {26–32},
	source = {Scopus},
	title = {Generative AI in Programming Education: An Empirical Analysis of Student Performance and Assessment Challenges in the LLM Era},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3806980.3806996,
	abstract = {This study presents a computational framework investigating how generative AI systems enhance creative thinking through prompt engineering mechanisms in teacher education. A 12-week quasi-experimental intervention with 240 pre-service teachers employed natural language processing-based instructional design tools to analyze human-AI interaction patterns. Quantitative results demonstrate that AI-assisted computational workflows significantly enhance all six creative thinking dimensions: fluency, flexibility, originality, elaboration, overall creativity, and instructional design quality (Cohen's d=0.94-1.28, p&lt;.001), with originality and design quality showing the most substantial improvements. System log analysis reveals disciplinary-specific interaction patterns: humanities majors generate higher lexical diversity in prompts (TTR=0.68 vs. 0.52) correlating with divergent thinking, while STEM majors exhibit superior algorithmic prompt structures enabling implementation capabilities. Critically, prompt engineering quality—quantified through syntactic complexity, semantic specificity, and iterative refinement metrics—emerged as the key computational mediating factor, with high-quality prompts (complexity score &gt;0.75) yielding 15-20% higher creative outcomes through optimized human-AI information exchange. Computational path analysis establishes and empirically validates a tripartite mechanism model with demonstrated effectiveness: (1) cognitive load reduction pathway via AI-automated routine tasks showing 38% reduction in instructional design processing time with corresponding increases in creative output, (2) metacognitive development pathway through iterative prompt reflection cycles showing positive correlation with originality scores (r=0.64, p&lt;.001), and (3) prompt-mediated collaboration quality pathway measured by semantic alignment scores between user intent and AI output (r=0.71, p&lt;.001) predicting final design quality. Cross-validation confirms this model explains 67% of variance in creative thinking enhancement. The study provides a computational pedagogy framework for integrating AI literacy and prompt engineering competencies into teacher education curricula, with implications for human-AI interaction design in educational computing systems.},
	affiliations = {},
	author = {Zhou, Jingxian},
	author_keywords = {AI-mediated instructional design; Computational pedagogy; Creative thinking enhancement; Educational computing; Generative AI systems; Human-AI interaction; Natural language processing; Prompt engineering algorithms},
	doi = {10.1145/3806980.3806996},
	issn = {},
	journal = {Proceedings of the 2026 International Conference on Big Data and Informatization Education},
	keywords = {},
	number = {},
	pages = {92–97},
	source = {Scopus},
	title = {Prompt Engineering as Pedagogical Interface: A Computational Study of Generative AI Systems for Enhancing Creative Thinking in Teacher Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3806980.3807012,
	abstract = {Digital competence (DC) stands as a crucial competency for international Chinese language teachers (ICTs) in the new era. Generative artificial intelligence technologies like large language models (LLMs)play a pivotal role in enhancing their DC. Building upon scholars 'established frameworks for ICTs' DC and leveraging LLMs' effectiveness in improving classroom instruction, this study develops DC system for ICTs based on LLMs.Through two rounds of anonymous Delphi consultations with 10 experts, the system was refined and validated. The framework comprises 7 primary indicators, 45 secondary indicators. Weighting for each level was determined via analytic hierarchy process, providing a practical reference for refining evaluation standards of ICTs' DC.},
