	title = {An AI-Driven Competence-Based Education Framework Integrating Competence Specification and AI-Enabled Teaching–Learning},
	type = {Book chapter},
	volume = {},
	year = {2026}
}

@article{10.1145/3802607.3802686,
	abstract = {This paper discusses the technologies and functions of Generative AI (GAI). The application of GAI in education has triggered significant changes in teaching methods and forms, bringing unprecedented impetus to both teaching and learning, while also giving rise to new problems and challenges. This study explores the integration of GAI technologies into online-offline blended teaching in higher education. Starting from the processes and needs of blended teaching, and based on the characteristics and functions of GAI tools, it discusses the impacts on teaching and learning content, teaching methods and learning approaches, as well as teaching design and educational research. The paper also investigates methods for integrating GAI into online-offline blended teaching, elaborating from both online and offline contexts, as well as from the perspectives of teachers and students. Through discussions on these contents and issues, this paper aims to provide application methods, objectives, and ideas for "Generative AI technology + online-offline blended teaching", highlighting the new opportunities and energy that GAI technologies bring to blended teaching, while also addressing the new crises and drawbacks that arise.},
