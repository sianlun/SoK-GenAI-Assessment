	source = {Scopus},
	title = {Anti-Cheating Online Exam Through Hand Gesture Answering Using Webrtc},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11473581,
	abstract = {In this paper, the impression of Artificial Intelligence (AI) as applied to the academic development of engineering students at the private universities in Bangladesh is reported. The study tried to identify trends in the adoption of AI, perceptions of benefits and limitations, and institutional preparedness. The sample consisted of 300 students. The given results have shown that 72.3% of engineering students use AI tools, with ChatGPT being the most popular (100% of AI users), followed by GitHub (23.5%), Grammarly (16.1%), Copilot (23.5%), MATLAB AI (7.4%), Wolfram Alpha (4.1%), and Symbolab (3.2%). Most AI users utilize AI to write, complete homework, and conduct research. The study reveals that almost 83% of users use AI on a daily or weekly basis. Approximately 55 percent of AI users report that AI has helped them improve their studies, and 72.3% of respondents report that AI saves them time. However, only 43.7% of respondents think that the use of AI has a positive impact on learning, while 56.3% of them respond that it has no significant impact on learning. The difference in discipline can also be seen when Computer Science and Engineering students prove to be the top AI users (99.1%), followed by Electrical and Electronic Engineering students (79.3%), Mechanical and Civil Engineering students (36.5% and 37%). In response to having institutional policies and awareness, the reply from 83.3% of respondents is negative, which represents the lack of awareness of the universities in Bangladesh, and 10.7% respond positively. By addressing the impressions, benefits, and academic usages of AI adoption, this study contributes to a deeper understanding of how AI can be leveraged to support academic growth while encouraging sustainable and equitable adoption in the context of resource-constrained higher education systems.},
	affiliations = {},
	author = {Islam, Md. Rounakul and Mahmud Parvez, Sofi and Hossain, Md. Asif},
	author_keywords = {Circuits; Circuit synthesis; Protocols; HTTP; Internet; Amplitude shift keying; Amplitude modulation; Communication systems; Computer networks; Artificial intelligence; AI adoption in engineering education; digital divide in higher education in Bangladesh; AI tools and academic integrity; student perceptions of AI learning impact; institutional preparedness},
	doi = {10.1109/ICEIDT66693.2025.11473581},
	issn = {},
	journal = {2025 1st International Conference on Emerging Innovation and Digital Technology (ICEIDT)},
	keywords = {},
	number = {},
	pages = {17-22},
	source = {Scopus},
	title = {The Impact of Artificial Intelligence (AI) on Engineering Students' Academic Development: A Perspective from Bangladeshi Private Universities},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11488560,
	abstract = {Project-based courses increasingly rely on Git version control systems such as GitHub, yet raw commit histories are difficult for instructors to interpret in terms of collaboration and feature development. This paper investigates how large language models (LLMs) can support this analysis by generating natural-language summaries of student commits and assigning feature-level labels. Using data from a software engineering project course, we apply a four-phase LLM pipeline that (i) extracts and normalizes commit data, (ii) infers high-level feature and non-feature categories from commit messages, (iii) consolidates synonymous labels into a unified vocabulary, and (iv) classifies each commit to a specific label. We then group the resulting labels into Compulsory Features, Optional Features, and Non-Features (maintenance tasks such as testing, refactoring, and configuration) to distinguish teams that implemented only minimum requirements from those that pursued additional functionality. We derive analytics on feature coverage, collaboration patterns, commit-size distributions across teams, and workload balance using per-student commit shares and the Gini coefficient. Our results show that many teams collaboratively implemented core features, while optional requirements revealed substantial variation in ambition. Teams that worked on optional features tended to receive higher grades, providing initial evidence that the LLM-derived analytics align with instructor judgements. In addition, the LLM-generated summaries and labels help instructors locate where features are implemented, exercise them during grading, and provide targeted feedback. We argue that LLMs can act as practical co-analysts for educational GitHub repositories, transforming low-level version-control data into actionable insights for teaching and assessment.},
	affiliations = {},
	author = {Gedeon, Rawan and Giacaman, Nasser},
	author_keywords = {Feedback; Circuits; Electronic mail; Service-oriented architecture; Crowdsourcing; Web services; Internet; Social computing; Amplitude shift keying; Feedback loop; Collaboration; educational data mining; feature extraction; Git; large language models; software engineering education; version control mining},
	doi = {10.1109/ACCESS.2026.3685720},
	issn = {2169-3536},
	journal = {IEEE Access},
	keywords = {},
	number = {},
	pages = {61117-61130},
	source = {Scopus},
	title = {LLM-Driven Feature Inference for Analyzing Student Git Collaboration},
	type = {Article},
	volume = {14},
	year = {2026}
}

@article{11521836,
	abstract = {Generative artificial intelligence (AI) systems, such as ChatGPT, are increasingly influencing educational practices in software requirements engineering (SRE). This study evaluates the feasibility of employing generative AI as a co-reviewer to support requirement quality assessment while maintaining student trust and perceived usefulness of feedback. The study adopts a mixed-methods design involving (1) the collection of 30 student-written functional and non-functional requirements, followed by parallel feedback generation from two human instructors and an AI system using a standardized prompt; (2) rubric-based evaluation of feedback quality across specificity, clarity, relevance, constructiveness, and tone; and (3) a post-revision student survey examining trust, perceived usefulness, and acceptance of AI-generated feedback. The results indicate that AI-generated feedback achieves quality levels comparable to human feedback for surface-level requirement issues, while human feedback remains more trusted for context-dependent cases. Student responses further reveal a strong preference for receiving combined human and AI feedback, supporting the positioning of AI as a complementary quality assurance assistant rather than a replacement for instructors. The findings provide practical insights for integrating generative AI tools into SRE education in a responsible, human-in-the-loop manner and contribute to ongoing discussions on AI-supported feedback in engineering education.},
	affiliations = {},
	author = {Attar, Ghadeer and Amara, Mohammed Abu},
	author_keywords = {Artificial intelligence; Feedback; Generative AI; Modeling; Requirements engineering; Learning (artificial intelligence); Printing; Software; Reviews; Software engineering; Generative AI; Software Requirements Engineering; AI-Assisted Review; Educational Technology; Engineering Education; AI Integration},
	doi = {10.1109/ICAIII69475.2026.11521836},
	issn = {},
	journal = {2026 International Conference on AI Innovations and Industry (ICAIII)},
	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {AI as a Co-Reviewer: Evaluating Trust and Usefulness of Generative AI Feedback in Software Requirements Engineering Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{11521992,
	abstract = {The fast-paced evolution of Information Technology (IT) presents challenges for educators in keeping assessment materials aligned with constantly changing curricula. To address this, we propose an Automated Test Paper Generation (ATPG) system that leverages large language models (LLMs) and Retrieval-Augmented Generation (RAG) techniques to generate diverse, high-quality test papers for K-12 IT education. The ATPG system comprises two main components: ITExt, which extracts structured knowledge from textbooks and syllabi to build an IT knowledge base, and ITGen, a question generation framework that fine-tunes LLMs to produce contextually relevant and varied test questions. Our approach also includes a standardized evaluation framework to assess the quality of the generated exams based on dimensions such as difficulty, diversity, and contextuality. Experimental results demonstrate that ATPG significantly outperforms existing methods in producing high-quality tests tailored to the evolving needs of IT education. This system not only eases the burden on educators but also helps keep educational tools up-to-date with modern IT standards.},
	affiliations = {},
