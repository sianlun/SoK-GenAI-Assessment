	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3802133.3802257,
	abstract = {The rapid development of generative artificial intelligence (AI) has exposed structural limitations in traditional integrated circuit (IC) engineering education, where teaching objectives remain focused on low-order cognitive tasks that AI can easily replace. This paper proposes a “coach-assistant” human-AI collaborative teaching paradigm that systematically reconstructs the IC education ecosystem by integrating multi-agent AI systems with electronic design automation (EDA) toolchains, thereby advancing computer technology applications in electronic engineering and promoting efficiency in IC design processes. In the proposed framework, AI is repositioned as an always-available intelligent partner that supports concept formation, design-space exploration, multi-objective optimization, and reflective practice, while instructors shift to facilitating higher-order thinking and learning-process design. Key implementation strategies include: (1) dynamic knowledge graphs for personalized theoretical learning; (2) open-ended performance-optimization competitions to drive inquiry-based experimental teaching; and (3) digital-twin-based visualization of multidimensional learning trajectories, enabling a shift from outcome-oriented to process-oriented developmental evaluation. The paradigm leverages generative AI to enhance EDA workflows, accelerating multi-objective optimization and trade-off analysis in IC design, cultivating compound talents proficient in AI-driven electronic systems.},
	affiliations = {},
	author = {Lin, Zhiting and Liu, Yu},
	author_keywords = {Artificial intelligence; and computer technology in education; electronic design automation; integrated circuits},
	doi = {10.1145/3802133.3802257},
	issn = {},
	journal = {Proceedings of the 2026 3rd International Conference on Informatics Education and Computer Technology Applications},
	keywords = {},
	number = {},
	pages = {761–766},
	source = {Scopus},
	title = {A “Coach-Assistant” Human-AI Collaborative Paradigm for AI-Empowered Integrated Circuit Design Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3802133.3802273,
	abstract = {The OBE concept has been widely applied in teaching practice. As a core component of computer-related majors, the implementation strategies of programming courses based on the OBE teaching model have also received considerable attention. However, in the process of promoting OBE teaching practice, there are still many long-term challenges, such as insufficient cultivation of students’ higher-order thinking ability, incomplete personalized learning support, relatively tight teacher resources, and the deficiency of a procedural assessment mechanism. At the same time, the rapid development of AI technology in recent years has brought new opportunities for educational reform. To address the challenging issues faced by OBE-based programming course teaching and meet the new requirements of the AI era for education, we propose an AI-enabled teaching reform scheme, which provides AI technology solutions for core issues such as outcome-oriented positioning, student-centered practice, continuous improvement, and assessment mechanisms in programming course teaching under the OBE framework. By restructuring the OBE teaching framework, designing adaptive intelligent agents and their supporting platforms, and building a systematic AI support system, key measures are taken to optimize traditional teaching models, provide effective paths for improving course teaching effectiveness and strengthening students’ core competence, and assist in the efficient implementation of OBE-based programming course teaching.},
	affiliations = {},
	author = {Chen, Rongxin and Wang, Zongyue and Wang, Zhihua and Wang, Zhijin},
	author_keywords = {AI agent; AI-enabled scheme; OBE concept; programming courses; teaching reform},
