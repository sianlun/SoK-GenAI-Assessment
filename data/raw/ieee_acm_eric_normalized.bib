@article{10.1145/3768310.3807795,
	abstract = {A long-standing challenge in engineering education is that first-year students often struggle to stay engaged when learning abstract concepts without immediate, hands-on feedback. In this paper, we propose a new approach to address this challenge by embedding a local large language model (LLM) assistant into Minecraft: Java Edition, using it as a hands-on learning environment where students practice engineering concepts through in-game building tasks. The assistant runs as a chatbot on a local Minecraft server, interacting with players through in-game chat to help with construction tasks related to engineering topics such as logic gates, Redstone circuits, and piston mechanisms. It also provides specific situational hints and explanations based on the questions raised by players in the game. We conducted an experiment with 40 college students to assess the assistant's support and impact on learning tasks involving Redstone and logic gates. A comparative evaluation shows that users performed better on these tasks with the chatbot's assistance than without. Our work demonstrates the feasibility of embedding a local LLM assistant in Minecraft and suggests potential educational value, laying a foundation for larger-scale user studies.},
	affiliations = {},
	author = {Wang, Wenxuan and Shen, Zijian and Lin, Li and Hsiao, Michael S.},
	author_keywords = {minecraft; game-based learning; large language models; ai agent; human-ai collaboration},
	doi = {10.1145/3768310.3807795},
	issn = {},
	journal = {Proceedings of the 63rd ACM Conference on Computers and People Research},
	keywords = {},
	number = {},
	pages = {91–99},
	source = {Scopus},
	title = {Enhancing Learning Motivation of Engineering Students via Minecraft: Incorporating an Embedded AI Agent},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3768310.3807799,
	abstract = {Generative artificial intelligence (GenAI) is rapidly reshaping IT-intensive knowledge work and has become a central concern for Information Systems (IS) research. While existing studies document productivity effects, new forms of human–AI collaboration, and emerging governance frameworks, they primarily examine adoption dynamics and oversight mechanisms. Less attention has been devoted to clarifying how GenAI reorganizes cognitive production itself. This theory-development paper advances a regime-level perspective to address this gap. We argue that by embedding execution-level cognition within technical infrastructures, generative systems expand the delegability of routine knowledge work and thereby reorganize abstraction, authority, and accountability across organizational layers. We conceptualize this configuration as cognitive Taylorism, a mode of organizing work in which routine expertise is progressively capitalized through infrastructure, execution and integrative judgment are partially decoupled, and professional career pathways compress. Drawing on labor process theory as an analytical lens, we develop a structural account of how this regime reshapes organizational layering, redistributes expertise, alters authorship and identity, and restructures capability formation in IT-related occupations. In doing so, our paper reframes GenAI as a transformation in how cognition is organized and outlines a research agenda that positions workforce dynamics, professional development, and institutional reproduction as central domains for IS scholarship in the age of generative infrastructures.},
	affiliations = {},
	author = {Schmalenbach, Kian},
	author_keywords = {generative artificial intelligence; cognitive taylorism; socio-technical systems; it workforce; capability formation},
	doi = {10.1145/3768310.3807799},
	issn = {},
	journal = {Proceedings of the 63rd ACM Conference on Computers and People Research},
	keywords = {},
	number = {},
	pages = {67–75},
	source = {Scopus},
	title = {GenAI and the Transformation of Cognitive Production: A Regime Perspective},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3768421.3768445,
	abstract = {Engineering education faces ongoing challenges in maintaining alignment between academic curricula and the rapidly changing skill requirements of the industry. This paper proposes EduAlign-KG, a structured evaluation framework that combines course knowledge graphs with labor market analysis based on online job postings. The framework consists of three modules: (1) constructing course knowledge graphs from course documents; (2) extracting industry skill requirements through web crawling and natural language processing (NLP), and applying them to online job data; (3)a graph-based course evaluation model, which applies graph matching and attention mechanisms to assess the alignment between course content and industry expectations. The paper evaluates the framework using simulated engineering courses, and the experimental results demonstrate that EduAlign-KG achieves higher skill coverage and alignment accuracy compared to recent benchmark methods. In conclusion, EduAlign-KG can assist course planners in identifying gaps and adjusting course structures to better reflect current engineering skill requirements.},
	affiliations = {},
	author = {Zhang, Kun and Tian, Ji},
	author_keywords = {Curriculum evaluation; Engineering education; Knowledge graph; Market-driven analysis; Skill alignment},
	doi = {10.1145/3768421.3768445},
	issn = {},
	journal = {Proceedings of the 2025 International Conference on AI-Enabled Education},
	keywords = {},
	number = {},
	pages = {137–142},
	source = {Scopus},
	title = {A Novel Engineering-Oriented Course Evaluation Framework Based on Knowledge Graphs and Market-Driven Analysis},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{10.1145/3768421.3768449,
	abstract = {The technological advancement represented by Artificial Intelligence Generated Content (AIGC) is fundamentally transforming higher education, particularly in the field of Computer Science (CS). CS programming education, centered on courses such as Data Structures and Algorithms (DSA), faces both unprecedented opportunities and challenges in its traditional teaching model. This article systematically examines the current landscape, key technologies, teaching methodologies, practical outcomes, and core challenges of implementing AIGC as an auxiliary teaching tool in university programming courses. The analysis focuses on how AIGC technology reshapes teaching objectives, innovates content delivery, transforms instructional methods, and reconstructs evaluation systems across four dimensions of programming education in universities. Through comprehensive literature review and case analysis of EI conference papers, academic journals, and authoritative research reports from the past five years, this study examines the specific applications and implementation strategies of AIGC in facilitating abstract concept comprehension, enhancing programming skills, developing human-machine collaborative teaching models, and establishing automated evaluation systems. Research findings indicate that effective AIGC-assisted programming instruction exhibits key characteristics including human-machine collaboration through "teacher-teaching assistant + AI" frameworks, instantaneous feedback systems, and individualized learning pathways. AIGC technology is catalyzing shifts from knowledge transmission to skills development in teaching objectives, from standardized to personalized content delivery, from unidirectional lectures to interactive inquiry in teaching methods, and from outcome-focused to process-oriented evaluation approaches. However, significant challenges persist, including concerns regarding academic integrity, insufficient AI literacy among educators, outdated evaluation systems, and technological ethical considerations. AIGC's role in programming education has evolved from a supplementary tool to become an integral partner in transforming teaching paradigms. The establishment of a new "ternary" educational ecosystem - student-centered, teacher-led, and AI-supported - represents an inevitable progression. This research provides practical insights and theoretical framework for educators, researchers, and policymakers seeking to advance programming education in the AI era.},
	affiliations = {},
	author = {Cao, Haoshun},
	author_keywords = {AI-assisted instruction; AIGC; Data structures and algorithms; Intelligent tutoring systems; Programming education; Teaching mode innovation},
	doi = {10.1145/3768421.3768449},
	issn = {},
	journal = {Proceedings of the 2025 International Conference on AI-Enabled Education},
	keywords = {},
	number = {},
	pages = {159–166},
	source = {Scopus},
	title = {Experiences and Insights Gained from AI-Assisted Programming Instruction in Higher Education},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{10.1145/3768421.3768457,
	abstract = {This study constructs a university teachers’ digital literacy assessment and enhancement model based on deep learning technology, focusing on the digital literacy development paths in the context of sports and arts curriculum integration. By collecting digital literacy data from 450 university teachers and employing a hybrid model combining convolutional neural networks and recurrent neural networks for analysis, the study identifies key factors affecting teachers’ digital literacy improvement, constructs a multi-dimensional digital literacy evaluation system, designs personalized digital literacy enhancement paths, validates the effectiveness of deep learning models in teacher digital literacy assessment, and provides scientific evidence for university teachers’ professional development. The CNN-LSTM hybrid model achieved 87.3% accuracy with F1 score of 0.859, successfully identifying five typical enhancement path patterns including gradual improvement (42.3%), leap-forward improvement (23.7%), and fluctuating improvement (18.9%) paths.},
	affiliations = {},
	author = {Li, Chenjie and Nian, Niannian and Zhang, Ziquan and Takenova, Zhyldyz},
