	keywords = {},
	number = {},
	pages = {1-9},
	source = {Scopus},
	title = {Optimizing Diary Studies Learning Outcomes with Fine-Tuned Large Language Models on the Diaryquest Platform},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11328715,
	abstract = {This full research paper investigates how Artificial Intelligence (AI) tools like ChatGPT can be thoughtfully integrated into computer science education to enhance learning while preventing over-reliance that could hinder students' development of critical thinking and problem-solving skills. Although AI can assist students in tasks such as debugging and code generation, its ease of use may inadvertently reduce their engagement with the underlying problem-solving process. To address this challenge, our research focuses on the design of CS1 assignments that make productive use of AI while encouraging deeper learning and creativity. We evaluate ChatGPT-4's ability to solve various programming problems and identify its limitations with AI-generated outputs. Based on this analysis, we propose a framework that encourages students to deconstruct complex problems, create innovative solutions beyond what AI typically generates, iteratively improve their code, and clearly explain their reasoning. Our methods include modifying standard lab assignments by adding non-textual elements such as flowcharts, real-world scenarios, and diagrams, making it more difficult for AI tools to directly solve them. These changes prompt students to engage in higher-order thinking as they interpret and solve the problems. Through this study, we offer practical recommendations for educators aiming to incorporate AI into computer science curricula without compromising the development of essential cognitive skills. By designing assignments that challenge students intellectually while leveraging the benefits of AI, we aim to promote responsible and effective use of emerging technologies in education.},
	affiliations = {},
	author = {Kurivella, Jaya Veera Surendra Gupta and Deoraj, Rajeshwari and Moraes, Marcia},
	author_keywords = {Flowcharts; Codes; Generative AI; Education; Learning (artificial intelligence); Chatbots; Problem-solving; Artificial intelligence; Standards; Programming profession; Undergraduate; Computer Science; Instructional Methods},
	doi = {10.1109/FIE63693.2025.11328715},
	issn = {2377-634X},
	journal = {2025 IEEE Frontiers in Education Conference (FIE)},
	keywords = {},
	number = {},
	pages = {1-9},
	source = {Scopus},
	title = {Designing CS Assignments to Foster Cogitation in the AI Era},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11332058,
	abstract = {This paper presents the design and development of the “EduTrack” Intelligent Achievement Analysis Platform, which integrates the Tongyi Qianwen large language model API and Alibaba's intelligent agent knowledge base to construct an intelligent analysis closed-loop system tailored for college teaching scenarios. Through fine-tuning training of the large language model, the system achieves semantic understanding of teaching texts, identification of knowledge gaps, and prediction of students' learning achievement levels. It also generates personalized teaching feedback and growth path recommendations. Meanwhile, built on the Spring Boot + Vue architecture and incorporating high-performance technical solutions such as multithreaded parallel computing, Redis high-speed caching, database sharding, and two-dimensional array algorithms, the platform effectively supports the processing, cleansing, and analysis of large-scale educational data. Ultimately, it enables the automated generation of analysis reports, helping teachers accurately grasp teaching effectiveness, optimize teaching strategies, and enhance the intelligence level of educational quality assessment.},
