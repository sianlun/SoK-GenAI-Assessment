	number = {},
	pages = {298-305},
	source = {Scopus},
	title = {Automated Test Paper Generation for K-12 IT Education Using Large Language Models and Retrieval-Augmented Generation},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11545654,
	abstract = {Large Language Models (LLMs) excel in linguistic tasks; however they have difficulty solving Physics multiplechoice questions (MCQs), especially in languages with fewer resources like Bengali. In this study, we test several advanced models on Bengali physics MCQs, such as Qwen2.5 (7B, 14B), Qwen3-14B, DeepSeek-R1-Distill-Qwen-7B, Qwen-Math-7B, and Mistral-7B-Instruct, as well as traditional methods like Random Forest and multilingual BERT. We use zero-shot and few-shot chain-of-thought prompting with carefully designed prompts to evaluate the models. The Qwen3-14B model, which has built-in reasoning abilities, achieves the highest accuracy of 0.8675 with few-shot CoT prompting. Our method uses advanced prompt design, 4-bit quantization for better computational efficiency, and detailed analysis of Bengali patterns to extract answers accurately. By reasoning step by step, the model shows strong results in understanding complex physics topics, including mechanics, thermodynamics, and electricity, all in Bengali. This work helps fill the gap in automated tools for Bengali physics education and shows that automated assessment can work well even in lowresource languages.},
	affiliations = {},
	author = {Chowdhury, Md. Sagor and Chowdhury, Adiba Fairooz and Banu, Ayesha and Hossain, Riad},
