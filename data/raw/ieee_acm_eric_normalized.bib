@article{10.1145/3748522.3779850,
	abstract = {Academic advising in higher education is under severe strain, with advisor-to-student ratios commonly exceeding 300:1. These structural bottlenecks limit timely access to guidance, increase the risk of delayed graduation, and contribute to inequities in student support. We introduce Aurora, a modular neuro-symbolic advising agent that unifies retrieval-augmented generation (RAG), symbolic reasoning, and normalized curricular databases to deliver policy-compliant, verifiable recommendations at scale. Aurora integrates three components: (i) a Boyce-Codd Normal Form (BCNF) catalog schema for consistent program rules, (ii) a Prolog engine for prerequisite and credit enforcement, and (iii) an instruction-tuned large language model for natural-language explanations of its recommendations. To assess performance, we design a structured evaluation suite spanning common and edge-case advising scenarios, including short-term scheduling, long-term roadmapping, skill-aligned pathways, and out-of-scope requests. Across this diverse set, Aurora improves semantic alignment with expert-crafted answers from 0.68 (Raw LLM baseline) to 0.93 (+36%), achieves perfect precision and recall in nearly half of in-scope cases, and consistently produces correct fallbacks for unanswerable prompts. On commodity hardware, Aurora averages 32.99 s per query (vs. 20.13 s for the Raw-LLM baseline), reflecting the runtime overhead of neuro-symbolic grounding. By combining symbolic rigor with neural fluency, Aurora advances a paradigm for accurate, explainable, and scalable AI-driven advising.},
	affiliations = {},
	author = {Quincoso Lugones, Lorena Amanda and Kverne, Christopher Lukas and Bhimani, Nityam Sharadkumar and Oliveira, Ana Carolina and Polyzou, Agoritsa and Lisetti, Christine and Bhimani, Janki},
	author_keywords = {academic advising; retrieval-augmented generation; neuro-symbolic AI; large language models; degree planning},
	doi = {10.1145/3748522.3779850},
	issn = {},
	journal = {Proceedings of the 41st ACM/SIGAPP Symposium on Applied Computing},
	keywords = {},
	number = {},
	pages = {22–29},
	source = {Scopus},
	title = {Aurora: Neuro-Symbolic AI Driven Advising Agent},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3748522.3779879,
	abstract = {Automated Essay Scoring (AES) has been explored for decades with the goal to support teachers by reducing grading workload and mitigating subjective biases. While early systems relied on handcrafted features and statistical models, recent advances in Large Language Models (LLMs) have made it possible to evaluate student writing with unprecedented flexibility. This paper investigates the application of state-of-the-art open-weight LLMs for the grading of Austrian A-level German texts, with a particular focus on rubric-based evaluation. A dataset of 101 anonymised student exams across three text types was processed and evaluated. Four LLMs, DeepSeek-R1 32b, Qwen3 30b, Mixtral 8x7b and LLama3.3 70b, were evaluated with different contexts and prompting strategies. The LLMs were able to reach a maximum of 40.6% agreement with the human rater in the rubric-provided sub-dimensions, and only 32.8% of final grades matched the ones given by a human expert. The results indicate that even though smaller models are able to use standardised rubrics for German essay grading, they are not accurate enough to be used in a real-world grading environment.},
	affiliations = {},
	author = {Kubesch, Jonas and Huber, Lena and Havas, Clemens},
	author_keywords = {automated essay scoring; large language models; rubric-based grading; RAG},
	doi = {10.1145/3748522.3779879},
	issn = {},
	journal = {Proceedings of the 41st ACM/SIGAPP Symposium on Applied Computing},
	keywords = {},
	number = {},
	pages = {46–53},
	source = {Scopus},
	title = {Evaluating Austrian A-Level German Essays with Large Language Models for Automated Essay Scoring},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3748522.3779975,
	abstract = {Learning to program poses significant challenges for Digital Humanists (DH) with limited computing experience, yet programming proficiency has become essential in contemporary academic and professional contexts. Despite this growing importance, existing research has not adequately explored effective pedagogical approaches or early identification methods for DH students struggling with programming concepts. This study investigates the application of Machine Learning (ML) techniques to predict programming performance among DH master's students. We analyze datasets from two cohorts using a combined framework of Computational Thinking (CT) concepts and ML methods. CT encompasses the cognitive processes necessary for problem understanding and solution formulation, including logic, pattern recognition, abstraction, and automation. Our approach evaluates quality, readability, and functionality to identify students who require additional support. Specifically, we employ Long Short-Term Memory (LSTM) networks to predict learner performance across sequential programming assignments. The result demonstrates a successful early prediction of at-risk students' performance throughout the course. This predictive capability enables timely curriculum adjustments, targeted interventions, and enhanced learning experiences for struggling students. Our findings contribute to the development of evidence-based teaching support strategies that address the unique challenges faced by both learners and instructors in programming education},
	affiliations = {},
	author = {Mohammed, Ahmed Taiye and Hooshyar, Danial and Milrad, Marcelo},
	author_keywords = {python programming; computational thinking; digital humanities; early prediction; machine learning},
	doi = {10.1145/3748522.3779975},
	issn = {},
	journal = {Proceedings of the 41st ACM/SIGAPP Symposium on Applied Computing},
	keywords = {},
	number = {},
	pages = {30–37},
	source = {Scopus},
	title = {Combining Computational Thinking Concepts and Machine Learning Techniques for Early Prediction of Digital Humanities Students’ Programming Performance},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3748627,
	abstract = {As the game industry expands, an increasing number of students and hobbyists are entering the game development field, eager to create their own titles. However, there is a lack of structured training programs that effectively prepare them for industry demands. Games convey meaningful messages through stories, assets, and mechanics, yet how early-stage developers make creative decisions while building production skills remains unclear. We explored skill development and cultural representation in game design during a 10-week professional development program at MassDigi with early-stage developers from the United Arab Emirates (UAE). Our findings reveal three observed strategies as themes through which developers incorporate their personal experiences and cultural backgrounds into game development to achieve cultural representation, as well as four themes that address developers' skill set improvement and personal growth during this process. We recommend structuring programs by considering these themes to enhance self-expressive game design and support skill development through a peer learning community.},
	affiliations = {},
	author = {Chen, Max and Smith, Gillian},
	author_keywords = {cultural representation; game design; game development education; professional development program; situated learning},
	doi = {10.1145/3748627},
	issn = {},
	journal = {Proc. ACM Hum.-Comput. Interact.},
	keywords = {},
	number = {6},
	pages = {},
	source = {Scopus},
	title = {Bridging Cultural Representation and Game Making: Analyzing the Experiences, Outcomes, and Lessons of Early-Stage Game Developers in a Professional Development Program},
	type = {Article},
	volume = {9},
	year = {2025}
}

@article{10.1145/3748825.3748843,
	abstract = {The integration of artificial intelligence and the education system brings us huge opportunities, but also faces implementation challenges. In this study, we established a four-dimensional analytical framework, covering key dimensions such as "Policy Objectives", "policy strength", "Instrumentation Strategies", and "Stakeholder Coverage", aiming to systematically evaluate the policies for the intelligent transformation of education in China. We conducted a systematic analysis of six national-level policy documents and determined the index weights by using the entropy weight TOPSIS method. Then we calculated the relative proximity coefficient of each policy text. The analysis results show that there are significant differences in the policy effects. Outstanding policies usually have clear goals, diverse implementation tools, strong regulatory influence and comprehensive stakeholder engagement. However, the policies with poor effects have deficiencies in these aspects. Based on the evidence, we put forward some suggestions, such as optimizing the goal-setting mechanism, enhancing policy enforcement, enriching the types of implementation tools, and expanding the coverage of beneficiaries. Our ultimate goal is to enhance the practical effect of intelligent transformation measures in China's education sector.},
	affiliations = {},
	author = {Wang, Jun and Wang, Baomin},
	author_keywords = {Education Intelligent Transformation; Entropy Weight TOPSIS Method; Four-dimensional Analysis Framework; Policy Evaluation},
	doi = {10.1145/3748825.3748843},
