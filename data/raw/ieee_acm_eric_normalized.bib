	year = {2025}
}

@article{11363950,
	abstract = {This experience report describes a series of professional development workshops designed to equip high school educators in Broward County, Florida, with the knowledge and skills to integrate Generative AI ethically into their classrooms. Grounded in Exploring Computer Science principles and AI4ALL frameworks, the workshops emphasized equity, inquiry-based learning, and responsible AI use. Through pre- and post-workshop surveys and qualitative feedback, we documented significant increases in educator confidence and AI literacy. Participants showed marked improvement in understanding AI tools, prompt engineering, and ethical considerations, particularly regarding bias and accountability. The intervention revealed unique insights about Black educators’ experiences with AI integration and the importance of culturally responsive approaches. Key takeaways include the need for differentiated professional development tracks, sustained support systems, and explicit attention to racial equity in AI education initiatives.},
