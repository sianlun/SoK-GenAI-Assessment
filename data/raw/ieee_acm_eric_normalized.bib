}

@article{11328433,
	abstract = {This Work-In-Progress research paper introduces the concept of micro-recruiting which leverages micro-credentials to initiate the job placement process. Micro-recruiting refines traditional job placement by actively pairing employers with appropriately badged learners, rather than relying on undirected employee searches. We investigate the feasibility of using micro-credentials as input to Generative AI (GenAI) for skill-to-job mapping facilitated by locally-hosted Large Language Models (LLMs). The AchieveUp micro-credentialing framework operates in three stages: AI-assisted tagging of achievable skills based on course content, tagging test bank questions with corresponding skills for fine-grained skill analysis, and dispersing badges to recipients who feature them in job applications and on LinkedIn. These stages have been implemented in a required undergraduate Computer Engineering course over nine semesters. We extend AchieveUp to a fourth stage using GenAI to connect badged learners to job opportunities. Development involved leveraging five LLMs to generate search queries aligning students' skills with job opportunities using the Adzuna API. The API returns job listings, organized into a JSON file and fed into the LLM, which identifies the most suitable matches for students. The recommended job descriptions and links are presented to students, providing actionable career insights. For example, the Llama 3.3 model generated 287 Adzuna job title queries paired with nine micro-credential skill badge names, fetching 29 local jobs. Llama 3.3 identified three jobs matching skills in memory capacity, digital signal communication, and datapath design. By invoking GenAI, AchieveUp aims to enhance grading paradigms with micro-credentials and link academic achievements to workforce demands.},
	affiliations = {},
	author = {Amoruso, Paul and Campbell, Laurie O. and DeMara, Ronald F.},
	author_keywords = {Industries; Social networking (online); Generative AI; Engineering profession; Large language models; Jobs listings; Tagging; Higher education; Industry Involvement; Computing skills},
	doi = {10.1109/FIE63693.2025.11328433},
	issn = {2377-634X},
	journal = {2025 IEEE Frontiers in Education Conference (FIE)},
	keywords = {},
	number = {},
	pages = {1-5},
	source = {Scopus},
	title = {WIP: Progressing from Micro-Credentialing to Micro-Recruiting: Connecting Employers with Ideally-Badged Learners via Last-Stage Invocation of GenAI},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11328493,
	abstract = {This work-in-progress innovative practice paper presents a novel methodology to integrate generative AI in undergraduate software engineering education. This approach has been adopted in survey courses at multiple institutions and shows substantial promise in teaching software design and modeling concepts using the Unified Modeling Language (UML). Adoption of AI tools based on large language models in undergraduate courses has grown since their introduction. Despite much promise and potential, the capabilities of such tools are still limited with respect to software design. These limitations should not be seen as a hindrance to classroom use. Rather, they can be beneficial in an educational setting. Our experience suggests that augmenting design modeling activities with generative AI can improve student achievement for both in-person and online delivery formats.},
