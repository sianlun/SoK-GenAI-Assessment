	journal = {2025 IEEE 16th International Conference on Cognitive Infocommunications (CogInfoCom)},
	keywords = {},
	number = {},
	pages = {000031-000036},
	source = {Scopus},
	title = {Engineering Students’ Emotional Engagement with Generative AI in the Learning Process},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11234526,
	abstract = {Accurately grading student-created diagrams, such as flowcharts, remains a core challenge in STEM education because automated tools must evaluate both structural correctness and logical coherence. Conventional approaches based on text-matching heuristics, OCR pipelines, or large language models often miss the nuanced dependencies that link diagram components and can penalize valid alternative representations. To overcome these limitations, graph-based frameworks transform diagram elements into knowledge graphs, enabling more rigorous verification of logical relationships and revealing inconsistencies that text-only methods overlook. Reinforcement learning strategies further enhance assessment by continuously fine-tuning evaluation criteria through reward-driven feedback loops. By combining graph analytics, adaptive learning, and knowledge distillation, hybrid systems promise greater scalability, higher grading precision, and richer feedback for students. This review maps the evolution of diagram assessment techniques from heuristic and LLM-powered grading to graph-driven and reinforcement learning models and highlights future research directions for building more robust and scalable automated grading frameworks in STEM education.},
	affiliations = {},
	author = {Kumar, R Keertish and N, Nanditha and Reddy, M Esha and Faizal, Mohamed and Praveen, M Shahina},
	author_keywords = {Flowcharts; Strips; Reviews; Shape; Optical character recognition; Reinforcement learning; Knowledge graphs; Transforms; Turning; Cognition; Diagram-based assessment; Flowchart grading; STEM education evaluation; Logical structure analysis; Graph-based verification; Adaptive feedback systems; educational technology tools; Machine learning assessment; Knowledge graph reasoning; Reinforcement learning evaluation},
	doi = {10.1109/ICCAMS65118.2025.11234526},
	issn = {},
	journal = {2025 2nd International Conference on New Frontiers in Communication, Automation, Management and Security (ICCAMS)},
	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {Automated Diagram Evaluation in STEM Education: A Review of Current Challenges and Emerging AI-Driven Solutions},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11252529,
	abstract = {The integration of generative artificial intelligence (AI) into educational assessment has shown potential in addressing inefficiencies in traditional evaluation methods, particularly in time-constrained STEM classrooms. This study proposes a hybrid framework that synergizes teacher expertise with generative AI to streamline the evaluation of verbal skills-a critical yet underexplored competency in STEM education. By focusing on collaborative dialogue, problemsolving explanations, and conceptual reasoning, this research aims to develop a system that enhances assessment efficiency while preserving the nuanced judgment of educators. Verbal skill evaluation in STEM contexts-such as assessing students’ ability to articulate hypotheses, defend solutions, or collaborate in technical discussions-remains labor-intensive and subjective. Teachers spend significant time analyzing spoken or written responses, often sacrificing opportunities for personalized instruction. While generative AI model proficiency in language processing standalone using in education raises concerns: (1) lack of contextual awareness in STEM-specific discourse, (2) potential biases in automated scoring, and (3) displacement of teachers’ formative feedback roles. In this research using a mixed-methods approach was employed across three phases: Framework Development, Pilot Testing, Scalability. By bridging the divide between automation and human judgment, this hybrid framework demonstrates that generative AI need not replace teachers but can instead amplify their capacity to nurture critical verbal skills in STEM. Future work explored by adaptive AI tutoring systems that leverage this model to provide real-time dialogue support during student presentations or group discussions.},
	affiliations = {},
	author = {Danang Arengga, W and Sendari, Siti and Herwanto, Heru Wahyu and Mukaromah and Setyowati, Aan Anjar and Setumin, Samsul},
	author_keywords = {Generative AI; Scalability; Education; Collaboration; Focusing; Hybrid power systems; Real-time systems; Creativity; STEM; Testing; Hybrid framework; AI-based evaluation; verbal skill assessment; STEM education; generative AI},
	doi = {10.1109/ICEEIE66203.2025.11252529},
	issn = {},
	journal = {2025 9th International Conference On Electrical, Electronics And Information Engineering (ICEEIE)},
	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {Teacher-AI Collaboration: A Hybrid Framework for Streamlining Verbal Skill Evaluation in STEM Education Using Generative AI},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11256211,
	abstract = {Traditional approaches to resource sharing, primarily via email or static repositories, pose challenges in accessibility and continuity of learning. The integration of a curated course webpage with the institutional digital library was explored to form a Digital Learning Library Platform (DLLP), to centralize delivery of learning material and provide easy access to relevant scholarly resources. This centralized digital learning environment was introduced as a single access point for course notes, reference papers, assignments, and multimedia resources, aiming to streamline the learning experience. The project aimed to assess whether such a platform enhances student engagement, improves resource access, and supports learning outcomes better than traditional delivery methods. The approach was evaluated using platform usage reports, course assignments, and examination results. Analysis of student outcomes shows that students who actively used DLLP generally performed better on assignments and exams. There was also a clear improvement in student outcomes before and after the implementation of DLLP. Indirect assessment was carried out through a structured survey with Likert scale and open-ended questions, evaluating students' experiences with the platform and the use of other AI tools, as well as direct student interactions. Survey results indicated that most of the students found DLLP helpful for accessing materials, with a majority favouring it over email-based delivery. Although many students used generative AI tools, their responses revealed that AI-generated content often lacked the depth and academic alignment provided by a curated academic source. Students expressed a strong preference for mobile accessibility and requested features such as instant feedback on assignments. The centralized digital platform was found to enhance engagement, resource access, and learning quality in a technical educational context.},
	affiliations = {},
	author = {Punnoose, Naveen John and Mathew, M.D. and Baxi, Viplav},
	author_keywords = {Surveys; Generative AI; Ecosystems; Streaming media; Turning; Libraries; Trajectory; Engineering education; Socioeconomics; Standards; student engagement; digital library; academic resource access; learning outcomes},
	doi = {10.1109/WEEF-GEDC66748.2025.11256211},
	issn = {2837-5025},
	journal = {2025 World Engineering Education Forum - Global Engineering Deans Council (WEEF-GEDC)},
	keywords = {},
	number = {},
	pages = {1-7},
	source = {Scopus},
	title = {Enhancing Student Engagement Through a Curated Digital Learning Library Platform},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11256231,
	abstract = {In the era of generative artificial intelligence (GenAI), traditional assessment practices in engineering education face new challenges, particularly in verifying student authenticity and fostering deep learning. This study proposes a Speech and Language Analysis (SLA) framework for evaluating student-produced video presentations as a resilient and pedagogically meaningful alternative. Drawing on five analytic dimensions-clarity, accuracy, critical thinking, engagement, and originality-the study analyzes final-year engineering students' video submissions using both transcript-based linguistic markers and live speech delivery cues. Results show that structured video presentations promote higher-order thinking, reflective articulation, and expressive communication. The integration of manual rubric scoring with natural language processing techniques provides educators with diagnostic insights and scalable evaluation tools. Findings support the use of video-based coursework as a viable strategy for fostering student ownership, safeguarding academic integrity, and enhancing communication skills in technical disciplines. The study concludes with practical recommendations for embedding SLA-informed video assessments into engineering curricula as part of future-ready, AI-resilient pedagogical design.},
