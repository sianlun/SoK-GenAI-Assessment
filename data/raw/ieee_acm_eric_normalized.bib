@article{11430745,
	abstract = {Generative Artificial Intelligence (GenAI) has become a key driver of the digital era, transforming creativity, productivity, and knowledge across sectors such as business, healthcare, education, and culture. Evolving from an experimental field into a pillar of the Fourth Industrial Revolution, GenAI systems—based on architectures like transformers, diffusion models, and generative adversarial networks—can generate human-like text, images, videos, and simulations. While these capabilities enable personalization, automation, and innovation, they also raise significant ethical and societal concerns, including bias, privacy violations, misinformation, and unequal access, which may undermine public trust if unaddressed.This paper argues that the future of GenAI should not be shaped solely by technical advances, but by ethical innovation that embeds responsibility, inclusivity, and sustainability into its design, deployment, and governance. Drawing on recent work in AI governance and digital transformation, the study proposes a multidimensional framework to examine GenAI as both a catalyst for progress and a source of risk. Through case studies in education, healthcare, and business, it examines how societies can responsibly harness generative AI to support inclusive and sustainable futures while mitigating its associated harms.},
	affiliations = {},
	author = {AbuEid, Aws I. and Jazzar, Moneef M.},
	author_keywords = {Ethics; Technological innovation; Privacy; Generative AI; Education; Medical services; Transformers; Sustainable development; Business; Videos; Generative Artificial Intelligence; AI Ethics; Artificial Intelligence; AI Regulation; Ethical AI Framework},
