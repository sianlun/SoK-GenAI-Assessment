	pages = {987–993},
	source = {Scopus},
	title = {Smart Teaching Assistant Empowers Engineering Foundational Courses: The Application of Generative Artificial Intelligence in Signals and Systems Education},
	type = {Book chapter},
	volume = {},
	year = {2026}
}

@article{10.1145/3802133.3802301,
	abstract = {As Generative Artificial Intelligence (GenAI) transforms industries, including tourism and hospitality, there is an urgent demand for professionals with both domain expertise and digital proficiency. However, traditional tourism curricula often lack systematic AI training, creating a digital divide for non-STEM students who face cognitive barriers when approaching technical AI courses designed primarily for computer science majors. This paper addresses this gap by proposing a specialized AI Literacy curriculum framework grounded in the TPACK (Technological Pedagogical Content Knowledge) model, specifically tailored for undergraduate Tourism Management majors. This research advances computer technology in education through three computational innovations: (1) a formalized algorithmic instructional model that transforms pedagogical principles into reproducible computational workflows using iterative feedback loops for mastery-based learning (Algorithm 1), (2) a quantitative competency assessment framework employing multi-dimensional weighted evaluation for objective measurement of AI literacy development (Equation 1), and (3) a data-driven curriculum optimization system validated through systematic pre-post statistical analysis. The curriculum integrates theoretical cognition, practical tool application (including ChatGPT, Midjourney, and other GenAI tools), and ethical reflection into a 32-hour hybrid course structure combining lectures and laboratory practice. Through systematic evaluation including pre-post survey data (n=87) using validated five-point Likert scales and analysis of student capstone projects ranging from cultural heritage tour designs employing spatio-temporal folding concepts to data-driven niche market analysis targeting Generation Z consumers, this study demonstrates that the proposed framework effectively enhances student capacity to solve complex industry problems using AI tools while fostering human-AI collaboration mindsets. Survey results show 94% of students reported significant confidence gains (pre-course M=2.1, SD=0.8; post-course M=4.3, SD=0.6; paired t-test p&lt;0.001), with 89% reporting reduced technology anxiety. These computational methodologies enable automated curriculum evaluation, algorithmic performance tracking, and data-driven instructional refinement, advancing intelligent educational system design. The findings provide a replicable model for interdisciplinary AI education in liberal arts disciplines facing similar digital transformation challenges.},
	affiliations = {},
	author = {Li, Shengchao},
	author_keywords = {AI Literacy; Algorithmic Learning Models; Computational Assessment Framework; Curriculum Design; Data-Driven Curriculum Optimization; Generative AI Applications; Intelligent Educational Systems; Non-STEM Education; TPACK Framework; Tourism Education},
	doi = {10.1145/3802133.3802301},
	issn = {},
	journal = {Proceedings of the 2026 3rd International Conference on Informatics Education and Computer Technology Applications},
	keywords = {},
	number = {},
	pages = {1050–1058},
	source = {Scopus},
	title = {Constructing an AI Literacy Curriculum for Non-STEM Students: A TPACK-Based Approach in Tourism Management Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3802133.3802305,
	abstract = {STEM education serves as the fundamental approach for cultivating innovative talents, and the significance of strengthening STEM education is even more pronounced in the era of artificial intelligence. Financial Statement Analysis is a core course in the accounting curriculum, primarily aimed at cultivating students' data analysis and problem-solving skills. Nevertheless, traditional courses face challenges in adapting to the requirements of the digital age, and textbook content is difficult to apply in practice. AIGC technology, characterized by robust data processing capabilities and intelligent analysis functions, offers new opportunities for teaching Financial Statement Analysis. This research, grounded in STEM education theory, presents the current situation of AIGC technology and the Financial Statement Analysis writing course and explores teaching reform concepts for the Financial Statement Analysis course in the AI era. The study reveals that by introducing AIGC technology, instructors can design more realistic teaching cases, guide students to use advanced tools for in-depth analysis, address deficiencies in traditional teaching, such as difficulties in data acquisition and limited methods, and enhance students' practical skills and innovative thinking. Through a multidisciplinary approach, the Financial Statement Analysis course can align with STEM education goals, thereby cultivating students' interdisciplinary comprehensive literacy.},
	affiliations = {},
	author = {Gao, Hui and Guo, Ying},
	author_keywords = {AIGC technology; Financial statement analysis; STEM; Teaching reform},
