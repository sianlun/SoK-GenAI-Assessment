	author_keywords = {Modeling; Learning (artificial intelligence); Engineering education; Printing; Design methodology; Conferences; Programming; Timing; Artificial intelligence; Reviews; engineering education; engineering curriculum reform; GenAI assisted education; sequential teaching; lifelong learning; hypotheses; standardization},
