	keywords = {},
	number = {},
	pages = {1-8},
	source = {Scopus},
	title = {BRIDGING Human Expertise and Generative AI in Software Quality: A Study on Code Smell Detection in Software Engineering Education},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11346631,
	abstract = {We present GAGA, a containerized web application for text-to-3D game asset generation designed for game development education. The system integrates text-to-image synthesis, an intermediate point-based 2D editing stage to align diffusion outputs with artist intent, background removal, and imageto-3D reconstruction, exporting assets for Unity and Unreal. Deployed in a university course (n = 11), GAGA was evaluated via post-project surveys, artifact review, and classroom observation. Students reported reduced workload, broader participation, and stronger understanding of asset pipelines and AI-assisted creativity; instructors observed more iteration, clearer design intent, and critiques grounded in tangible intermediates. A Unity prototype, My Little Helper, whose characters, props, and environments were generated end-to-end with GAGA, demonstrates rapid asset creation with meaningful user control. Common issues (e.g., baked-in lighting) are mitigated with a retro-style shader, while automated post-processing addresses format and material and texture problems frequently encountered by novices. GAGA lowers technical barriers, supports project-based learning, and shows how generative tools can shift effort from low-level production toward higher-order design reflection, collaboration, and critique.},
	affiliations = {},
	author = {Li, Tianze and Tim, Troy and Sun, Ruoxin and Ng, Qi Ting and Bhojan, Anand},
	author_keywords = {Surveys; Visualization; Three-dimensional displays; Generative AI; Pipelines; Text to image; Games; Reflection; Virtual prototyping; Image reconstruction; Computer graphics; Computer science education; Diffusion models; Educational technology; Generative AI; Image reconstruction; Image synthesis; Text to image; Virtual prototyping},
