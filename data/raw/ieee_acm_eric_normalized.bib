@article{10.1145/3799457.3799566,
	abstract = {With the rapid development of digital health, artificial intelligence, and medical big data, traditional teaching models in medical information engineering are increasingly unable to meet the demand for cultivating interdisciplinary talent capable of integrating medicine, engineering, and informatics. To address this challenge, this study aims to investigate medical students’ learning needs and influencing factors related to digital health education under the Outcome-Based Education (OBE) framework. A questionnaire survey was administered to 1,049 medical students from multiple disciplines, and the data were analyzed using a Random Forest classification algorithm—a tree-based ensemble machine learning method. The model was used to identify key determinants of students’ willingness to pursue digital health–related careers, supported by feature importance analysis, Receiver Operating Characteristic (ROC) curve evaluation, and probability prediction across student cohorts. The results reveal that year of study, major category, prior informatics-related coursework, and students’ perceptions of OBE and digital skills are the strongest predictors of digital health career intention, with lower-year students showing significantly higher willingness. The findings demonstrate the value of combining OBE pedagogy with machine learning to generate quantitative insights for curriculum reform. This study contributes a data-driven foundation for designing targeted digital health training strategies and highlights the importance of integrating artificial intelligence (AI), interdisciplinary learning, and innovative evaluation mechanisms in the future development of medical information engineering education.},
	affiliations = {},
	author = {Zhang, Haiyang and Li, Siqi},
	author_keywords = {Digital Health Education; Machine Learning–Based Curriculum Reform; Medical Information Engineering; Outcome-Based Education (OBE); Random Forest Algorithm},
