	journal = {2025 IEEE Frontiers in Education Conference (FIE)},
	keywords = {},
	number = {},
	pages = {1-8},
	source = {Scopus},
	title = {Analysis and Evaluation of Gemini for Question Generation in Two Engineering Courses},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11328606,
	abstract = {This full research study explored STEM faculty perspective on the challenges they face in designing assessments and the strategies they used to mitigate its misuse in this new era of Generative artificial intelligence (GenAI). Specifically, the study aims to answer this research question: How do faculty members navigate the challenges of designing assessments in the context of GenAI tools? A qualitative approach was employed to answer our research questions. Semi-structured interviews were conducted with five STEM faculty focusing on their challenges, their approaches, and ethical concerns to safeguarding students against the unethical use of the GenAI tools while designing the classroom assessments. Thematic analysis revealed six major themes: 1) reimagining assessment in the age of GenAI, 2) perceived pedagogical potential of GenAI, 3) navigating ethical uncertainty in AI usage, 4) ambivalence and uneven adoption across faculty, 5) AI and educational equity, 6) envisioning a future-ready assessment culture. This study's findings contributed to the current discussion on the faculty's concerns on the students' unethical use of the GenAI tool while designing assessments. It is expected that this study, in combination with the subsequent studies, could be used to strengthen policies for ethical AI adoption in higher education assessment.},
	affiliations = {},
	author = {Butt, Ahmed Ashraf and Kamal, Syed Ali and Ashraf, Rabia},
	author_keywords = {Ethics; Uncertainty; Navigation; Generative AI; Plagiarism; Focusing; Interviews; Faces; GenAI; STEM; Ethics; Plagiarism},
