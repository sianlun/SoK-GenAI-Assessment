	title = {Massive Open Online Courses (MOOCs) and Micro-Credentials Reshaping the Digital Education Model for Lifelong Learning},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{10.1145/3746469.3746562,
	abstract = {This article uses bibliometric methods to explore the research progress and cutting-edge trends of artificial intelligence (AI) applications in the field of children's education. 177 English literatures selected from Web of science (core set) database were selected as the data sources, and CiteSpace and VOSviewer software were used to analyze the application research of artificial intelligence in the field of children's education in terms of the number of publications, authors, institutions, countries and keywords. The research results indicate that the research in this field is growing exponentially, with a wide range of applications covering special education, teaching systems, AI literacy development, and other aspects, and diverse research hotspots. Countries such as China and the United States lead in the quantity and quality of research, and countries promote the development of technology application through cooperation. In recent years, the research on the combination of AI and children's education, as well as its application in classroom teaching, has become increasingly popular. In the future, artificial intelligence will promote the popularization of personalized education and help children develop comprehensively. This study provides a reference for subsequent academic research and educational practice in this field.},
