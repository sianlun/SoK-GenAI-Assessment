	pages = {946–951},
	source = {Scopus},
	title = {An AI-Driven Teaching Reform Model for Engineering Education: A Case Study of the Android Course},
	type = {Book chapter},
	volume = {},
	year = {2026}
}

@article{10.1145/3799457.3799629,
	abstract = {With the increasing demand for practical skill development in engineering education, traditional assessment methods have become inadequate, as they are often subjective and time-consuming. This research proposes an advanced framework for action recognition and practical skill assessment based on Convolutional Neural Networks (CNN), BiLSTM with an Attention Mechanism, Spatio-Temporal Convolutional Networks (ST-CNN), and Particle Swarm Optimization (PSO). The framework aims to provide real-time, accurate, and automated skill assessments, addressing the growing need for efficient and scalable solutions in education. By leveraging deep learning, this approach aligns with the Sustainable Development Goals (SDGs), particularly Quality Education (SDG 4), by offering accessible, objective, and data-driven solutions that enhance learning outcomes and promote equitable, inclusive, and quality-driven education. Experimental results demonstrate significant improvements in training time, computational efficiency, and assessment accuracy, marking a step forward in modernizing skill evaluation in engineering education.},
	affiliations = {},
	author = {Jiang, Yuying and Luan, Shan and Nardo, Mario Di},
	author_keywords = {Action Recognition; Convolutional Neural Networks; Deep Learning; Practical Skill Assessment; Quality Education},
	doi = {10.1145/3799457.3799629},
