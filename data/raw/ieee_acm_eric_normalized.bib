	title = {Making Software Development More Diverse and Inclusive: Key Themes, Challenges, and Future Directions},
	type = {Article},
	volume = {34},
	year = {2025}
}

@article{10.1145/3713043.3727056,
	abstract = {As global migration makes classrooms increasingly diverse, culturally responsive education has emerged as an effective international approach. Educational materials are best when they leverage students’ cultural backgrounds, but time and resource constraints make creating culturally responsive materials challenging for teachers. Generative AI offers a promising medium for assisting this process, but its potential for helping develop customized educational content remains underexplored. We conducted a one-month case study with five early childhood teachers from predominantly Latine schools who collaborated with generative AI to create science materials. Our findings reveal how teachers maintained agency throughout the process and integrated their pedagogical and cultural expertise while working with AI to suit creative needs. Based on these insights, we propose an initial framework for teacher-AI co-creation of culturally responsive educational materials, emphasizing teachers’ leadership in cultural and pedagogical knowledge and their generative AI literacy, both of which contribute to their effective collaboration with AI.},
	affiliations = {},
	author = {He, Kunlei and Liu, Xuechen and Xu, Ying and Bustamante, Andres S. and Warschauer, Mark},
	author_keywords = {Culturally responsive pedagogy; human-AI co-creation; generative AI},
