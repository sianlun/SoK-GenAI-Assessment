	title = {Practical Solutions for Integrating Generative AI into Modern Engineering Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{11546902,
	abstract = {The teaching of numerical methods is essential in engineering, yet their complexity and the heterogeneity of learning curves hinder mastery, particularly when comparing the Finite Element Method (FEM) with the Finite Difference Method (FDM). To address this challenge, we integrated generative artificial intelligence (AI) as a pedagogical scaffold in a MATLABbased course with two equivalent groups: FDM ($\mathbf{n} \boldsymbol{=} \mathbf{2 8}$) and FEM ($\mathrm{n}=30$), both under the same AI usage protocol and assessment criteria. Over five weeks, we measured accuracy (L2 error), efficiency (time), prompting quality, robustness, documentation, transfer, and AI hallucinations. Mixed-model analyses showed significant reductions in error ($\eta^{2}=0.17, \mathrm{p}<0.001$) and time ($\eta^{2}=0.14, p<0.001$); slopes were steeper for FDM, while FEM exhibited consistent improvements under higher cognitive load. Prompting quality emerged as a predictor of performance $(\rho=-0.41, \quad p<0.05)$. The competency radar revealed complementary profiles; heatmaps showed decreasing hallucination frequency through verification and validation; and the forest plot identified prompting ($\boldsymbol{\beta} \approx-\mathbf{0. 2 8}$) and systematic validation ($\boldsymbol{\beta} \boldsymbol{\approx} \boldsymbol{-} \mathbf{0. 2 2}$) as key factors. We conclude that generative AI, when responsibly applied, accelerates, stabilizes, and diversifies numerical learning, strengthens the instructor's role, and offers a replicable model aligned with Tec21/ABET frameworks and SDG 4: Quality Education.},
	affiliations = {},
	author = {Chim, Adrian Isrrael Tec and Nieto-Jalil, José M. and Alvarez, Jorge and Ibarra-Zarate, David I. and Martínez Huerta, Juan Manuel},
	author_keywords = {Artificial intelligence; Finite element analysis; Modeling; Learning (artificial intelligence); Frequency division multiplexing; Generative AI; Timing; Printing; MATLAB; STEM; Generative Artificial Intelligence; Numerical Methods in Engineering; STEM Education Competencies; Sustainable Development Goal},
	doi = {10.1109/EDUNINE62390.2026.11546902},
	issn = {},
	journal = {2026 IEEE Engineering Education World Conference (EDUNINE)},
	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {Generative AI in FDM and FEM Numerical Methods: Prompting, Validation, and Competency-Based Learning in Engineering Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{11547041,
	abstract = {This paper is a work-in-progress study that explores how Large Language Models (LLMs) can be used to improve automated short-answer grading (ASAG) in handwritten exams. A hybrid e-assessment approach that combines Handwritten Text Recognition (HTR) and LLM-based grading for Spanish short-answer questions is presented. Initial experiments show that LLMs can accurately transcribe and understand handwritten responses. Commercial models performed best overall, but open-source options also showed promising results. Overall, the findings suggest that this first experience with LLMs could make grading more automated and scalable, helping educators manage assessments more effectively in digital and blended learning environments.},
