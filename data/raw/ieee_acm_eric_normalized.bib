	title = {Bridging Traditional Pedagogy and AI Integration: Effects of AI Google Essentials on Writing Assessment Performance},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3789859.3789903,
	abstract = {Automated grading systems play an increasingly vital role in programming education, yet most existing platforms rely on batch-style submissions and delayed evaluation, limiting their effectiveness for formative learning. This paper presents Guided Incremental Grading, a novel system for Java programming assignments that continuously monitors student code and delivers immediate, adaptive feedback. The platform integrates three core components: (1) a live code monitor, built on a web-based editor and JavaParser, which parses source code into Abstract Syntax Trees (ASTs), detects fine-grained changes, and triggers incremental testing upon successful compilation; (2) an incremental test execution engine that leverages custom Javadoc annotations and Java Reflection to dynamically run targeted tests on methods, constructors, and fields, with flexible configuration; and (3) a guidance and feedback generator that combines structural analysis with pedagogical metadata, progressively offering hints, examples, resource links, and partial code revelations. Unlike traditional systems, the proposed framework tightly integrates assessment with instruction, enabling immediate detection of structural errors, missing class members, and faulty logic. Preliminary deployment in an introductory Java programming course demonstrates that the system improves debugging efficiency, increases student confidence, and supports deeper conceptual understanding. By aligning automated grading with the iterative nature of programming practice, Guided Incremental Grading advances the shift from summative evaluation toward continuous, formative learning support.},
	affiliations = {},
	author = {Anotaipaiboon, Weerachai},
	author_keywords = {Adaptive guidance; Automated grading; Incremental testing; Java programming language; Programming education; Real-time feedback},
	doi = {10.1145/3789859.3789903},
	issn = {},
	journal = {Proceedings of the 2025 9th International Conference on Education and E-Learning},
	keywords = {},
	number = {},
	pages = {135–140},
	source = {Scopus},
	title = {Guided Incremental Grading for Java Programming Assignments},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3789859.3789907,
	abstract = {Programming education faces engagement challenges in K-12 settings, particularly as students transition to more complex computational thinking. This mixed-methods quasi-experimental study investigates how generative artificial intelligence (GenAI) impacts Grade 8 students’ engagement in secondary programming education in Mainland China. Seventy students participated in a four-week intervention comparing GenAI-assisted instruction with traditional teacher-led methods. Quantitative analysis using the Student Engagement Instrument revealed significant improvements in cognitive (F=14.826, p&lt;.001) and emotional engagement (F=9.637, p=.003) for the GenAI group, but no statistical difference in behavioral engagement. Qualitative interviews complemented the quantitative findings by revealing an apparent contradiction: students demonstrated new forms of behavioral engagement, such as peer collaboration and independent debugging, that were not captured by the pre- and post-test data. These findings suggest GenAI's potential to transform programming pedagogy while highlighting the need for AI-specific engagement indicators in educational assessment.},
	affiliations = {},
	author = {Ren, Nan-Lan and Tse, Alex W.C.},
	author_keywords = {artificial intelligence in education; generative AI; secondary programming education; student engagement},
	doi = {10.1145/3789859.3789907},
	issn = {},
	journal = {Proceedings of the 2025 9th International Conference on Education and E-Learning},
