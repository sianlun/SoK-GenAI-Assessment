	year = {2026}
}

@article{10.1145/3799457.3799651,
	abstract = {To address the disconnection between web design course teaching, student cognitive development, and industry practical demands, this study proposes a Triple-Dimension Integration (TDI) teaching model integrating technical proficiency, cognitive competence, and industrial adaptability. Taking 88 second-year Network Technology majors at Guangzhou University of Software as research objects, a convergent parallel mixed-methods design was adopted (2024–2025). Quantitative data included course project scores, industry competency tests, and student skill questionnaires; qualitative data came from interviews with 4 teachers, 3 industry experts, and 8 students. To enhance the engineering and empirical rigor, additional mathematical modeling (AHP-Entropy weight method for evaluation index optimization), engineering analysis (enterprise cooperative project case), and multivariate statistical analysis (regression and correlation verification) were incorporated. Results show that the TDI model significantly improves student performance (overall score mean increased from 73.5 to 82.3, p&lt;0.05), enhances industry demand matching rate (from 62% to 89%), and reduces learning barriers (technical application difficulties decreased by 41%). The structural equation model (SEM) verification shows the model's goodness-of-fit (χ²/df=2.31, RMSEA=0.068, CFI=0.92), confirming its validity. The model realizes the organic integration of knowledge teaching, ability training, and industry connection, providing a feasible reform path for web design course optimization in application-oriented universities.},
	affiliations = {},
	author = {Liu, Ming and Li, Yehui},
	author_keywords = {Engineering Analysis; Industry-University Collaboration; Mathematical Modeling; Triple-Dimension Integration; Web Design},
	doi = {10.1145/3799457.3799651},
	issn = {},
	journal = {Proceedings of the 2025 3rd International Conference on Information Education and Artificial Intelligence},
	keywords = {},
	number = {},
	pages = {1184–1192},
	source = {Scopus},
	title = {Triple-Dimension Integration Teaching Model for Web Design Courses: Industry-University Collaboration Oriented Reform and Validation},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3799457.3799657,
	abstract = {Traditional education in IoT wireless communication encounters significant challenges, particularly due to the invisibility of electromagnetic signals and the gap between theoretical knowledge and practical application in industry. While students may grasp Shannon's formula, they often find it difficult to implement Socket codes or configure 5G-NR QoS parameters in real-world contexts. This paper introduces a "Generative AI-Empowered Project Incubation" model, centered around the "5G-NR UAV Logistics System." We restructured the curriculum into a three-stage scaffolding process: (1) Basic Communication Construction, (2) System Integration &amp; Optimization, and (3) Real-world Logistics Application. An enterprise simulation framework is established, wherein the instructor assumes the role of CTO and Generative AI functions as a "Virtual Technical Mentor." This setup facilitates immersive visualization while offering intelligent code scaffolding and advanced troubleshooting support. The results of a comparative study indicate significant pedagogical improvements. The experimental group demonstrated substantial progress in mastering complex communication protocols and configuring QoS parameters. Notably, success rates in challenging Non-Line-of-Sight (NLOS) control tasks and overall project completion increased markedly. Furthermore, the systems developed by students achieved industrial-grade performance concerning latency and packet loss reliability. The proposed model operates as a "Cognitive Amplifier," effectively translating AI convenience into profound engineering capabilities. It significantly enhances students' proficiency in solving complex engineering problems and offers a replicable framework for engineering education reform in the intelligent era.},
	affiliations = {},
	author = {Sun, Hengyi and Yu, Liang and Feng, Xingcan and Zhang, Xiaochen},
	author_keywords = {5G New Radio (NR); Enterprise Simulation; Generative AI; IoT Wireless Communication; Project-Based Learning (PBL); Scaffolding Teaching},
	doi = {10.1145/3799457.3799657},
	issn = {},
	journal = {Proceedings of the 2025 3rd International Conference on Information Education and Artificial Intelligence},
	keywords = {},
	number = {},
	pages = {1221–1227},
	source = {Scopus},
	title = {Generative AI-Enabled Project Incubation Teaching Design and Practice in IoT Wireless Communication Courses: A Case Study of 5G-NR UAV Logistics System},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3799457.3799663,
	abstract = {Artificial intelligence (AI) in higher education is undergoing a fundamental paradigm shift, moving from a focus on “technology application” toward a new era of “human-AI collaboration” in cultivating student creativity. To map the intellectual structure and evolution of this field, we conducted a comprehensive bibliometric analysis of literature published between 2005 and 2025. Our analysis, which included thematic evolution and burst detection, provides robust evidence of this transition: early research was dominated by intelligent tutoring systems and adaptive learning, whereas the current frontier is defined by generative AI, critical thinking, and AI literacy. This evolution signals that AI's role is being redefined from a functional tool to a cognitive partner in the creative process. In response to these findings, we propose the Human-AI Collaborative Creativity Model (HAI-CCM), an integrative theoretical framework that conceptualizes this new paradigm. The study equips educators and policymakers with a critical lens and practical guidance to navigate the challenges and opportunities of generative AI, thereby supporting the co-construction of future-oriented, creative learning ecosystems.},
	affiliations = {},
	author = {Gao, Yiyang and Yang, Tingting and Cao, Lihui and Fang, Xianyun and Ma, Li},
	author_keywords = {Bibliometrics; Artificial Intelligence in Education; Paradigm Shift; Generative Artificial Intelligence; Higher Education; Human-AI Collaboration; Creativity},
	doi = {10.1145/3799457.3799663},
	issn = {},
	journal = {Proceedings of the 2025 3rd International Conference on Information Education and Artificial Intelligence},
	keywords = {},
	number = {},
	pages = {1257–1270},
	source = {Scopus},
	title = {From Tools to Partners: A Bibliometric Analysis of the Paradigm Shift in AI-Supported Creativity Cultivation in Higher Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3799457.3799667,
	abstract = {Against the backdrop of the deep integration of emerging engineering education and artificial intelligence (AI) technology, traditional engineering mathematics teaching faces challenges including disjointed content from practice, outdated computational methods, and lack of personalization. This study constructs a trinity intelligent teaching system of "knowledge graph + AI case library + process-oriented evaluation" for engineering majors at Army Branch University. A typical engineering scenario is used for experimental verification, and AI teaching is added for probability and statistics. Tools like Doubao and DeepSeek enable theoretical visualization, computational automation, and contextualized application. Experimental data show that, compared with the traditional instruction control group, students' engineering problem-solving ability increased by 42.3%, and course satisfaction reached 91.7%. The research indicates that AI empowerment effectively addresses traditional teaching pain points and offers a replicable paradigm for engineering mathematics reform.},
	affiliations = {},
