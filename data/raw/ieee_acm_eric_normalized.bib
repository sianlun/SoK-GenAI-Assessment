	author = {AlJallal, Nourah},
	author_keywords = {Training; Surveys; Productivity; Navigation; Generative AI; Instruments; Encoding; Indexes; Artificial intelligence; Engineering students; AI literacy; engineering education; faculty adoption; student perceptions; academic integrity},
