@article{11269627,
	abstract = {According to the 2022 National Crime Records Bureau, over 172 girls went missing, 170 were kidnapped, and nearly three were trafficked daily in India, with West Bengal and Madhya Pradesh recording the highest incidences. A key driver of child trafficking is lack of education, a problem worsened by the COVID-19 pandemic, which plunged many vulnerable families into poverty. In many cases, families resorted to child labor and early marriages for survival. PACE Learning Center (PLC) in Piyali Junction, West Bengal, has been working to break the cycle through its mission "Educate a girl and you educate a community". PLC provides education and vocational training to over 250 girls from underserved communities. In September 2023, an IEEE humanitarian initiative was launched at PLC through a collaboration between IEEE Region 6 Educational Activities Committee and IEEE Region 10 Kolkata Section SIGHT. The initial phase featured hands-on STEM workshops using TryEngineering.org lesson plans, supported by the IEEE EDS Center of Excellence, Heritage Institute of Technology. Ongoing efforts include teacher training to integrate STEM permanently into PLC’s curriculum. The second phase of the project, launched in early 2025, involves an experimental research study evaluating the role of generative AI, specifically ChatGPT as a learning assistant in hands-on circuit design education. A between-subjects design is being used to compare a control group receiving traditional instruction with an experimental group receiving additional AI-assisted support. Participants complete a final exam and a post-workshop survey assessing learning comfort, confidence, and satisfaction. Preliminary data analysis, including independent samples t-tests, descriptive and inferential statistics, and effect size calculations (Cohen’s d, Cliff’s Delta). This study aims to evaluate the effectiveness of AI-assisted learning in facilitating and enhancing educational outcomes among girls in marginalized communities and to explore scalable interventions for promoting STEM engagement and equity in education.},
