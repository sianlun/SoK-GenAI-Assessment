	journal = {2025 IEEE Frontiers in Education Conference (FIE)},
	keywords = {},
	number = {},
	pages = {1-5},
	source = {Scopus},
	title = {WIP: Guiding, Not Giving: Analyzing the Effectiveness of Guided Problem-Solving in CS1},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11328238,
	abstract = {This work-in-progress paper introduces the PROTECT framework, an innovative methodology designed to safeguard the integrity of PBL in engineering education facing the challenge of the escalating capabilities of artificial intelligence (AI). As AI systems increasingly demonstrate advanced chain-of-thought (CoT) reasoning, code generation, and automated reporting, ensuring that student work genuinely reflects individual effort is paramount. The PROTECT framework, rooted in experiential learning and authentic assessment literature, embeds seven interconnected pillars to ensure authentic student engagement and learning. Personalization tailors project to individual student contexts; Realism incorporates real-world complexities to expose AI's limitations; Originality mandates multimodal deliverables beyond text; Taxonomy (Guided Progression) structures projects to advance through increasing cognitive complexity; Evaluation Diversity employs varied assessment modalities like oral defenses; Constraints establish clear boundaries for appropriate AI use; and Transparency requires students to document and disclose their AI tool usage. This comprehensive approach addresses AI's current limitations, such as its lack of technical depth, multimodality output, or creative problem-solving. Pilot implementations of PROTECT in engineering courses have shown promising results, including increased pass rates, improved student performance, and a significant reduction in AI misuse, with only one AI-generated submission attempt observed among approximately 230 assessments. This framework offers actionable strategies for integrating robust assessment practices into PBL, balancing AI integration with authentic, student-centered learning outcomes. Future work will extend PROTECT across diverse engineering domains, refining evaluation mechanisms and exploring scalable models to mitigate AI misuse.},
	affiliations = {},
	author = {Ma, Xiaoguang and Wu, Yanwei and Roopaei, Mehdi and Wang, Jing},
	author_keywords = {Resistance; Generative AI; Taxonomy; Refining; Cognition; Complexity theory; Problem-solving; Logic; Artificial intelligence; Engineering education; Project-Based Learning; Academic Integrity; Course Assessment},
	doi = {10.1109/FIE63693.2025.11328238},
	issn = {2377-634X},
	journal = {2025 IEEE Frontiers in Education Conference (FIE)},
	keywords = {},
	number = {},
	pages = {1-5},
	source = {Scopus},
	title = {WIP: Protect: a Framework for Preserving Project-Based Learning Integrity in the AI Era},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11328240,
	abstract = {This full research-to-practice paper addresses key challenges in programming education within engineering, particularly the uncritical use of generative AI (GenAI) and its potential to hinder independent learning. It introduces JULIUS, an AI-powered chatbot designed to serve as a virtual tutor in a Fundamentals of Programming course, aiming to enhance technical skills, emotional resilience, and student confidence. Grounded in connectivism and Challenge-Based Learning (CBL), JULIUS promotes autonomy, reduces anxiety, and supports real-world problem-solving through structured group dynamics and tools like Excel and PSeInt. A mixed-methods approach combined quantitative pre- and post-tests with qualitative thematic analysis. Results show significant improvements in conceptual understanding, logical reasoning, motivation, and collaboration. JULIUS also enhanced emotional well-being, metacognition, and teamwork, addressing cognitive and affective learning needs. The findings underscore JULIUS's effectiveness in bridging theory and practice while supporting adaptive and collaborative learning. This research highlights the potential of AI-driven tools to transform engineering education by promoting deeper learning, reducing anxiety, and improving group dynamics, aligning with broader trends in digital transformation and educational innovation.},
	affiliations = {},
	author = {Martinez, Julio R. and Chong, Mario and Maya, Susana and Caicedo, María Alejandra and Luna, Ana},
	author_keywords = {Technological innovation; Heuristic algorithms; Anxiety disorders; Transforms; Metacognition; Market research; Teamwork; Problem-solving; Programming profession; Resilience; E-learning; Challenge Based Instruction; computational thinking; critical thinking},
	doi = {10.1109/FIE63693.2025.11328240},
