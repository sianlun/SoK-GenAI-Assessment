	author_keywords = {Modeling; Testing; Automatic test pattern generation; Printing; Generative Pre-trained transformer; Large language models; Retrieval augmented generation; Artificial intelligence; Question generation; Banking; large language model; retrieval-augmented generation; test paper generation; information technology education},
