@article{11299074,
	abstract = {This study proposes and empirically validates a large-language-model(LLM) driven framework that aligns undergraduate majors and course portfolios with the competency requirements of specific job roles. Using Samsung Electronics’ Device Solutions division as a testbed, we analyzed two highly representative semiconductor positions System LSI circuit-architecture design and R&D Center process-architecture integration because they respectively demand the narrowest and broadest disciplinary scopes in the industry. The 4o LLM was sequentially prompted with structured job descriptions, 6 STEM majors at KAIST, and 248 associated courses. A two-tier evaluation quantified major-level (Level 1) and course-level (Level 2) relevance both before and after Knowledge Injection (KI) of the “Recommended Subject” field in each job description. KI reinforced Electrical Engineering’s dominance in circuit design by + 1.1% total score but markedly broadened multidisciplinary suitability for process integration by + 7.7%. As a result, Mechanical Engineering and Chemistry were elevated into a higher relevance tier according to the evaluation criteria. At the course level, all Recommended Subjects and their advanced courses consistently ranked among the highest within each major, and they were found to be most susceptible to the effects of KI. This confirms their utility as anchors for automated job education mapping. The results demonstrate that KI granularity should mirror role characteristics core-focused for design-centric jobs and dispersive for integration-oriented jobs. Beyond extending LLM use to curriculum design and hiring-fit assessment, the framework offers a scalable pathway for universities, firms, and policymakers to co-engineer evidence-based talent pipelines and mitigate looming bachelor-level workforce shortages in semiconductors.},
	affiliations = {},
	author = {Lee, Hochan and Yi, Sangyoon},
	author_keywords = {Large language models; Engineering education; Electronics industry; Curriculum development; Industries; Chatbots; Research and development; Programming profession; Pipelines; Bibliometrics; Large language model; job assessment; semiconductor education; curriculum design; knowledge injection},
	doi = {10.1109/ACCESS.2025.3643626},
	issn = {2169-3536},
	journal = {IEEE Access},
	keywords = {},
	number = {},
	pages = {214605-214617},
	source = {Scopus},
	title = {Strategic Framework for Evaluating Curriculum-Job Fit via Knowledge-Injected Large Language Models},
	type = {Article},
	volume = {13},
	year = {2025}
}

@article{11304281,
	abstract = {This study examines the utilization of generative artificial intelligence (Gen-AI) tools among engineering students in the U.S.-Mexico border region. Based on a survey targeting students who have used Gen-AI tools at least once, the research examines usage frequency, perceived usefulness, timing of use in academic tasks, awareness of institutional policies, and perceived effects on learning. The results indicate that more than 60% of the respondents use Gen-AI at least weekly, highlighting perceived benefits in efficiency and idea generation, but also revealing a low awareness of institutional guidelines and mixed perceptions regarding its influence on deep learning. These findings complement previous work addressing students' preparedness for Industry 4.0 in the same region and contribute to ongoing discussions on the responsible integration of AI in engineering education.},
