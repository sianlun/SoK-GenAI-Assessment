@article{10.1145/3748825.3748968,
	abstract = {With the rapid development of Generative AI, the field of language education is undergoing profound technology-driven changes. Research has confirmed that AI tools have significantly improved language learning efficiency and equity through personalized learning path design, immediate feedback mechanisms, and multimodal resource supply, but the existing results are fragmented and lack cross-scenario theoretical integration and long-term impact assessment. To this end, using bibliometric methods, combined with CiteSpace and vosviewer tools, this paper systematically analyzes 209 high-quality documents on AI enabled language education in the web of science core database in the past eight years (2017-2025), and draws a knowledge map to reveal research trends and knowledge networks. The results show that the research focuses on three core directions - the application of generative AI (such as ChatGPT) in language skills training and emotional interaction, the optimization of AI-driven automated assessment systems, and the exploration of technology ethics and sociocultural adaptability. It provides a global perspective and empirical basis for the theoretical integration and practical optimization of AI enabled language education.},
	affiliations = {},
	author = {Min, Qishu},
	author_keywords = {Artificial intelligence; Deep learning; English education; Language instruction},
