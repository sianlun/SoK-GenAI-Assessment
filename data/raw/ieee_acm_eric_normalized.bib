	volume = {},
	year = {2025}
}

@article{11039329,
	abstract = {Artificial Intelligence (AI) has emerged as a transformative force in higher education, particularly in STEM disciplines, revolutionizing teaching, learning, and administrative processes. This survey provides a comprehensive overview of AI applications in university education, focusing on large language models (LLMs) and generative AI. Key areas include intelligent tutoring systems, automated grading, adaptive learning platforms, and AI-driven administrative support. While AI offers significant benefits, such as personalized learning and operational efficiency, it also introduces challenges, including ethical concerns, algorithmic bias, and data privacy risks. This paper critically examines these challenges and identifies future directions, such as the integration of generative AI in STEM education, advancements in natural language processing, and the development of explainable and trustworthy AI systems. By synthesizing current research, this survey aims to equip educators, policymakers, and researchers with insights into the evolving role of AI in education and its implications for creating equitable and effective learning environments.},
