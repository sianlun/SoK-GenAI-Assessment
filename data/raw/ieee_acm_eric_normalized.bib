@article{11304842,
	abstract = {Large language models (LLMs) are increasingly integrated into educational contexts, particularly for the automated assessment of problem-solving and reasoning tasks. Their capacity to generate answers and explanatory feedback at scale makes them attractive for engineering education, but inconsistency, bias, and limited reproducibility remain major concerns. To address these limitations, this paper reports on the application of CourseEvalAI, a rubric-guided evaluation framework designed to ensure transparency and comparability in automated scoring.The framework was applied to a dataset derived from a university-level course in artificial intelligence. Two configurations of the Mistral-7B model were investigated: the baseline version and a LoRA-adapted variant fine-tuned on course-specific data. Model outputs, consisting of answers and explanations, were evaluated by GPT-4 using rubric-based criteria across technical, argumentative, and explanation dimensions. Prior work has shown that GPT-4 achieves results comparable to human evaluators, supporting its use as an expert proxy in this context.Experimental validation demonstrates that CourseEvalAI enables fine-grained analysis of model behavior, detecting scoring drift, rubric-specific improvements, and inter-model performance differences. By integrating structured rubrics, expert evaluation, and graph-based storage, the framework enhances transparency and reproducibility. The approach shows direct applicability in electrical and electronics engineering, automation, and computer science, offering a robust methodology for reliable and interpretable automated assessment.},
	affiliations = {},
	author = {Anghel, Catalin and Craciun, Marian Viorel and Pecheanu, Emilia and Cocu, Adina and Istrate, Adrian and Anghel, Andreea Alexandra},
	author_keywords = {Computer science; Databases; Large language models; Reliability engineering; Reproducibility of results; Robustness; Data models; Problem-solving; Engineering education; Context modeling; large language models; LoRA fine-tuning; rubric-guided scoring; Neo4j graph database; automated assessment},
	doi = {10.1109/ISEEE67817.2025.11304842},
	issn = {},
	journal = {2025 9th International Symposium on Electrical and Electronics Engineering (ISEEE)},
	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {Rubric-Guided Evaluation Framework for Consistent Scoring with Large Language Models},
	type = {Conference paper},
	volume = {CFP2593K-ART},
	year = {2025}
}

@article{11311457,
	abstract = {Short-answer questions are commonly used in educational assessments, as they are often viewed as a more effective way than multiple-choice questions to determine whether students have achieved the intended learning outcomes. However, manually creating appropriate questions targeting different cognitive levels such as those defined by the Bloom’s Taxonomy, and grading text answers from students are not trivial tasks for instructors. Existing work on auto-question generation and scoring in computing education typically targets coding-based questions. However, in software engineering courses, assessments can extend beyond coding to understanding of processes, DevOps methodologies, system design, etc. This work aims to address the dual problem of auto-generating and auto-scoring text based short-answer questions in software engineering courses. We propose an agent-based approach to question generation and scoring, in which each agent performs a distinct task and communicates with each other to complete its tasks. An agent can be realized using a selected large language model (LLM). To this end, we have implemented the proposed approach into a fully functional web app, utilizing OpenAI’s GPT-3.5 and GPT-4o models, which was deployed to support instructors and students in our course. We conducted a thorough evaluation of the agent-based approach using several public and private datasets. The results demonstrated the effectiveness of our approach. Among other insights, we observed that the LLM agents are good at generating questions at Bloom’s cognitive levels of Remember, Understand, Apply, and Analyze; and are good at scoring students’ answers when provided with 3 or more actual examples of human scoring.},
	affiliations = {},
	author = {Duong, Ta Nguyen Binh and Shar, Lwin Khin},
	author_keywords = {Software engineering; Question generation; Taxonomy; Encoding; Electronic mail; Training; Programming profession; Large language models; Information systems; Hands; Agent based systems; large language models; short-answer questions; auto-scoring; question generation},
	doi = {10.1109/ACCESS.2025.3647111},
	issn = {2169-3536},
	journal = {IEEE Access},
	keywords = {},
	number = {},
	pages = {215804-215821},
	source = {Scopus},
	title = {GenScore: Agent-Based Short-Answer Question Generation and Scoring in Software Engineering Courses},
	type = {Article},
	volume = {13},
	year = {2025}
}

@article{11311879,
	abstract = {Microcontroller education is shifting from syntaxfocused programming to engineering reasoning under real constraints. We report a five-week, project-based and cooperative learning module using ESP32 with Arduino, where generative $\mathbf{A I}$ is allowed as guided scaffolding under mandatory traceability and individual oral verification. Two independent cohorts ($n=14$ and $n=15; N=29$) worked in triads with rotating roles and evidence boards. Summative assessment combined public prototype demonstration (50 percent) and individual viva (50 percent), while structured peer assessment supported accountability. The overall mean grade was 75.54 (SD 14.61); cohort means were 77.45 and 73.75, with a small between-cohort difference (Cohen d about 0.25). The approval rate was 72.4 percent. Peer assessment averaged 0.917 and correlated strongly with grades ($r$ about 0.78 overall; 0.85 and 0.69 by cohort), indicating alignment between recognized contributions and summative performance. Student perception was high and homogeneous across teaching, guidance, environment, expertise, and challenge. We conclude that integrating traceable generative AI with product-viva-peer assessment can accelerate learning in short blocks without compromising validity, offering a replicable design for instrumentation and control courses. The study provides pedagogical insights into how GenAI-supported PBL can enhance engineering reasoning and accountability. It contributes an evidence-based design model that integrates authentic assessment, cooperative learning, and AI literacy for modern engineering education.},
	affiliations = {},
	author = {Pozos, Jose Manuel Medina and Nieto-Jalil, Jose M.},
	author_keywords = {Technological innovation; Sensitivity; Generative AI; Microcontrollers; Federated learning; Instruments; Prototypes; Cognition; Engineering education; Programming profession; educational innovation; higher education; projectbased learning; arduino; embedded systems education; oral assessment; peer assessment; instrumentation and control; humanAI},
	doi = {10.1109/ENC68268.2025.11311879},
	issn = {2332-5712},
	journal = {2025 Mexican International Conference on Computer Science (ENC)},
	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {Educational Integration of ESP32 Project-Based Learning with Generative AI: Design, Implementation, and Evaluation in Two Engineering Cohorts},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11319042,
	abstract = {Artificial intelligence (AI) is transforming engineering education through technologies. These include intelligent tutoring systems, generative AI, adaptive learning platforms, and virtual teaching assistants. However, despite growing interest in AI-driven tools, the field lacks a comprehensive synthesis of how it is changing the engineering classrooms, indicating a gap in the literature. To address this, we conducted a narrative review of recent studies, aiming to map its pedagogical impacts, opportunities, and challenges. Our analysis identified major thematic areas such as personalized learning, generative and adaptive tools, curriculum and policy evolution, and ethical frameworks to accommodate AI. Collectively, these findings underscore a key message of its potential to augment engineering pedagogy by improving learning experiences and efficiency, but realizing this promise requires thoughtful integration and oversight. This review contributes to the field of engineering education and educational technology by guiding educators and policymakers in harnessing AI to elevate teaching and learning.},
	affiliations = {},
