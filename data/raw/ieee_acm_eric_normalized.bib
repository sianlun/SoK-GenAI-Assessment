	author = {Xie, Wenyi and Shi, Haojie and Li, Yixuan and Liu, Junwei},
	author_keywords = {Adaptive Learning; Large Language Models; Programming Education; Pedagogical Scaffolding; Human-Computer Interaction; Formative Evaluation},
