@article{10.1145/3708394.3708446,
	abstract = {This study aims to explore the construction of an efficient model for building a "dual-qualified and dual-capable" teacher team to enhance the quality of teachers and talent cultivation in applied undergraduate education. Through qualitative analysis using classic grounded theory, this study synthesized relevant construction documents from 63 applied undergraduate colleges and proposed a multi-level, multi-mechanism teacher team construction model. The model consists of three levels: basic level, core level, and support guarantee level; and covers five key mechanisms: admission, cultivation, introduction, incentive, and supervision. The study revealed the foundational role of the admission mechanism in ensuring the quality of the teacher team, while emphasizing the importance of the cultivation and introduction mechanisms in maintaining team development. In addition, the incentive and supervision mechanisms play a crucial supporting role in team stability and performance improvement. This study also provides a mechanism for building a "dual-qualified and dual-capable" teacher team based on AI technology. The findings of this study provide theoretical basis and practical guidance for the construction of teacher teams in applied undergraduate colleges, and are of great value in promoting educational reform and improving teaching quality.},
	affiliations = {},
	author = {Shi, Yanping and Wu, Huajun},
	author_keywords = {AI technology; applied undergraduate colleges; classic grounded theory; dual-qualified and dual-capable teacher},
	doi = {10.1145/3708394.3708446},
