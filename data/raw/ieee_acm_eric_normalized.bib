	title = {Relief or displacement? How teachers are negotiating generative AI's role in their professional practice},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3772318.3791940,
	abstract = {Generative chatbots promise to scale personalized learning. Most publicly available generative chatbots are designed to provide confident and eloquent responses by default, even when hallucinating. Prior work has observed that learners using such chatbots often engage shallowly and fail to detect chatbot errors due to overtrust, cognitive overload, and prioritization of short-term gains. To address these challenges, this work examines two chatbot design options in a STEM learning context: introducing verbal uncertainty and reducing response verbosity. Using Bayesian causal inference and thematic analysis in a quasi-experimental setting, we found that a less verbose chatbot improved detection of errors with logical fallacies, but did not increase the use of alternative resources. A chatbot that always expressed uncertainty reduced the adoption of incorrect chatbot responses, but had mixed effects on learning outcomes, suggesting the need to increase signal credibility and maintain learners’ engagement in the learning process despite chatbot disuse.},
	affiliations = {},
	author = {Li, Tiffany Wenting and Song, Yifan and Sundaram, Hari and Karahalios, Karrie},
	author_keywords = {Pedagogical chatbots; Generative AI; STEM education; Error detection; Cognitive Engagement; Uncertainty; Verbosity; Trust},
	doi = {10.1145/3772318.3791940},
	issn = {},
	journal = {Proceedings of the 2026 CHI Conference on Human Factors in Computing Systems},
	keywords = {},
	number = {},
	pages = {},
	source = {Scopus},
	title = {Supporting Learners' Use of Imperfect Generative Pedagogical Chatbots: The Role of Chatbot Response Uncertainty and Reduced Verbosity},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3772318.3793207,
	abstract = {As AI-assisted coding becomes standard in software development, computer science educators need a clearer understanding of how Large Language Models (LLMs) can support the learning process. Recent work has examined how students can benefit from using LLMs in their courses, but most studies rely on self-reported usage or controlled experiments with short, isolated programming tasks. To complement these approaches, this paper investigates how students organically leverage LLMs in an advanced computer science course where assignments reflect real-world complexity. We analyze 448 LLM chat logs from 147 students across two offerings of a senior-level web programming course at a large U.S. research university. Through open coding, we identified 14 distinct prompt–response pair types that cluster into three categories: to generate code, debug code, and explain programming concepts. Our analysis reveals that how students interact with LLMs correlates with academic performance. High-effort detailed specifications for code generation positively correlated with final grades (r = 0.25, p &lt; 0.01), whereas low-effort behaviors such as pasting raw error messages showed negative correlations (r = −0.34, p &lt; 0.01). We also observed a temporal shift toward explanation-oriented interactions, suggesting that students increasingly use LLMs as conceptual tutors and not just as code generators.},
	affiliations = {},
	author = {Isa, Hajara-Yasmin and Weston, Matthew and Wellyanto, Muhammad Rizky and Karna, Ishita and Talton, Jerry O. and Kumar, Ranjitha},
	author_keywords = {large language models; computer science education; programming education; prompt engineering; web programming},
	doi = {10.1145/3772318.3793207},
	issn = {},
	journal = {Proceedings of the 2026 CHI Conference on Human Factors in Computing Systems},
	keywords = {},
	number = {},
	pages = {},
	source = {Scopus},
	title = {From Code Generation to Conceptual Learning: Student Use of LLMs in a Web Programming Course},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3772318.3793705,
	abstract = {Mixed reality (MR) and AI-powered pedagogical agents have been increasingly explored in STEM labs context as a means of providing hands-on practice with virtual teaching assistants. However, teaching microelectronics presents unique challenges because learners must integrate conceptual knowledge, procedural skills, and visual–spatial understanding to reason about multilayer chip structures and how fabrication processes optimize performance. We introduce ChipXR, a mixed-reality learning environment developed through a design-science approach and multistakeholder participatory design involving instructors, teaching assistants, students, education researchers, and HCI researchers to systematically refine interaction design and reduce potential cognitive load. The final prototype integrates interactive lecture modules for conceptual understanding, embodied MR activities for procedural skill development, and a LEGO-based building task to foster visual–spatial reasoning, all supported by a GPT-powered agent that explains the principles behind each activity. In a controlled study comparing MR+AI agent, MR-only, and traditional video-based lecture, we found no significant differences in conceptual quiz scores, but the MR+AI condition showed trends associated with visual–spatial understanding and perceived knowledge gains. A deployment in an introductory advanced semiconductor packaging course, supplemented by think-aloud sessions and focus groups, further contextualizes these findings. Together, these results suggest how MR+AI systems can be purposefully orchestrated to target complementary knowledge types and inform the design of future microelectronics curricula and other complex STEM domains requiring conceptual, procedural, and spatial reasoning.},
	affiliations = {},
	author = {Cheon, Serene and Stanbury, Austin J. and Arjunamahanthi, Pavanbabu and Kottur, Himanandhan and Kang, Hyo},
	author_keywords = {Extended Reality; STEM Education; AI Agent},
	doi = {10.1145/3772318.3793705},
	issn = {},
	journal = {Proceedings of the 2026 CHI Conference on Human Factors in Computing Systems},
	keywords = {},
	number = {},
	pages = {},
	source = {Scopus},
	title = {Learning Inside the Chip: A Design-Science Approach to Developing MR Lab and an AI Agent for Conceptual, Procedural, and Spatial Understanding in Microelectronics Education},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3772326.3772335,
	abstract = {Generative Artificial Intelligence (GenAI) technology, which empowers the construction of structured semantic knowledge bases via knowledge graphs, is key to solving the problem of knowledge fragmentation in online open courses, particularly within engineering education domains characterized by complex skill chains like Integrated Circuit (IC) design. Using a national-level online course in a relevant engineering field as a case study, this research proposes a framework for the construction and application of knowledge graphs empowered by GenAI. We employed a sequence labeling method based on pre-trained language models (e.g., Bidirectional Encoder Representations from Transformers, BERT) and utilized graph neural networks (e.g., Graph Convolutional Network, GCN) for semantic validation and relation inference on the extracted triplets to build the knowledge graph. Experimental results demonstrate that the student group using the knowledge graph for personalized learning paths, tailored to individual skill progression, achieved an average course pass rate 15.3% higher than the control group (p &lt; 0.01). The intelligent Q&amp;A system achieved an accuracy of 94.2% in answering domain-specific questions, effectively reducing the teaching burden of answering queries. Through theoretical analysis and practical guidance, this study provides a reference for promoting the intelligent development of online open courses.},
	affiliations = {},
	author = {Qiao, Yifang and Peng, Kanghua and Shi, Jincheng},
	author_keywords = {Engineering Education; Generative AI; Integrated Circuit Design; Knowledge Graph; Skill Training},
	doi = {10.1145/3772326.3772335},
