@article{10.1145/3748495.3704731,
	abstract = {Microlearning delivers focused learning experiences that improve knowledge retention and engagement by breaking complex topics into small, manageable units. By reducing cognitive load and minimizing distractions, learners can absorb and apply information quickly, aligning with modern attention spans and supporting just-in-time learning. It's ideal for addressing skills and knowledge gaps without overwhelming learners. Generative AI tools support microlearning by rapidly creating concise, targeted content. This article provides several definitions of microlearning and includes an example of a microlearning unit created with generative AI.},
