	year = {2026}
}

@article{10.1145/3777730.3777756,
	abstract = {Forgetting is the complementary process to memory, enabling both biological and artificial systems to prioritize relevant information while discarding outdated or redundant data. In large language models (LLMs), forgetting occurs through computational mechanisms such as attention bottlenecks, catastrophic interference, and optimization dynamics, mirroring neurobiological processes such as synaptic decay and memory consolidation. While existing research has extensively studied memory mechanisms in LLMs, there remains a critical gap in systematically analyzing forgetting phenomena and their implications for AI system design. This study presents a comprehensive review of forgetting mechanisms in LLMs through a neuroscience-inspired lens. This study first establishes parallels between human forgetting processes and computational forgetting patterns in LLMs. Building on these foundations, this study proposes a novel taxonomy that classifies LLM forgetting across four key dimensions. This taxonomy is further supported by the introduction of quantitative evaluation metrics to provide additional evidence. Furthermore, this study demonstrates how controlled forgetting can be transformed from a limitation into a design feature through bio-inspired optimization strategies. These approaches enable critical applications in privacy-compliant AI, adaptive education systems, and sustainable computing. The study concludes by identifying open challenges in generalization, ethical governance of machine forgetting, and computational efficiency, while outlining future directions for developing LLMs with human-like memory adaptability.},
	affiliations = {},
	author = {Xie, Yuchen},
	author_keywords = {AI-driven LLM; Bio-Inspired AI; Forgetting Mechanisms; Memory Management; Neuroscience and AI},
	doi = {10.1145/3777730.3777756},
	issn = {},
	journal = {Proceedings of the 2025 International Conference on Artificial Intelligence, Virtual Reality and Interaction Design},
	keywords = {},
	number = {},
	pages = {153–161},
	source = {Scopus},
	title = {Bio-Inspired LLMs Forgetting: Integrating Neuroscience and Computational Mechanisms},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3777904,
	abstract = {Learning to program a new language presents persistent challenges such as debugging, program design and understanding advanced programming concepts, all of which contribute to high dropout rates and learning difficulties. Meanwhile, the emergence of Large Language Models (LLMs) like ChatGPT introduces new dimensions in programming education, offering personalised and interactive learning experiences that could mitigate traditional learning challenges. This study investigates students’ perceptions of programming learning difficulties before and a year after the release of ChatGPT. Through self-reported surveys, the study examines differences in perceived difficulties, evaluates the role of learning materials, including ChatGPT, and explores correlations between students’ perceptions of fairness, trust and effectiveness of ChatGPT and their programming learning difficulties. Findings confirm that even in the era of ChatGPT, the challenges associated with learning programming are complex and continue to be deeply linked to understanding programming concepts, learning situations and learning materials. There was no gender difference in programming learning difficulties, while students concerned about plagiarism from ChatGPT reported more programming learning difficulties. Students who trust ChatGPT report higher perceived effectiveness of its use in learning. These findings highlight the potential of ChatGPT to complement traditional learning resources while emphasising the importance of foundational skills and ethical guidelines. Educators and policymakers must consider these findings to develop programming curricula that leverage technological advancements and address the persistent challenges that hinder student programming learning.},
	affiliations = {},
	author = {Bikanga Ada, Mireilla},
	author_keywords = {Programming education; Novice programming difficulties; ChatGPT; student perceptions; higher education; computer science education},
	doi = {10.1145/3777904},
	issn = {},
	journal = {ACM Trans. Comput. Educ.},
	keywords = {},
	number = {2},
	pages = {},
	source = {Scopus},
	title = {Programming Challenges and Perceptions: A Study of Separate Groups before and after the Release of ChatGPT},
	type = {Article},
	volume = {26},
	year = {2026}
}

@article{10.1145/3777911.3800643,
	abstract = {Performance engineering education traditionally relies on analytical models supported by specialized queueing solvers. While effective, this approach creates strong tool dependencies and limits opportunities for qualitative reasoning when solvers are unavailable, difficult to maintain, or inappropriate for exploratory learning. This position paper argues that Model Interchange Formats (MIFs), combined with recent advances in Artificial Intelligence (AI), enable a solver-independent approach to teaching performance engineering. Our experience has been specifically grounded in the use of PMIF+ (Performance Model Interchange Format), one instance of a Model Interchange Format, which provides a structured yet solver-agnostic representation of Queuing Networks based models. Rather than replacing analytical methods, AI can act as a pedagogical assistant that supports reasoning, interpretation, and exploratory analysis of MIF-based performance models. We discuss what this approach enables, where it fails, and its implications for performance engineering education.},
	affiliations = {},
	author = {Lladó, Catalina M.},
	author_keywords = {performance evaluation; tools; academia; teaching; ai},
	doi = {10.1145/3777911.3800643},
	issn = {},
	journal = {Companion of the 17th ACM/SPEC International Conference on Performance Engineering},
	keywords = {},
	number = {},
	pages = {115–119},
	source = {Scopus},
	title = {Can We Teach Performance Engineering Using Model Interchange Formats and AI?},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3778534.3778583,
	abstract = {This study is based on the practical application of artificial intelligence technology in the higher education industry, aiming to assist in reconstructing the "dual-qualified" teaching literacy system for vocational college teachers. By conducting an in-depth analysis of the current development status of AI technology and fully utilizing its technical advantages in data collection, analysis, and indicator construction, the research innovatively constructs a "three-dimensional, six-level" teaching literacy indicator system encompassing multiple dimensions such as teacher ethics practice, professional teaching, digital literacy, social service, and innovation and entrepreneurship. The study comprehensively employs the Delphi Method, Analytic Hierarchy Process (AHP), and Fuzzy Comprehensive Evaluation (FCE) to scientifically determine the weights of each indicator and conducts empirical testing. The research findings hold significant theoretical value and practical guidance for promoting the high-quality development of vocational education and enhancing the quality of training high-quality technical and skilled talents.},
