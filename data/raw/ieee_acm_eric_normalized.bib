}

@article{10.1145/3789595.3789613,
	abstract = {Competitive programming (CP) is widely used in computer science education to train algorithmic thinking: solutions must match exact input/output formats, pass both public and hidden tests, and finish within strict time and memory limits. Students can now use large language models (LLMs) to generate sample CP solutions and learn from them by comparing, self-checking, and improving their own code. It is therefore important to understand how well LLMs solve CP problems, especially in university settings where access often comes through privacy-preserving deployments, so their capability for CP training is unclear. This paper reports an empirical study of privately deployed LLMs that generate candidate CP solutions. We measure success by online judge acceptance and analyze results by problem category (e.g., dynamic programming, graphs, greedy) and by two attributes: Popularity (attempts) and Solvability (success rate). We also test a simple few-shot strategy for the better-performing model by adding brief judge feedback after a failed first attempt, for up to four attempts. Results show where these models work well, where they struggle, and how acceptance changes across categories and across Popularity and Solvability ranges. Judge-feedback retries improve acceptance, with the biggest gain after the first retry and smaller gains later. Overall, the study offers practical guidance on when and how privately deployed LLMs can support CP self-training and algorithm practice.},
	affiliations = {},
	author = {Dang, Tran Tri and Jani, Jaronie Mohd and Ling, Huo-Chong and Tran, Linh Duc and Tran, Quang and Nguyen, Quy and Tran, Hoang and Pham, Thanh Chi},
	author_keywords = {Large Language Models; Competitive Programming; Algorithmic Problem Solving; Code Generation; Few-shot Prompting; Computer Science Education},
	doi = {10.1145/3789595.3789613},
	issn = {},
	journal = {Proceedings of the 2026 14th International Conference on Software and Information Engineering},
	keywords = {},
	number = {},
	pages = {88–94},
	source = {Scopus},
	title = {Are LLMs Ready for Competitive Programming? An Empirical Study},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3789692.3789765,
	abstract = {The research is about the integration of instructional technology and material design (IT&amp;MD) in English Language Teaching at Central Asian University. It investigates students’ perceptions of the “Instructional Technology and Material Design” course and provides a thorough analysis of the course content, outcomes, and assessment. The course was designed to enhance pre-service teachers' digital competency, material development skills, and making it part of the language teaching. The researchers used a survey and document analysis as data collection tools. From the findings, it was possible to notice that there is a positive trend toward the course structure, agreeing that the course improved their material design skills, digital literacy, and technology integration into the ELT classroom in a meaningful way. Additionally, results showed that the Instructional Technology and Material Design course had a positive impact on creativity, digital literacy, and teaching readiness.},
