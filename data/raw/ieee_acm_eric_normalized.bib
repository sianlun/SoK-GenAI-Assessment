	year = {2025}
}

@article{10.1145/3735091.3737530,
	abstract = {Specifications and mastery grading models have been shown to reduce student anxiety and improve perceptions of learning, while at the same time reducing teaching grading load and providing a more equitable and accessible framework for evaluation. This report details the experiences of converting a CS0 (introduction to programming and data management for non-majors) course to a variation of specification grading. In this model, course outcomes are delineated as individual skills, and students have multiple attempts to demonstrate proficiency in each skill. Final grades are calculated based on the level and set of skills demonstrated regardless of the number of attempts, or time taken to complete. We track the evolution of a skills-based evaluation model across three separate offerings, showing how the model changed and adapted over time in response to both student feedback and changing circumstances. We find both students and teaching assistants strongly preferred all variations of this evaluation model. This experience report contributes to the ongoing discussion in the database and computing education communities about best practices for teaching core data concepts.},
	affiliations = {},
	author = {Harrington, Brian and Lambert, Katherine and Lee, Leon and Nalluri, Rohita and Setarehdan, Seyed Sadra and Vadarevu, Anagha and Zavaleta Bernuy, Angela},
	author_keywords = {},
	doi = {10.1145/3735091.3737530},
