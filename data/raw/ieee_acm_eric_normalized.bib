@article{10854964,
	abstract = {The widespread adoption of Large Language Models (LLMs) in academic settings has raised concerns about student cheating and assessment integrity. While many educators respond by attempting to exclude LLMs from the learning process, this paper presents an alternative approach. We describe the redesign of a peer feedback assessment that was initially vulnerable to LLM-assisted cheating in an Engineering Education subject. Instead of resisting LLM use, we developed a new assessment that assumes student access to LLMs, focusing on skills that remain crucial in this context: selecting important feedback, delivering it effectively, and fostering generative conversations.This paper outlines the original task, its vulnerabilities, and the rationale behind the redesigned assessment. We present data from a pilot implementation, including student perceptions of the new process and its impact on their learning. The redesign aimed to enhance peer-to-peer learning, emotional connections, and support among students while potentially reducing marking costs. Our findings suggest that while the new approach presents some challenges, it offers significant benefits in terms of skill development, particularly in communication, empathy, and the task being fed back.We discuss the implications of this assessment redesign for student learning, including the potential trade-offs between leveraging LLMs for novel learning experiences and the development of critical thinking skills. This study contributes to the ongoing discourse on adapting engineering education to technological advancements, offering insights into innovative assessment strategies that embrace, rather than resist, the integration of AI tools in the learning process.},
	affiliations = {},
	author = {Cebon, Peter and Doyle, Rowan},
	author_keywords = {Costs; Large language models; Focusing; Resists; Peer-to-peer computing; Engineering education; Large Language Models; Reflective Practice; Feedback},
