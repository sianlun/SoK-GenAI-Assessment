	keywords = {},
	number = {},
	pages = {507-512},
	source = {Scopus},
	title = {LLM-Based Evaluation of Software Engineering Curriculum Coverage Against SWEBOK 4.0a: A Case Study},
	type = {Conference paper},
	volume = {},
