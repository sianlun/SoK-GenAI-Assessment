@article{10.1145/3797552.3797788,
	abstract = {This study explores the deep integration of educational metaverse and generative artificial intelligence (GAI), proposing an evaluation framework for intelligent educational literacy for pre-service teachers. Then a LSTM-based evaluation model using multimodal data mining and virtual simulation technologies is given to calculate pre-service teachers’ intelligent educational literacy. By constructing a system framework that combines VR/AR scenario simulations, GAI content generation, and learner behavior data collection and analysis, the research achieves dynamic and precise assessment of three dimensions of pre-service teachers' intelligent education literacy: technological awareness, application capabilities, and educational consciousness. This study not only enhances the evaluation system for smart education literacy in new engineering pre-service teachers but also provides actionable system architectures and methodological support for computer technology-based smart education literacy training programs in higher education institutions.},
