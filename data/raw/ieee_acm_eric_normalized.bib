@article{10.1145/3769694.3771119,
	abstract = {The ubiquity of artificial intelligence (AI) is proliferating faster than the frequency of curricular updates in higher education. Meanwhile, cybersecurity educators are quickly trying to determine what to teach students to be ready for the AI-enabled workforce. To compound this growing concern, the global workforce needs for cybersecurity professionals are outpacing higher education. This gap between academia and industry continues to widen with the advent of AI. This position paper discusses the critical need for the curricular convergence of cybersecurity and artificial intelligence (CyAI) in higher education, along with the pressing need to upskill cybersecurity professionals already in the workforce. For contextualization of our CyAI curricular convergence, we present an overview of cybersecurity and AI in higher education. Furthermore, a metaphor for thinking about the CyAI curricular convergence is proposed, and several pioneering exemplars are provided. The paper concludes with future explorations intended to stimulate further collaboration to think collectively about how to address this urgent education and workforce challenge.},
	affiliations = {},
	author = {Hawthorne, Elizabeth K and Sabin, Mihaela},
	author_keywords = {Cybersecurity education; AI education; curricular convergence},
	doi = {10.1145/3769694.3771119},
