@article{11449989,
	abstract = {The integration of Large Language Models (LLMs) into software requirements engineering education marks a significant shift in teaching strategies, as shown by this study's examination of the ReQuest platform. Designed to leverage LLMs for managing both functional and non-functional requirements, ReQuest automates the generation, analysis, and summarization of requirements to improve students' grasp of software engineering principles, offering a hands-on experience reflective of industry practices. This research details the platform's development and LLM integration, showcasing how LLMs can transform requirements education. It emphasizes LLMs' critical role in evolving software engineering education, enhancing student engagement, and equipping learners for industry challenges. Key findings include the ReQuest platform's success in facilitating requirement understanding and collaborative learning, although it also highlights challenges like technology acceptance biases and the need for ongoing adaptation to LLM advancements. The paper calls for integrating AI tools into educational frameworks to create innovative, engaging learning environments, contributing to discussions on the future of software engineering education.},
