	title = {Advancing Engineering Education in the Age of AI Through Innovative Methods},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11369381,
	abstract = {Creating final exams that meet accreditation standards and Bloom’s Taxonomy with diverse question types remains a persistent challenge. Manual preparation from lecture PDFs is time-consuming and predictable, while large language models (LLMs) like OpenAI’s GPT, xAI’s Grok, Perplexity, Google’s Gemini, and DeepSeek offer efficient alternatives, though their security and originality require validation. This study develops a universal framework for secure exam generation through multiple phases. In Phase 1, PDF lectures and sample questions are provided to an LLM provider, which generates a final exam aligned with accreditation-mandated types (e.g., MCQs, problems, essay questions) and Bloom’s levels, evaluated by instructors for quality. Phase 2 integrates PDF lectures, the previous two exams, and a blank exam specification table as inputs; the LLM outputs a secure N-question exam and a completed table mapping questions to lectures, types, and Bloom’s levels, using natural language processing (NLP) and cryptographically secure randomized sampling to ensure unpredictability and compliance. Phase 3 focuses on generating multiple exams of similar difficulty for computerized testing, enabling unique assessments for students seated in the same testing venue or computer laboratory, enhancing equity. The resulting framework outperforms manual methods, reducing preparation time and ensuring integrity through cryptography. Preliminary trial of Phase 1 suggests high compliance with standards like those of NAQAAE, ABET, and ACQUIN. This phased approach leverages LLMs’ strengths, offering a scalable, secure solution for modern assessments in engineering education. Further testing across institutions and broader adoption are recommended to validate and refine the framework.},
	affiliations = {},
	author = {El-Damak, Dina Reda and Alexan, Wassim},
	author_keywords = {Large language models; Taxonomy; Manuals; Natural language processing; Accreditation; Cryptography; Engineering education; Standards; Testing; Accreditation standards; Bloom’s Taxonomy; Cryptography; Engineering education; Large language models (LLMs); Secure exam generation},
	doi = {10.1109/GECon64629.2025.11369381},
	issn = {},
	journal = {2025 IEEE 4th German Education Conference (GECon)},
	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {Using Large Language Models to Create a Universal Framework for Secure Exam Generation},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11379175,
	abstract = {To address persistent challenges in Electrical Engineering education for non-electrical majors–including the gap between theoretical instruction and practical application, insufficient development of engineering thinking, and limited hands-on experience with complex systems–this paper proposes an integrated, multi-level, and student competency–oriented teaching model. The model adopts the dSPACE real-time simulation platform as the core environment for engineering practice, tightly integrates project-based learning, designs projects aligned with industry–education–research collaboration, and incorporates a large language model–based AI agent to provide personalized learning support. Teaching practice demonstrates that the proposed model establishes a closed-loop engineering training framework encompassing theoretical learning, simulation modeling, and hardware-in-the-loop validation. Experimental and assessment results indicate significant improvements in students' practical engineering abilities, system-level design skills, and complex problem-solving capabilities compared with traditional teaching approaches. These results suggest that the proposed model offers a scalable and effective paradigm for reforming foundational engineering courses for non-electrical majors in the context of Emerging Engineering Education.},
