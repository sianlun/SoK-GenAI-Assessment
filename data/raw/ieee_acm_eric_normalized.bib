	title = {Digital Empowerment of Foreign Language Education: A Dao–Fa–Shu–Qi Framework for Human–AI Collaborative Learning},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3797552.3797633,
	abstract = {The gap between legal education and advancements in digital technology presents significant challenges to cultivating competent legal professionals for the digital era. This study investigates the integration of Natural Language Processing (NLP) into legal education to address the theory-practice gap, which is exacerbated by outdated teaching methods and inadequate digital literacy. Using an empirical approach with multi-source data, including pass rates from China's Unified Legal Professional Qualification Examination (CLPQE), legal competition outcomes, bibliometric analysis of Web of Science (WOS) literature, and visualization techniques such as heatmaps and word clouds, this research systematically identifies deficiencies in practical legal skills training within traditional curricula. The core methodology combines empirical data analysis, bibliometric assessment, and visualization to map the current state of legal education and its alignment with digital advancements. The findings indicate that NLP technology enhances legal education by providing immersive learning opportunities through advanced language understanding, text analysis, knowledge graphs, and intelligent question-answering systems. These capabilities enable the effective simulation of legal scenarios, thereby fostering practical skills such as legal document drafting, case analysis, and moot court performance. A key finding is the mediating role of self-efficacy in the relationship between NLP application and the enhancement of practical competencies. By providing sustained successful learning experiences and positive feedback, NLP tools bolster students’ confidence in their legal abilities, thereby strengthening the internalization of professional knowledge, academic writing, and critical thinking. The study's practical value lies in providing a theoretical foundation and actionable strategies for integrating NLP into legal education.},
	affiliations = {},
	author = {Wang, Ziyang and Du, Jinyu},
	author_keywords = {Higher Legal Education; Natural Language Processing; Practical Legal Skills; Practical Teaching; Self-efficacy},
	doi = {10.1145/3797552.3797633},
	issn = {},
	journal = {Proceedings of the 2025 4th International Conference on Artificial Intelligence and Education},
	keywords = {},
	number = {},
	pages = {499–509},
	source = {Scopus},
	title = {AI-Driven Natural Language Processing for Higher Legal Education: A Technical Framework to Enhance Practical Competencies via Self-Efficacy Mediation},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3797552.3797655,
	abstract = {This paper addresses the emerging challenges posed to the traditional “Software Testing” course by the advancement of new engineering education initiatives and artificial intelligence (AI) technologies. It proposes a novel teaching model that integrates the CDIO engineering education framework with a bidirectional AI empowerment strategy. The study begins by clarifying the dual roles of AI—both as a tool for software testing and as a target of testing—and systematically develops a four-stage teaching model aligned with the CDIO paradigm. Four integrated case studies are presented, encompassing functional testing of AI mini-programs, automated testing of AI applications, performance evaluation of AI calculators, and interface testing of AI chatbots, which collectively illustrate the seamless integration of theoretical instruction and hands-on engineering practice. Empirical results demonstrate that this approach not only significantly enhances student engagement and strengthens their practical competencies across diverse testing scenarios, but also equips them with the ability to leverage AI tools for improved testing efficiency and to conduct quality assurance for AI-based systems. As such, the model offers an innovative and scalable solution for reforming engineering education in the age of AI.},
	affiliations = {},
	author = {Yang, Xiaonan},
	author_keywords = {Artificial Intelligence; Bidirectional Empowerment; CDIO; Software Testing Education},
