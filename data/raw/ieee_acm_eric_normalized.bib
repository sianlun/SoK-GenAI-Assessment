@article{10.1145/3796496.3811786,
	abstract = {A decade after “CS for All” established Computer Science (CS) as a vital K-12 subject, this paper critically examines the resulting stand-alone course model. Grounded in two decades of work in CS education and recent national educator interviews, we argue this siloed structure is neither the most equitable nor sustainable path forward. Persistence of low participation and constraints on teacher capacity challenge the model. We propose a strategic shift toward systemically integrating CS across all disciplines, treating it as a foundational literacy. The urgent need for AI literacy, which depends on a basic understanding of CS, amplifies this call to invest in policy and curriculum to ensure an equitable foundation for every student.},
