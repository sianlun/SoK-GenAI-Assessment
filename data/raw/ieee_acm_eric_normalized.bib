	journal = {Proceedings of the ACM/IEEE 27th International Conference on Model Driven Engineering Languages and Systems},
	keywords = {},
	number = {},
	pages = {570–577},
	source = {Scopus},
	title = {Teaching Model-Driven Low-Code Development Platforms},
	type = {Conference paper},
	volume = {},
	year = {2024}
}

