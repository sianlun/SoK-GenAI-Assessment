	author_keywords = {Design methodology; Printing; Timing; Artificial intelligence; Learning (artificial intelligence); Engineering education; Testing; Real-time systems; Writing; Technology; academic integrity; project-based learning; practical skills evaluation; critical thinking; educational technology; curriculum development; ethical reasoning},
