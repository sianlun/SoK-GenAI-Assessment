@article{11400464,
	abstract = {This study investigates the integration of artificial intelligence (AI) in educational assessments across private K–12 schools in Abu Dhabi, United Arab Emirates (UAE), focusing on teachers' perceptions, adoption patterns, and systemic challenges. Aligned with the UAE's National AI Strategy 2031, which positions AI as a catalyst for educational innovation, the research employs a quantitative survey of 610 teachers to evaluate the alignment between theoretical expectations and practical realities. Findings reveal moderate AI adoption in assessments ($M=3.70$ for student evaluation), with tools like ChatGPT predominantly used for content creation and student engagement. While teachers express strong optimism for AI's future role in personalising learning ($M=3.89$) and enhancing feedback ($M=3.94$), adoption remains constrained by ethical concerns (e.g., algorithmic bias), infrastructural disparities, and insufficient institutional support. The study highlights a critical paradox: enthusiasm for AI's transformative potential coexists with hesitation to deploy it in high-stakes tasks, underscoring the irreplaceable role of human judgment in pedagogy. Recommendations emphasise the need for ethical frameworks, teacher-centred professional development, and equitable resource allocation to bridge the gap between AI's promise and practice. By addressing these challenges, the UAE can advance its vision of a dynamic, inclusive educational landscape powered by responsible AI integration.},
	affiliations = {},
