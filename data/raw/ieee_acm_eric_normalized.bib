@article{11387367,
	abstract = {This study presents an educational model integrating flipped classroom strategies, video-based instruction, and generative AI to reinforce theoretical learning in an undergraduate circuits course. Implemented across three cohorts, the model incorporated Wisdolia, a generative AI tool that transforms video content into personalized flashcards for selfdirected practice. Descriptive results showed promising trends in the AIsupported group, including improved averages and reduced grade dispersion. While not statistically significant, these patterns, alongside strong voluntary student engagement, suggest potential for fostering autonomy and consistency in engineering education. Future work will explore structured implementation and the development of adaptive AI tutoring systems.},
