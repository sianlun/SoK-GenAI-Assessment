@article{10.1145/3769694.3771116,
	abstract = {The rise of generative artificial intelligence (GenAI) challenges the design, delivery, and integrity of assessments in undergraduate cybersecurity programs. While GenAI offers opportunities for enhancing instruction and learning, it also disrupts traditional written and authentic assessments, enabling students to bypass critical thinking and skill development. This paper examines institutional policies, pedagogical models, and assessment strategies to help instructors and programs adapt effectively. Drawing on recent studies, case examples, and curricular frameworks, the paper presents a rubric for addressing the use of GenAI by students in courses. These strategies can help maintain both the integrity and the relevance of cybersecurity education in a rapidly evolving technological context.},
	affiliations = {},
