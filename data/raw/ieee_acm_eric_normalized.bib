@article{10.1145/3806980.3807017,
	abstract = {Under the background of digital transformation in education, Business English bilingual teaching faces core challenges including the imbalance between scale and personalization, knowledge fragmentation, and disconnection among teaching, learning, and assessment. This study first conducts a bibliometric analysis of intelligent curriculum literature using CiteSpace, identifying a significant application gap in English for Specific Purposes (ESP). It then integrates knowledge graph and machine learning technologies to develop an intelligent course system tailored to the characteristics of Business English. A framework of “three layers, dual engines and a closed loop” is designed, along with a full-process implementation pathway. Theoretically, the study demonstrates the feasibility of this system in promoting differentiated instruction within large-scale classes, constructing a systematic business knowledge network, and promoting formative assessment reform. It thus provides a framework with both theoretical foresight and practical operability for the digital transformation of bilingual Business English teaching.},
