	source = {Scopus},
	title = {Toward AI-Resilient Assessment in Engineering Education: Evaluating Student Video Presentations Through Speech and Language Analysis},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11256367,
	abstract = {Standardised examinations are essential tools in higher education, providing a reliable assessment of graduation competencies and institutional accountability. However, traditional preparation methods for standard examinations can often lack in student engagement and opportunities for personalised learning. This study explores the potential of artificial intelligence (AI) in addressing these gaps, particularly through AI-generated standardised assessments. A virtual assistant was created using the ChatGPT platform to help Civil Engineering students at Tecnologico de Monterrey prepare for their Mexican national standardised exams. Surveys were used to gather information about student engagement, self-directed learning, educational outcomes, and acceptance of technology. Initial expectations suggest that by integrating AI assessment, practitioners can significantly enhance student engagement and foster self-directed learning behaviour, improving overall preparation and outcomes in formal graduation exams. These findings offer new insights into the educational benefits of AI, suggesting a significant shift toward more interactive and personalised assessment methods.},
	affiliations = {},
	author = {Luna-Villarreal, Kevin and Bonila-Bustillo, Eduardo and Oropeza, Ricardo Swain and Hernandez-Aguirre, Angel},
	author_keywords = {Surveys; Technological innovation; Virtual assistants; Chatbots; Reliability; Artificial intelligence; Engineering education; Standards; Civil engineering; Higher Education; Educational Innovation; Technology acceptance; Artificial Intelligence Tutors; Standardised exams},
