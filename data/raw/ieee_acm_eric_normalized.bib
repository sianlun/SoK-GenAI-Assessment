@article{10.1145/3796496.3811787,
	abstract = {Service-learning in accessible and inclusive IT design education becomes ethically consequential when people with disabilities share lived expertise with student teams. Such courses can foster learning, perspective change, and disability-informed design, but semester timelines, grading pressures, and abrupt endings can create foreseeable risks for participants and partners. This perspectives paper argues that instructor goodwill is insufficient and proposes Responsible Service-Learning in inclusive settings: a governance framework specifying ethical duties, auditable course artifacts, and tiered implementation levels. The framework treats agency, dignity, reciprocity, and credible exit as course-level responsibilities.},
