@article{10.1145/3789859.3789870,
	abstract = {The use of Artificial Intelligence (AI) tools among students has grown significantly in recent years, especially with the increasing accessibility of platforms like ChatGPT, Grammarly, and other AI-powered learning assistants. AI tools, while powerful aids for learning, can be misused in ways that undermine academic integrity and the learning process. Students’ view of ethical implications of using AI tools in academics are influenced—or not—by institutional policies, awareness of academic honesty guidelines. Thus, prompting the need for targeted interventions ensures ethical and responsible AI use aims to increase student awareness and understanding of AI policies and academic honesty while shaping balanced attitudes towards AI use and potential bans.   In this study, researchers used a mixed-methods research design to investigate the degree of AI tool usage among university students, their opinions of academic honesty, and their support for institutional policies governing use of AI tools. Data were gathered from seven (7) different higher education institutions in the Philippines using a standardized online questionnaire. Quantitative data was evaluated with SPSS and Microsoft Excel. Moreover, NVivo was used to evaluate qualitative data from open-ended replies for the identification of common themes and keywords related to AI misuse. Correlation analysis was conducted to determine the correlations between categorical variables as students risk factors on AI tools use in academics and a list of possible interventions was created to match risk factors to proposed institutional responses. In the survey findings, the results show that AI tools are now deeply embedded in student academic practices, yet many students lack clarity on the ethical boundaries of their use. While some view AI as helpful, others remain concerned about fairness and dishonesty. The widespread use of AI, combined with low policy awareness and divided perceptions, signals a pressing need for universities to act. Institutions must implement targeted interventions such as academics integrity policy updates, AI literacy education, use of AI detection tools, academic honesty pledge, AI integration in learning, and behavioral analytics to promote responsible use.},
	affiliations = {},
	author = {Maurat, John Ivan Curbano and Labanan, Rogel Masecampo and Isip, Elsie Villareal},
	author_keywords = {AI Policy; AI Tools; Academic Honesty; Academic Integrity},
	doi = {10.1145/3789859.3789870},
	issn = {},
	journal = {Proceedings of the 2025 9th International Conference on Education and E-Learning},
	keywords = {},
	number = {},
	pages = {213–219},
	source = {Scopus},
	title = {Transforming University Assessments in the AI Era: Innovative Solutions for Ensuring Academic Honesty},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3789859.3789893,
	abstract = {Abstract: In recent years, Artificial Intelligence (AI) has significantly transformed higher education, especially in the domains of language and writing instruction. The emergence of generative AI (GenAI) tools like ChatGPT and the growing significance in academic environments has rendered AI literacy indispensable, especially for students in Writing for Various Purposes courses. This study addresses the gap in practical approaches for incorporating AI literacy by integrating the Google AI Essentials Coursera course into the Blackboard Learning Management System (LMS). The study used a quantitative research methodology to examine the effects of AI literacy integration on students' writing assessment results. Descriptive statistics and the Mann–Whitney U-test were utilized to assess data obtained from two groups: a control group that underwent traditional writing lecture and an experimental group that finished the Google AI Essentials Coursera course. The findings reveal a statistically significant difference in writing assessment outcomes between the control and experimental groups, with results favoring the experimental group. These findings underscore the potential of integrating AI literacy into writing teaching to effectively address students' changing academic requirements in a technology-enhanced learning environment.},
	affiliations = {},
	author = {Gamez, Jhona and Torres, Ramachandra},
	author_keywords = {Artificial Intelligence; Blended Learning; E-Learning; Generative AI; Pandemic Performance; Writing Assessment},
