	author_keywords = {Learning (artificial intelligence); Printing; Modeling; Design methodology; Codes; Amplitude shift keying; Engineering education; Artificial intelligence; Bridges; Chatbots; pedagogical innovation; curriculum development; personalized learning; critical thinking; active learning; computational thinking; ethics in engineering; STEM education},
