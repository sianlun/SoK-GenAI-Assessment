@article{10.1145/3806980.3807033,
	abstract = {As Large Language Models (LLM) become ubiquitous in engineering education, there is a critical paucity of quantitative frameworks to assess their impact on student cognition. This study addresses this gap by mining fine-grained dialogue logs from an Engineering Mechanics cohort to characterize collaboration patterns. By integrating Natural Language Processing with clustering algorithms, we introduce a novel Log-based Cognitive Load Index (L-CLI) as a behavioral proxy for cognitive states. The results identify discrete collaboration phenotypes, differentiating between superficial “Passive Dependency” and deep “Active Scaffolding”. Quantitative analysis demonstrates a significant positive correlation between high L-CLI patterns and problem-solving precision, validating that cognitive engagement remains the governing factor in AI-assisted learning. These findings provide a rigorous, data-driven foundation for developing adaptive pedagogical interventions that mitigate algorithmic reliance while amplifying critical thinking skills.},
