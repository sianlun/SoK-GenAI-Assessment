	author_keywords = {Learning (artificial intelligence); Artificial intelligence; Printing; Technology acceptance model; Educational institutions; Modeling; Tools; Technology; Design methodology; Generative AI; artificial intelligence; educational innovation; self-study; higher education; mathematics innovation},
