	journal = {2023 International Conference on Computational Science and Computational Intelligence (CSCI)},
	keywords = {},
	number = {},
	pages = {1670-1676},
	source = {Scopus},
	title = {Leveraging LLMs and MLPs in Designing a Computer Science Placement Test System},
	type = {Conference paper},
	volume = {},
	year = {2023}
}

@article{10604578,
	abstract = {Artificial Intelligence (AI) is a transformational technology that has the potential to completely change everything in various fields. In education, AI has been focused on due to its ability towards customization as well as adaptability in learning. Some of these technologies including “OATutor” and “Intelligent Tutoring Supported Collaborative Learning (ITSCL), have made their mark in the education industry. However, they often encounter hurdles like deep concept understanding, fostering creativity, encouraging critical thinking and promoting effective problem-solving skills. This abstract outlines the “AI Tutor”, a unique educational solution that fully overcomes these challenges. The “AI Tutor” exploits GPT-4's language understanding and Invideo AI's text-to-video generation capabilities to deliver customized educational videos, lectures and quizzes. Moreover, it tailors itself to individual needs of learners ensuring that content delivery remains dynamic and engaging while assessments are carried out so effectively with progress tracking being done through interactive lessons, videos, quizzes and practice exercises thereby enabling students receive instant feedback and performance analysis about their educational activities. One major strength of “AI Tutor” is its personalization capability. It is adaptable to the level of each learner, in that it helps them understand information better and acquire more knowledge. The AI Tutor differs from other technologies in that its scope goes beyond superficial levels of learning with objectives of promoting a profound concept comprehension. It also encourages creativity by employing text-to-video generation thus allowing learners to visualize and express their views. In addition, it has been designed to foster critical thinking and problem-solving abilities among learners through presenting them with difficult questions and giving specific feedback so as to develop their analytical skills.},
	affiliations = {},
	author = {Shahri, Hossein and Emad, Mohammed and Ibrahim, Nahid and Rais, Rao Naveed Bin and Al-Fayoumi, Yousef},
	author_keywords = {Industries; Visualization; Federated learning; Education; Performance analysis; Problem-solving; Text to video; AI; AI in education; Interactive Technology; Education; OpenAI},
	doi = {10.1109/URC62276.2024.10604578},
	issn = {},
	journal = {2024 15th Annual Undergraduate Research Conference on Applied Computing (URC)},
	keywords = {},
	number = {},
	pages = {1-5},
	source = {Scopus},
	title = {Elevating Education through AI Tutor: Utilizing GPT-4 for Personalized Learning},
	type = {Conference paper},
	volume = {},
	year = {2024}
}

@article{10633247,
	abstract = {Due to the recent improvements and wide availability of Large Language Models (LLMs), they have posed a serious threat to academic integrity in education. Modern LLM-generated text detectors attempt to combat the problem by offering educators with services to assess whether some text is LLM-generated. In this work, we have collected 124 submissions from computer science students before the creation of ChatGPT. We then generated 40 ChatGPT submissions. We used this data to evaluate eight publicly-available LLM-generated text detectors through the measures of accuracy, false positives, and resilience. Our results find that Copy Leaks is the most accurate LLM-generated text detector, G PTKit is the best LLM-generated text detector to reduce false positives, and GLTR is the most resilient LLM-generated text detector. We note that all LLM-generated text detectors are less accurate with code, other languages (aside from English), and after the use of paraphrasing tools.},
	affiliations = {},
	author = {Orenstrakh, Michael Sheinman and Karnalim, Oscar and Suárez, Carlos Aníbal and Liut, Michael},
	author_keywords = {Measurement; Accuracy; Plagiarism; Large language models; Education; Detectors; Chatbots; Large Language Models; ChatGPT; GPT; AI Detectors; Plagiarism; Academic Integrity},
	doi = {10.1109/COMPSAC61105.2024.00027},
	issn = {2836-3795},
	journal = {2024 IEEE 48th Annual Computers, Software, and Applications Conference (COMPSAC)},
	keywords = {},
	number = {},
	pages = {121-126},
	source = {Scopus},
	title = {Detecting LLM-Generated Text in Computing Education: Comparative Study for ChatGPT Cases},
	type = {Conference paper},
	volume = {},
	year = {2024}
}

@article{10636140,
	abstract = {In recent years, large language models (LLMs) have been employed significantly in different domains of computing education. Nevertheless, these models have been focused on essential adherence to their integration as coding assistants in computing education. However, attention has been switched to thoroughly examining and analyzing LLM behavior, particularly in computing education for programming tasks such as code generation, code explanation, and programming error message explanation. Therefore, it becomes imperative to understand their behavior to examine potential pitfalls. This article addresses this gap systematically and details how different LLM-based coding chatbots, such as ChatGPT, Codex, Copilot, and others, react to various coding inputs within computing education. To achieve this objective, we collected and analyzed articles from 2021 to 2024, and 72 studies were thoroughly examined. These objectives include investigating the existing limitations and challenges associated with utilizing these systems for coding tasks, assessing their responses to prompts containing coding syntax, examining the impact of their output on student learning, and evaluating their performance as debugging tools. The findings of this review highlight that it is premature to incorporate these systems into computing education due to their limitations that may limit their effectiveness as comprehensive coding assistants for computer science students. These limitations include issues with handling prompts containing code snippets, potential negative impacts on student learning, limited debugging capabilities, and other ineffectiveness. The finding also reports multiple research directions that can be considered in future research related to LLMs in computing education.},
	affiliations = {},
