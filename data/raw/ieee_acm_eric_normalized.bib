	abstract = {Disabled people live at the intersection of multiple identities that shape their access needs and technology experiences. Designing equitable systems requires preparing future technologists to critically engage with how technologies interact with systems of oppression. This experience report presents the design and instruction of an accessibility capstone that integrates intersectional theories, both within course content and as a guiding pedagogical framework. We outline the theoretical foundations informing the course, its structure and implementation, and reflect on the tensions that emerged throughout the course. We offer considerations for educators seeking to meaningfully integrate intersectional accessibility into computing education.},
	affiliations = {},
	author = {Lewis, Aaleyah and Hsueh, Stacy and Mankoff, Jennifer},
