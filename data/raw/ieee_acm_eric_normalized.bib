	author_keywords = {Deep learning; Accuracy; Generative AI; Navigation; Manuals; Linguistics; Natural language processing; Engineering students; Faces; Videos; video presentation; engineering education; multimodal analysis; innovative assessment},
	doi = {10.1109/WEEF-GEDC66748.2025.11256231},
