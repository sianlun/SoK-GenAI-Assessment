	title = {Competency-Based Model for CS Education in the Era of AI},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11200545,
	abstract = {Generative AI (GenAI) revolutionizes students’ learning experiences in higher education, yet understanding students’ engagement with these technologies, particularly emotional engagement, remains unexplored. This study explores postgraduate engineering students’ interaction with GenAI and how it shapes their emotional attachment and learning experiences. Using an ethnographic qualitative approach, data were collected through semi-structured interviews and contextual observations. The findings reveal four qualitatively differentiated phenomena of students’ emotional engagement: (i) Reaction Variability- curiosity and frustration depending on GenAI responses. Such variations lead to motivation or disengagement in learning. (ii) Engagement Quality- GenAI facilitated both deep and passive learning. Passive engagement diminishes critical thinking and promotes surface-level learning. (iii) Academic Integrity- overreliance on GenAI for quick and easy solutions. This reliance can lead to reduced creativity and originality in the learning process, and (iv) Mindset- socio-economic status and prior technology experience shape students’ attitude toward GenAI use. While GenAI holds transformative potential, it presents both challenges and opportunities within educational settings, especially in developing nations. The study offers actionable insights for educators, curriculum designers, and policymakers seeking to foster emotionally supportive, ethically grounded, and effective uses of GenAI in engineering education.},
	affiliations = {},
	author = {Saidu, Musa Kallah and Mamun, Md Abdullah Al},
	author_keywords = {Ethics; Shape; Generative AI; Learning (artificial intelligence); Engineering education; Socioeconomics; Interviews; Surface treatment; Creativity; Engineering Education; Artificial Intelligence; Emotional engagement; Learning behaviour; Academic Integrity},
	doi = {10.1109/CogInfoCom66819.2025.11200545},
