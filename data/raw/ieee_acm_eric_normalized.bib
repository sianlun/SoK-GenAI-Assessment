@article{11556827,
	abstract = {The article addresses the problem of inefficient allocation of computational resources for artificial intelligence tasks within centralized cloud infrastructure. It is shown that the concentration of computing power in the hands of a limited number of providers leads to inflated unit costs (up to 80% higher than the market potential), vendor lock-in, and violations of regulatory requirements regarding data residency. Vendor lock-in extends beyond contractual constraints: it manifests in proprietary APIs, incompatible orchestration tools, and egress fees that can increase total migration costs by 200–400%. For AI startups operating on thin margins, these barriers stifle innovation and limit competitive dynamics. The decentralized market model mitigates this risk by abstracting hardware heterogeneity through a unified interface, enabling seamless workload portability and fostering a more competitive pricing environment driven by real-time supply and demand. An economico-mathematical model of a decentralized computation market (exemplified by the ReGraph platform) is proposed, enabling aggregation of heterogeneous resources (GPU/TPU/NPU/mobile processors) through multi-objective optimization of request routing. An equation for reducing the unit cost of inference to 0.0001 USD per request while maintaining 99.9% availability is theoretically substantiated and empirically verified. A quantitative assessment of idle capacity utilization efficiency is conducted: the computational resource utilization rate increases from 0.23 (traditional data centers) to 0.68 in the decentralized architecture. Results demonstrate the possibility of reducing the total cost of ownership (TCO) for AI service developers by 76.4% while simultaneously creating new monetization opportunities for hardware owners. This research responds to the urgent need for sustainable and inclusive computational infrastructure in the era of generative AI. By leveraging underutilized hardware across geographic boundaries, the proposed model not only addresses economic inefficiencies but also contributes to reducing the carbon footprint associated with idle data center capacity. The decentralized approach democratizes access to high-performance computing, enabling small-scale developers, research institutions, and emerging markets to participate in the AI economy without prohibitive upfront investments.},
	affiliations = {},
	author = {Dushin, Iliya and Gabriel, Mikhaeli and Denisenko, Vera},
	author_keywords = {Modeling; Equations; Costing; Costs; Artificial intelligence; Hardware; Pricing; Optimization; Routing; Tagging; decentralized computing; computational resource market; AI model inference; heterogeneous infrastructure; economic efficiency; request routing; warm pools},
	doi = {10.1109/Inforino68543.2026.11556827},
	issn = {},
	journal = {2026 8th International Conference on Information Technologies in Engineering Education (Inforino)},
	keywords = {},
	number = {},
	pages = {1-4},
	source = {Scopus},
	title = {Economico-Mathematical Model of a Decentralized Computational Resource Market for Inference and Training of Artificial Intelligence Models},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{3636517.3636523,
