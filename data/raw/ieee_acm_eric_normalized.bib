	title = {Exploration and Practice of AI Application-oriented Talent Training Model Based on OBE Concept},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{10.1145/3722237.3722369,
	abstract = {Base on CiteSpace and VOSviewer, the visualization analysis method of bibliometrics were used in this study. Taking 571 articles indexed by the SCI literature from the core collection of Science Direct database, as research object, the hotspots, evolution and development trend of artificial intelligence (AI) application research in the field of higher education were discussed. Analysis found out that the annual number of published papers on the application of AI in the field of higher education generally shows an overall growth trend. Research institutions mainly conduct research independently or in collaboration with internal secondary units, the author's research involves in multiple disciplines. The research models shows a diversified trend, focusing on the deep integration of AI and higher education, technological empowerment education reform, future oriented talent cultivation, and policy governance. However, there is also a lack of cross institutional cooperation. Therefore, research on the application of AI in higher education should also be based on the background of the times and policy requirements, strengthen basic theoretical and empirical research, create an intelligent foundation for high-quality development, and effectively support the digital transformation of higher education.},
