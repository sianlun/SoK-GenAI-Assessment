	author_keywords = {Surveys; Generative AI; Conferences; Transforms; Chatbots; Vocational training; Circuit synthesis; Trajectory; Recording; STEM; AI-assisted learning; STEM education; Generative AI in education; Hands-on learning; Girls’ education; human trafficking; vulnerable communities},
	doi = {10.1109/ISTAS65609.2025.11269627},
