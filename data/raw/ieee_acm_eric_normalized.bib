@article{10.1145/3796523,
	abstract = {The Rules of Program Behavior framework notes that teachers target a model of program behavior instead of the complex semantics of the programming language, and allows describing these models as sets of rules of program behavior. When learners execute code, its behavior is defined by the semantics of the programming language, which might differ from the targeted model of program behavior. In this article, we present a theoretical framework that builds on the Rules of Program Behavior framework, while giving a more prominent role to the differences between the targeted models and the programming language semantics. We call these differences Program Behavior gaps and distinguish between incompleteness gaps—untaught parts—and conflict gaps—a semantic rule that conflicts with a rule of program behavior—, and between transparent and opaque gaps. Visualizations of the relation between the semantics of the programming language and the targeted model of program behavior are an integral part of our framework as they allow visualizing the gaps that could exist in a code fragment and whether these gaps are activated or not. On top of this, the framework contains clear definitions to distinguish between valid conceptions, misconceptions, missing conceptions, prior conceptions, fluid conceptions and program behavior gaps. The framework can be used to devise programming courses, to investigate the mental model of learners and to make a case for gradually evolving languages that are designed to have fewer program behavior gaps. To illustrate this, we (1) present a real-life progression of models of program behavior and discuss, for this progression, the program behavior gaps in 21 code fragments, and (2) present a study grounded in our theoretical framework in which we determine the mental model of each participant.},
	affiliations = {},
	author = {Hoobergs, Jesse and Schrijvers, Tom and Hermans, Felienne},
	author_keywords = {Programming education; introductory programming; rules of program behavior; notional machines; model of program behavior; program behavior gaps; learning objectives; instructional design; semantics; mental models; conceptions},
	doi = {10.1145/3796523},
	issn = {},
	journal = {ACM Trans. Comput. Educ.},
	keywords = {},
	number = {3},
	pages = {},
	source = {Scopus},
	title = {Program Behavior Gaps: An Extension of the Rules of Program Behavior Framework},
	type = {Article},
	volume = {26},
	year = {2026}
}

@article{10.1145/3796525,
	abstract = {Background and Context: Today’s software industry increasingly values intricate conceptual knowledge (e.g., sufficient expertise to fix AI-generated code). Though program comprehension and scaffolding have mature literature, the intermediate-to-expert transition for programmers is under-researched relative to its socioeconomic impact. Learner-focused inspection tools exist (e.g., Ply, Isopleth, Python Tutor), but these often address specific problems (e.g., implicit CSS dependencies, async JS, call stacks), without systematic guidance for developing deep conceptual models of architectures and techniques across large real-world codebases or interactions.Objectives: We aim to support non-experts in learning holistically from professional code and to understand how they explore and learn in this context. Given that learners outnumber expert instructors who can teach these concepts, we propose Process Management (PM), a framework for designing tools that scaffold sensemaking on underused yet plentiful real-world code. PM addresses core obstacles learners face (code complexity, surface-level focus, and transfer challenges) through core design principles (intuitive sensemaking processes, comparison, reflection). After prototyping and piloting over 5 years, we developed 3 PM tools that surface JavaScript, CSS, and Python techniques. In this work, we seek to understand the effectiveness of PM tools, and the processes learners follow with and without PM support.Study Methods: We report on think-aloud studies conducted over 1.5 years to evaluate our 3 PM tools. Data include  (sim) 300 hours of remote observation of intermediate-level developers using these tools or controls (Chrome DevTools, VS Code). There were five participants in each condition for each tool. Studies consisted of tool training and pre-test, tool-use, and post-test phases, followed by a post-study interview. We qualitatively coded pre/post- and tool-use data, and present learning gains and in-task behavioral metrics.Findings: Our mixed-methods evaluations show PM tool users explored effectively (e.g., comparing, mapping) and achieved  (sim) 3× more learning outcomes (e.g., conceptual clarity, transferable patterns). Such outcomes were observed consistently across the three programming domains under study. Our qualitative data shows how PM tools can shape learners’ exploration order and process, enhance their understanding of nuanced techniques through interactive comparison, and help them uncover the domain-specific rationales behind design pattern usage through analogical mapping and reflection activities.Implications: Finally, we discuss PM’s potential impact on cognitive load, the role of experts today, and a sketch for how LLMs may scale PM. In particular, we envision a world in which educators and builders can develop PM systems that provide intermediate-level engineers a process for learning holistically from open source professional code to gain conceptual expertise, which they can then use to refine AI-generated code. We also provide examples of LLM prompts that can be used to potentially automate aspects of our PM tool-use sessions, laying some groundwork for AI-driven professional development.In summary, our work contributes to computing education by introducing a scalable and forward-looking tool-building framework and design paradigm for helping intermediate-level learners extract expert-level concepts from complex, real-world code.},
	affiliations = {},
	author = {Dasu, Gobi and O’Rourke, Eleanor and Zhang, Haoqi and Whitely, Maxine and Wilcox, Roxanna and Rosenberg, Lev and Mulat, Mieraf and Liu, Jonathan and Brewster, Natalie},
	author_keywords = {program comprehension; professional development; self-directed learning; design patterns; scaffolding; knowledge maps; code instrumentation; analogical transfer; authentic learning; developer tools; sensemaking},
	doi = {10.1145/3796525},
	issn = {},
	journal = {ACM Trans. Comput. Educ.},
	keywords = {},
	number = {3},
	pages = {},
	source = {Scopus},
	title = {Process Management for Learning from Professional Source Code: Cultivating Experts in the Age of AI},
	type = {Article},
	volume = {26},
	year = {2026}
}

@article{10.1145/3796527,
	abstract = {This article presents and discusses the results of a national survey on adults’ media and robot literacy in Finland with a focus on robot literacy. The study addresses three pressing global challenges: population aging, increasing robotization, and a research gap concerning the skills and competencies needed for interacting with robots. The survey operationalized the authors’ robot literacy framework, which focuses on physical robots and defines robot literacy across seven skill dimensions: (1) Awareness of robots; (2) Interaction with robots; (3) Understanding and evaluating the information robots provide; (4) Understanding the data security and privacy of robots; (5) Programming of robots; (6) Ethical reflection; and (7) Providing and receiving social support on robotics-related questions. The survey addressed the following research questions: What is the scope of adults’ robot literacy? How are gender, age, education, household composition, and use of the Internet connected to adults’ robot literacy?The study marks the first attempt to map robot literacy across a national population. It shows that despite recent progress in AI and future forecasts of advances in the development of social and humanoid robots, awareness of robots is still limited among Finland’s adult population and does not originate mainly in firsthand experiences with robots. Furthermore, the respondents exhibited uncertainty in their ethical reflection, in knowledge about interaction with robots, and in their understanding and evaluation of the information provided by robots. They also reported being entirely unprepared—or possessing low or very low skills—in providing social support related to robotics. For the field of computing education, the study offers new insights into the relatively limited robot literacy of adults, particularly older adults. A key practical implication is that adult educators—computing educators included—as well as researchers, instructional designers, the media, robotic service providers, robot developers, and other stakeholders must actively promote robot literacy among the adult population.},
	affiliations = {},
	author = {Rasi-Heikkinen, Päivi and Kannasoja, Sirpa and Vuojärvi, Hanna and Kaartinen, Henna and Ahtinen, Aino and Selkälä, Arto},
	author_keywords = {Robot literacy; Survey; Lifelong learning; Adult education},
	doi = {10.1145/3796527},
	issn = {},
	journal = {ACM Trans. Comput. Educ.},
	keywords = {},
	number = {3},
	pages = {},
	source = {Scopus},
	title = {Adults’ Robot Literacy—Results from a Finnish Survey},
	type = {Article},
	volume = {26},
	year = {2026}
}

@article{10.1145/3796705,
	abstract = {Older adults are often subjected to online attacks and can be vulnerable to social engineering. In addition to direct harms, this may contribute towards lower rates of technology use and digital literacy in older populations. Since September 2019, we have worked with older adult volunteers to create a peer-to-peer cybersecurity advocacy initiative. We present a thematic analysis of longitudinal qualitative data that explores links between cybersecurity and digital literacy. Our findings highlight a technical ceiling that limited some proactive changes for peer advocates and for those they reached. We suggest that overcoming such issues requires significant practical familiarity, aided by the provision of repeat practice in a safe environment and with longitudinal support. This, we position as part of a need for the integration of cybersecurity training within digital literacy education for older learners. Finally, we elaborate on the structure of our engagement in terms of layered and distributed scaffolding.},
	affiliations = {},
	author = {Holt, Jack and Nicholson, James},
	author_keywords = {Peer teaching; security advocates; digital literacy; password managers; two-factor authentication},
