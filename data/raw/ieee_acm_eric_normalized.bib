	author_keywords = {Artificial intelligence; Printing; Large language models; Learning (artificial intelligence); Modeling; Chatbots; Codes; Testing; Educational institutions; Education; large language models; artificial intelligence in education; critical thinking; dual control strategy; cognitive skills; assessment of learning quality},
