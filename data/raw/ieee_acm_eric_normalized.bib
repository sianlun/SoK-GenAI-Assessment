@article{11280249,
	abstract = {The rapid integration of generative artificial intelligence (GenAI) into the IT sector presents both a challenge and an opportunity for higher education. Although the use of new technologies in education raises concerns about academic integrity, this study argues against rejecting them. Instead, it explores their systematic integration. This case study explores the systematic integration of GenAI as a development tool in a Software Engineering course at Matej Bel University. We examine the reported impact on students’ work efficiency, the perceived quality of their outputs, and their attitudes toward GenAI's role in their future careers. This research was a case study of a group of students who used GenAI as a tool in a software engineering course. Data was collected through observation and a final self-assessment questionnaire completed by a small cohort of students (n=24). The findings indicate that students responded positively to using GenAI, perceiving it as an important future career skill, particularly for documentation and requirements analysis. We conclude that GenAI can be a beneficial addition to education, provided its use is systematic, though the small sample size necessitates these results be interpreted within the specific context of this pedagogical intervention.},
	affiliations = {},
	author = {Siládi, Vladimír},
	author_keywords = {Systematics; Software design; Generative AI; Engineering profession; Reviews; Education; Software; Regulation; Software engineering; Software development management; generative AI; software engineering education; AI in education; software requirement analysis; software design},
