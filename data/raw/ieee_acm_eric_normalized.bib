	title = {University Information Resource Management and Sharing Services Empowered by AI},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3797552.3797632,
	abstract = {In this study, “AI-enhanced” refers to Artificial Intelligence–enhanced digital learning systems, in which computational techniques augment instructional processes. This paper develops an AI-enhanced digital learning system for foreign language education based on the Dao–Fa–Shu–Qi framework. To bridge the gap between educational philosophy and computational implementation, we design a human–AI collaborative learning architecture that integrates large language models, automated speech evaluation, learning analytics dashboards, and prompt-engineering–based interaction workflows. A 16-week quasi-experimental study was conducted using an AI-supported English Public Speaking platform that automatically analyzes pronunciation, fluency, prosody, and discourse coherence using a multi-metric scoring algorithm. System logs, behavioral data, and speech performance metrics were collected and processed through Python-based data pipelines and NVivo qualitative coding. Experimental results show that students using the AI-driven system achieved significantly higher gains in pronunciation accuracy (+37.2%), speech fluency (+29.8%), and value-oriented cultural expression, compared with the control group. The study demonstrates how computational technologies can operationalize the Dao–Fa–Shu–Qi model and provides a reproducible technical pathway for integrating large language models into foreign language instruction.},
	affiliations = {},
	author = {Luo, Xiaoxue and Ling, Shuzhen and Han, Fangting},
	author_keywords = {Dao-Fa-Shu-Qi; Digital Empowerment; Foreign Language Education; Large Language Models; English Public Speaking; Human-AI Collaboration},
