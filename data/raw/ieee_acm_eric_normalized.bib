	title = {The Design and Development of a Computer Science Teaching Assistant Agent Based on Large Language Models},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786229,
	abstract = {Learning the process of writing a computer program is an important part of introductory computer programming education. Many educators attempt to teach programming process implicitly through live coding. One major obstacle preventing more direct instruction on process is that we have no empirically derived terms to describe it. In this paper, we begin to build a set of programming process descriptors by classifying topics and concepts that students pay attention to as they watch replays of other students writing code. We conducted think-aloud interviews with students in a CS1 course while they watched reconstructed playbacks of peers completing a programming task. We observe that, surprisingly, students talk about the temporal aspects of writing code almost twice as often as the code itself. Some participants did not recognize their own code-writing process when played back to them. We also find that students are surprisingly interested in what the programmer is thinking while writing. We identify clusters of similar phrases that students use to describe the evolution of code, such as being written “top to bottom” or “jumping back and forth”. These descriptive features will, in future work, be used to develop and validate quantifiable measures of programming process that are grounded in empirical measures of student behavior.},
	affiliations = {},
	author = {Rau, Matthew and Edwards, John},
	author_keywords = {CS1; keystrokes; programming process},
	doi = {10.1145/3786228.3786229},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {1–10},
	source = {Scopus},
	title = {What Do Students Pay Attention to While Watching Others Code?},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786231,
	abstract = {Human skills, such as teamwork, communication, and ethical reasoning, are crucial in STEM education and the modern workforce. They enable students and professionals to work effectively in diverse teams, translate technical solutions into user-friendly applications, and navigate the complex ethical considerations that often arise in technological innovation. Despite widespread consensus on the importance of human skills, companies face a significant workforce gap. This article describes the design, implementation, and evaluation of an undergraduate software engineering course that embeds human skills and Oxford-style debates directly into its technical and collaborative learning activities by leveraging large language models’ capabilities to address integration barriers (e.g., time constraints, resource scarcity, lack of scaffolding). A mixed-methods evaluation, including pre-/post-surveys and qualitative analysis, examined changes in students’ perceptions of their interest, relevance, learning potential, satisfaction, and transferability of human skills. Results indicate consistently positive interest, relevance, learning potential, satisfaction, and transferability of human skills, suggesting that structured discussion and emphasis on collaboration can reinforce both technical learning and professional skill development. These findings underscore the feasibility of integrating human skills training into technical curricula to prepare students for the collaborative and ethically complex realities of modern software engineering. The implications of embedding human skills training within computing curricula are discussed.},
	affiliations = {},
	author = {Fouh, Eric},
	author_keywords = {Human Skills; Software Engineering Education; Debate-based Learning; Active Learning; Ethics Education},
	doi = {10.1145/3786228.3786231},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {11–19},
	source = {Scopus},
	title = {Integrating Human Skills and Debates into Computing Education: An Experience Report},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786233,
	abstract = {AI-powered chatbots and digital teaching assistants (AI TAs) are gaining popularity in programming education, offering students timely and personalized feedback. Despite their potential benefits, concerns about student over-reliance and academic misconduct have prompted the introduction of “guardrails” into AI TAs—features that provide scaffolded support rather than direct solutions. However, overly restrictive guardrails may lead students to bypass these tools and use unconstrained AI models, where interactions are not observable, thus limiting our understanding of students’ help-seeking behaviors. To investigate this, we deployed a novel AI TA tool with optional guardrails in one lab of a large introductory programming course. As students completed three code writing and debugging tasks, they had the option to receive guardrailed help or use a “See Solution” feature which disabled the guardrails and generated a verbatim response from the underlying model. We investigate students’ motivations and use of this feature and examine the association between use and their course performance. We found that 50% of the 885 students used the “See Solution” feature for at least one problem and 14% used it for all three problems. Additionally, low-performing students were more likely to use this feature and use it close to the deadline as they started assignments later. The predominant factors that motivated students to disable the guardrails were assistance in solving problems, time pressure, and lack of self-regulation. Our work provides insights into students’ solution-seeking motivations and behaviors, which has implications for the design of AI TAs that balance pedagogical goals with student preferences.},
	affiliations = {},
	author = {Kapoor, Amanpreet and Denny, Paul and Porter, Leo and MacNeil, Stephen and Diaz, Marc},
	author_keywords = {AI tutor; Feedback; Digital TAs; Automated Tutors; Programming},
	doi = {10.1145/3786228.3786233},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {22–31},
	source = {Scopus},
	title = {Exploring Student Behaviors and Motivations when using AI Teaching Assistants with Optional Guardrails},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786234,
	abstract = {Large language models (LLMs) have broad implications for education in general, impacting the foundations of what we teach and how we assess. This is especially true in computing, where LLMs tuned for coding have demonstrated shockingly good performance on the types of assignments historically used in introductory CS (CS1) courses. As a result, CS1 courses will need to change in terms of the skills that are taught and how they are assessed. Computing education researchers have begun to study student use of LLMs, but there remains much to be understood about the ways that these tools affect student outcomes. In this paper, we present the design and evaluation of a new CS1 course at a large research-intensive university that integrates the use of LLMs for student learning. We describe the design principles used to create our course, our new course objectives, and evaluation of student outcomes and perceptions throughout the course as measured by assessment scores and surveys. Our findings suggest that 1) student exam performance outcomes, including differences among demographic groups, are largely similar to historical outcomes for courses without integration of LLM tools, 2) large, open-ended projects may be particularly valuable in an LLM context, and 3) students predominantly found the LLM tools helpful, although some had concerns regarding over-reliance on the tools.},
	affiliations = {},
	author = {Vadaparty, Annapurna and Smith, David H. and Srinath, Samvrit and Padala, Mounika and Alvarado, Christine and Gorson Benario, Jamie and Porter, Leo and Zingaro, Daniel},
	author_keywords = {Introductory Programming; CS1; GenAI; LLM; Student Outcomes},
	doi = {10.1145/3786228.3786234},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {32–41},
	source = {Scopus},
	title = {Evaluating CS1-LLM: Integrating LLMs and Examining Student Outcomes in an Introductory Computer Science Course},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786238,
	abstract = {One promising application of Generative Artificial Intelligence (GenAI) in large introductory computing courses is to power automated tools for responding to student queries on online course forums, which can greatly reduce instructor workload and improve the timeliness of responses to students. However, there is a need to carefully evaluate the suitability and effectiveness of AI-generated responses. We address this by comparing bot responses, which are automatically generated using GenAI, and instructor responses, which are manually written by instructors, to student queries on an online forum for a large introductory programming course. Using a rubric derived from previously identified characteristics for effective feedback in programming education, we assess responses on qualities such as helpfulness and conciseness. We find that while bot responses excel in some areas, such as timeliness and comprehensiveness, they are often verbose and not always effective in handling administrative queries or in capturing the interpersonal aspects of human communication. Our findings suggest that AI-generated responses could be immediately published to students, but only as constructive starting points that instructors should review, comment on, or revise to ensure their accuracy and usefulness. This hybrid approach has the potential to create more effective learning environments that leverage the strengths of both automated and human feedback.},
	affiliations = {},
	author = {Feng, Tony Haoran and Hooper, Steffan and Denny, Paul and Wünsche, Burkhard C. and Luxton-Reilly, Andrew},
	author_keywords = {Generative Artificial Intelligence; GenAI; Student Forums; Student Queries; Responses; Automated; Bot; Quality; Characteristics},
	doi = {10.1145/3786228.3786238},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {63–72},
	source = {Scopus},
	title = {Bot or Prof: Comparing the Characteristics of AI-generated and Instructor-written Responses to Student Queries in an Introductory Programming Course Forum},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786241,
	abstract = {Research projects in postgraduate computing education courses often rely on existing datasets due to the practical and ethical constraints of collecting authentic learner data within a single semester. However, finding high-quality data sets can be a considerable challenge for educators. Large language models (LLMs) offer a promising way to address this challenge by enabling the on-demand generation of synthetic data that closely resembles real learner data. This allows research students to practice key elements of the research process, including data cleaning, analysis, and reporting. This paper reports on an initiative in which 44 postgraduate computing education students across 15 groups used LLMs to generate datasets for their research projects. The resulting datasets were highly varied, including buggy code in multiple languages, code with stylistic variations, UML diagrams, and natural language programming prompts. Students valued the efficiency and scalability of this approach but, as expected, raised concerns about authenticity. Several groups also over-relied on AI for analysis, which was not intended. We discuss lessons learned and highlight the potential of synthetic data to enable authentic, scalable, and accessible research experiences in computing education.},
	affiliations = {},
	author = {Denny, Paul and Riegel, Kaitlin and Luxton-Reilly, Andrew and Leinonen, Juho and Prather, James and MacNeil, Stephen},
	author_keywords = {synthetic data; computing education; generative AI; large language models; LLMs; postgraduate projects; synthetic data generation},
	doi = {10.1145/3786228.3786241},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {85–94},
	source = {Scopus},
	title = {Enabling Postgraduate Projects in Computing Education through Synthetic Research Data Generation},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786243,
	abstract = {Generative AI tools such as GitHub Copilot are very effective at producing functional code for many introductory programming tasks, which in turn is impacting how students learn to program. While such tools provide some clear benefits, including offering on-demand explanations, feedback, and debugging support, they also risk reducing students’ engagement in critical evaluation and problem-solving, particularly when AI solutions can be accepted uncritically. Appropriate scaffolding may be effective in slowing down this process and promoting deliberate reasoning. Drawing inspiration from structured activities such as Parsons Problems, and building on recent ideas for quizzing students in real-time as code solutions are being built, we introduce AI Assist Problems, a tool that supports reflective code evaluation by requiring students to generate, review, and accept AI-suggested code one line at a time. While the tool constrains how code is built, it does not constrain what code can be written, allowing students to explore multiple valid pathways and produce diverse final solutions. We deployed this tool in a large first-year programming course (n = 996) and examined student interactions and perceptions, and the diversity of resulting code solutions. We found that greater exploration of AI suggestions predicts higher decision accuracy, and students’ belief in the need to carefully review AI-generated code increased after use. We discuss how structured AI assistance can encourage reflection and critical evaluation as code-generation tools become an integral part of programming education.},
	affiliations = {},
	author = {Qiu, Victor and Parker, Liam and Riegel, Kaitlin and Giacaman, Nasser and Denny, Paul and MacNeil, Stephen and Prather, James},
	author_keywords = {AI Assist Problems; Computing Education; Generative AI; LLMs; Scaffolding; Autosuggestion Quiz; Parsons Problems},
	doi = {10.1145/3786228.3786243},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {102–111},
	source = {Scopus},
	title = {One Line at a Time: Scaffolding Reflective Code Evaluation through Structured AI Assistance},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786244,
	abstract = {Advances in generative artificial intelligence (genAI) are reshaping the way we work. In education, genAI has the potential to aid in personalising learning and providing greater access to education. However, genAI also provides challenges in terms of academic integrity that is forcing many academics to rethink their approach to assessment. This is particularly the case in computing and STEM education, where genAI is able to produce solutions to many typical assessment tasks. In this experience report we present our use of a layered approach to identifying and intervening in suspected cases of AI misuse within introductory programming and discrete mathematics units. Our reflections illustrate how combining formative feedback, in class discussions, learning-focused tasks, and targeted interventions were effective at guiding students towards genuine learning. This provides an illustrative framework for others considering how to tackle challenges in upholding integrity in a positive and supportive manner.},
	affiliations = {},
	author = {Ugon, Julien and Pierce, Charlotte and Cain, Andrew and Laird, Brianna},
	author_keywords = {academic integrity; artificial intelligence; computing education; portfolio assessment},
	doi = {10.1145/3786228.3786244},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {112–118},
	source = {Scopus},
	title = {"You're not learning": A layered formative intervention to turn AI misuse into a learning opportunity},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786247,
	abstract = {Randomisation in programming assessment is a popular way to create many versions of the same question or exam. However, the technique of question pooling, writing multiple distinct questions and presenting students a random one, raises issues of fairness, as it is challenging for experienced programmers, such as tertiary assessors, to determine if two questions are actually of a similar difficulty. Some randomisation techniques, such as simple substitution, only require the question author to write a template, and provide a list of keywords that they want substituted into each part of the question. As these questions are generated by programmatically substituting flavour text, and do not actually change how the student should write their solution at an algorithmic level, it seems reasonable to assume that this type of randomisation is perfectly fair. This paper outlines our first steps in researching whether or not this type of randomisation is actually fair, by analysing 22 questions, with over 17,000 real student responses from an introductory programming course. A cursory analysis, looking solely at student marks, reveals that in some assessments, students perform differently based on what question variant they get. However, a further statistical analysis using one-way ANOVA showed that these differences were not practically meaningful, with no statistical significance between question variant difficulty. Overall, the results suggest that variant randomization did not materially affect student outcomes and that the assessment design was robust and fair across versions. This indicates to us that this form of randomisation is not unfairly discriminating against students, and gives confidence in our continued use of the technique.},
	affiliations = {},
	author = {Hickman, Henry and Bell, Tim},
	author_keywords = {Assessment; Automated Assessment; Programming Assessment},
	doi = {10.1145/3786228.3786247},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {123–130},
	source = {Scopus},
	title = {The Impact of Randomised Questions on Student Outcomes in Introductory Programming Assessment},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786248,
	abstract = {Microcredentials offer flexibility for career changers, specialists, and generalists, yet assessment often remains one-size-fits-all, overlooking diverse goals, contexts, and experience. This paper introduces a novel approach using learner personas to personalise microcredential pathways while maintaining a single credential standard. The design pairs core mandatory tasks—demonstrating postgraduate-level mastery—with optional, persona-aligned tasks tailored to technical, strategic, or creative roles. Set in authentic workplace scenarios, optional tasks let learners explore career pathways, deepen skills, and connect study to real-world practice without affecting credential attainment. Using the Artificial Intelligence (AI) Applications microcredential as example, we show how scaffolded tasks integrate technical application, ethical reasoning, governance evaluation, and strategic planning. Reflections from the design team highlight how personas reshaped assessment thinking, prompting more authentic, career-aligned tasks. This transferable approach demonstrates how assessment can balance rigor and flexibility, support professional identity formation, and provide actionable guidance for educators designing learner-centred, future-focused microcredentials.},
	affiliations = {},
	author = {Tubino, Laura and Zaidi, Nayyar},
	author_keywords = {persona; microcredentials; professional learning},
	doi = {10.1145/3786228.3786248},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {131–137},
	source = {Scopus},
	title = {One Credential, Many Journeys: Persona-Aligned Assessment for Postgraduate Microcredentials in Emerging Technologies},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786249,
	abstract = {A widely used pedagogy in introductory programming courses involves students solving small code-writing exercises with well-defined problem statements. Although such exercises help students practice basic programming skills and become familiar with syntax, they offer little opportunity to interpret or clarify ambiguous requirements. However, real-world programming rarely provides such clarity. Developers must interpret incomplete specifications, ask questions, and resolve inconsistencies before writing code. At the same time, advances in large language models (LLMs) have made well-specified programming problems trivial to solve, allowing students to obtain correct solutions with little effort when task requirements are explicit. In this paper, we present a web-based tool that delivers ‘Probeable Problems’ which are programming tasks with deliberately ambiguous specifications that require students to clarify requirements before coding. Our tool extends prior implementations by enabling students to engage in a natural language dialogue with an AI “client” to uncover and resolve ambiguities, alongside a traditional mechanism for probing behaviour using code inputs. We deployed the tool in a large introductory programming course and examined how students engaged with the conversational interface. Students reported that the tool helped them appreciate the importance of asking specific questions and valued the realism of interacting with a simulated client, even when they found the tasks challenging. We also found that greater exploration of ambiguities was associated with fewer failed attempts, indicating that deliberate inquiry before coding supports more effective problem solving.},
	affiliations = {},
	author = {Tang, Kay and Tong-Ho, Hoanh Nguyen Hosea and Riegel, Kaitlin and Denny, Paul and Giacaman, Nasser and Leinonen, Juho},
	author_keywords = {Probeable Problems; CS1; programming education; large language models; test cases; requirements; ambiguity},
	doi = {10.1145/3786228.3786249},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {138–147},
	source = {Scopus},
	title = {Ambiguity by Design: Practicing Requirement Clarification through Natural-Language Dialogue with LLMs},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786250,
	abstract = {A recent study investigating the effectiveness of a large language model (LLM) tutor in supporting non-native English-speaking students (NNES) in introductory computer science courses showed promising results. It demonstrated that LLMs can be leveraged to better support NNES by facilitating learning in their native languages. In this study, we repeat the previous experiment to confirm the results while addressing some key validity threats. We used a more advanced LLM, introduced the LLM Tutor from the beginning of the course, and enabled multilingual responses instead of English-only ones. For LLM Tutor usage, we found that (a) NNES showed a marginally higher enrollment rate compared to NES; (b) both groups demonstrated similar overall levels of CodeHelp usage; (c) NES and NNES exhibited parallel temporal usage patterns; (d) NNES made substantially greater use of non-English and multilingual queries, whereas NES queries were almost exclusively in English; and (e) multilingual queries often combined English programming keywords with other natural languages, reflecting code-meshed language use. Overall, students viewed the LLM Tutor as an immediate and valuable aid for independent learning, particularly valuing its guided support rather than direct answers. However, some expressed concerns regarding its accuracy, usability, and potential to foster over-reliance or compromise academic integrity. Some other students preferred other available resources or were unaware of the tool. These findings suggest that while LLM-based tools hold strong potential to enhance self-directed learning, their design and implementation should balance accessibility and guidance with safeguards that promote responsible and critical use.},
	affiliations = {},
	author = {Kavuri, Sriharsha and Delgado-Diaz, Danae and Ortiz, Kristhian and Chao, Alex and Villegas Molina, Ismael and Ochoa, Benjamin and Porter, Leo},
	author_keywords = {LLMs; large language models; digital teaching assistants; tutoring systems; non-native english speakers; NNES},
	doi = {10.1145/3786228.3786250},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {148–157},
	source = {Scopus},
	title = {Further Study of Leveraging LLM Tutoring Systems for Non-Native English Speakers in Introductory Computer Science},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3786228.3786255,
	abstract = {Introductory programming courses often rely on small code-writing tasks with clear and complete problem specifications. Such tasks limit opportunities for students to practice clarifying ambiguous requirements – a critical skill in real-world programming. Given the ubiquity of large language models (LLMs) that can produce accurate solutions for such well-specified tasks, students may question the relevance of learning to write code for such tasks. Probeable Problems, by contrast, deliberately omit essential details, encouraging students to think critically, identify ambiguities, and seek clarifications. This study builds on theories of metacognition, cognitive flexibility, and design thinking to explore the strategies used by human students when tackling ambiguous programming tasks. For three Probeable Problems, we analyze the contents of 40,000 student-written probes to investigate how thoroughly and efficiently students are able to explore ambiguities. Our results offer insights into the effective design of feedback for Probeable Problems, and emphasize the benefits of engaging learners with authentic, ill-structured problems to enhance critical thinking and metacognitive skills.},
	affiliations = {},
	author = {Kumar, Viraj and Denny, Paul and Leinonen, Juho and Prather, James and MacNeil, Stephen},
	author_keywords = {Probeable Problems; CS1; test cases; requirements; ambiguity},
	doi = {10.1145/3786228.3786255},
	issn = {},
	journal = {Proceedings of the 28th Australasian Computing Education Conference},
	keywords = {},
	number = {},
	pages = {182–191},
	source = {Scopus},
	title = {Unraveling Ambiguities: Analyzing Student Approaches to Solving Probeable Problems},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3788042,
	abstract = {As AI is increasingly used in public services, concerns have grown about bias and misalignment with community values. To investigate how ordinary citizens reason about fairness in public-sector AI, we conducted a scenario-based study with 110 participants who evaluated 13 algorithmically-informed government decision systems. Drawing on their responses, we analyze how auditors evaluate risks, identify impacted groups, and navigate fairness trade-offs. Our findings reveal that participants do not audit arbitrarily; they adjust their evaluations to context, reason from values, and exhibit principled subjectivity by applying fairness orientations consistently while remaining sensitive to scenario-specific details. However, we also observe tensions between bias recognition and prioritization, suggesting a gap between awareness and actionable design focus. Building on literature in participatory AI, algorithmic impact assessments, and user-driven auditing, we argue that good auditors are not merely detectors of error but normative agents who surface latent value tensions. We conclude by offering design implications for audit tooling that supports individual and group deliberation, trade-off reasoning, and equity-centered decision-making in the oversight of public algorithms.},
	affiliations = {},
	author = {Jackson, Corey and Ahmad, Tallal and Raj, Shelcia David and Wu, Natalie},
	author_keywords = {AI auditing; algorithmic fairness; participatory AI; value-centered design; bias detection; public interest technology},
	doi = {10.1145/3788042},
	issn = {},
	journal = {Proc. ACM Hum.-Comput. Interact.},
	keywords = {},
	number = {2},
	pages = {},
	source = {Scopus},
	title = {Beyond Bias Detection: Community Auditors and Normative Reasoning in AI Oversight},
	type = {Article},
	volume = {10},
	year = {2026}
}

@article{10.1145/3788910.3789010,
	abstract = {Artificial Intelligence (AI) has increasingly penetrated the field of education, reshaping teaching practices through algorithmic recommendation, intelligent feedback, and automated assessment. To quantitatively analyze K–12 teachers’ acceptance and trust of AI teaching tools, this study applies a computer-assisted modeling framework that integrates the Technology Acceptance Model (TAM) with computational methods such as structural equation modeling (SEM) and data visualization. The research employs AMOS 26.0 and Python-based statistical scripts for covariance matrix computation, path coefficient estimation, and bootstrapping analysis, ensuring reproducibility and algorithmic transparency. The empirical findings, based on 584 valid teacher samples, demonstrate that perceived usefulness, perceived ease of use, and trust in AI jointly predict behavioral intention toward AI adoption, with institutional support and professional identity serving as significant contextual moderators. The computer-based model achieves strong goodness-of-fit indices (χ²/df = 2.41, RMSEA = 0.049, CFI = 0.945) and stable predictive accuracy (RMSE = 0.162), confirming the robustness of computational estimation. This study thus highlights how computational modeling and algorithmic analysis can reveal the cognitive and emotional mechanisms underlying teachers’ technology acceptance, offering both theoretical and technological insights for the design of trustworthy, data-driven educational AI systems.},
	affiliations = {},
	author = {Yi, Fang},
	author_keywords = {Artificial Intelligence in Education; Educational technology adoption; Human–AI collaboration; K–12 teachers; Teacher trust; Technology Acceptance Model (TAM)},
	doi = {10.1145/3788910.3789010},
	issn = {},
	journal = {Proceedings of the 2025 International Conference on Digital Society and Intelligent Computing},
	keywords = {},
	number = {},
	pages = {672–677},
	source = {Scopus},
	title = {K–12 Teachers' Acceptance and Trust of Artificial Intelligence Teaching Tools: A Computer-Assisted Analysis Based on the Technology Acceptance Model},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3788910.3789030,
	abstract = {Against the backdrop of digital transformation, the integrated development of aesthetic education and extracurricular programs in vocational colleges faces challenges such as fragmented resources and a monolithic evaluation system. To address this, an AI-supported personalized learning system for aesthetic education in computer science extracurricular programs was designed. This system incorporates an intelligent recommendation engine and adaptive adjustment mechanism to achieve smart resource matching and dynamic learning path generation. Experimental validation demonstrates that this solution effectively enhances aesthetic education outcomes for computer science students, offering new insights for digital reform in vocational college aesthetic education.},
