	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {Enhancing Automated Assignment Assessment in Higher Education with a CNN–BiLSTM Model},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11147305,
	abstract = {This paper examines the potential of GPT-4 as an automated grading system for open-ended questions in computer science education, employing an extended version of Bloom’s Taxonomy as its theoretical framework. Traditionally, the evaluation of open-ended responses has relied on labor-intensive manual grading, which is not only time-consuming but also subject to variability in consistency and subjective bias. Recent advances in natural language processing, however, offer promising alternatives by enabling the automation of complex evaluative tasks. This study aims to investigate whether GPT-4 can serve as a reliable and scalable tool for formative assessments in educational environments, thereby reducing the workload on educators and providing timely, consistent feedback to students. A quantitative comparison between GPT-4’s evaluations and those of human experts reveals moderate alignment, with stronger consistency at lower cognitive levels (e.g., recall and application) and more pronounced discrepancies at higher levels (e.g., evaluation and creation). Statistical metrics, including Pearson’s correlation, Intraclass Correlation Coefficient (ICC), and Cosine Similarity, were employed to measure agreement. The findings demonstrate that GPT-4 can effectively maintain relative rankings of student performance, providing a scalable option for formative assessments. However, limitations remain in nuanced and context-specific evaluations, requiring further refinement for deployment in the evaluation process.},
	affiliations = {},
	author = {Heimberg, Matthias and Bernhard, Willi},
	author_keywords = {Training; Analytical models; Adaptation models; Scalability; Taxonomy; Probabilistic logic; Computer science education; Reliability; Artificial intelligence; Tuning; Automated grading; extended Bloom’s taxonomy; GPT-4; Open-ended questions},
	doi = {10.1109/ISEC64801.2025.11147305},
	issn = {2473-7623},
	journal = {2025 IEEE Integrated STEM Education Conference (ISEC)},
	keywords = {},
	number = {},
	pages = {1-7},
	source = {Scopus},
	title = {GPT-4 as an Automatic Grading System for Open-Ended Questions in Computer Science Education},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11147332,
	abstract = {Contemporary learners routinely acquire knowledge asynchronously from sources outside of formal learning settings, thus increasing the demand for instructional technologies to address the learners’ various knowledge gaps within STEM fields. Whereas post-assessment remediation is a high payoff target for such interventions, we investigate invoking Generative AI (GenAI) to ‘prime the pump’ for learners with any needed terminology, concepts, and technical-leveling prior to conventional human-delivered remediation. We have developed the GenAIprime framework that invokes GenAI Large Language Models (LLMs) to create personalized, multimedia-based remedial materials by prompting GenAI with the specific incorrect responses to each student’s digitized quiz/exam submission. By integrating with the Canvas Learning Management System (LMS), GenAIprime analyzes assessment content and extracts context using the OpenAI GPT 3.5 Turbo model. In addition to high relevancy, it also demonstrates a 2.15-fold execution speedup over the local Llama 3.1 model for more feasible extension to institutional-scale delivery. The platform offers students a detailed performance overview and targeted video recommendations to address misconceptions, while instructors can monitor progress, refine AI-driven suggestions, and provide contextual feedback. The potential for GenAIprime to enhance learning outcomes by focusing learners’ time and attention is described herein as a novel instructional technology that can be delivered and scaled up with minimal burden to instructional staff.},
	affiliations = {},
	author = {Amoruso, Paul and Chen, Baiyun and De Mara, Ronald F.},
	author_keywords = {Learning management systems; Analytical models; Generative AI; Terminology; Large language models; Focusing; Monitoring; STEM; Videos; Context modeling; Instructional Technology; Large-Language Model; Remedial Instruction; STEM Instruction; Skill-Leveling},
	doi = {10.1109/ISEC64801.2025.11147332},
	issn = {2473-7623},
	journal = {2025 IEEE Integrated STEM Education Conference (ISEC)},
	keywords = {},
	number = {},
	pages = {1-4},
	source = {Scopus},
	title = {GenAIprime: Generative AI for Remediation-Priming of Knowledge Gaps by Dynamically Creating Multimedia Learning Resources},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11147374,
	abstract = {Grading programming assignments is a labor-intensive and time-consuming process that demands careful evaluation across multiple dimensions of the code. To overcome these challenges, automated grading systems are leveraged to enhance efficiency and reduce the workload on educators. Traditional automated grading systems often focus solely on correctness, failing to provide interpretable evaluations or actionable feedback for students. This study introduces StepGrade, which explores the use of Chain-of-Thought (CoT) prompting with Large Language Models (LLMs) as an innovative solution to address these challenges. Unlike regular prompting, which offers limited and surface-level outputs, CoT prompting allows the model to reason step-by-step through the interconnected grading criteria, i.e., functionality, code quality, and algorithmic efficiency, ensuring a more comprehensive and transparent evaluation. This interconnectedness necessitates the use of CoT to systematically address each criterion while considering their mutual influence. To empirically validate the efficiency of StepGrade, we conducted a case study involving 30 Python programming assignments across three difficulty levels (easy, intermediate, and advanced). The approach is validated against expert human evaluations to assess its consistency, accuracy, and fairness. Results demonstrate that CoT prompting significantly outperforms regular prompting in both grading quality and interpretability. By reducing the time and effort required for manual grading, this research demonstrates the potential of GPT-4 with CoT prompting to revolutionize programming education through scalable and pedagogically effective automated grading systems.},
	affiliations = {},
	author = {Akyash, Mohammad and Azar, Kimia Zamiri and Mardani Kamali, Hadi},
	author_keywords = {Codes; Accuracy; Large language models; Education; Manuals; Algorithmic efficiency; Programming profession; Python; Large Language Models; Programming Assignments; Automated Grading; Chain-of-Thought Prompting},
	doi = {10.1109/ISEC64801.2025.11147374},
	issn = {2473-7623},
	journal = {2025 IEEE Integrated STEM Education Conference (ISEC)},
	keywords = {},
	number = {},
	pages = {1-6},
	source = {Scopus},
	title = {StepGrade: Grading Programming Assignments with Context-Aware LLMs},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

@article{11147424,
	abstract = {This innovative practice paper explores the integration of ChatGPT into the feedback process for university programming courses, addressing the growing demand for efficient and consistent grading and feedback. The research involved a cohort of postgraduate students enrolled in a compulsory Java programming module. ChatGPT was utilized to generate feedback, which was then compared with traditional feedback methods. The results demonstrated that ChatGPT could produce quick, accurate, and human-like responses, significantly reducing the workload for faculty. Feedback generation was generally well-narrated and detailed, although occasional technical errors required manual adjustments. A survey conducted with the student cohort revealed that 75% of respondents preferred ChatGPT-generated feedback over traditional methods, appreciating its detailed and constructive nature. However, some students expressed a need for more specific guidance, such as code snippets. Lecturers also noted that while the AI feedback was efficient, it sometimes lacked the empathetic tone of human-generated comments. Despite these challenges, the overall response from both students and faculty was positive, highlighting the potential of ChatGPT to enhance the feedback process in programming education.},
	affiliations = {},
	author = {McGowan, Aidan and Anderson, Neil and Smith, Chris},
	author_keywords = {Surveys; Fabrication; Java; Accuracy; Manuals; Chatbots; Reliability; Artificial intelligence; Programming profession; STEM; programming; Gen AI; ChatGPT; university; feedback},
	doi = {10.1109/ISEC64801.2025.11147424},
