	volume = {16},
	year = {2025}
}

@article{10.1145/3769126.3769244,
	abstract = {This article presents a framework for automating legal reasoning in judicial decisions using LLMs. It combines advanced techniques, including Chain-of-Density prompting, the CO-STAR methodology, and the FIRAC model, to analyze requests, claims, and evidence, generating structured and coherent reasoning. Evaluated on first-instance cases from a Brazilian State Court of Justice, the framework was assessed using ROUGE, METEOR, CHRF, TER, ALIGNSCORE, and BERTSCORE metrics. While lexical metrics revealed challenges in abstractive text generation, semantic metrics showed strong alignment with reference texts, confirming the framework’s ability to preserve meaning. The results highlight its potential to streamline judicial workflows, enhance consistency, and improve transparency.},
	affiliations = {},
	author = {Bomfim, Francisco and Neto, João and Neves, Alicia and Furtado, Vasco and Silva, Sara and Pinheiro, Vladia},
	author_keywords = {Generative Artificial Intelligence (GAI); Legal Reasoning Automation; Judicial Decision-Making; Large Language Models (LLMs)},
