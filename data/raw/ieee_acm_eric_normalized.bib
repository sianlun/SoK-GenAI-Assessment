@article{10.1145/3796496.3811779,
	abstract = {In Advanced Placement computer science (APCS) courses, students are often asked to complete short Java programming problems, a practice that can be challenging for beginners to the topic. One scaffolding approach is the use of mixed-up code puzzles, known as Parsons puzzles. We present a thematic analysis of 12 minoritized high school women enrolled in AP CS courses. We examine how they used Parsons puzzles as scaffolding during short programming tasks, as well as their perceptions of this support. This work extends existing research by examining how minoritized high school women use Parsons puzzles as scaffolding in short programming tasks.},
