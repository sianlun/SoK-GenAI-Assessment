}

@article{10.1145/3806980.3807050,
	abstract = {Online education platforms face persistent challenges in delivering effective personalized learning at scale. Current approaches suffer from three critical limitations: (1) inadequate evaluation frameworks that fail to capture multi-dimensional pedagogical capabilities of large language models across varying difficulty levels, (2) static learning path generation that ignores individual student states and temporal knowledge dynamics, and (3) isolated single-agent architectures that lack collaborative intelligence for sustained engagement and knowledge retention. We propose AMALS (Adaptive Multi-Agent Learning Systems), a hierarchical framework integrating LLM assessment, reinforcement learning-based optimization, and multi-agent collaboration. Our approach introduces three key innovations: (1) a difficulty-adaptive evaluation mechanism with exponential decay modeling for robust LLM selection, (2) a Markov Decision Process formulation with composite reward functions balancing immediate gains and long-term retention, and (3) a three-agent collaborative architecture (Tutor-Peer-Evaluator) with dynamic contribution rebalancing. Extensive experiments on simulated student populations demonstrate that AMALS achieves 15-20% improvement in learning performance, 30% higher engagement retention over 30 sessions, and 72% knowledge retention after 30 days compared to single-agent baselines.},
	affiliations = {},
	author = {Ma, Chenyang and Tan, Rui and Yu, Sitong},
	author_keywords = {Adaptive Assessment; Knowledge Tracing; Large Language Models; Multi-Agent Systems; Online Education; Personalized Learning; Reinforcement Learning},
	doi = {10.1145/3806980.3807050},
	issn = {},
	journal = {Proceedings of the 2026 International Conference on Big Data and Informatization Education},
	keywords = {},
	number = {},
	pages = {445–450},
	source = {Scopus},
	title = {Adaptive Multi-Agent Learning Systems: A Reinforcement Learning Framework with LLM-Powered Assessment for Personalized Online Education and study},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3806980.3807090,
	abstract = {The rapid rise of Generative Artificial Intelligence (GenAI) is forcing higher education institutions to fundamentally rethink their governance models. While early responses were often fragmented or purely reactive, this study moves beyond qualitative debate to provide a systematic, data-driven evaluation of AI policies at the world's top 50 universities (QS 2026). We introduce a novel AI Policy Acceptance Model (APAM) to quantify institutional stances across three specific fronts: Permissibility, Ethical Density, and Pedagogical Integration. By applying Natural Language Processing (NLP) to policy documents from leaders like MIT, Oxford, and ETH Zurich, we established a quantitative benchmark for governance maturity. Our multi-dimensional analysis, backed by linear ({rm{regression }}( {{{rm{R}}}^2 approx 0.48} ) ), reveals a strong link: as institutional prestige rises, so does policy openness. The data exposes a strategic divergence where elite institutions are moving from “defensive prohibition” to “integrated empowerment,” often securing data sovereignty through enterprise-grade firewalls. This paper delivers a standardized quantitative framework for benchmarking AI governance in engineering and global education.},
	affiliations = {},
	author = {Zhou, Huiqian and Feng, Jingjing and Deng, Shuangquan and Zeng, Qinghui},
	author_keywords = {APAM Model; Data Mining; Engineering Education Governance; Generative AI; Higher Education Policy; NLP},
	doi = {10.1145/3806980.3807090},
	issn = {},
	journal = {Proceedings of the 2026 International Conference on Big Data and Informatization Education},
	keywords = {},
	number = {},
	pages = {697–702},
	source = {Scopus},
	title = {Quantitative Assessment of Generative AI Governance in Global Higher Education: A Multi-Dimensional Policy Spectrum Analysis of Elite Global Universities},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3806980.3807111,
	abstract = {Based on a systematic review of 4,863 articles about the educational uses of Generative Artificial Intelligence published before October 28, 2025, this study employs visualization techniques to analyze the literature. The results show that a research network centered on artificial intelligence, generative AI, and large language models has been created in the field. Additionally, 11 thematic clusters were identified, covering technical fundamentals, disciplinary integration, learning theories, and user acceptance, thus illustrating a diverse research landscape. This study shows that successfully integrating generative artificial intelligence into education depends on cross-disciplinary technology collaboration and well-organized human-machine teamwork. Significant practical benefits have been seen in the main areas, such as personalized learning, academic writing assistance, and science education. User acceptance is influenced by various factors, including habits, performance expectations, and AI literacy; however, the use of these technologies also encounters challenges such as factual accuracy, data privacy, and ethical concerns. Future research on AI applications in education can advance in four key areas. It can improve the study of technology acceptance and its influencing pathways while observing users’ actual experiences. It should expand interdisciplinary empirical research and carefully examine application methods and ethical boundaries in highly specialized contexts. It may incorporate technical models to explore proactive and personalized learning support systems. It also needs to strengthen dynamic and inclusive ethical governance frameworks and develop contextually adaptable literacy courses.},
	affiliations = {},
	author = {Liu, Qi and Ren, Huichan},
	author_keywords = {CiteSpace; Education; Generative Artificial Intelligence; Pathways; Visualization},
	doi = {10.1145/3806980.3807111},
	issn = {},
	journal = {Proceedings of the 2026 International Conference on Big Data and Informatization Education},
	keywords = {},
	number = {},
	pages = {842–846},
	source = {Scopus},
	title = {Research on the Pathways of Integrating Generative Artificial Intelligence into Education: A Visualization Analysis Based on CiteSpace},
	type = {Conference paper},
	volume = {},
	year = {2026}
}

@article{10.1145/3806980.3807156,
	abstract = {Taking the course “UI Element Graphic Creative Design” in institute education as an example, this article focuses on the requirements for design talents’ digital literacy in the digital and intelligent era. It constructs a “three-level differentiated” teaching model oriented towards digital literacy cultivation and driven by multi-modal AI and adaptive learning algorithms. This model first applies Analytic Hierarchy Process (AHP) to determine the weight distribution of digital literacy goals. The course content is divided into five modules: icons, logos, advertisements, illustrations, and interfaces. Each module is designed with three progressive difficulty levels of design tasks—”basic, comprehensive, and innovative”—enabling adaptive learning path selection through a capability-transfer model (LI) and a capability-project matching model (MM). Throughout the teaching process, multi-modal AI tools such as Midjourney, GPT-4V, Figma AI, Hotjar, Dreamina, and ERNIE Bot are deeply integrated, supporting intelligent assistance in design generation, user behavior analysis, and solution evaluation. A quantitative evaluation system for AI design schemes is established using the fuzzy comprehensive evaluation method. Teaching practice demonstrates that this technology-enhanced model significantly improves students’ UI design skills, digital literacy, and learning initiative (p&lt;0.001), effectively promoting the transformation of teaching from “knowledge impartation” to “technology-empowered literacy development”. It provides an operable, computer-technology-driven implementation path for the intelligent and personalized reform of design courses in institute education.},
	affiliations = {},
	author = {Wei, Yunke and Lin, Weijian},
	author_keywords = {AI-empowered; Adaptive Learning Algorithm; Digital Literacy; Multi-Modal AI; Teaching Model; Three-level Differentiated; UI Design},
	doi = {10.1145/3806980.3807156},
	issn = {},
	journal = {Proceedings of the 2026 International Conference on Big Data and Informatization Education},
	keywords = {},
