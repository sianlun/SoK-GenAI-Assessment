@article{10.1145/3795154.3795325,
	abstract = {To enhance enterprise-level data asset governance capabilities and improve the collaborative processing performance of heterogeneous business systems, this study proposes a distributed architecture-based information data management platform. The platform is designed to address challenges in data standardization, quality control, and compliance auditing that commonly arise in complex application environments. Key components of the system include a Schema Registry for semantic consistency, a data quality (DQ) engine for integrity and accuracy validation, and Apache Atlas for metadata and lineage tracking. These modules collaboratively enable dynamic enforcement of data standards, continuous monitoring of data quality metrics, and rule-based verification of access control policies. The platform supports multi-source data integration, real-time rule execution, and closed-loop governance across the full data lifecycle. Performance validation was conducted using the TPC-DS benchmark dataset, simulating enterprise workloads at scales ranging from 100 GB to 1 TB with concurrent users up to 500. Results demonstrate that the system maintains stable operation under high-throughput access, with low-latency processing and high consistency scores. The architecture effectively satisfies enterprise demands for high concurrency, standardized data governance, and compliance in distributed big data environments.},
	affiliations = {},
	author = {Yang, Lei},
	author_keywords = {},
	doi = {},
