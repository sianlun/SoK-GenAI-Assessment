	title = {Design and Implementation of an Enterprise Information Data Management Platform Based on Big Data Technology},
	type = {Book chapter},
	volume = {},
	year = {2026}
}

@article{10.1145/3795546.3795580,
	abstract = {This study explores the integration of artificial intelligence (AI) to optimize professional cluster reform in higher engineering education. Drawing on questionnaire data, a one-dimensional convolutional neural network (1D-CNN) combined with correlation analysis was used to identify critical factors affecting students’ satisfaction and learning engagement. The model achieved strong reliability (Cronbach's α = 0.958, KMO = 0.921) and high predictive accuracy (92.4%, F1 = 0.90), confirming its robustness. Results reveal that employability, enterprise collaboration, AI-based personalized learning, virtual simulation, and interdisciplinary courses significantly enhance students’ positive perceptions. Based on these insights, a strategic framework was formulated to strengthen digital infrastructure, deepen industry–education integration, establish feedback mechanisms, and foster interdisciplinary innovation. The findings demonstrate that AI-enabled analytical models can effectively convert learner perceptions into actionable educational strategies, providing a sustainable, data-driven pathway for curriculum modernization and talent cultivation aligned with intelligent industrial transformation.},
	affiliations = {},
	author = {Zhang, Xiaojiao},
	author_keywords = {Artificial Intelligence (AI); Convolutional Neural Networks (CNN); Professional Cluster Iteration; Vocational Undergraduate Universities},
	doi = {10.1145/3795546.3795580},
