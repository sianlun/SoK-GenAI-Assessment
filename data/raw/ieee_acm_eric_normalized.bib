@article{10.1145/3764593,
	abstract = {Programming demands a variety of cognitive skills, and mastering these competencies is essential for success in computer science education. The importance of formative feedback is well acknowledged in programming education, and thus, a diverse range of techniques has been proposed to generate and enhance formative feedback for programming exercises. This article reviews state-of-the-art automated feedback generation techniques and categorizes the various approaches based on the underlying computational techniques, programming languages, the kind of programming errors they deal with, and the type of feedback they provide. It covers data-driven techniques, those which use program repair methods, machine learning-based techniques, and techniques based around the use of large language models, particularly noting the rapid uptake of the latter. The article provides a summary of key findings and challenges, alongside recommendations for future work. The findings reveal that although there exist numerous tools for automated programming feedback, many studies depend on non-public benchmarks, which limits reproducibility and independent evaluation of the tools and their datasets. Additionally, tools are not always language agnostic and in some cases involve complex configuration steps. Large language models have demonstrated transformative potential in generating feedback. However, most research has focused on introductory courses (CS1 and CS2) indicating the need to apply them in advanced fields like machine learning and image processing. Although large language models have outperformed traditional approaches, challenges related to hallucinations and incorrect responses still need to be addressed as precision is critical in a pedagogical setting. Most of the studies use proprietary models that lack transparency and customization options, emphasizing the need for further research into open LLM alternatives.},
	affiliations = {},
	author = {Kumar, Smitha S. and Lones, Michael A. and Maarek, Manuel and Zantout, Hind},
	author_keywords = {literature review; automated feedback; hints; learning programming; programming languages},
	doi = {10.1145/3764593},
	issn = {},
	journal = {ACM Trans. Comput. Educ.},
	keywords = {},
	number = {4},
	pages = {},
	source = {Scopus},
	title = {Navigating the Landscape of Automated Feedback Generation Techniques for Programming Exercises},
	type = {Article},
	volume = {25},
	year = {2025}
}

@article{10.1145/3764687.3764698,
	abstract = {Language does practical work in design: the ways students refer to people, position expertise, and describe methods signal orientations that surface in their design decisions. In inclusive and accessible computing courses, attitude surveys often show ceiling effects; discourse-in-use offers a situated indicator of learning and partnership quality. We report a two-cohort, longitudinal, mixed-methods study within a one-semester service-learning course on inclusive and assistive IT design co-taught at two German universities. Students from computer science and related programs (2023: N = 30; 2024: N = 16) completed four within-semester measurement waves, comprising surveys administered to all students and repeated interviews with a fixed sub-sample in each cohort. Based on lessons learned from Cohort&nbsp;1, Cohort&nbsp;2 implemented four structured co-design checkpoints with people with diverse disabilities and complex support needs. Across both cohorts, qualitative analysis identified consistent discursive shifts: students moved from generic or deficit-oriented phrasing toward individualized, collaborative, and design-with framings. Prior disability-related experience shaped entry points but not direction; the steepest shifts appeared among students without prior exposure once iterative co-design was in place. Quantitative attitudes toward people with disabilities scores indicated a high, stable baseline and did not mirror these discursive changes. We offer an auditable, time-resolved account of discursive development in inclusive and accessible computing education and point to three curricular levers that appear to foster and make such development visible: structured co-design checkpoints, discourse-aware reflection, and facilitation attuned to diverse communication needs.},
	affiliations = {},
	author = {Hermann, Julia and Dogangün, Aysegül},
	author_keywords = {discourse analysis; language use; accessibility; computing education; co-design; participatory design; service-learning; disability; mixed methods},
	doi = {10.1145/3764687.3764698},
	issn = {},
	journal = {Proceedings of the 37th Australian Conference on Human-Computer Interaction},
	keywords = {},
	number = {},
	pages = {271–286},
	source = {Scopus},
	title = {Toward Dialogue: Longitudinal Shifts in Computing Students’ Discourse Through Sustained Engagement with People with Diverse Support Needs},
	type = {Conference paper},
	volume = {},
	year = {2025}
}

