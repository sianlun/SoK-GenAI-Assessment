@CONFERENCE{Martinez-Tellez2023,
	author = {Martinez-Tellez, Reyna and Camacho-Zuniga, Claudia},
	title = {Enhancing mathematics education through AI Chatbots in a Flipped Learning Environment},
	year = {2023},
	journal = {2023 IEEE IFEES World Engineering Education Forum and Global Engineering Deans Council: Convergence for a Better World: A Call to Action, WEEF-GEDC 2023 - Proceedings},
	pages = {},
	doi = {10.1109/WEEF-GEDC59520.2023.10343838},
