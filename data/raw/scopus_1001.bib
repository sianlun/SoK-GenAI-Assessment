@CONFERENCE{El-Damak2025,
	author = {El-Damak, Dina Reda and Alexan, Wassim},
	title = {Using Large Language Models to Create a Universal Framework for Secure Exam Generation},
	year = {2025},
	journal = {2025 IEEE 4th German Education Conference, GECon 2025},
	pages = {},
	doi = {10.1109/GECon64629.2025.11369381},
	url = {https://www.scopus.com/pages/publications/105034744275?origin=resultslist},
	affiliations = {German University in Cairo, Faculty of Information Engineering and Technology, Egypt},
	abstract = {Creating final exams that meet accreditation standards and Bloom's Taxonomy with diverse question types remains a persistent challenge. Manual preparation from lecture PDFs is time-consuming and predictable, while large language models (LLMs) like OpenAI's GPT, xAI's Grok, Perplexity, Google's Gemini, and DeepSeek offer efficient alternatives, though their security and originality require validation. This study develops a universal framework for secure exam generation through multiple phases. In Phase 1, PDF lectures and sample questions are provided to an LLM provider, which generates a final exam aligned with accreditation-mandated types (e.g., MCQs, problems, essay questions) and Bloom's levels, evaluated by instructors for quality. Phase 2 integrates PDF lectures, the previous two exams, and a blank exam specification table as inputs; the LLM outputs a secure N-question exam and a completed table mapping questions to lectures, types, and Bloom's levels, using natural language processing (NLP) and cryptographically secure randomized sampling to ensure unpredictability and compliance. Phase 3 focuses on generating multiple exams of similar difficulty for computerized testing, enabling unique assessments for students seated in the same testing venue or computer laboratory, enhancing equity. The resulting framework outperforms manual methods, reducing preparation time and ensuring integrity through cryptography. Preliminary trial of Phase 1 suggests high compliance with standards like those of NAQAAE, ABET, and ACQUIN. This phased approach leverages LLMs' strengths, offering a scalable, secure solution for modern assessments in engineering education. Further testing across institutions and broader adoption are recommended to validate and refine the framework.  © 2025 IEEE.},
	author_keywords = {Accreditation standards; Bloom's Taxonomy; Cryptography; Engineering education; Large language models (LLMs); Secure exam generation},
	keywords = {Accreditation; Blooms (metal); Computer testing; Education computing; Engineering education; Natural language processing systems; Regulatory compliance; Accreditation standard; Bloom taxonomies; Google+; In-phase; Language model; Large language model; Phase 1; Phase 2; Question type; Secure exam generation; Cryptography},
