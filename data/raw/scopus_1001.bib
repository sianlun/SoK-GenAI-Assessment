	journal = {Proceedings - 9th International Conference on Information Technology, InCIT 2025},
	pages = {235 - 242},
	doi = {10.1109/InCIT66780.2025.11276004},
	url = {https://www.scopus.com/pages/publications/105031094414?origin=resultslist},
	affiliations = {Universitas Gadjah Mada, Department of Electrical and Information Engineering, Yogyakarta, Indonesia; Politeknik Negeri Jember, Department of Information Technology, Jember, Indonesia; Universitas Gadjah Mada, Faculty of Psychology, Yogyakarta, Indonesia},
	abstract = {Large Language Models (LLMs) are widely used in education; however, the responses frequently fail to capture learners' real-time progress or task context. This paper presents a Kanban-driven context engineering framework for LLM prompts that incorporates structured workflow data, including task states, deadlines, and activity logs, to improve pedagogical alignment and feedback accuracy. Using the RAGAS assessment pipeline, the framework was tested across three LLMs (OpenAI/gpt-oss-120b, deepseek-r1-distill-llama-70b, and gemma2-9b-it) to evaluate semantic similarity and response efficiency. The results demonstrate that OpenAI/gpt-oss-120b achieved the best balance of accuracy and latency, with an average similarity of 0.68 and a response time of 5.1 s, above the others. A usability test conducted with fifty graduate students provided an average System Usability Scale (SUS) score of 84.4, suggesting high acceptance and interaction quality. The findings show that a structured Kanban context enhances response relevance, interaction, and user satisfaction while being computationally efficient. This paradigm provides a scalable framework for creating context-aware pedagogical agents, connecting workflow analytics and adaptive learning, and directing future research on multimodal and self-regulated learning support.  © 2025 IEEE.},
	author_keywords = {Context Engineering; Context-aware Chatbot; Kanban; Large Language Model; Pedagogic Agent},
	keywords = {Computation theory; Engineering education; Intelligent agents; Learning systems; Semantics; Students; Teaching; Usability engineering; User interfaces; Chatbots; Context engineering; Context-Aware; Context-aware chatbot; Kanbans; Language model; Large language model; Pedagogic agent; Task-oriented; Work-flows; Acceptance tests},
