	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Tsakalerou2026,
	author = {Tsakalerou, Mariza and Lukhmanov, Yevgeniy},
	title = {The ethical frontier: ChatGPT’s cultural impact on academic practices},
	year = {2026},
	journal = {Innovations in Education and Teaching International},
	pages = {},
	doi = {10.1080/14703297.2026.2614477},
	url = {https://www.scopus.com/pages/publications/105027968800?origin=resultslist},
	affiliations = {School of Engineering and Digital Sciences, Nazarbayev University, Astana, Kazakhstan},
	abstract = {The integration of ChatGPT into academic environments represents a cultural and pedagogical shift, challenging assumptions about learning and academic integrity. This mixed-methods study examines ChatGPT use among engineering students and faculty at an English-language university. Quantitative data were collected via surveys from 89 students and 23 faculty members; qualitative data were gathered through semi-structured interviews with four faculty members. Results reveal a usage gap between students (58.5% frequent use) and faculty (21.7%), alongside faculty concerns about critical thinking and skill development. Thematic analysis shows that educators perceive ChatGPT as both a productivity aid and a pedagogical risk, prompting redesign of assessments and reliance on oral verification of learning. Drawing on Vygotsky’s Zone of Proximal Development, the findings conceptualise ChatGPT as a digital scaffold when it extends learners’ capabilities, but as an external crutch when used without reflective engagement. This tension helps explain generational divides in perceptions of appropriate AI use. © 2026 Informa UK Limited, trading as Taylor & Francis Group.},
	author_keywords = {AI ethics; AI literacy; AI-assisted learning; conversational AI; digital transformation; engineering education},
	correspondence_address = {M. Tsakalerou; School of Engineering and Digital Sciences, Nazarbayev University, Astana, Kazakhstan; email: mariza.tsakalerou@nu.edu.kz},
