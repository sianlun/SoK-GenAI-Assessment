@CONFERENCE{Zabala2025,
	author = {Zabala, Ignacio Despujol and Turro Ribalta, Carlos and Mataix, Jaime Busquets},
	title = {Enhancing Educational Content Through AI-Assisted Transformation of Video Transcriptions},
	year = {2025},
	journal = {2025 IEEE Digital Education and MOOCS Conference, DEMOcon 2025},
	pages = {},
	doi = {10.1109/DEMOcon65705.2025.11282786},
	url = {https://www.scopus.com/pages/publications/105031891404?origin=resultslist},
	affiliations = {Universitat Politècnica de València, Área de Sistemas de Información y Comunicaciones (ASIC), Valencia, Spain},
	abstract = {This paper presents our research on utilizing artificial intelligence to transform a vast repository of over 50,000 educational video transcriptions into comprehensive learning materials. We developed and refined an AI prompt methodology capable of converting raw video transcripts into structured academic documents, including detailed study notes, concise summaries of key concepts, and SEO-optimized abstracts. Our system further extends functionality by automatically generating assessment materials: paragraph-style questions with complete answers, single-sentence questions with correct answers, and five plausible but incorrect distractors for each single-sentence question. The creation of convincing distractors presented the greatest difficulty, requiring careful prompt engineering to produce options that appear authentic while being definitively incorrect. Through multiple prompt iterations and comparative analysis, we tested four leading large language models: Meta's Llama 3.3 70B, OpenAI's GPT-4o and GPT-4o mini, and Google's Gemini Flash 2.0. After extensive testing, Gemini Flash 2.0 demonstrated superior performance in generating pedagogically sound materials, being better at creating believable yet unambiguously incorrect answer options. This research demonstrates the potential for AI-Assisted transformation of educational content, offering scalable solutions for converting passive video content into interactive learning materials with integrated assessment components.  © 2025 IEEE.},
