@CONFERENCE{Rybicki2025,
	author = {Rybicki, Jan-Mikael and Sarsa, Sami and Leinonen, Juho and Hellas, Arto},
	title = {Developing Written Communication Skills in Engineering Education Using Automated Short Answer Grading},
