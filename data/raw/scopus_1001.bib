@ARTICLE{Yang2025190890,
	author = {Yang, Christopher C.Y. and Liu, Guan-Jie and Yu, Cheng-Jui},
	title = {Optimizing RAG in Programming Education: A Comparative Study of Models and Strategies},
	year = {2025},
	journal = {IEEE Access},
	volume = {13},
	pages = {190890 - 190903},
	doi = {10.1109/ACCESS.2025.3629843},
	url = {https://www.scopus.com/pages/publications/105021264661?origin=resultslist},
	affiliations = {National Taipei University of Education, Department of Computer Science, Taipei, 106320, Taiwan; National Central University, Department of Computer Science and Information Engineering, Taoyuan, 32001, Taiwan},
	abstract = {This study examines how Retrieval-Augmented Generation (RAG) enhances the effectiveness of generative artificial intelligence in programming education. This study compares commercial and open-source large language models within a RAG system, examining how retrieval design and prompt engineering affect response quality. By creating a database specific to machine learning courses and using the RAGAS (Retrieval-Augmented Generation Assessment) evaluation framework, a comparative analysis of five prominent models (GPT-4o, Claude-3.7-Sonnet, Gemini-2.0-Flash, Llama3.3-70b, and Ministral-8b) is conducted based on five quality metrics, namely Context Precision, Context Recall, Context Entities Recall, Faithfulness, and Response Relevance. The findings reveal considerable performance differences between different model types, with structured reasoning prompts (Chain-of-Thought and Take a Step Back) significantly improved the overall model performance. Re-ranking was identified as the most effective retrieval approach, especially in enhancing the performance of lightweight open-source models. This research provides empirical evidence for the effectiveness of economically feasible RAG systems in programming education, thus helping bridge the gap in the performance of commercial and open-source models and providing real-world solutions for resource-constrained educational settings. © 2013 IEEE.},
	author_keywords = {AI in education; generative AI; LLMs; programming education; prompt engineering; Retrieval-augmented generation (RAG); retrieval-augmented generation assessment (RAGAS)},
	keywords = {Artificial intelligence; Curricula; Education computing; Engineering education; Information retrieval; Learning systems; Open source software; Open systems; Search engines; AI in education; Commercial sources; Generation systems; Generative AI; LLM; Performance; Programming education; Prompt engineering; Retrieval-augmented generation; Retrieval-augmented generation assessment; Quality control},
