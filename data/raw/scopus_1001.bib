@ARTICLE{Mansouri2025330,
	author = {Mansouri, Taha and Torkestani, Mohammad Saleh},
	title = {AIMA: An Agentic AI Approach to Vulnerability Scanning of Higher-Education Assessment},
	year = {2025},
