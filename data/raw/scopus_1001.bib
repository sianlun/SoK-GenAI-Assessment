	affiliations = {Fpt University Can Tho Campus, Can Tho, Viet Nam; Ho Chi Minh National Academy of Politics, Ha Noi City, Ha Noi, Viet Nam; Foreign Languages Faculty, Dong Thap University, Dong Thap, Viet Nam},
	abstract = {The rapid proliferation of artificial intelligence (AI) technologies, exemplified by large language models like ChatGPT, has precipitated significant paradigmatic shifts in second language acquisition pedagogies, particularly in Chinese language instruction. This study critically examines the multifaceted implications of AI-driven technological interventions on international Chinese language education, focusing on transformative potential in instructor training and learner engagement strategies. The research methodology employs a comprehensive analytical framework to evaluate ChatGPT's functional capabilities and epistemological implications. Through systematic assessment of knowledge production mechanisms, learning modalities, and technological integration, the study investigates the emergent challenges and opportunities presented by AI in second language pedagogical environments. The research design integrates qualitative discourse analysis with technological impact assessment to generate nuanced insights into AI's transformative potential. Empirical findings reveal that while AI technologies do not render international Chinese language instruction obsolete, they necessitate fundamental recalibrations in pedagogical approaches and instructor preparation. The study advocates for a paradigm shift in teacher education, emphasizing the cultivation of interdisciplinary competencies and advanced technological literacy. Specifically, the research recommends developing instructor training models that prioritize adaptive technological skills, critical AI integration strategies, and innovative pedagogical interventions. The proposed framework suggests transitioning from traditional educational models to dynamic, technology-enhanced instructional paradigms. This approach entails cultivating educators who are not merely language instructors but sophisticated technological mediators capable of leveraging AI tools to enhance linguistic and cultural learning experiences. Critically, the research underscores the imperative of maintaining human-centric pedagogical approaches while strategically incorporating AI-driven technological innovations.  © 2024 Copyright held by the owner/author(s). Publication rights licensed to ACM.},
	author_keywords = {artificial intelligence; Chatgpt; international Chinese-language education; teacher training},
	keywords = {Education computing; Engineering education; Human engineering; Learning systems; Linguistics; Personnel training; Sustainable development; Teaching; Artificial intelligence technologies; Chatgpt; Chinese language; International chinese-language education; Language education; Language model; Pedagogical approach; Research methodologies; Second language acquisition; Teacher training; Artificial intelligence},
