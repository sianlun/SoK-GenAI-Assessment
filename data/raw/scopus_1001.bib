@CONFERENCE{Suhartono2026,
	author = {Suhartono, Joni and Karmawan, I. Gusti Made and Wiryawan, Drajad},
	title = {The Role of Self-Efficacy and Technological Readiness in Student Reliance on Generative AI},
	year = {2026},
	journal = {Proceedings of the 4th IEEE International Conference on Interdisciplinary Approaches in Technology and Management for Social Innovation, IATMSI 2026},
	pages = {},
	doi = {10.1109/IATMSI68868.2026.11465178},
	url = {https://www.scopus.com/pages/publications/105036969139?origin=resultslist},
	affiliations = {School of Information Systems, Bina Nusantara University, Information Systems Department, Jakarta, 11480, Indonesia},
	abstract = {The rapid, unprecedented adoption of Generative Artificial Intelligence (AI) in higher education presents a dualism of revolutionary potential and radical disruption, raising fundamental questions about academic integrity and over-reliance. Indonesian university students, in particular, demonstrate this global phenomenon, where their high digital fluency aligns with the country's national strategic focus on digitalising education. While existing technology adoption models often overlook the factors that foster deep dependence, this study addresses that gap by developing and validating an inclusive model that identifies the determinants of Generative AI Dependency (GAD) among this key demographic. Utilising Structural Equation Modeling (SEM) on a sample of 453 Indonesian university students, the model incorporates constructs such as Academic Self-Efficacy (ASE), Technological Readiness (TR), Perceived Usefulness (PU), Perceived Ease of Use (PEU), Effort Expectancy (EE), Personal Innovativeness (PI), Performance Expectation (PX), and Positive Experiences (PE). The results indicate that ASE, PU, and PE all have a statistically significant, positive impact on GAD. Notably, we found that Performance Expectation (PX) has no substantial direct influence on GAD. Conversely, Technological Readiness (TR) has a significant impact on Academic Self-Efficacy (ASE), which, in turn, influences GAD. Overall, the model explains a meaningful portion of the variance in the endogenous constructs, confirming its relevance for predicting generative AI usage and student behavioural outcomes. These findings provide valuable insights for educators and policymakers seeking to promote a balanced and healthy integration of AI in higher education.  © 2026 IEEE.},
	author_keywords = {Academic Self-Efficacy; Generative AI Dependency; Perceived Usefulness; Structural Equation Modelling; Technological Readiness},
	keywords = {Artificial intelligence; Behavioral research; Education computing; Engineering education; Academic self-efficacy; Generative artificial intelligence dependency; High educations; Perceived usefulness; Performance expectations; Positive experiences; Self efficacy; Structural equation models; Technological readiness; University students; Students},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
