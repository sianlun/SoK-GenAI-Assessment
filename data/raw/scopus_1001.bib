@CONFERENCE{Mendonca2025,
	author = {Mendonca, Paula and Carvalho, José Reginaldo Hughes and Oran, Ana Carolina},
	title = {Using Prompt Engineering to Enhance a Project-Based Learning Course on Project Management},
	year = {2025},
	journal = {Proceedings - Frontiers in Education Conference, FIE},
	pages = {},
	doi = {10.1109/FIE63693.2025.11328531},
	url = {https://www.scopus.com/pages/publications/105033042603?origin=resultslist},
	affiliations = {Federal University of Amazonas, AM, Manaus, Brazil},
	abstract = {This Innovative Practice Paper presents a methodology that integrates prompt engineering of Large Language Models (LLMs) into the teaching of software project management in undergraduate education. Addressing the challenges of conveying complex and evolving project management practices, the approach combines the Project Management Institute (PMI) framework with Scrum and project-based learning (PBL), creating an adaptive learning environment supported by LLM-driven mentorship. During a 12 -week period, the student project team (squads) managed their own software projects, developing documentation aligned with the Project Management Body of Knowledge (PMBOK) performance domains. LLMs acted as virtual specialists, providing real-time guidance and filling expertise gaps typically addressed by domain specialists. Students engaged in six practical activities that culminated in a cross-validation task comparing results generated by different LLMs. The evaluation focused on the completeness and PMBOK compliance of the produced documentation, with LLM assessments moderated by the instructors. In addition, students applied prompt engineering strategies in a final exam to iteratively refine LLM responses to PMIstyle certification questions. The results align with recent research, emphasizing the role of prompt engineering in educational contexts, and illustrate how LLMs can foster responsive, industry-relevant learning environments. This methodology enhances decision-making skills, promotes hands-on experience with PMI and Scrum, and introduces students to emerging Artificial Intelligence (AI) technologies. It also demonstrates scalability and potential for democratizing high-quality mentorship in resourceconstrained educational settings. The paper discusses the implementation, results, and limitations, offering insights for adapting the approach to other software engineering courses. © 2025 IEEE.},
