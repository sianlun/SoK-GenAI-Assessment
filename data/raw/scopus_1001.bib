@ARTICLE{Almasri2025,
	author = {Almasri, Wesam and Saad, Marwa and Mohiyeddini, Changiz},
	title = {Evaluating Google Gemini’s Capability to Generate NBME-Standard Pharmacology Questions Using a 16-Criterion NBME Rubric},
	year = {2025},
	journal = {Algorithms},
	volume = {18},
