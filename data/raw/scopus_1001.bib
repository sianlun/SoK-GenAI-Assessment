	year = {2025},
	journal = {Proceedings - 2025 IEEE 18th International Symposium on Embedded Multicore/Many-core Systems-on-Chip, MCSoC 2025},
	pages = {98 - 104},
	doi = {10.1109/MCSoC67473.2025.00026},
	url = {https://www.scopus.com/pages/publications/105032481899?origin=resultslist},
	affiliations = {Engineering Product Development, Singapore University of Technology and Design, Singapore; MNEED, Singapore University of Technology and Design, Singapore Chang Gung University, Taiwan},
	abstract = {This study investigates student perceptions and usage patterns of artificial intelligence (AI) learning tools, specifically focusing on DeepSeek, ChatGPT, and Gemini. Through a comprehensive survey of 22 respondents across 26 questions, we examined students' familiarity with AI tools, their classroom and self-learning applications, effectiveness perceptions, and concerns about AI integration in education. Our findings reveal widespread adoption of AI tools among students (86.4 %), with notable benefits in conceptual understanding and independent learning, alongside concerns about accuracy (77.3%), over-reliance (81.8%), and academic integrity (72.7%). ChatGPT emerged as the dominant platform (81.8% usage), while 77.3% of students envision AI as supplementary support rather than a replacement for traditional instruction. The study provides insights into how AI reasoning tools are reshaping educational practices and offers recommendations for effective integration of these technologies in formal and informal learning environments.  © 2025 IEEE.},
