@ARTICLE{Humble202416,
	author = {Humble, Niklas and Boustedt, Jonas and Holmgren, Hanna and Milutinovic, Goran and Seipel, Stefan and Östberg, Ann-Sofie},
	title = {Cheaters or AI-Enhanced Learners: Consequences of ChatGPT for Programming Education},
	year = {2024},
	journal = {Electronic Journal of e-Learning},
	volume = {22},
