	title = {Personalized Assessment in Education: Enhancing MCQ Generation Using Advanced AI and Contextual Learning Models},
	year = {2025},
	journal = {2025 International Conference on Circuits, Controls and Communications, CCUBE 2025},
	pages = {},
	doi = {10.1109/CCUBE66458.2025.11340281},
	url = {https://www.scopus.com/pages/publications/105033152092?origin=resultslist},
	affiliations = {Symbiosis Institute of Technology, Symbiosis International (Deemed University), Nagpur Campus, Pune, India; Shri Umiya Kanya Mahavidyalaya, Department of Education, Indore, India; Oriental University, Department of Education, Indore, India; School of Education, Devi Ahilya Vishwavidyalaya, Indore, India; Dr. C.V. Raman University, Department of Commerce and Management, Bilaspur, India},
	abstract = {The PAMGen framework meets the increasing demand for automatic generation of multiple-choice questions (MCQs), a critical component for personalized learning and assessment. We are employing state-of-the-art AI to make PAMGen generate enhanced multiple-choice questions that are difficulty matched to the intended audience and focused on various subject areas. Although it has the potential to revolutionize many fields, challenges of diversity, cognitive complexity, and adaptability in the domain still need to be overcome. We used a dataset of quality-crafted, instructordesigned, and student-generated MCQs along with domainspecific information to add more contextual information to the document. PAMGen is built upon our recent development of a large language model (LLM)-based framework utilizing retrieval-augmented generation (RAG) and state-of-the-art prompt engineering strategies - including Chain-of-Thought (CoT) reasoning and self-refinement. Our approach's novelty lies in its iteration aspect, making it pedagogically ready for use in diverse educational contexts. Performance metrics scope grammatical fluency, answerability, diversity, difficulty, and relevance and are evaluated on the basis of human and machine assessments. Results underscore PAMGen's strengths in linguistic accuracy and relevance, with high scores for MCQs that were concept-based and coding-based. © 2025 IEEE.},
	author_keywords = {Adaptive Assessment Systems; Automated MCQ Generation; PAMGen Framework; Personalized Learning; Retrieval-Augmented Generation (RAG)},
