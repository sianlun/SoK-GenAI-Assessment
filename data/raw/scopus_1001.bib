@CONFERENCE{Wu2025,
	author = {Wu, Xiaojun and Li, Shanshan and Zheng, Ninghan and Gao, Yuchao},
	title = {WIP: Evaluating the Capabilities of GPT Applications in Solving Introductory-Level Algorithm Problems},
