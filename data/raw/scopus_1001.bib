	title = {EduLoop-Agent: An End-To-End Personalized Learning Agent with Diagnosis-Recommendation -Feedback Loop for Intelligent Education},
	year = {2025},
	journal = {IEIR 2025 - Proceedings of the 4th International Conference on Intelligent Education and Intelligent Research},
	pages = {},
