@CONFERENCE{Thi20251037,
	author = {Thi, Ngoc-Bich Nguyen and Minh, Tam Vo and Vu, Anh-Khoa Nguyen and Nguyen, Vinh-Tiep},
	title = {Can LLMs Construct Valid Syllabi? Vietnamese High School Math Case Study},
	year = {2025},
	journal = {Proceedings - 2025 RIVF International Conference on Computing and Communication Technologies, RIVF 2025},
	pages = {1037 - 1042},
	doi = {10.1109/RIVF68649.2025.11365100},
	url = {https://www.scopus.com/pages/publications/105034482294?origin=resultslist},
	affiliations = {University of Information Technology, Ho Chi Minh City, Viet Nam; Vietnam National University, Ho Chi Minh City, Viet Nam},
	abstract = {Large language models (LLMs) are increasingly applied to educational contexts, particularly for generating lesson plans and syllabi aligned with national curricula. Despite their potential to reduce preparation time and support curriculum development, evaluating the quality and relevance of LLM-generated content remains a critical challenge due to the reliance on subjective expert judgments and limited scalability. To address this gap, we investigate the ability of four widely used LLMs-ChatGPT-4o, Gemini 2.5 Flash, Grok 3, and Copilot-to generate Grade 1 0 Mathematics syllabi aligned with the Vietnamese Ministry of Education and Training (MOET) standards. Our methodology assesses outputs through Criterion-Embedded LLM Ensemble for Syllabus Testing (CELEST). Specifically, the four LLMs score a generated syllabus based on the official criteria. This cross-validation provides a replicable and reliable method for syllabus assessment. In addition, our findings provide insights into the extent to which LLMs can recommend and construct complete syllabi, as well as highlight differences in performance among models. This study contributes to ongoing discussions on the role of AI in education by demonstrating both the opportunities and limitations of LLMs for curriculum-aligned content generation in the Vietnamese context. © 2025 IEEE.},
	author_keywords = {Artificial intelligence; Educational technology; Large language models; Syllabus generation},
	keywords = {Curricula; Educational technology; Engineering education; Case-studies; Curriculum development; Educational context; Higher School; Language model; Large language model; Lesson plans; Modeling construct; Syllabus generation; Vietnamese; Artificial intelligence},
	correspondence_address = {V.-T. Nguyen; University of Information Technology, Ho Chi Minh City, Viet Nam; email: tiepnv@uit.edu.vn},
	editor = {Bao V.N.Q. and Nguyen H.T. and Hai H.T. and Khang K.T. and Tu N.H. and Thanh T.T.},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
