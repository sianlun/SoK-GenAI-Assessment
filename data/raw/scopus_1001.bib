@ARTICLE{Pinto2025470,
	author = {Pinto, Agostinho Sousa and Abreu, António and Carvalho, João Vidal and Carvalho, Milena and Martins, Susana and Paiva, Jerónimo},
	title = {The Technology Acceptance Model (TAM): A Meta-Analytic Structural Equation Modeling (MASEM) Approach to Explaining the Adoption of GenAI Tools in Higher Education},
