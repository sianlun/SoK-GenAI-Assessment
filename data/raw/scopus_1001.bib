@CONFERENCE{Huang2025420,
	author = {Huang, Yan and Chen, Liuqiao and Wu, Jing and Zhang, Hailing and Chen, Ying},
	title = {KB-Driven Learning Analytics Dashboard for an Introductory Image Processing Course: Early Risk Detection and TA Interventions},
	year = {2025},
	journal = {Proceedings of 2025 2nd International Symposium on Artificial Intelligence for Education, ISAIE 2025},
	pages = {420 - 425},
	doi = {10.1145/3775073.3775140},
	url = {https://www.scopus.com/pages/publications/105026933644?origin=resultslist},
	affiliations = {School of Information Science and Technology, Sanda University, Shanghai, China; Hitachi Energy High Voltage Equipment Co., Ltd., Jiangsu, Suqian, China},
	abstract = {We present a knowledge-base (KB)-driven learning analytics system for an introductory image processing course offered in blended/online mode. The pipeline consolidates assignment logs (tool choice, iterations, time-on-task, submission status, grades) and structured lab reports (prompts, error traces, function usage, artifacts) into a versioned KB. From these traces we operationalize process features - tool stickiness, prompt-to-debug ratio, first-run success, error density, and function-coverage - and use them to predict lateness or low performance on the next assignment using only information available up to time t. A TA dashboard presents interpretable explanations and links each factor to targeted interventions (prompt-repair coaching, MATLAB/Python debugging primers, function-coverage micro-tasks) prioritized by a risk×urgency queue. Using artifacts from five labs (N 216 tool selections), we observe high AI-tool adoption (KIMI 41.2%, Wenxin 38.9%), scarce independent coding (4.2%), similar time per problem across tools (∼8-9 minutes), and tool-sensitive iteration profiles. These results indicate that process signals, rather than tool identity, are most diagnostic; the KB enables timely, reproducible support for online labs and actionable TA workflows. © 2025 Copyright held by the owner/author(s).},
	author_keywords = {Early risk detection; Educational assessment; Educational technology; Generative AI in education; Image processing education; Knowledge base; Learning analytics; Online learning; TA interventions},
	keywords = {Curricula; E-learning; Educational technology; Engineering education; Human engineering; Information use; Learning systems; Program debugging; Risk assessment; Early risk detection; Educational assessment; Generative AI in education; Image processing education; Images processing; Knowledge base; Learning analytic; Online learning; Risk detections; TA intervention; Knowledge based systems},
	correspondence_address = {Y. Chen; School of Information Science and Technology, Sanda University, Shanghai, China; email: ychen@sandau.edu.cn},
	publisher = {Association for Computing Machinery, Inc},
	isbn = {979-840071579-2},
	language = {English},
