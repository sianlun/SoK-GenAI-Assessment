	language = {English},
	abbrev_source_title = {ACM Int. Conf. Proc. Ser.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 93}
}

@CONFERENCE{Giray2025326,
	author = {Giray, Louie and Carreon, Rodrigo Emil and Aragon, Jeffran Jake},
	title = {Understanding Student Cheating with Generative AI through the Lens of the Theory of Planned Behavior (TPB)},
	year = {2025},
	journal = {2025 2nd International Conference on Artificial Intelligence and Teacher Education, ICAITE 2025},
	pages = {326 - 331},
	doi = {10.1109/ICAITE68636.2025.11442543},
	url = {https://www.scopus.com/pages/publications/105036301035?origin=resultslist},
	affiliations = {School of Foundational Studies Education, Mapúa University, Department of Liberal Arts, Philippines},
	abstract = {Student motivations for using generative artificial intelligence (GenAI) in academic cheating represent a growing concern in Philippine higher education as AI tools become increasingly accessible and sophisticated. This qualitative study employed semi-structured interviews with undergraduate students from universities in Intramuros, Manila, guided by the Theory of Planned Behavior framework to explore underlying motivations for AI-assisted academic dishonesty. Results revealed five primary motivational themes: time constraints driven by overwhelming deadlines and workloads, efficiency seeking through AI's instantaneous responses, social normalization where peer usage reduces moral barriers, fear of academic inadequacy prompting compensatory AI use, and technological ease making dishonesty effortlessly accessible. Students said they turned emergency use of AI into smart, planned strategies. As more classmates joined in, it created a group safety net that made using AI to cheat feel normal. Results indicate that AI cheating behaviors emerge from complex interactions between academic pressures, social dynamics, and technological affordances rather than simple moral failures. The study suggests that educational institutions must address systemic issues including curriculum design, assessment methods, and institutional culture that inadvertently promote hyper-competitive environments. Educational reforms emphasizing inquiry-based learning and process-oriented teaching may better prepare students for ethical AI integration.  © 2025 IEEE.},
	author_keywords = {academic dishonesty; cheating; generative AI; higher education; student motivations},
	keywords = {Artificial intelligence; Curricula; Education computing; Engineering education; Ethical technology; Learning systems; Motivation; Academic dishonesty; Cheating; Generative AI; High educations; Philippines; Qualitative study; Semi structured interviews; Student motivation; Theory of Planned Behavior; Through the lens; Students},
