	affiliations = {Nagasaki University, School of Global Humanities and Social Sciences, Nagasaki, Japan},
	abstract = {Education has never been 'natural'; it has always been shaped by the dominant media of its time. With generative AI entering the learning space, the order shifts more radically: for the first time, a technology competes not only with the teacher's tools but with the teacher's core function - the production, structuring, and legitimation of knowledge. From a genealogical perspective, the teacher appears less as an anthropological constant than as a function of techno-social conditions. At the same time, error studies show how authority logics and ritualization can turn the teacher into a source of persistent mistakes. In GenAI environments, the classroom becomes co-semiotic; categories such as authorship and originality begin to slide. Quid nunc de magistro fiet? The teacher loses the monopoly yet persists in altered roles framing relevance, curating error ecologies, moderating ethics and citation, and co-creating situational curricula. The proposed transition is from a Decalogue of infallible rules to a 'control grammar': meta-rules of visibility, provenance, transformation, and cross-checking. The teacher 'dies' as the old figure and survives as the new - not lord of answers but master of questions.  © 2025 IEEE.},
	author_keywords = {Assessment; Authority; Control Grammar; Error Ecology; Generative AI; Human-AI Collaboration; Instructional Design; Provenance; Teacher Role},
	keywords = {Artificial intelligence; Computer aided instruction; Ecology; Engineering education; Teaching; Assessment; Authority; Control grammar; Error ecology; Generative AI; Human-AI collaboration; Instructional designs; Provenance; Teacher role; Teachers'; Errors},
	correspondence_address = {A. Gülbeyaz; Nagasaki University, School of Global Humanities and Social Sciences, Nagasaki, Japan; email: a.guelbeyaz@nagasaki-u.ac.jp},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
