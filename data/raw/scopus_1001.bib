@CONFERENCE{Ng2025304,
	author = {Ng, Jun Wei and Naval, Mark Anthony},
	title = {Technological Acceptance and Motivation of Generative Artificial Intelligence (GenAI) in Sport Education},
	year = {2025},
	journal = {2025 2nd International Conference on Artificial Intelligence and Teacher Education, ICAITE 2025},
	pages = {304 - 308},
	doi = {10.1109/ICAITE68636.2025.11442478},
	url = {https://www.scopus.com/pages/publications/105036312940?origin=resultslist},
	affiliations = {PSB Academy, Singapore; UCAM Universidad Católica San Antonio de Murcia, Spain},
	abstract = {This paper investigates the technological acceptance and motivation of Generative Artificial Intelligence (GenAI) among sport & exercise science students in Singapore's private higher education sector. Since the advent of GenAI tools like ChatGPT, opportunities and challenges at the higher education landscape had focus on concerns over academic integrity and ethical implications. As understanding student perception is critical for responsible integration, this study employed a pragmatic philosophical approach and a sequential mixed methods design across three phases, pilot focus group interviews and open-ended questionnaires were conducted with 109 faculty and 15 students to uncover emerging themes. These findings are cornerstone to development and validation of a new measurement instrument, Values Expectancy and Motivation Perception for AI in Education (VEM-AIEd), grounded in the Unified Theory of Acceptance and Use of Technology (UTAUT), Expectancy-Value Theory (EVT), and Self-Determination Theory (SDT), incorporating ethical considerations (EC) as a novel construct. A hierarchical multiple regression analysis was used to examine constructs with behavioural intent was on 247 students with results indicated that facilitating conditions (FC) emerged as the strongest predictor (p<.05) of behavioural intention (BI), followed by intrinsic motivation (IV), competence (COMP), success expectancy (SUC), attainment value (AV), and autonomy (AUT). The relationship between BI and acceptance constructs was significantly moderated by course level and voluntariness of use (p <.05). A subsequent six-week intervention with 89 students demonstrated that sustained AI exposure enhanced student confidence (CON), success expectancy (SUC), attainment value (AV), social influence (SI), and relatedness (REL) (p<.05). The findings advance theory by integrating ethical considerations into AI acceptance models and offer actionable recommendations for prioritizing values and expectations in responsible AI implementation in private higher education.  © 2025 IEEE.},
	author_keywords = {Chatbot; Expectancy-Value Theory; Generative Artificial Intelligence; Higher Education; Self-Determination Theory; Technological Acceptance; Unified Theory of Acceptance and Use of Technology},
	keywords = {Artificial intelligence; Behavioral research; Curricula; Education computing; Engineering education; Ethical technology; Regression analysis; Sports; Students; Teaching; Behavioral intention; Chatbots; Ethical considerations; Expectancy-value theory; Generative artificial intelligence; High educations; Self-determination theories; Sport educations; Technological acceptance; The unified theory of acceptance and use of technology(UTAUT); Motivation},
	correspondence_address = {J.W. Ng; PSB Academy, Singapore; email: pt.ngjw@gmail.com},
