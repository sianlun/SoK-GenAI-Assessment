	year = {2026},
	journal = {Computers and Education},
	volume = {249},
	pages = {},
	doi = {10.1016/j.compedu.2026.105602},
	url = {https://www.scopus.com/pages/publications/105033070937?origin=resultslist},
	affiliations = {Hubei Key Laboratory of Digital Education, Faculty of Artificial Intelligence in Education, Central China Normal University, Hubei, Wuhan, China; Faculty of Artificial Intelligence in Education, Central China Normal University, Hubei, Wuhan, China; Department of Mathematics and Information Technology, The Education University of Hong Kong, Hong Kong S.A.R, China; School of Design, The Hong Kong Polytechnic University, Hong Kong S.A.R, China},
	abstract = {Fostering preservice teachers’ (PSTs) design thinking (DT) is essential for addressing complex instructional challenges, yet remains difficult to achieve in teacher education. Although generative artificial intelligence (GenAI) and analytics-supported reflective assessment (ASRA) show promise for supporting DT, how they can be pedagogically integrated within collaborative inquiry remains relatively underexplored. The study aimed to explore the effects of the combined use of GenAI and ASRA within a collaborative inquiry Knowledge Building (KB) environment on PSTs’ DT, and how their DT competencies evolves with this integrative design. Participants were 110 PSTs enrolled in a semester-long Modern Educational Technology Applications course. We proposed a conceptual framework integrating collaborative inquiry, strategically delayed GenAI use, and ASRA, and operationalized it through a pedagogical model that positions GenAI as a cognitive and reflective design partner rather than a solution provider. Multiple data sources were analyzed, including a DT competency scale, successive instructional design artifacts, and 1305 online discourse notes. Results showed significant gains in problem discovery and definition, along with a developmental shift from stage-bound engagement toward more integrated and iterative practices, particularly in prototyping and testing. GenAI was most effective when introduced after human-only design efforts, while reflective analytics supported monitoring of collective progress and sustained iteration. This study contributes to learning sciences by theorizing how GenAI and ASRA can be integrated within a KB environment to support DT, and offers an empirically grounded approach for preparing PSTs for AI-rich teaching contexts. © 2026 Elsevier Ltd},
	author_keywords = {Cooperative/collaborative learning; Improving classroom teaching; Pedagogical issues; Personalized learning; Teaching/learning strategies},
	keywords = {Artificial intelligence; Collaborative learning; Computer aided instruction; Curricula; Educational technology; Engineering education; Iterative methods; Building environment; Cooperative/ collaborative learning; Design thinking; Improving classroom teaching; Knowledge building; Pedagogical issues; Personalized learning; Preservice teachers; Teacher education; Teaching/learning strategy; Teaching},
