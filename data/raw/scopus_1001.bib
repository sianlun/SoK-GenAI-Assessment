	affiliations = {School of Foreign Languages, Guangzhou College of Commerce, Guangdong, Guangzhou, China; School of Software Engineering, Sun Yat-sen University, Guangdong, Zhuhai, China; Aisino Co., Ltd., Beijing, China},
	abstract = {This study proposes a Systemic Functional Prompting (SFP) framework based on GPT-4 to enhance the capabilities of Automated Essay Scoring (AES). The framework guides the model to generate discourse-oriented, interpretable scores and feedback by integrating prompt engineering with Systemic Functional Linguistics (SFL). By incorporating Chain-of-Thought (CoT) and Chain-of-Knowledge (CoK) strategies, SFP enables reasoning across six linguistic dimensions. Based on an empirical study involving over 10,000 essays from a national college English writing competition, the SFP-generated scores demonstrated high consistency with human ratings and produced feedback with greater pedagogical relevance. Regression analysis indicates the positive effect of incorporating explicit linguistic features to improve transparency and pedagogical value in language assessment. © 2025 Copyright held by the owner/author(s).},
