	affiliations = {Sri Lanka Institute of Information Technology, Department of Software Engineering, Sri Lanka},
	abstract = {Digital education is a key component in higher education, driving changes in instructional methods and learning experiences. This study explores the integration of research-based pedagogical methods into digital platforms enhanced with Artificial Intelligence. These methods are reflected in some of the successful traditional practices, which include formative assessments, real-time feedback mechanism, peer collaboration, and structured knowledge documentation, to improve student engagement and performance. The research evaluates existing digital tools and platforms, analyzing how presentation style, content delivery formats, and infrastructure configurability impact learner motivation and engagement. Based on insights gained from this evaluation process, a new system architecture is proposed that digitally implements active learning techniques, immediate support structures for students, collaborative task frameworks, and content management strategies. A mixed-methods approach was used to evaluate the system's effectiveness by combining quantitative assessments of academic performance with qualitative learner feedback. Results show that integrating research-driven instructional strategies into digital learning environments enhances academic outcomes. The study presents a structured approach for developing adaptive, high-quality online education systems, addressing critical challenges which are related to engagement, accessibility, and course completion while offering a framework for future educational technology initiatives. © 2025 IEEE.},
