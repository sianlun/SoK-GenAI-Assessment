	author = {Balart, Trini and Díaz, Brayan and Shryock, Kristi},
	title = {A Systematic Literature Review on the Pedagogical Implications and Impact of GenAI on Students’ Critical Thinking},
	year = {2026},
	journal = {Algorithms},
	volume = {19},
	number = {3},
