@ARTICLE{Akgun202544,
	author = {Akgun, Mahir and Toker, Sacip},
	title = {Short-Term Gains, Long-Term Gaps: The Impact of GenAI and Search Technologies on Retention},
	year = {2025},
	journal = {Communications in Computer and Information Science},
	volume = {2591 CCIS},
	pages = {44 - 52},
