	title = {Artificial Intelligence and Data-Driven Approaches in University Science Education: A Review of Applications and Outcomes},
	year = {2025},
	journal = {2025 1st International Conference on Data Science and Geoinformatics, ICDSG 2025},
	pages = {19 - 24},
	doi = {10.1109/ICDSG67714.2025.11381391},
	url = {https://www.scopus.com/pages/publications/105038037267?origin=resultslist},
	affiliations = {Department of Science Education, Universitas Sebelas Maret, Surakarta, Indonesia; Department of Educational Technology, Universitas Sebelas Maret, Surakarta, Indonesia; School of Computing, Telkom University, Bandung, Indonesia},
	abstract = {The integration of artificial intelligence (AI) and data-driven approaches into higher education has accelerated in recent years, particularly within science education, where traditional models often struggle with scalability, diverse learning needs, and assessment quality. This review examines applications of artificial intelligence (AI)—encompassing both classical machine-learning systems and emerging generative AI models—and data-driven methods in university-level science education. It uniquely contributes by mapping recent empirical evidence (2016–2025) through a governance–readiness–implementation lens that links technical deployment to pedagogical and ethical outcomes. A narrative review of peer-reviewed literature published between 2016 and 2025 was conducted, drawing on studies that explore the pedagogical, technological, and institutional dimensions of AI adoption. The findings indicate that AI is most commonly employed in learning analytics, predictive modeling, adaptive learning systems, and AI-enabled assessment and feedback, with additional applications in immersive laboratory environments and institutional decision-making. Across studies, these approaches often enhance personalization, support at-risk students, streamline faculty workload, and enable curriculum reform. Reported outcomes include improved academic performance, higher engagement, and greater student autonomy; however, these benefits are tempered by challenges relating to equity, data ethics, algorithmic bias, and sustainability. The review highlights that AI and data-driven education represent transformative yet ethically sensitive innovations whose effectiveness depends on governance frameworks, educator readiness, and responsible implementation. Universities are thus called to adopt AI not merely as a technical enhancement but as a pedagogical partner, ensuring its integration aligns with equity, integrity, and evidence-based learning. By synthesizing cross-disciplinary findings, this study extends prior reviews by delineating evidence strength and ethical governance mechanisms specific to STEM domains. © 2025 IEEE.},
	author_keywords = {artificial intelligence; data-driven learning; higher education; learning analytics; science education},
	keywords = {Computer aided instruction; Curricula; Education computing; Engineering education; Ethical technology; Learning systems; Machine learning; Students; Teaching; Data driven; Data-driven approach; Data-driven learning; High educations; Intelligence models; Learning analytic; Machine learning systems; Model-driven method; Science education; Traditional models; Decision making},
	correspondence_address = {K.D.H. Gunawan; Department of Science Education, Universitas Sebelas Maret, Surakarta, Indonesia; email: kadek.dhg@staff.uns.ac.id},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
