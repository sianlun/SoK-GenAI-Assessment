@CONFERENCE{Megahed2025195,
	author = {Megahed, Ahmed Amin and Ibrahim, Ahmed Momen and Moussa, Ahmed and Arnous, Mohamed Farag and Elmoataz, Youssef and Aslan, Heba K. and Abu-Krisha, Ismail Ahmed and Abdelsattar, Malak Magdy},
	title = {Aduvia: A Multi-Purpose AI-Powered Learning Management System (LMS)},
	year = {2025},
	journal = {7th Novel Intelligent and Leading Emerging Sciences Conference, NILES 2025 - Proceedings},
	pages = {195 - 198},
	doi = {10.1109/NILES68063.2025.11231978},
	url = {https://www.scopus.com/pages/publications/105027132602?origin=resultslist},
	affiliations = {Nile University, Department of Computer Science, Giza, Egypt},
	abstract = {Modern educational environments require unified, intelligent platforms that integrate conversational assistance, formative assessment, and secure exam management. We present Aduvia, an AI-driven system built on Retrieval-Augmented Generation (RAG) and the Llama 3.3 large language model, which delivers subject-specific, context-aware dialogue; automated quiz generation with instant feedback. Our methodology comprises five phases: (1) content Processing via OCR and semantic chunking, (2) embedding using the e5-base-v2 model and FAISS indexing, (3) RAG-based retrieval with dynamic prompt engineering and context management, (4) generative inference on a GPU-scaled Kubernetes cluster with responsive streaming, and (5) microservices deployment with comprehensive monitoring and iterative feedback loops. Experimental evaluation demonstrates that Llama 3.3 reduces non-streaming response latency by ∼0.4 s and streaming latency by 30-40% compared to version 3.0. Embedding comparisons show that e5-base-v2 produces tighter similarity distributions (0.50-0.93) versus MiniLM (0.27-0.83). A relevance classification threshold of 0.65 yields a precision of 0.85, recall of 0.92, and F1 score of 0.88. These results validate Aduvia's capability to enhance engagement, accuracy and operational efficiency in digital learning. © 2025 IEEE.},
	author_keywords = {educational AI; exam management; Llama 3.3; quiz automation; Retrieval-Augmented Generation; semantic embedding},
	keywords = {Artificial intelligence; E-learning; Embeddings; Engineering education; Indexing (materials working); Information retrieval; Search engines; Educational AI; Educational environment; Embeddings; Exam management; Learning management system; Llama 3.3; Multi-purpose; Quiz automation; Retrieval-augmented generation; Semantic embedding; Semantics},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
