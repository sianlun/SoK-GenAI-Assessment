@CONFERENCE{Li20261050,
	author = {Li, Shengchao},
	title = {Constructing an AI Literacy Curriculum for Non-STEM Students: A TPACK-Based Approach in Tourism Management Education},
	year = {2026},
	journal = {Proceedings of 2026 3rd International Conference on Informatics Education and Computer Technology Applications, IECA 2026},
	pages = {1050 - 1058},
	doi = {10.1145/3802133.3802301},
	url = {https://www.scopus.com/pages/publications/105038723396?origin=resultslist},
	affiliations = {School of Management, Guangdong University of Education, Guangdong, Guangzhou, China},
	abstract = {As Generative Artificial Intelligence (GenAI) transforms industries, including tourism and hospitality, there is an urgent demand for professionals with both domain expertise and digital proficiency. However, traditional tourism curricula often lack systematic AI training, creating a digital divide for non-STEM students who face cognitive barriers when approaching technical AI courses designed primarily for computer science majors. This paper addresses this gap by proposing a specialized AI Literacy curriculum framework grounded in the TPACK (Technological Pedagogical Content Knowledge) model, specifically tailored for undergraduate Tourism Management majors. This research advances computer technology in education through three computational innovations: (1) a formalized algorithmic instructional model that transforms pedagogical principles into reproducible computational workflows using iterative feedback loops for mastery-based learning (Algorithm 1), (2) a quantitative competency assessment framework employing multi-dimensional weighted evaluation for objective measurement of AI literacy development (Equation 1), and (3) a data-driven curriculum optimization system validated through systematic pre-post statistical analysis. The curriculum integrates theoretical cognition, practical tool application (including ChatGPT, Midjourney, and other GenAI tools), and ethical reflection into a 32-hour hybrid course structure combining lectures and laboratory practice. Through systematic evaluation including pre-post survey data (n=87) using validated five-point Likert scales and analysis of student capstone projects ranging from cultural heritage tour designs employing spatio-temporal folding concepts to data-driven niche market analysis targeting Generation Z consumers, this study demonstrates that the proposed framework effectively enhances student capacity to solve complex industry problems using AI tools while fostering human-AI collaboration mindsets. Survey results show 94% of students reported significant confidence gains (pre-course M=2.1, SD=0.8; post-course M=4.3, SD=0.6; paired t-test p<0.001), with 89% reporting reduced technology anxiety. These computational methodologies enable automated curriculum evaluation, algorithmic performance tracking, and data-driven instructional refinement, advancing intelligent educational system design. The findings provide a replicable model for interdisciplinary AI education in liberal arts disciplines facing similar digital transformation challenges.  © 2026 Copyright held by the owner/author(s).},
	author_keywords = {AI Literacy; Algorithmic Learning Models; Computational Assessment Framework; Curriculum Design; Data-Driven Curriculum Optimization; Generative AI Applications; Intelligent Educational Systems; Non-STEM Education; Tourism Education; TPACK Framework},
	keywords = {Artificial intelligence; Commerce; Curricula; E-learning; Education computing; Engineering education; Engineering research; Knowledge management; Learning algorithms; Learning systems; Students; Teaching; Tourism; AI applications; AI literacy; Algorithmic learning; Algorithmic learning model; Computational assessment framework; Curricula design; Data driven; Data-driven curriculum optimization; Generative AI application; Intelligent educational systems; Knowledge frameworks; Learning models; Non-STEM education; Optimisations; STEM education; Technological pedagogical content knowledge; Technological pedagogical content knowledge framework; Tourism education; Iterative methods},
