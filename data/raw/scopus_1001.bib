	pages = {},
	doi = {10.1109/WEEF-GEDC66748.2025.11256367},
	url = {https://www.scopus.com/pages/publications/105030131994?origin=resultslist},
	affiliations = {Technologies and Civil Engineering, School of Engineering and Sciences, Tecnologico de Monterrey, Department of Sustainable, Monterrey, Mexico; School of Engineering and Sciences, Department of Mechanics, Tecnologico de Monterrey, Monterrey, Mexico; School of Engineering and Sciences, Department of Bioengineering, Tecnologico de Monterrey, Monterrey, Mexico},
	abstract = {Standardised examinations are essential tools in higher education, providing a reliable assessment of graduation competencies and institutional accountability. However, traditional preparation methods for standard examinations can often lack in student engagement and opportunities for personalised learning. This study explores the potential of artificial intelligence (AI) in addressing these gaps, particularly through AI-generated standardised assessments. A virtual assistant was created using the ChatGPT platform to help Civil Engineering students at Tecnologico de Monterrey prepare for their Mexican national standardised exams. Surveys were used to gather information about student engagement, self-directed learning, educational outcomes, and acceptance of technology. Initial expectations suggest that by integrating AI assessment, practitioners can significantly enhance student engagement and foster self-directed learning behaviour, improving overall preparation and outcomes in formal graduation exams. These findings offer new insights into the educational benefits of AI, suggesting a significant shift toward more interactive and personalised assessment methods.  © 2025 IEEE.},
	author_keywords = {Artificial Intelligence Tutors; Educational Innovation; Higher Education; Standardised exams; Technology acceptance},
	keywords = {Computer aided instruction; Education computing; Educational technology; Engineering education; Students; Artificial intelligence tutor; Educational innovations; High educations; Preparation method; Reliable assessment; Self-directed learning; Standardized exam; Student engagement; Student preparation; Technology acceptance; Artificial intelligence},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
