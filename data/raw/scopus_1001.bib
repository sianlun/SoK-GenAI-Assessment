	title = {Evaluating Generative AI for CS1 Code Grading: Direct Vs Reverse Methods},
	year = {2025},
	journal = {Proceedings - 2025 IEEE International Conference on Collaborative Advances in Software and Computing, CASCON 2025},
	pages = {178 - 183},
	doi = {10.1109/CASCON66301.2025.00040},
	url = {https://www.scopus.com/pages/publications/105033238071?origin=resultslist},
	affiliations = {University of British Columbia Okanagan, Canada},
	abstract = {Manual grading of programming assignments in introductory computer science courses can be time-consuming and prone to inconsistencies. While unit testing is commonly used for automatic evaluation, it typically follows a binary pass/fail model and does not give partial marks. Recent advances in large language models (LLMs) offer the potential for automated, scalable, and more objective grading. This paper compares two AI-based grading techniques: Direct, where the AI model applies a rubric directly to student code, and Reverse (a newly proposed approach), where the AI first fixes errors, then deduces a grade based on the nature and number of fixes. Each method was evaluated on both the instructor's original grading scale and a tenfold expanded scale to assess the impact of range on AI grading accuracy. To assess their effectiveness, AIassigned scores were evaluated against human tutor evaluations on a range of coding problems and error types. Initial findings suggest that while the Direct approach is faster and straightforward, the Reverse technique often provides a more fine-grained assessment by focusing on correction effort. Both methods require careful prompt engineering, particularly for allocating partial credit and handling logic errors. To further test consistency, we also used synthetic student code generated using Gemini Flash 2.0, which allowed us to evaluate AI graders on a wider range of controlled error types and difficulty levels. We discuss the strengths and limitations of each approach, practical considerations for prompt design, and future directions for hybrid human-AI grading systems that aim to improve consistency, efficiency, and fairness in CS courses. © 2025 IEEE.},
	author_keywords = {AI vs Human Grading; Artificial Intelligence; Automated Grading; Code Assessment; Generative AI; LLMs; Prompt Engineering; Rubric-Based Evaluation},
	keywords = {Automatic test pattern generation; Codes (symbols); Coding errors; Computer aided instruction; Computer programming; Curricula; Education computing; Engineering education; Grading; Reverse engineering; Students; Teaching; AI vs human grading; Automated grading; Code assessment; Error types; Generative AI; Language model; Large language model; Programming assignments; Prompt engineering; Rubric-based evaluation; Artificial intelligence},
	editor = {Muller H.A. and Zou Y. and Bradbury J. and Stroulia E.},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833159948-5},
	language = {English},
	abbrev_source_title = {Proc. - IEEE Int. Conf. Collab. Adv. Softw. Comput., CASCON},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Pankiewicz2026412,
	author = {Pankiewicz, Maciej and Baker, Ryan S.},
	title = {Enhancing Student Focus and Problem-Solving with Real-Time LLM Feedback on Compiler Errors},
	year = {2026},
	journal = {Lecture Notes in Computer Science},
	volume = {16063 LNCS},
	pages = {412 - 426},
	doi = {10.1007/978-3-032-03870-8_28},
	url = {https://www.scopus.com/pages/publications/105016226918?origin=resultslist},
	affiliations = {University of Pennsylvania, Philadelphia, PA, United States; Warsaw University of Life Sciences, Warsaw, Poland},
	abstract = {Programming syntax is highly complex, which has made it consistently difficult to automate feedback for compiler errors in educational settings. Large language models (LLMs) show promise for addressing this issue at scale by providing personalized feedback tailored to specific code submissions, but the effectiveness of this feedback remains uncertain. This study evaluated the impact of GPT-4o at generating real-time feedback for compiler errors during a randomized controlled trial. A total of 248 CS1 students participated, submitting 22,674 pieces of code to an automated programming assessment platform. Students in the Experimental group received LLM feedback, while the Control group did not. Results showed that students who received LLM feedback rated it highly for usefulness, and submitted fewer non-compiling code attempts. These students also had significantly improved performance in terms of resolving errors in consecutive attempts compared to the Control group. Affective surveys revealed that the LLM feedback group self-reported higher focus and lower levels of “confrustion” (a combination of confusion and frustration) after encountering compiler errors. When LLM feedback was temporarily disabled, students in the Experimental group solved programming problems more quickly and demonstrated significant improvement in resolving errors across attempts. However, no significant differences were observed between groups in terms of final scores on a simulated exam. These findings suggest that LLM-generated feedback can improve students’ coding experience, engagement, and problem-solving efficiency in the initial phases of computer science education, though it may not lead to better final performance. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2026.},
	author_keywords = {Automated Assessment; Automated Feedback; Compiler Errors; CS1; GPT; Large Language Models; LLM},
	keywords = {Automation; Codes (symbols); Education computing; Errors; Feedback; Optimal systems; Problem oriented languages; Problem solving; Students; Automated assessment; Automated feedback; Compiler error; GPT; Language model; Large language model; Model feedback; Problem-solving; Program compilers},
	correspondence_address = {M. Pankiewicz; University of Pennsylvania, Philadelphia, United States; email: mpank@upenn.edu},
	editor = {Tammets K. and Sosnovsky S. and Ferreira Mello R. and Pishtari G. and Nazaretsky T.},
	publisher = {Springer Science and Business Media Deutschland GmbH},
	issn = {03029743},
	isbn = {978-303203869-2},
	language = {English},
	abbrev_source_title = {Lect. Notes Comput. Sci.},
	type = {Conference paper},
