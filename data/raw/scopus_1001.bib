	affiliations = {Beijing Jiaotong University, No.3 Shangyuancun, Haidian District, Beijing, 100044, China; CMCC (Hangzhou) Information Technology Co., No.1600 Yuhangtang, Zhejiang, Hangzhou, 311100, China; School of Information Technology Management, University of International Business and Economics, Beijing, 100190, China},
