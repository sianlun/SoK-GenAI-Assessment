@CONFERENCE{Wilhelmsen2024431,
	author = {Wilhelmsen, Åshild and Haneberg, Dag Håkon and Sivertsen, Ingrid Berg and Alsos, Ole Andreas and Solvoll, Sølvi},
	title = {GENERATIVE AI IN DESIGN EDUCATION: BUSINESS AS USUAL, A TROUBLEMAKER, OR A GAME CHANGER?},
	year = {2024},
	journal = {Proceedings of the 26th International Conference on Engineering and Product Design Education: Rise of the Machines: Design Education in the Generative AI Era, E and PDE 2024},
	pages = {431 - 436},
