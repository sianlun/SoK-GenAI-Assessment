	affiliations = {Jiangxi University of Chinese Medicine, Jiangxi, Nanchang, China},
	abstract = {This paper explores the application of generative artificial intelligence, with a specific focus on Large Language Model (LLM), within the educational sector and the dual consequences that arise from this integration. We propose a dual-track framework that analyzes how LLM revolutionize educational paradigms while triggering ethical concerns through two dimensions: technological empowerment pathways and ethical research. Within the technological empowerment dimension, the study examines LLM applications in personalized learning, intelligent tutoring and automated assessment. In the other dimension, it focuses on critical issues including data privacy, algorithmic bias, and accountability. This research aims to provide guidance for the responsible deployment of LLM in education and outlines future research directions. © 2025 Copyright held by the owner/author(s).},
