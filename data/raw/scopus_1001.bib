@CONFERENCE{Wyszynski2025,
	author = {Wyszynski, Jacklyn F. and Dosse, Lee A. and Barry, Matthew M.},
	title = {WIP: 'Can You Do My Homework?' and Other Queries - An Analysis of Student Prompts to Generative AI in an Engineering Statics Course},
	year = {2025},
