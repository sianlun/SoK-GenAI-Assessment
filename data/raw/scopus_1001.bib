@CONFERENCE{Rosli2025265,
	author = {Rosli, Raja Muhammad Khairuddin Raja and Zakaria, Anies Faziehan},
	title = {Showcasing a Chatbot Suite for Multi-Domain Academic Pre-Evaluation: A Score-Based Demonstration Frameworks},
	year = {2025},
	journal = {2025 IEEE 14th International Conference on Engineering Education: Engineering Education 5.0: Innovation, Intelligence, and Impact, ICEED 2025},
	pages = {265 - 270},
	doi = {10.1109/ICEED66794.2025.11400468},
	url = {https://www.scopus.com/pages/publications/105035994305?origin=resultslist},
	affiliations = {Universiti Kebangsaan Malaysia, Department of Engineering and Built Environment, Malaysia},
	abstract = {Large language models (LLMs) such as ChatGPT have gained traction in academia for tasks like ideation and manuscript drafting. However, their general-purpose nature limits their effectiveness in domain-specific academic evaluations. This paper presents chatbot suite, consisting of five Custom Generative Pre-trained Transformer (GPT), each designed to support structured academic pre-evaluation across various scholarly outputs, including research proposals, journal manuscripts, innovation ideas, conference papers, and action research reports. Each chatbot is built using ChatGPT's Custom GPT feature and is guided by the SCORE framework (Scholarly Criteria for Organized Review and Evaluation), which ensures consistent, rubric-aligned assessments tailored to specific document types and academic standards. Developed through prompt engineering rather than fine-tuning, this chatbot suite offers domain-sensitive feedback without requiring large datasets or extensive retraining. Demonstrations across five use cases illustrate how the system enhances clarity, coherence, and methodological rigor by simulating expert review and providing criterion-based suggestions. The system also addresses common academic challenges such as feedback scarcity, fragmented drafts, and presentation anxiety. Through iterative improvement and promoting independent learning, the chatbot suite complements traditional supervision and review mechanisms. The proposed framework represents a scalable approach for integrating AI support into academic and innovation ecosystems, with future work focusing on ethical alignment, robustness, and continuous learning. © 2025 IEEE.},
	author_keywords = {Academic AI; Custom ChatGPT; Pre-evaluation Tools; Prompt Engineering; Rubric Feedback},
	keywords = {Artificial intelligence; Engineering education; Engineering research; Feedback; Large datasets; Academic AI; Chatbots; Custom ChatGPT; Evaluation tool; Language model; Multi-domains; Pre-evaluation; Pre-evaluation tool; Prompt engineering; Rubric feedback; Chatbots},
