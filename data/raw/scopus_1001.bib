	author = {Liu, Zifeng and Xing, Wanli and Jiao, Xinyue and Li, Chenglu and Zhu, Wangda},
	title = {What are the differences between student and ChatGPT-generated pseudocode? Detecting AI-generated pseudocode in high school programming using explainable machine learning},
	year = {2025},
	journal = {Education and Information Technologies},
	volume = {30},
