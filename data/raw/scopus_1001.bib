	title = {Analyzing the Impact of ChatGPT on Student Over-Reliance and Plagiarism using Artificial Neural Network (ANN)},
	year = {2025},
	journal = {2025 6th International Conference on Artificial Intelligence and Data Sciences: From Insights To Impact: Leveraging AI And Data Science For Strategic Decisions, AiDAS 2025 - Conference Proceedings},
	pages = {552 - 558},
	doi = {10.1109/AiDAS67696.2025.11213518},
	url = {https://www.scopus.com/pages/publications/105023677275?origin=resultslist},
	affiliations = {Universiti Teknologi Mara, Faculty of Computer and Mathematical Sciences, Perak Branch, Tapah Campus, Malaysia; Universiti Teknologi Mara, Faculty of Computer and Mathematical Sciences, Negeri Sembilan Branch, Rembau Campus, Malaysia},
	abstract = {The rapid advancement of artificial intelligence (AI) technologies has significantly transformed the educational landscape with tools like ChatGPT. While these AI-driven platforms offer enhanced accessibility to information and support for learning, this also raises critical concerns regarding academic integrity. This study focuses on analyzing the impact of ChatGPT on student behavior, specifically concerning over-reliance and academic plagiarism in higher education, using an Artificial Neural Network (ANN) approach. A total of 354 students from UiTM Tapah were selected as the sample using stratified sampling to ensure adequate representation across different academic programs and levels. This study examined the influence of ChatGPT on academic behavior among students by analyzing two key predictors of over-reliance and plagiarism using ANN modeling. The Multilayer Perceptron (MLP) model emerged as the most accurate, outperforming the Radial Basis Function (RBF) network with lower test errors and greater generalizability. Among the two predictors, over-reliance demonstrated a notably higher predictive significance compared to plagiarism. In conclusion, this study proposes several strategies to support the responsible use of ChatGPT in higher education. AI literacy should be integrated into the curriculum to encourage ethical usage. Assessment practices must emphasize critical thinking and originality. Institutions should establish and communicate guidelines for acceptable AI use. Faculty training is also essential to support effective student guidance. These efforts aim to balance the benefits of AI with the preservation of academic integrity and the promotion of intellectual development. © 2025 IEEE.},
	author_keywords = {Artificial Neural Network; Behavioral Intention; Blended Learning System},
	keywords = {Curricula; Education computing; Engineering education; Intellectual property; Learning systems; Multilayer neural networks; Students; Teaching; Academic integrity; Accessibility to informations; Artificial intelligence technologies; Behavioral intention; Blended learning; Blended learning system; High educations; Neural-networks; Over reliance; Students' behaviors; Radial basis function networks},
