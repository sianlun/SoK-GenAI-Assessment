@CONFERENCE{Lecu2025,
	author = {Lecu, Alexandru and Ciupe, Aurelia and Groza, Adrian and Orza, Bogdan},
	title = {Leveraging LLMs for Student Assessment Generation in Engineering Education: A Study on Context Requirements and Adoption},
	year = {2025},
	journal = {Proceedings of 2025 34th Annual Conference of the European Association for Education in Electrical and Information Engineering, EAEEIE 2025},
	pages = {},
	doi = {10.1109/EAEEIE65428.2025.11136216},
	url = {https://www.scopus.com/pages/publications/105016460346?origin=resultslist},
	affiliations = {Technical University of Cluj-Napoca, Computer Science Department, Cluj-Napoca, Romania; Technical University of Cluj-Napoca, Electronics and Telecommunications Department, Cluj-Napoca, Romania; Digital Science & Research Solutions Ltd, Romania; European University of Technology (EUt+), European Union, Romania},
	abstract = {Instructors are leveraging LLMs in various innovative ways to enhance assessment generation and overall educational practices within engineering education. By focusing on practical engagement, personalized feedback, and the development of new assessment methodologies, educators aim to create a more dynamic and effective learning environment. The current work systematically examines the capabilities of Large Language Models (LLMs), such as GPT, Claude, and Copilot, to augment pedagogical practices and learning outcomes in university environments, with a particular emphasis on their use in quiz generation. Specifically, three difficulty levels were employed-elementary, intermediate, and advanced-Along with three question formats: multiple choice questions with one correct answer, multiple choice questions with more correct answers, and open-Answer questions. The study involved a sample of five instructors from two engineering departments, along with 24 students, to assess their perceptions and experiences within the designed context. A Technology Assessment Model (TAM) was employed to evaluate the adoption and integration of LLMs within educational contexts. The findings reveal that both educators and students regarded LLMs as intuitive and user-friendly, demonstrating a strong conviction in their potential to enhance instructional activities, particularly assessment tools. Index Terms-AI, Large Language Models, GPT, CoPilot, Claude, Engineering Disciplines, Technology Acceptance Model.  © 2025 IEEE.},
