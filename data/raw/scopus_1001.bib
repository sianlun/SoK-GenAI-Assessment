@CONFERENCE{Jamieson2025,
	author = {Jamieson, Peter and Ricco, George D. and Swanson, Brian A. and Van Scoy, Bryan},
	title = {BOARD #134: Results and Evaluation of an Early LLM Benchmarking of our ECE Undergraduate Curriculums},
	year = {2025},
	journal = {ASEE Annual Conference and Exposition, Conference Proceedings},
	pages = {},
	doi = {10.18260/1-2--55951},
