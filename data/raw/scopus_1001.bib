	url = {https://www.scopus.com/pages/publications/105004550258?origin=resultslist},
	affiliations = {University of Kelaniya, Faculty of Graduate Studies, Sri Lanka},
	abstract = {Generative AI is transforming education by providing innovative tools for personalized learning, content creation, and teaching assistance. This paper explores the potential of generative AI in enhancing teaching methodologies and learning experiences, addressing challenges, and proposing solutions for its effective integration into education systems. The generative AI tool, ChatGPT, has captivated global attention with its remarkable ability to perform sophisticated and complex tasks. Its advanced capabilities, particularly within the field of education, have elicited mixed reactions among educators, as this breakthrough in AI technology is poised to revolutionize traditional educational practices. This exploratory study synthesizes recent literature to examine the potential benefits and challenges of ChatGPT in enhancing teaching and learning. On the positive side, ChatGPT offers opportunities to foster personalized and interactive learning experiences, support the creation of prompts for formative assessments, and provide ongoing feedback to inform teaching and learning processes. However, the study also identifies significant limitations inherent to ChatGPT, such as the generation of inaccurate information, potential biases stemming from its training data, and privacy concerns that may exacerbate existing inequities. To ensure the constructive and safe integration of ChatGPT into education, the study presents recommendations for its effective use. These include encouraging collaboration among policymakers, researchers, educators, and technology experts to address the risks and ethical implications of generative AI. By initiating proactive discussions and developing comprehensive guidelines, stakeholders can harness the potential of ChatGPT to enhance education while safeguarding the interests of learners and educators alike.  © 2025 IEEE.},
	author_keywords = {ChatGPT; Generative AI; Graduate Education; Personalized Learning; Teaching and Learning},
