@CONFERENCE{Wu2025223,
	author = {Wu, Hsin-Ying and Lee, Chi-Ching},
	title = {Design of an AI-Assisted Support System for Manual Procedure Education Using LLMs and RAG},
	year = {2025},
	journal = {Proceedings - 2025 2nd International Conference on Artificial Intelligence for Medicine, Health and Care, AIxMHC 2025},
	pages = {223 - 224},
	doi = {10.1109/AIxMHC65380.2025.00046},
	url = {https://www.scopus.com/pages/publications/105033217186?origin=resultslist},
	affiliations = {Chang Gung University, Department of Computer Science and Information Engineering, Taoyuan City, Taiwan},
	abstract = {In many manual-operation-based courses, such as those involving microscope use, students' ability to review after class is limited by the high cost of equipment and the inability to carry specimen slides. As a result, they cannot easily revisit specimens or reproduce classroom observations. Moreover, key teacher instructions are often delivered verbally and not fully recorded in teaching materials, forcing students to rely on time-consuming video reviews. Existing teaching systems typically rely on static images, lacking interactivity and platform integration, and are insufficient to meet learning needs. To solve the above problems, this study designs an AI-assisted teaching system that combines large language model and retrieval-augmented generation technology. The system consists of modules such as textbook uploading, segmentation indexing, search generation and interactive interface. It supports users to upload classroom text books and quickly obtain review texts and reference materials through prompts, thereby improving data availability and learning efficiency. In addition, the system is also planned to support images and multimodal data in the future, and will introduce learning effectiveness assessment and multi-platform authentication mechanisms. The initial construction has been completed, and it is planned to conduct small-scale closed testing in actual courses to collect feedback to optimize system functions and verify application potential. © 2025 IEEE.},
	author_keywords = {AI-Assisted Teaching; Digital Teaching Materials; LLM; Teaching System; Virtual Microscope},
	keywords = {Curricula; E-learning; Education computing; Engineering education; Learning systems; Microscopes; Reviews; Students; Teaching; Virtual reality; AI-assisted teaching; Assisted teachings; Digital teaching materials; High costs; LLM; Manual operations; Support systems; Teachers'; Teaching systems; Virtual microscope; Search engines},
