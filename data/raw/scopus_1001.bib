@CONFERENCE{Hsu202511,
	author = {Hsu, Victor Wei-Che and Lee, Yi-Fang and Tran, Duong Hoang Thuy and Kao, Wen-Chung},
	title = {Leveraging ChatGPT for English Writing Instruction: Curriculum and Instructional Design Perspectives},
	year = {2025},
	journal = {2025 6th International Conference on Information Technology and Education Technology, ITET 2025},
	pages = {11 - 15},
	doi = {10.1109/ITET65804.2025.11100827},
	url = {https://www.scopus.com/pages/publications/105014315693?origin=resultslist},
	affiliations = {National Taiwan Normal University, Department of Industrial Education, Taipei, Taiwan; National Taiwan Normal University, College of Industry Academia Innovation, Taipei, Taiwan},
	abstract = {With the rapid advancement of artificial intelligence technology, Chat Generative Pre-trained Transformer (ChatGPT) is increasingly being applied in the educational field, particularly in language learning and writing instruction. This paper aims to explore the curriculum and instructional design of ChatGPT on high school students' English writing motivation and writing abilities. This paper employs a methodology, designing a course for twelfth-grade students from a high school in Taiwan. The goal is to tease the effectiveness out of ChatGPT as a writing assistance tool. The study is conducted over two phases spanning six weeks, including a pre-test, instructional intervention, and a post-test, combined with questionnaires, writing assessments, interviews to comprehensively evaluate changes in students' writing performance and learning attitudes. During the instructional phase, a series of writing tasks are designed, integrating ChatGPT as a real-time writing assistance tool. Students are encouraged to use ChatGPT throughout the writing process to generate ideas, expand their vocabulary, modify sentence structures, and perform self-corrections. The authors observe the students' performance after using the AI tool and collect writing samples for analysis. © 2025 IEEE.},
