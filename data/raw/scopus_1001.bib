@CONFERENCE{Rathod2025,
	author = {Rathod, Ganesh and Mane, Suresh D. and Mane, Abhijit M.},
	title = {Emerging Approaches in Computing Education: AI-Powered Heutagogy for Sustainable and Self-Directed Learning},
	year = {2025},
	journal = {2025 International Conference on Future Technologies, ICFT 2025},
	pages = {},
	doi = {10.1109/ICFT66708.2025.11336596},
	url = {https://www.scopus.com/pages/publications/105033706004?origin=resultslist},
	affiliations = {Dr. D. Y. Patil Pratisthan's College of Engineering, Salokhenagar. Affilated to Shivaji University, CSE Dept., Kolhapur, India},
	abstract = {This paper proposes an Artificial Intelligence (AI)-Driven Heutagogy Framework custom-designed for engineering education with intentional alignment to Sustainable Development Goal 4 and sustainable software practices. The framework consists of: (1) an AI-Assessment Engine that automates multi-level evaluations according to Revised Bloom's Taxonomy with supervised learning algorithms and rubricbased scores; (2) an Automated E-Learning System providing AI-driven, gamified learning trajectories with adaptive neural architectures; and (3) a Metacognitive Layer utilizing NLPbased sentiment and creativity detection with reflective journals. In an empirical case study with 120 engineering students (AI-assisted vs. non-AI groups), they created real-time image classification CNN models. The AI-assisted cohort produced a 133% increment in model iterations (28±3 vs. 12±2), 53% decrease in debugging time (1.5 vs. 3.2 hours), and 42% increase in RBT-based rubric scores (9.2±1.1 vs. 6.5±1.5). Moreover, their models exhibited a 42% higher inference speed (135 vs. 95 frames per second), 29% reduced memory usage (220 vs. 310 MB), and higher classification accuracy (F1-score: 0.92±0.03 vs. 0.85±0.04). Nonetheless, their peer-reviewed creativity ratings were 15% lower (7.1 vs. 8.3/10), which is a signal to curb algorithmic dependency. Critical incident technique-based qualitative analysis found that the AI cohort attained 35% higher metacognitive depth and facilitated a 60% reduction in grading workloads for educators. To counter creativity risks, the framework incorporates randomized prompt modules and reflective checkpoints. These findings validate AI-based heutagogy's scalability to efficiently upgrade engineering curricula and assessment to meet SDG 4 with opensource tool deployment and policy initiatives toward balanced technical and creativity development. © 2025 IEEE.},
	author_keywords = {Artificial Intelligence (AI); Automated E-Learning; Educational Assessment; Engineering Education; Generative AI; Heutagogy; Self-Directed Learning; Sustainable Development Goal 4 (SDG 4); Sustainable Technology},
	keywords = {Computer aided instruction; E-learning; Education computing; Learning algorithms; Learning systems; Self-supervised learning; Supervised learning; Sustainable development; Sustainable development goals; Artificial intelligence; Automated E-learning; Computing education; E - learning; Educational assessment; Generative artificial intelligence; Heutagogy; Self-directed learning; Sustainable development goal 4; Sustainable technology; Engineering education},
