	keywords = {Computer aided instruction; Curricula; Education computing; Engineering education; Knowledge graph; Students; Educational assessment; Intelligent tutoring; Intelligent tutoring system; Knowledge graphs; Language model; Language processing; Large language model; Natural language processing; Natural languages; Tutoring system; Semantics},
