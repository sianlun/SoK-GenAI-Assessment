@ARTICLE{Habib2026293,
	author = {Habib, Fahimul and Saifullah, S.M. and Chowdhury, Sajid Sami and Akter, Sharmin and Chowdhury, Showrav and Usama Islam, Muhamamd},
	title = {AI in Classroom: Evaluating Teachers’ and Students’ Perceptions of AI-Generated Grammar Materials},
	year = {2026},
