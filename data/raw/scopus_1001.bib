	journal = {CEUR Workshop Proceedings},
	volume = {3796},
	pages = {},
	url = {https://www.scopus.com/pages/publications/85208796495?origin=resultslist},
	affiliations = {Intelligent Systems Program, University of Pittsburgh, Pittsburgh, PA, United States},
	abstract = {Educational data used by data mining approaches in the domain of Computer Science education primarily focused on working with code-based data, such as student homework submissions. However, the increased use of natural language techniques and Large Language models (LLM) in all domains of learning including Computer Science education is now producing an abundance of natural language data, such as code explanations generated by students and LLMs as well as feedback and hints produced by instructors, TAs, and LLMs. These data represent new challenges for CSEDM research and need new creative approaches to leverage. In this paper, we present a first attempt to analyze one type of these new data, student explanations of worked code examples. The main challenge in working with these data is to evaluate the correctness of self-explanations. Using a dataset of student explanations collected in our previous work, we demonstrate the difficulty of this problem and discuss a possible way to solve it. © 2024 Copyright for this paper by its authors.},
	author_keywords = {automated assessment; code explanations; worked examples},
	keywords = {Adversarial machine learning; Data mining; Natural language processing systems; Students; Automated assessment; Code explanation; Computer Science Education; Creatives; Language model; Natural language techniques; Natural languages; Self explanations; Worked examples; Codes (symbols)},
