	affiliations = {Computer Science, Colorado School of Mines, Golden, CO, United States; Physics, Colorado School of Mines, Golden, CO, United States; Applied Mathematics & Statistics, Colorado School of Mines, Golden, CO, United States; Geophysics, Colorado School of Mines, Golden, CO, United States; Chemical & Biological Engineering, Colorado School of Mines, Golden, CO, United States; Mechanical Engineering, Colorado School of Mines, Golden, CO, United States},
