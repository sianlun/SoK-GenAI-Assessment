@CONFERENCE{Wen2025644,
	author = {Wen, Erh-Ya and Lu, Yu-Ling},
	title = {Integrating Computational Thinking into Learning Physics from the Perspective of Big Data Analytics},
	year = {2025},
	journal = {Proceedings of the 2025 IEEE International Conference on Computation, Big-Data and Engineering, ICCBE 2025},
	pages = {644 - 650},
	doi = {10.1109/ICCBE65177.2025.11255683},
	url = {https://www.scopus.com/pages/publications/105031085729?origin=resultslist},
	affiliations = {National Taipei University of Education, Department of Science Education, Taipei, Taiwan},
	abstract = {In this study, we integrated computational thinking (CT) into physics teaching materials using big data big analysis to explore the impact of CT elements on students' learning abilities. Physics is a crucial subject in elementary school science curriculum. However, research on the incorporation of CT into physics with big data analysis remains limited. Therefore, we investigated how CT elements in physics education affect students' CT abilities. The participants were 477 fifth-grade students from a public elementary school in Taiwan. To avoid instructional bias, we employed two types of teaching materials: artificial intelligence-assisted material (n = 239) and teacher-developed material (n = 238), incorporating CT into physics problems in a six-week instructional experiment. The study employed a CT ability assessment to evaluate students' performance. The K-means clustering algorithm was used to categorize students' scores into high, middle, and low progress groups. ANOVA was used to analyze the differences among the three improvement groups, and the J48 decision tree was employed to examine CT improvement patterns. Students in different groups showed significant differences in their improvement scores for the CT elements: "decomposition", "generalization", and "sequencing". Post hoc analysis results revealed a decreasing trend in "decomposition"and "sequencing"in the following pattern: high progress group score > middle progress group score > low progress group score. For "generalization", high progress group score = middle progress group score > low progress group score. The accuracy of the models to discern students using generative AI-assisted material for CT, teacher-developed material, and overall students exceeded 80%. The area under the receiver operating characteristic curve was above 0.85, and the F1 score was 0.80, indicating strong predictive performance. "Generalization"and "decomposition"were the most critical CT elements influencing students' CT skill development. The combined results of the generative AI-assisted material group, the teacher-developed material group, and the overall student group indicated that "generalization"and "decomposition"were the primary elements influencing improvements in CT skills. Students with different levels of CT skill require support in different CT elements. Students with moderate to high CT skills need to improve their overall CT competence by enhancing "generalization"and "decomposition"abilities. Conversely, students with weaker CT skills need to strengthen their "sequencing"ability. Therefore, designing differentiated instructional strategies is required to target specific CT elements based on students' skill levels to enhance their problem-solving ability. These results serve as a reference for future research on enhancing computational thinking performance and provide a basis for the future integration of CT into science education. © 2025 IEEE.},
	author_keywords = {big data analysis; computational thinking; physics learning},
	keywords = {Advanced Analytics; Artificial intelligence; Curricula; Education computing; Engineering education; K-means clustering; Students; Teaching; Big data analyze; Computational thinkings; Data analytics; Generalisation; Learning physics; Physics learning; Physics teaching; Teachers'; Teaching materials; Thinking skills; Big data},
	correspondence_address = {Y.-L. Lu; National Taipei University of Education, Department of Science Education, Taipei, Taiwan; email: yllu@tea.ntue.edu.tw},
	editor = {Meen T.-H.},
