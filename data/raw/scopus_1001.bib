@CONFERENCE{Sharma2026,
	author = {Sharma, Nakul and Lohar, Dhruv and More, Swanand and Mahalaxme, Anish},
	title = {A Multi-Layered Hybrid Framework for Robust Source Code Plagiarism Detection Against AI-Enhanced Obfuscation in Programming Education},
	year = {2026},
	journal = {2026 International Conference on Emerging Smart Computing and Informatics, ESCI 2026},
	pages = {},
	doi = {10.1109/ESCI68015.2026.11493349},
	url = {https://www.scopus.com/pages/publications/105040828178?origin=resultslist},
	affiliations = {Department of Computer Science and Engineering (IoT and Cybersecurity Including Blockchain Technology), Vishwakarma Institute of Technology, Pune, India},
	abstract = {The spread of the artificial-intelligence-enhanced code generation is a serious threat to the integrity of computer science education since it requires both detection mechanisms resistant to advanced semantic and logic-preserving obfuscation methods and scalability. The traditional token-based methods do not work well with such structural changes, but the state-of-the-art large-language models (LLMs) incur prohibitive computational expenses and comes with high false-positive rates (FPRs). We therefore present HybridDetect, a new multi-layered hybrid architecture which is designed to address the inherent accuracy efficiency trade-off. The model uses three sequential analysis layers, including Layer 0 that performs canonical standardisation based on abstract syntax tree (AST) normalisation to prevent superficial plagiarism; Layer 1, which uses a high-efficiency Jaccard similarity metric (30% weighting) as a high-precision structural anchor and filter-of-probability; and Layer 2 that performs deep semantic analysis via optimised sentence-transformer embeddings (all-MiniLM-L6-v2, 70% weighting). Large-scale academic settings would require computational efficiency which is achieved through large scale vector storage and high-speed indexing using FAISS. Validation It has been tested that the synthesis is better resistant to semantic obfuscation than legacy systems and that the weighting balance renders accuracy and provides granular and actionable reports needed in subtle human judgement. © 2026 IEEE.},
	author_keywords = {Abstract Syntax Tree; Academic Integrity; AI-Enhanced Obfuscation; FAISS Indexing; Semantic Embeddings; Source Code Plagiarism},
	keywords = {Artificial intelligence; Codes (symbols); Computational efficiency; Computer programming languages; Data obfuscation; Education computing; Embeddings; Engineering education; Indexing (of information); Intellectual property; Legacy systems; Scales (weighing instruments); Semantics; Syntactics; Abstract Syntax Trees; Academic integrity; AI-enhanced obfuscation; FAISS indexing; Hybrid framework; Multi-layered; Plagiarism detection; Programming education; Semantic embedding; Source code plagiarisms; Economic and social effects},
