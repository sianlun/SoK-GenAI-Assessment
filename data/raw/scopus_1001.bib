}

@CONFERENCE{Zlotnikova2025289,
	author = {Zlotnikova, Irina and Mokgetse, Tshepiso Larona and Hlomani, Hlomani},
	title = {Generative AI in Postgraduate Computing Research in Sub-Saharan Africa: A Threat to Academic Integrity or a Catalyst for Innovation?},
	year = {2025},
	journal = {CompEd 2025 - Proceedings of the ACM Global Computing Education Conference 2025},
	volume = {1},
	pages = {289 - 293},
	doi = {10.1145/3736181.3747148},
	url = {https://www.scopus.com/pages/publications/105021403639?origin=resultslist},
	affiliations = {Botswana International University of Science and Technology, Central District, Palapye, Botswana},
	abstract = {The integration of Generative AI (GenAI) into postgraduate computing research presents both transformative opportunities and pressing ethical challenges. While GenAI tools enhance research productivity through support for academic writing, data analysis, and coding tasks, they also raise complex issues around academic integrity, authorship, overreliance, and digital inequality. These concerns are especially salient in Sub-Saharan Africa, where postgraduate students often face infrastructural constraints, limited mentorship, and systemic inequities in access to advanced technologies. This position paper critically examines the dual role of GenAI as a catalyst for innovation and a source of epistemic and institutional risk drawing on literature and observations from the context of Botswana. We explore ethical gray areas in GenAI use, review institutional policy responses, and highlight the underrepresentation of Indigenous data in large language models, which perpetuates Western epistemic dominance. Particular attention is given to the implications for postgraduate computing education, where contextually relevant and socially responsive GenAI applications are urgently needed. We argue for ethical, inclusive, and locally grounded frameworks that support responsible GenAI integration in postgraduate research. The paper concludes by outlining key areas for future empirical investigation, including discipline-specific adoption, supervisor engagement, and equity in GenAI access across higher education systems in the Global South.  © 2025 Copyright held by the owner/author(s). Publication rights licensed to ACM.},
	author_keywords = {academic integrity; ai ethics; computing; generative ai; postgraduate research; research automation; sub-saharan africa},
	keywords = {Artificial intelligence; Computer programming; Engineering education; Ethical technology; Human engineering; Academic integrity; Ai ethic; Computing; Computing research; Generative ai; Post-graduate research; Pressung; Research automation; Sub-saharan africa; ]+ catalyst; Education computing},
