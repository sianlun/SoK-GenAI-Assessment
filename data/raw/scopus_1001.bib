@CONFERENCE{Bolgova20251474,
	author = {Bolgova, Olena and Ganguly, Paul and Mavrych, Volodymyr},
	title = {Prompt Engineering Large Language Models for Healthcare Decision-Making Training},
	year = {2025},
	journal = {2025 International Conference on Decision Aid Sciences and Applications, DASA 2025},
	pages = {1474 - 1478},
	doi = {10.1109/DASA68193.2025.11498718},
	url = {https://www.scopus.com/pages/publications/105040837586?origin=resultslist},
	affiliations = {Alfaisal University, College of Medicine, Riyadh, Saudi Arabia},
	abstract = {Background: Traditional grading of medical short-answer questions is resource-intensive and potentially inconsistent, limiting educational feedback quality. Large language models (LLMs) offer potential solutions, but their effectiveness depends heavily on the design of the prompting strategy.Objective: To evaluate the impact of progressive prompting strategies on DeepSeek R1's performance in grading medical short-answer questions compared to expert human graders.Methods: We assessed DeepSeek's grading accuracy across four prompting strategies: zero-shot (P1), few-shot with examples (P2), chain-of-thought reasoning (P3), and advanced prompting with expert criteria (P4). Three expert faculty members independently graded two hundred anonymized student responses to a clinical question. Agreement was measured using Cohen's Kappa coefficient, with expert-expert agreement as a benchmark.Results: Expert agreement was substantial (average Kappa 0.66, ICC 0.87). DeepSeek's agreement with expert consensus improved systematically: P1 achieved fair agreement (Kappa 0.32, 46% of expert-level agreement), P2 reached moderate agreement (Kappa 0.47, 68%), P3 achieved substantial agreement (Kappa 0.56, 81%), and P4 reached substantial agreement (Kappa 0.61, 88% of expert-level agreement). Perfect agreement increased from 48% (P1) to 79% (P4), while major grading errors decreased from 18% to 2%. DeepSeek demonstrated conservative grading tendencies that diminished with sophisticated prompting.Conclusions: Advanced prompting strategies enable LLMs to achieve near-expert-level performance in medical assessments, reaching 88% agreement with human experts. The systematic error reduction and improved reliability suggest that carefully designed LLM prompting could support medical education assessment, particularly for formative evaluation and preliminary grading tasks. © 2025 IEEE.},
	author_keywords = {Artificial intelligence; Assessment; Decision making; Educational technology; Inter-rater reliability; Large language models; Medical education; Prompt engineering; Short answer questions},
	keywords = {Behavioral research; Educational technology; Engineering education; Grading; Medical education; Students; Teaching; Assessment; Decisions makings; Faculty members; Health-care decisions; Interrater reliability; Language model; Large language model; Performance; Prompt engineering; Short answer question; Artificial intelligence; Decision making},
	correspondence_address = {O. Bolgova; Alfaisal University, College of Medicine, Riyadh, Saudi Arabia; email: obolgova@alfaisal.edu},
