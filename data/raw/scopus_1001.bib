@CONFERENCE{Ahlam202523,
	author = {Ahlam, Anabousy and Huda, Shayeb and Hala, Habayib and Nimer, Baya'A and Wajeeh, Daher},
	title = {Navigating AI Adoption: Challenges and Suggested Solutions for College Lecturers},
	year = {2025},
	journal = {2025 International Conference on Smart Learning Courses, SCME 2025},
	pages = {23 - 29},
	doi = {10.1109/SCME62582.2025.11104880},
	url = {https://www.scopus.com/pages/publications/105015708004?origin=resultslist},
	affiliations = {Al-Qasemi Academic College of Education, Mathematics Department, Baqa Al-Gharbiyye, Israel; Al-Qasemi Academic College of Education, Innovative Pedagogy Unit-Ict Center, Baqa Al-Gharbiyye, Israel; Al-Qasemi Academic College of Education, Baqa Al-Gharbiyye, Israel; Al-Qasemi Academic College of Education, ICT Center, Baqa Al-Gharbiyye, Israel},
	abstract = {The development of artificial intelligence (AI), particularly generative AI tools, has significantly transformed higher education. This study examined the key challenges encountered by college lecturers in the AI environment and the practical solutions they offered for these challenges. Seventeen heads of departments or academic units from a teacher education college participated in this study. Data were collected through a video-recorded focus group interview and supplemented reports. Data were analyzed inductively using the constant comparison method to identify recurring themes and patterns across the participants. The findings revealed five central challenges faced by college lecturers: (1) Assessment integrity that includes difficulties in verifying student authenticity, increasing plagiarism risks, and diminishing academic originality; (2) AI adoption resistance characterized by reluctance or hesitancy in embracing AI technologies stemming from limited familiarity and a lack of confidence; (3) Pedagogical adaptation imperative that necessitates the revision of instructional methodologies and a redefinition of the lecturer's role in the context of AI integration; (4) Technological literacy disparities that refer to gaps in digital literacy among both faculty and students, compound by unequal familiarity with AI tools; and (5) Limited institutional resources that result in restricted access to advanced AI tools and insufficient professional development opportunities. In response to these challenges, the participants proposed several potential solutions: fostering transparent and ethical student utilization of AI tools, implementing alternative assessment strategies focused on personal and critical thinking skills, enhancing institutional support through ICT centers, offering structured training programs, and ensuring equitable access to AI platforms. So, colleges need to open dialogue and collaboration among faculty members to develop shared guidelines and best practices for the ethical and effective use of AI in academic settings. In addition, teaching should focus more on thinking critically and personal skills, which are especially essential in the AI environment.  © 2025 IEEE.},
	author_keywords = {Artificial intelligence; Teaching challenges. Higher education; Technology in education},
	keywords = {Education computing; Engineering education; Ethical technology; Personnel training; Students; Teaching; Artificial intelligence technologies; Artificial intelligence tools; Comparison methods; Focus groups; High educations; Practical solutions; Teacher education; Teaching challenge.; Teaching challenges; Technology in educations; Artificial intelligence},
	correspondence_address = {A. Ahlam; Al-Qasemi Academic College of Education, Mathematics Department, Baqa Al-Gharbiyye, Israel; email: ahlam_anabousy@qsm.ac.il},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
