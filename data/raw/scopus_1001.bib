@CONFERENCE{Remache20251010,
	author = {Remache, Abdelghani and Remache, Sonia},
	title = {Arab EFL Students' Engagement with Prompt- Engineered AI Writing Feedback},
	year = {2025},
	journal = {2025 3rd International Conference on Foundation and Large Language Models, FLLM 2025},
	pages = {1010 - 1017},
	doi = {10.1109/FLLM67465.2025.11391002},
	url = {https://www.scopus.com/pages/publications/105035874732?origin=resultslist},
	affiliations = {Al Ain University, English Language and Translation, Al Ain, United Arab Emirates; Cergy-Pontoise University, École Doctorale ED AHSS, Cergy-Pontoise, France},
	abstract = {This study aims to address a central instructional problem in Arab EFL writing classrooms: the difficulty of providing timely, rubric-aligned, pedagogically meaningful feedback at scale due to large class sizes and instructor workload. The objective is therefore twofold: (1) to examine whether prompt-engineered AI can replicate rubric-based instructor feedback with sufficient precision, and (2) to evaluate how Arab EFL learners behaviorally, cognitively, and affectively engage with such feedback.By doing so, the study seeks to advance the state of the art by demonstrating how prompt engineering can overcome the limitations of earlier AWE systems, which were restricted to surface-level corrections and lacked pedagogical alignment.The Generative Artificial Intelligence system (GAI system) used in the study was intended to simulate an English for Academic Purposes (EAP) instructor by providing feedback consistent with the same rubric used by the instructor to assess student written compositions. The data collected for this case study was comprised of the participants' draft essays, revision logs, and semi-structured interviews to obtain insight into their experiences when using the GAI systems as a source of feedback.Students reported that AI-generated feedback contributed positively to their motivation and sense of support, while offering comments that were linguistically precise and straightforward. They referred to AI as a motivator and a "coach". However, when comparing the AI feedback with human feedback, students perceived human generated feedback to be better at teaching higher order writing skills including argumentation and critical thinking.Both the affective (i.e., how students felt) and cognitive (how much mental processing the student used) responses to receiving the AI-generated feedback influenced the amount of time that students engaged with the system. While students expressed appreciation for the ease of access and encouraging nature of the AI system, they still relied on instructor input to enhance the conceptual depth and academic reasoning of their written work.This research concludes that while well-designed and prompt- engineered generative AI could be an instructional tool that provides value-added assistance to both students and teachers, and can foster a collaborative relationship between them; it should only be utilized as an assistive tool, not as a replacement for the instructor's guidance throughout the learning process. © 2025 IEEE.},
	author_keywords = {EFL Writing; Feedback Engagement; Generative Artificial Intelligence Systems; Large Language Models; Prompt Design; Prompt-Engineered AI; Rubric-Based Assessment},
	keywords = {Education computing; Engineering education; Engineering research; Intelligent systems; Motivation; Students; Teaching; Artificial intelligence systems; EFL writing; Feedback engagement; Generative artificial intelligence system; Language model; Large language model; Prompt design; Prompt-engineered AI; Rubric-based assessment; Student engagement; Feedback},
	correspondence_address = {A. Remache; Al Ain University, English Language and Translation, Al Ain, United Arab Emirates; email: abdelgani.remache@aau.ac.ae},
	editor = {Erenli K. and Guetl C. and Jararweh Y. and Jansen J.},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
