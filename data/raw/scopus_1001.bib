@CONFERENCE{Amoruso2025,
	author = {Amoruso, Paul and Campbell, Laurie O. and Demara, Ronald F.},
	title = {WIP: Progressing from Micro-Credentialing to Micro-Recruiting: Connecting Employers with Ideally-Badged Learners via Last-Stage Invocation of GenAI},
	year = {2025},
	journal = {Proceedings - Frontiers in Education Conference, FIE},
	pages = {},
	doi = {10.1109/FIE63693.2025.11328433},
	url = {https://www.scopus.com/pages/publications/105032994978?origin=resultslist},
	affiliations = {University of Central Florida, Dept. of Electrical and Computer Engineering, Orlando, FL, United States; University of Central Florida, Dept. of Learning Sciences and Educational Research, Orlando, FL, United States},
	abstract = {This Work-In-Progress research paper introduces the concept of micro-recruiting which leverages micro-credentials to initiate the job placement process. Micro-recruiting refines traditional job placement by actively pairing employers with appropriately badged learners, rather than relying on undirected employee searches. We investigate the feasibility of using micro-credentials as input to Generative AI (GenAI) for skill-to-job mapping facilitated by locally-hosted Large Language Models (LLMs). The AchieveUp micro-credentialing framework operates in three stages: AI-assisted tagging of achievable skills based on course content, tagging test bank questions with corresponding skills for fine-grained skill analysis, and dispersing badges to recipients who feature them in job applications and on LinkedIn. These stages have been implemented in a required undergraduate Computer Engineering course over nine semesters. We extend AchieveUp to a fourth stage using GenAI to connect badged learners to job opportunities. Development involved leveraging five LLMs to generate search queries aligning students' skills with job opportunities using the Adzuna API. The API returns job listings, organized into a JSON file and fed into the LLM, which identifies the most suitable matches for students. The recommended job descriptions and links are presented to students, providing actionable career insights. For example, the Llama 3.3 model generated 287 Adzuna job title queries paired with nine micro-credential skill badge names, fetching 29 local jobs. Llama 3.3 identified three jobs matching skills in memory capacity, digital signal communication, and datapath design. By invoking GenAI, AchieveUp aims to enhance grading paradigms with micro-credentials and link academic achievements to workforce demands. © 2025 IEEE.},
	author_keywords = {Computing skills; Higher education; Industry Involvement},
	keywords = {Curricula; Education computing; Employment; Engineering education; Engineering research; Job analysis; Personnel; Students; Computing skills; Course contents; High educations; In-progress research; Industry involvement; Job opportunities; Language model; Last stage; Placement process; Research papers; Grading},
