@CONFERENCE{Obata2025477,
	author = {Obata, Youssef and Hamada, Mohamed},
	title = {Adaptive Retrieval-Augmented Generative Intelligent Tutoring System for Automata Theory},
	year = {2025},
	journal = {Proceedings - 2025 IEEE 18th International Symposium on Embedded Multicore/Many-core Systems-on-Chip, MCSoC 2025},
	pages = {477 - 482},
	doi = {10.1109/MCSoC67473.2025.00080},
	url = {https://www.scopus.com/pages/publications/105032495306?origin=resultslist},
	affiliations = {University of Aizu, Software Eng. Lab, Aizu, Japan},
	abstract = {Over the past few years, large language models (LLMs) and retrieval-augmented generation (RAG) have redefined what is possible in various fields, and the field of AI-driven education is no different. Studies have shown that fewer students have been reading books related to their courses, instead heavily relying on lecture notes offered by their professors, which ultimately doesn't always suffice, especially for core, foundational courses. Automata Theory, a course fundamental for Computer Science and Engineering majors, is a subclass of theoretical computer science that focuses on abstract machines (automata) and the formal languages they recognize. Through this paper, we detail the architecture and preliminary assessment of a customized intelligent tutoring system that provides a comprehensive and adaptive learning environment for a formally rigorous subject like Automata Theory. Our primary contribution lies in the synergistic integration of a specialized pipeline that addresses key limitations of standard RAG approaches. This includes: a hierarchical segmentation method that preserves the pedagogical structure of the textbook, the generation of context-aware summaries and quizzes, and a fully integrated, RAG-powered chatbot specialized in Automata Theory. The system personalizes learning paths and is specifically designed to handle the scale and complexity of a full-course textbook, aiming to help students study the course more effectively. Preliminary evaluations from a pilot study have shown highly positive user reception, with participants self-reporting enhanced comprehension and a significant increase in their motivation to engage with the subject matter.  © 2025 IEEE.},
	author_keywords = {Automata Theory; Conversational AI; Educational Technology; Intelligent Tutoring Systems; Large Language Models; Retrieval-Augmented Generation (RAG); Vector-based Semantic Search (FAISS)},
