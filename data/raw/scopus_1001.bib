@CONFERENCE{Bhoomika2025465,
	author = {Bhoomika, B.K. and Brunda, L. and Chandan, K.H. and Anure, Prachi Shivanand and Upadhyaya, Sujatha R.},
	title = {CogniLearn: Integrating AI-Powered Insights for Class 10 Syllabus},
	year = {2025},
	journal = {Proceedings - 2025 11th International Conference on Computing and Artificial Intelligence, ICCAI 2025},
	pages = {465 - 472},
	doi = {10.1109/ICCAI66501.2025.00077},
	url = {https://www.scopus.com/pages/publications/105015683128?origin=resultslist},
	affiliations = {Department of CSE, PES University, Bengaluru, India},
	abstract = {Cognilearn is an AI-powered educational platform designed to provide high-quality and examination-focused answers for class 10 CBSE exams. The project aims to fine-tune and train AI models to deliver responses that align with board examination standards for Science, Social Studies, and English courses. The study uses two base Language Models namely, Llama2 7B and Qwen 0.5B. These pre-trained language models are further fine tuned with custom datasets for the question-answering task. Other fine tuning techniques such as LoRA and QLoRa are employed to enhance the capability of the Language Models. The project incorporated Retrieval-Augmented Generation which enables feeding of textbooks and question papers to improve the answer accuracy and relevance. Finally, Prompt Engineering ensures that the retrieved answers are presented appropriately, adhering to standard guidelines. The entire approach ensures that responses are contextually enriched to meet the specific needs of the board examination preparation. The study includes experiments that analyze how effectively these Language Models are used for question-answering tasks in the context of CBSE Class 10 Examination preparation. ©2025 IEEE.},
	author_keywords = {AI in education; CBSE Class 10; fine-tuning; large language models (LLMs); LLaMA 2; Qwen 0.5B; Retrieval-Augmented Generation (RAG)},
