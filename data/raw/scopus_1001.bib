@ARTICLE{Bamasoud2025,
	author = {Bamasoud, Doaa M. and Mohammad, Rasheed and Bilal, Sara},
	title = {Adopting Generative AI in Higher Education: A Dual-Perspective Study of Students and Lecturers in Saudi Universities},
	year = {2025},
	journal = {Big Data and Cognitive Computing},
	volume = {9},
