	title = {Conceptualizing Authenticity in Generative AI-Driven E-Learning: A Critical Examination of Generative Artificial Intelligence in Educational Systems},
	year = {2025},
	journal = {2025 International Conference on Innovation and Intelligence for Informatics, Computing,and Technologies, 3ICT 2025},
