@ARTICLE{Marazzini202678,
	author = {Marazzini, Stefano and Pozzi, Rossella and Rossi, Tommaso and Saporiti, Nicolò and Pirola, Fabiana and Rossi, Monica and Terzi, Sergio},
	title = {Use of Generative AI for Assessing Experiential Learning in Engineering Education},
	year = {2026},
	journal = {IFIP Advances in Information and Communication Technology},
	volume = {769 IFIPAICT},
	pages = {78 - 92},
	doi = {10.1007/978-3-032-03550-9_6},
	url = {https://www.scopus.com/pages/publications/105015396202?origin=resultslist},
	affiliations = {Department of Industrial Engineering, LIUC University, Castellanza, Italy; Department of Management, Information and Production Engineering, University of Bergamo, Dalmine, Italy; Department of Management Engineering, Politecnico Di Milano, Milano, Italy},
	abstract = {In the context of Industry 5.0, the development of skills through experiential learning is becoming increasingly important in industrial engineering education. However, traditional assessment methods often fail to capture the effectiveness of these activities and the actual skills acquired by students. This gap calls for new, more adaptive and dynamic approaches to evaluation. To address this need, this study proposes an innovative solution that employs recent Generative Artificial Intelligence (GenAI) technology to develop a dynamic and self-adaptive assessment system designed specifically for experiential learning environments. The proposed model uses a web-based, self-correcting quiz integrated with ChatGPT via OpenAI’s API. Questions are dynamically generated according to Bloom's taxonomy, and the student's responses are checked in real time to adapt the subsequent questions accordingly. At the end of each session, the system automatically provides both quantitative scores and qualitative feedback for each response and for the overall performance. An application case was conducted in i-FAB, the learning factory at Università Carlo Cattaneo - LIUC, in which students were involved in an experiential learning activity aimed at learning and practicing the Data Analytics skills considered fundamental in the Industry 5.0 context. The results obtained from the test of the method demonstrated its validity and consistency with the set objectives. The proposed method is thus a significant contribution to experiential learning research, filling the gap of inadequate assessment systems while leaving room for possible future improvements. © IFIP International Federation for Information Processing 2026.},
	author_keywords = {Assessment Method; Engineering Education; Experiential Learning; Generative Artificial Intelligence; Industry 5.0},
	keywords = {Application programming interfaces (API); Computer aided instruction; Education computing; Industry 4.0; Information systems; Information use; Learning systems; Machine learning; Students; Adaptive approach; Assessment method; Assessment system; Dynamic approaches; Experiential learning; Generative artificial intelligence; Industrial engineering education; Industry 5.0; Learning in engineering; Traditional assessment; Engineering education},
	correspondence_address = {S. Marazzini; Department of Industrial Engineering, LIUC University, Castellanza, Italy; email: st08.marazzini@stud.liuc.it},
