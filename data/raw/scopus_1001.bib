@ARTICLE{Martín-Gómez2025302,
	author = {Martín-Gómez, Sebastián and González Ruiz, Carlos J.},
	title = {AI in Higher Education: Initial Teacher Training in the Critical and Didactic Use of Artificial Intelligence},
	year = {2025},
	journal = {Revista Iberoamericana de Tecnologias del Aprendizaje},
	volume = {20},
	pages = {302 - 309},
