	title = {Evaluating Handwritten and Multimodal, Free-Style Responses in Algorithms and Data Structures: A RAG-LLM-Based Feedback Framework},
	year = {2025},
	journal = {Proceedings - Frontiers in Education Conference, FIE},
	pages = {},
